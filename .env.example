NODE_ENV=development
PORT=3100
SESSION_SECRET=change-this-in-production
DB_PATH=./data/chronolab.db
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_OTP_ISSUER=Chrono LAB
ADMIN_OTP_ENFORCED=1
ADMIN_ENTRY_PATH=/admin
ADMIN_ROUTE_PATH=/admin
ADMIN_WAF_IP_ALLOWLIST=
ADMIN_WAF_IP_ALLOWLIST_ENFORCED=0
SECURITY_ALERT_NOTIFY_THROTTLE_MS=60000
SECURITY_ALERT_NOTIFY_NOISY_THROTTLE_MS=600000
SECURITY_ALERT_NOTIFY_BURST_ENABLED=1
SECURITY_ALERT_NOTIFY_BURST_WINDOW_MS=300000
SECURITY_ALERT_NOTIFY_BURST_THRESHOLD=20
SECURITY_ALERT_NOTIFY_BURST_COOLDOWN_MS=1800000
SECURITY_ALERT_NOTIFY_BURST_REASONS=security.admin.hidden_route_blocked,security.admin.auth_required
SECURITY_ALERT_NOTIFY_SUPPRESS_REASONS=security.admin.hidden_route_blocked,security.admin.auth_required
SECURITY_ALERT_NOTIFY_INCLUDE_RAW_CODE=0
