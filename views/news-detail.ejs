<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="block-card narrow">
  <h2><%= newsPost.title %></h2>
  <p class="muted-label"><%= newsPost.created_at.slice(0, 10) %></p>

  <% const newsImages = Array.isArray(newsPost.image_paths) ? newsPost.image_paths : []; %>
  <% if (newsImages.length > 0) { %>
    <% newsImages.forEach((src, imageIndex) => { %>
      <img src="<%= src %>" alt="<%= `${newsPost.title}-${imageIndex + 1}` %>" class="notice-image" data-lightbox-enabled="1" />
    <% }) %>
  <% } %>

  <article class="content-article"><%= newsPost.content %></article>
  <a href="/news" class="chip"><%= isEn ? 'Back to news' : '뉴스 목록으로' %></a>
</section>

<section class="block-card">
  <div class="section-head">
    <h3><%= isEn ? 'Latest News' : '최근 뉴스' %></h3>
    <a href="/news"><%= isEn ? 'View all' : '전체보기' %></a>
  </div>
  <ul class="line-list">
    <% if (relatedNews.length === 0) { %>
      <li><%= isEn ? 'No related news.' : '다른 뉴스가 없습니다.' %></li>
    <% } %>
    <% relatedNews.forEach((item) => { %>
      <li>
        <a href="/news/<%= item.id %>"><%= item.title %></a>
        <span><%= item.created_at.slice(0, 10) %></span>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/layout-end') %>
