<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="block-card">
  <div class="section-head">
    <h2>QC</h2>
    <form method="get" action="/qc" class="inline-search">
      <input type="text" name="orderNo" value="<%= orderNo %>" placeholder="<%= isEn ? 'ex: CL-20260326-AB12CD' : '예: CL-20260326-AB12CD' %>" />
      <button type="submit" class="chip dark"><%= isEn ? 'Search' : '검색' %></button>
    </form>
  </div>

  <ul class="media-line-list qc-media-list">
    <% if (items.length === 0) { %>
      <li class="media-line-empty"><%= isEn ? 'No QC images found.' : '등록된 QC 이미지가 없습니다.' %></li>
    <% } %>
    <% items.forEach((item) => { %>
      <li class="media-line-item">
        <span class="media-line-thumb">
          <img src="<%= item.image_path %>" alt="qc image" loading="lazy" />
        </span>
        <div class="media-line-body">
          <strong class="media-line-title"><%= isEn ? 'Order No.' : '구매번호' %>: <%= item.order_no %></strong>
          <p class="media-line-note"><%= item.note || '-' %></p>
          <small class="media-line-meta"><%= item.created_at.slice(0, 10) %></small>
        </div>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/layout-end') %>
