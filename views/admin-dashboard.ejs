      <a href="/admin/products?section=list" class="menu-pill <%= productsTab === 'list' ? 'active' : '' %>"><%= isEn ? 'Product List' : '상품 목록' %></a>
      <a href="/admin/products?section=badges" class="menu-pill <%= productsTab === 'badges' ? 'active' : '' %>"><%= isEn ? 'Badge Settings' : '배지 설정' %></a>
