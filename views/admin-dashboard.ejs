    <% if (memberSection === 'active' || memberSection === 'blocked') { %>
    <script>
      (() => {
        const toggles = Array.from(document.querySelectorAll('[data-member-edit-toggle]'));
        if (toggles.length === 0) return;

        const labels = {
          open: <%- JSON.stringify(isEn ? 'Edit' : '수정') %>,
          close: <%- JSON.stringify(isEn ? 'Close' : '닫기') %>
        };

        const closeAll = () => {
          toggles.forEach((btn) => {
            const targetId = btn.getAttribute('data-member-edit-toggle');
            const panel = document.getElementById(`member-editor-${targetId}`);
            if (!panel) return;
            panel.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
            btn.textContent = labels.open;
          });
        };

        toggles.forEach((btn) => {
          btn.addEventListener('click', () => {
            const targetId = btn.getAttribute('data-member-edit-toggle');
            const panel = document.getElementById(`member-editor-${targetId}`);
            if (!panel) return;

            const isOpen = panel.classList.contains('open');
            closeAll();
            if (!isOpen) {
              panel.classList.add('open');
              btn.setAttribute('aria-expanded', 'true');
              btn.textContent = labels.close;
            }
          });
        });

        const blockForms = Array.from(document.querySelectorAll('form[data-member-block-form]'));
        blockForms.forEach((form) => {
          form.addEventListener('submit', (event) => {
            event.preventDefault();
            const reasonInput = form.querySelector('[data-member-block-reason]');
            const promptLabel = <%- JSON.stringify(isEn ? 'Enter block reason (optional):' : '블락 사유를 입력해 주세요. (선택)') %>;
            const reasonRaw = window.prompt(promptLabel, reasonInput ? reasonInput.value : '');
            if (reasonRaw === null) {
              return;
            }
            if (reasonInput) {
              reasonInput.value = String(reasonRaw).trim().slice(0, 120);
            }
            form.submit();
          });
        });
      })();
    </script>
    <% } %>
  </article>
  <% } %>

  <% if (tab === 'points') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Point Management' : '포인트 관리' %></h3>
    <div class="security-subnav">
      <a href="/admin/points?section=signup" class="menu-pill <%= pointsTab === 'signup' ? 'active' : '' %>"><%= isEn ? 'Signup Points' : '회원가입 포인트' %></a>
      <a href="/admin/points?section=level-rates" class="menu-pill <%= pointsTab === 'level-rates' ? 'active' : '' %>"><%= isEn ? 'Level Point Rates' : '등급별 적용 포인트' %></a>
    </div>

    <% if (pointsTab === 'signup') { %>
      <section class="kpi-card">
        <h4><%= isEn ? 'Signup Bonus Points' : '회원가입 포인트 설정' %></h4>
        <p class="muted-label"><%= isEn ? 'Set how many points are credited immediately after signup. (1 point = 1 KRW)' : '회원가입 완료 즉시 지급할 포인트를 설정합니다. (1포인트 = 1원)' %></p>
        <form method="post" action="/admin/points/signup" class="form-grid">
          <label>
            <%= isEn ? 'Signup Bonus Points' : '회원가입 포인트' %>
            <input type="number" name="signupBonusPoints" min="0" step="1" value="<%= Number(settings.signupBonusPoints || 0) %>" required />
          </label>
          <button type="submit" class="chip dark"><%= isEn ? 'Save Signup Points' : '회원가입 포인트 저장' %></button>
        </form>
      </section>
    <% } %>

    <% if (pointsTab === 'level-rates') { %>
      <section class="kpi-card">
        <h4><%= isEn ? 'Level Point Rate Settings' : '등급별 포인트 적립률 설정' %></h4>
        <p class="muted-label">
          <%= isEn ? 'Manage point percentage per member level. Updated rates apply only to new purchases after update.' : '회원등급별 포인트 적립 퍼센테이지를 설정합니다. 변경된 적립률은 변경 이후 신규 구매건부터 적용됩니다.' %>
        </p>

        <% if (memberLevelRules.length === 0) { %>
          <p class="muted-label"><%= isEn ? 'No member levels configured. Please create levels first in Member Management.' : '설정된 회원등급이 없습니다. 회원관리 > 회원레벨 설정에서 먼저 등급을 생성해 주세요.' %></p>
        <% } else { %>
          <form method="post" action="/admin/points/level-rates" class="form-grid">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th><%= isEn ? 'Level' : '등급' %></th>
                    <th><%= isEn ? 'Condition' : '조건' %></th>
                    <th><%= isEn ? 'Accumulated Amount' : '누적 구매금액' %></th>
                    <th><%= isEn ? 'Point Rate (%)' : '포인트 적립률 (%)' %></th>
                  </tr>
                </thead>
                <tbody>
                  <% memberLevelRules.forEach((rule) => { %>
                    <tr>
                      <td><strong><%= rule.name %></strong></td>
                      <td><%= rule.operatorLabel || '-' %></td>
                      <td>₩<%= Number(rule.thresholdAmount || 0).toLocaleString('ko-KR') %></td>
                      <td>
                        <input type="number" min="0" max="100" step="0.01" name="rate_<%= rule.id %>" value="<%= Number(rule.pointRate || 0) %>" />
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <button type="submit" class="chip dark"><%= isEn ? 'Save Level Point Rates' : '등급별 포인트 저장' %></button>
          </form>
        <% } %>
      </section>
    <% } %>
  </article>
  <% } %>

  <% if (tab === 'site') { %>
