        const targetTabKey = tabDefs.some((item) => item.key === tabKey) ? tabKey : (tabDefs[0]?.key || 'price');
        const previousMode = getScopeMode(activeTabKey);
        if (dirty && previousMode === 'factory' && targetTabKey !== activeTabKey) {
          flushAutoSaveNow(isEn ? 'auto-saved before tab switch' : '탭 전환 전 자동 저장');
        }

        activeTabKey = targetTabKey;
        mainTabButtons.forEach((button) => {
          button.classList.toggle('active', button.getAttribute('data-sales-main-tab') === targetTabKey);
        });
        if (saveBtn) {
          saveBtn.style.display = isPriceTableActive() ? 'none' : '';
        }
        ensureActiveScope();
        const createdTodayScope = ensureTodayScopeForDateTab();
        renderGlobalFields();
        renderScopeControls();
        renderTableRows();
        renderSummary();
        renderMeta();
        if (createdTodayScope) {
          void saveWorkbook({ silent: true, reason: isEn ? 'new date scope created' : '신규 날짜 시트 생성' });
        }
      };

      const loadWorkbook = async () => {
        clearError();
        try {
          const response = await fetch('/admin/sales/data', {
            headers: { accept: 'application/json' }
          });
          const payload = await response.json();
          if (!response.ok || !payload?.ok || !payload?.workbook) {
            throw new Error(payload?.message || (isEn ? 'Failed to load workbook.' : '워크북을 불러오지 못했습니다.'));
          }
          workbook = payload.workbook;
          ensureActiveScope();
          dirty = false;
          renderGlobalFields();
          setMainTab(activeTabKey);
        } catch (error) {
          showError(error instanceof Error ? error.message : (isEn ? 'Unknown error' : '알 수 없는 오류'));
        }
      };

      mainTabButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const tabKey = button.getAttribute('data-sales-main-tab') || '';
          setMainTab(tabKey);
        });
      });

      const resolveScopeForRowTarget = (targetElement, rowId = '') => {
        const rowScopeId = String(targetElement?.closest('tr')?.dataset.scopeId || '');
        if (rowScopeId) {
          const matchedScope = getScopes().find((scope) => String(scope?.id || '') === rowScopeId);
          if (matchedScope && Array.isArray(matchedScope.rows)) {
            if (!rowId || matchedScope.rows.some((row) => String(row?.id || '') === rowId)) {
              return matchedScope;
            }
          }
        }
        const activeScope = getActiveScope();
        if (activeScope && Array.isArray(activeScope.rows)) {
          return activeScope;
        }
        return null;
      };

      tableBody.addEventListener('input', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        const rowId = String(target.dataset.rowId || '');
        const field = String(target.dataset.field || '');
        if (!rowId || !field) return;

        const scope = resolveScopeForRowTarget(target, rowId);
        if (!scope || !Array.isArray(scope.rows)) return;
        const row = scope.rows.find((item) => item.id === rowId);
        if (!row) return;

        if (field === 'costRmb' || field === 'saleKrw') {
          row[field] = toPositive(target.value, 0);
        } else if (field === 'quantity') {
          row[field] = Math.max(1, Math.floor(toPositive(target.value, 1) || 1));
        } else {
          row[field] = String(target.value || '').slice(0, field === 'memo' ? 500 : 200);
        }

        const tr = target.closest('tr');
        if (tr) updateComputedCells(tr, row);
        markDirty();
        renderSummary();
        renderMeta();
      });

      tableBody.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;
        const rowId = String(target.dataset.rowDelete || '');
        if (!rowId) return;

        const scope = resolveScopeForRowTarget(target, rowId);
        if (!scope || !Array.isArray(scope.rows)) return;
        scope.rows = scope.rows.filter((row) => row.id !== rowId);
        markDirty();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      addRowBtn?.addEventListener('click', () => {
        const scope = getActiveScope();
        if (!scope || !Array.isArray(scope.rows)) return;
        const isPriceSheet = getScopeMode(activeTabKey) === 'factory';
        if (isPriceSheet) {
          if (activePriceScopeAll) {
            showError(isEn ? 'Select one factory sheet to add rows.' : '행 추가는 공장 시트를 하나 선택한 뒤 가능합니다.');
            return;
          }
          ensurePriceFilters();
        }
        scope.rows.push({
          id: `row-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
          factory: isPriceSheet ? String(scope?.name || '') : '',
          brand: isPriceSheet ? String(activePriceBrand || '') : '',
          model: isPriceSheet ? String(activePriceModel || '') : '',
          reference: '',
          spec: '',
          costRmb: 0,
          saleKrw: 0,
          quantity: 1,
          memo: ''
        });
        markDirty();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      const applySettingsInputsToActiveScope = () => {
        const tab = getTabData();
        const scope = getActiveScope();
        const activeSettings = getActiveSettings();
        if (!tab || !activeSettings) return;

        activeSettings.exchangeRate = Number(
          roundToStep(Math.max(0.01, toPositive(exchangeRateInput.value, activeSettings.exchangeRate || 0.01)), 0.01).toFixed(2)
        );
        activeSettings.shippingFeeKrw = Math.max(
          0,
          Math.round(roundToStep(toPositive(shippingFeeInput.value, activeSettings.shippingFeeKrw || 0), 1000))
        );
        activeSettings.updatedAt = new Date().toISOString();

        const mode = getScopeMode(activeTabKey);
        const nextScopeDate = normalizeDate(scopeDateInput.value || '');
        if (nextScopeDate && scope) {
          ensureScopeSettings(scope, mode);
          scope.settings.baseDate = nextScopeDate;
          scope.date = nextScopeDate;
          if (mode === 'date') {
            scope.name = nextScopeDate;
          }
        }

        markDirty();
      };

      exchangeRateInput?.addEventListener('input', () => {
        applySettingsInputsToActiveScope();
        renderGlobalFields();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      shippingFeeInput?.addEventListener('input', () => {
        applySettingsInputsToActiveScope();
        renderGlobalFields();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      scopeDateInput?.addEventListener('change', () => {
        applySettingsInputsToActiveScope();
        renderGlobalFields();
        renderScopeControls();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      applyGlobalBtn?.addEventListener('click', () => {
        applySettingsInputsToActiveScope();
        void saveWorkbook();
      });

      saveBtn?.addEventListener('click', () => {
        void saveWorkbook();
      });

      fxSyncBtn?.addEventListener('click', async () => {
        clearError();
        try {
          const requestBody = {
            tabKey: activeTabKey,
            scopeId: activeScopeId || '',
            scopeDate:
              normalizeDate(scopeDateInput.value || '') ||
              normalizeDate(getActiveScope()?.settings?.baseDate || getActiveScope()?.date || '')
          };
          const response = await fetch('/admin/sales/fx-sync', {
            method: 'POST',
            headers: {
              accept: 'application/json',
              'content-type': 'application/json'
            },
            body: JSON.stringify(requestBody)
          });
          const payload = await response.json();
          if (!response.ok || !payload?.ok || !payload?.workbook) {
            throw new Error(payload?.message || (isEn ? 'FX sync failed.' : '환율 자동 반영 실패'));
          }
          workbook = payload.workbook;
          dirty = false;
          ensureActiveScope();
          renderGlobalFields();
          renderScopeControls();
          renderTableRows();
          renderSummary();
          renderMeta(isEn ? 'Naver/Hana rate applied' : '네이버/하나은행 환율 반영됨');
        } catch (error) {
          showError(error instanceof Error ? error.message : (isEn ? 'Unknown error' : '알 수 없는 오류'));
        }
      });

      window.addEventListener('pagehide', () => {
        if (!dirty || !workbook || !isPriceTableActive()) return;
        if (autoSaveTimer) {
          clearTimeout(autoSaveTimer);
          autoSaveTimer = null;
        }
        try {
          fetch('/admin/sales/workbook', {
            method: 'POST',
            headers: {
              'content-type': 'application/json',
              accept: 'application/json'
            },
            body: JSON.stringify({ workbook }),
            keepalive: true
          });
        } catch (error) {
          // ignore keepalive errors during unload
        }
      });

      void loadWorkbook();
    })();
  </script>
  <% } else { %>
  <article class="block-card sales-daily-card">
    <h3><%= isEn ? 'Daily Total Sales' : '날짜별 전체 매출' %></h3>
    <p class="muted-label">
      <%= isEn ? 'Automatically recorded from shop orders. Columns show sales/cost/margin/real margin by shop category and overall total.' : '쇼핑몰 주문건 기준으로 자동 기록됩니다. 쇼핑몰별 매출/원가/마진/실제마진과 전체 합계를 날짜별로 확인할 수 있습니다.' %>
    </p>

    <form method="get" action="/admin/sales" class="form-grid compact sales-daily-filter-form">
      <input type="hidden" name="section" value="daily" />
      <label>
        <span><%= isEn ? 'Shop Category' : '쇼핑몰 분류' %></span>
        <select name="salesGroup">
          <option value="all" <%= activeSalesGroupFilter === 'all' ? 'selected' : '' %>><%= isEn ? 'All' : '전체' %></option>
          <% productGroupKeys.forEach((groupKey) => { %>
            <option value="<%= groupKey %>" <%= activeSalesGroupFilter === groupKey ? 'selected' : '' %>><%= groupLabelByKey[groupKey] || groupKey %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <span><%= isEn ? 'From' : '시작일' %></span>
        <input type="date" name="salesDateFrom" value="<%= activeSalesDateFrom %>" />
      </label>
      <label>
        <span><%= isEn ? 'To' : '종료일' %></span>
        <input type="date" name="salesDateTo" value="<%= activeSalesDateTo %>" />
      </label>
      <div class="admin-field-chip-row">
        <button type="submit" class="chip dark"><%= isEn ? 'Search' : '조회' %></button>
        <a href="/admin/sales?section=daily" class="chip"><%= isEn ? 'Reset' : '초기화' %></a>
      </div>
    </form>

    <div class="sales-daily-summary-grid">
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Order Count' : '주문건' %></h4>
        <strong><%= salesDaily.totals.orderCount %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Sales' : '전체 매출' %></h4>
        <strong><%= formatPrice(salesDaily.totals.salesKrw) %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Cost' : '전체 원가' %></h4>
        <strong><%= formatPrice(salesDaily.totals.costKrw) %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Margin' : '전체 마진' %></h4>
        <strong><%= formatPrice(salesDaily.totals.marginKrw) %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Real Margin' : '전체 실제마진' %></h4>
        <strong><%= formatPrice(salesDaily.totals.realMarginKrw) %></strong>
      </article>
    </div>

    <div class="table-wrap sales-daily-table-wrap">
      <table class="sales-daily-table">
        <thead>
          <tr>
            <th><%= isEn ? 'Date' : '날짜' %></th>
            <% salesDaily.groups.forEach((group) => { %>
              <th><%= group.label %></th>
            <% }) %>
            <th><%= isEn ? 'Total' : '전체' %></th>
          </tr>
        </thead>
        <tbody>
          <% salesDaily.rows.forEach((row) => { %>
            <tr>
              <td>
                <strong><%= row.date %></strong>
                <small class="muted-label"><%= isEn ? `Orders ${row.total.orderCount}` : `주문 ${row.total.orderCount}건` %></small>
              </td>
              <% salesDaily.groups.forEach((group) => { const metrics = row.metricsByGroup[group.key] || { orderCount: 0, salesKrw: 0, costKrw: 0, marginKrw: 0, realMarginKrw: 0 }; %>
                <td>
                  <div class="sales-daily-metric-cell">
                    <small><%= isEn ? 'Orders' : '주문건' %> <strong><%= metrics.orderCount %></strong></small>
                    <small><%= isEn ? 'Sales' : '매출' %> <strong><%= formatPrice(metrics.salesKrw) %></strong></small>
                    <small><%= isEn ? 'Cost' : '원가' %> <strong><%= formatPrice(metrics.costKrw) %></strong></small>
                    <small><%= isEn ? 'Margin' : '마진' %> <strong><%= formatPrice(metrics.marginKrw) %></strong></small>
                    <small><%= isEn ? 'Real Margin' : '실제마진' %> <strong><%= formatPrice(metrics.realMarginKrw) %></strong></small>
                  </div>
                </td>
              <% }) %>
              <td>
                <div class="sales-daily-metric-cell total">
                  <small><%= isEn ? 'Orders' : '주문건' %> <strong><%= row.total.orderCount %></strong></small>
                  <small><%= isEn ? 'Sales' : '매출' %> <strong><%= formatPrice(row.total.salesKrw) %></strong></small>
                  <small><%= isEn ? 'Cost' : '원가' %> <strong><%= formatPrice(row.total.costKrw) %></strong></small>
                  <small><%= isEn ? 'Margin' : '마진' %> <strong><%= formatPrice(row.total.marginKrw) %></strong></small>
                  <small><%= isEn ? 'Real Margin' : '실제마진' %> <strong><%= formatPrice(row.total.realMarginKrw) %></strong></small>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (salesDaily.rows.length === 0) { %>
            <tr>
              <td colspan="<%= salesDaily.groups.length + 2 %>">
                <span class="muted-label"><%= isEn ? 'No daily sales records found for this filter.' : '조건에 맞는 날짜별 매출 기록이 없습니다.' %></span>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </article>
  <% } %>
  <% } %>
  <% if (tab === 'inquiries') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Inquiry Answer Management' : '문의 답변 관리' %></h3>
    <div class="security-subnav">
      <a href="/admin/inquiries?section=reply" class="menu-pill <%= inquiriesTab === 'reply' ? 'active' : '' %>"><%= isEn ? 'Reply Queue' : '답변 등록' %></a>
      <a href="/admin/inquiries?section=list" class="menu-pill <%= inquiriesTab === 'list' ? 'active' : '' %>"><%= isEn ? 'Inquiry List' : '문의 목록 관리' %></a>
    </div>

    <% if (inquiriesTab === 'reply') { %>
      <% const replyTargets = inquiries.filter((item) => !String(item.reply_content || '').trim()); %>
      <div class="admin-list">
        <% replyTargets.forEach((item) => { %>
          <div class="inquiry-admin-item">
            <strong><%= item.title %></strong>
            <p><%= isEn ? 'Writer' : '작성자' %>: <%= item.username %></p>
            <p><%= isEn ? 'Created' : '작성일' %>: <%= item.created_at ? item.created_at.slice(0, 16) : '-' %></p>
            <p><%= isEn ? 'Content' : '내용' %>: <%= item.content %></p>
            <% if (Array.isArray(item.image_paths) && item.image_paths.length > 0) { %>
              <div class="inline-file-preview-grid">
                <% item.image_paths.forEach((src, imageIndex) => { %>
                  <img src="<%= src %>" alt="<%= `${item.title}-${imageIndex + 1}` %>" class="inline-file-preview-image zoomable-media" data-lightbox-enabled="1" />
                <% }) %>
              </div>
            <% } %>
            <form method="post" action="/admin/inquiry/<%= item.id %>/reply" class="form-grid">
              <label><%= isEn ? 'Reply' : '답변' %>
                <textarea name="replyContent" rows="3" required></textarea>
              </label>
              <button type="submit" class="chip dark"><%= isEn ? 'Save Reply' : '답변 저장' %></button>
            </form>
          </div>
        <% }) %>
        <% if (replyTargets.length === 0) { %>
          <p class="muted-label"><%= isEn ? 'No pending inquiries for reply.' : '답변 대기 중인 문의가 없습니다.' %></p>
        <% } %>
      </div>
    <% } else { %>
      <div class="admin-list">
        <% inquiries.forEach((item) => { %>
          <details class="admin-list-item">
            <summary>
              <strong><%= item.title %></strong>
              <small><%= isEn ? 'Writer' : '작성자' %>: <%= item.username %></small>
              <small><%= item.created_at ? item.created_at.slice(0, 16) : '-' %></small>
              <small><%= Number(item.is_hidden || 0) === 1 ? (isEn ? 'Hidden' : '숨김') : (isEn ? 'Visible' : '노출중') %></small>
            </summary>
            <form id="inquiryUpdateForm-<%= item.id %>" method="post" action="/admin/inquiry/<%= item.id %>/update" enctype="multipart/form-data" class="form-grid compact">
              <label><span><%= isEn ? 'Title' : '제목' %></span>
                <input type="text" name="title" value="<%= item.title %>" required />
              </label>
              <label><span><%= isEn ? 'Content' : '내용' %></span>
                <textarea name="content" rows="3" required><%= item.content %></textarea>
              </label>
              <label><span><%= isEn ? 'Reply' : '답변' %></span>
                <textarea name="replyContent" rows="3"><%= item.reply_content || '' %></textarea>
              </label>
              <label><span><%= isEn ? 'Replace Images' : '이미지 교체' %></span>
                <input type="file" name="image" accept="image/*" multiple />
              </label>
              <% if (Array.isArray(item.image_paths) && item.image_paths.length > 0) { %>
                <div class="inline-file-preview-grid">
                  <% item.image_paths.forEach((src, imageIndex) => { %>
                    <img src="<%= src %>" alt="<%= `${item.title}-${imageIndex + 1}` %>" class="inline-file-preview-image zoomable-media" data-lightbox-enabled="1" />
                  <% }) %>
                </div>
              <% } %>
            </form>
            <div class="admin-field-chip-row admin-post-action-row">
              <button type="submit" form="inquiryUpdateForm-<%= item.id %>" class="chip dark"><%= isEn ? 'Save' : '수정 저장' %></button>
              <form method="post" action="/admin/inquiry/<%= item.id %>/toggle" class="inline-form">
                <button type="submit" class="chip"><%= Number(item.is_hidden || 0) === 1 ? (isEn ? 'Show' : '표시') : (isEn ? 'Hide' : '숨김') %></button>
              </form>
              <form method="post" action="/admin/inquiry/<%= item.id %>/delete" class="inline-form">
                <button type="submit" class="chip" onclick="return confirm('<%= isEn ? 'Delete this inquiry?' : '이 문의 항목을 삭제할까요?' %>');"><%= isEn ? 'Delete' : '삭제' %></button>
              </form>
            </div>
          </details>
        <% }) %>
        <% if (inquiries.length === 0) { %>
          <p class="muted-label"><%= isEn ? 'No inquiries found.' : '문의 항목이 없습니다.' %></p>
        <% } %>
      </div>
    <% } %>
  </article>
  <% } %>
</section>

<%- include('partials/layout-end') %>
