                                <input type="hidden" name="optionValue" value="<%= optionValue %>" />
                                <label><%= isEn ? 'Stored Value' : '저장값' %>
                                  <input type="text" name="nextOptionValue" value="<%= optionValue %>" required />
                                </label>
                                <label><%= isEn ? 'Name (KR)' : '이름 (KR)' %>
                                  <input type="text" name="optionLabelKo" value="<%= factoryLabelEntry.labelKo || optionValue %>" required />
