                          <div class="admin-list-item">
                            <div class="menu-manage-item-row">
                              <strong><%= optionValue %></strong>
                              <form method="post" action="/admin/product-group/filter/remove" class="inline-form">
                                <input type="hidden" name="groupKey" value="<%= group.key %>" />
                                <input type="hidden" name="filterType" value="factory" />
                                <input type="hidden" name="optionValue" value="<%= optionValue %>" />
                                <button type="submit" class="chip"><%= isEn ? 'Delete' : '삭제' %></button>
                              </form>
