                                <input type="hidden" name="filterType" value="brand" />
                                <input type="hidden" name="optionValue" value="<%= brandOption %>" />
                                <label><%= isEn ? 'Stored Value' : '저장값' %>
                                  <input type="text" name="nextOptionValue" value="<%= brandOption %>" required />
                                </label>
                                <label><%= isEn ? 'Name (KR)' : '이름 (KR)' %>
                                  <input type="text" name="optionLabelKo" value="<%= brandLabelEntry.labelKo || brandOption %>" required />
                                </label>
                                <label><%= isEn ? 'Name (EN)' : '이름 (EN)' %>
                                  <input type="text" name="optionLabelEn" value="<%= brandLabelEntry.labelEn || brandOption %>" required />
                                </label>
                                <div class="admin-account-actions menu-brand-model-actions">
                                  <button type="submit" class="chip dark filter-chip"><%= isEn ? 'Save Brand' : '브랜드 수정' %></button>
                                </div>
                              </form>
                            </div>

                            <div class="admin-account-actions menu-brand-model-actions">
                              <form method="post" action="/admin/product-group/filter/remove" class="inline-form">
                                <input type="hidden" name="groupKey" value="<%= group.key %>" />
                                <input type="hidden" name="filterType" value="brand" />
                                <input type="hidden" name="optionValue" value="<%= brandOption %>" />
                                <button type="submit" class="chip filter-chip"><%= isEn ? 'Delete Brand' : '브랜드 삭제' %></button>
                              </form>
                            </div>

                            <% if (brandModels.length === 0) { %>
                              <p class="muted-label"><%= isEn ? 'No models for this brand yet.' : '이 브랜드에 등록된 모델이 없습니다.' %></p>
                            <% } else { %>
                              <div class="admin-list menu-brand-model-list">
                                <% brandModels.forEach((optionValue) => { %>
                                  <%
                                    const modelLabelEntry = resolveFilterLabelEntry(brandModelLabelMap, optionValue);
                                    const modelDisplayName = isEn ? (modelLabelEntry.labelEn || optionValue) : (modelLabelEntry.labelKo || optionValue);
                                  %>
                                  <div class="admin-list-item">
                                    <div class="menu-brand-model-row">
                                      <strong class="menu-brand-model-name"><%= modelDisplayName %></strong>
                                      <form method="post" action="/admin/product-group/filter/update" class="form-grid compact">
                                        <input type="hidden" name="groupKey" value="<%= group.key %>" />
                                        <input type="hidden" name="brandValue" value="<%= brandOption %>" />
                                        <input type="hidden" name="filterType" value="model" />
                                        <input type="hidden" name="optionValue" value="<%= optionValue %>" />
                                        <label><%= isEn ? 'Stored Value' : '저장값' %>
                                          <input type="text" name="nextOptionValue" value="<%= optionValue %>" required />
                                        </label>
                                        <label><%= isEn ? 'Name (KR)' : '이름 (KR)' %>
                                          <input type="text" name="optionLabelKo" value="<%= modelLabelEntry.labelKo || optionValue %>" required />
                                        </label>
                                        <label><%= isEn ? 'Name (EN)' : '이름 (EN)' %>
