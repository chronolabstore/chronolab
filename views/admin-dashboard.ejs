      </div>

      <button type="submit" class="cta-main"><%= isEn ? 'Save Theme Settings' : '테마 설정 저장' %></button>
    </form>
    <% } %>
  </article>
  <% } %>

  <% if (tab === 'menus') { %>
  <article class="block-card menu-manage-card">
    <h3><%= isEn ? 'Menu Manager' : '메뉴 관리' %></h3>
    <div class="security-subnav">
      <a href="/admin/menus?section=public" class="menu-pill <%= menusTab === 'public' ? 'active' : '' %>"><%= isEn ? 'Public Menus' : '공개 메뉴' %></a>
      <a href="/admin/menus?section=groups" class="menu-pill <%= menusTab === 'groups' ? 'active' : '' %>"><%= isEn ? 'Category Manager' : '분류 관리' %></a>
      <a href="/admin/menus?section=group-filters" class="menu-pill <%= menusTab === 'group-filters' ? 'active' : '' %>"><%= isEn ? 'Category Filters' : '분류 필터' %></a>
      <a href="/admin/menus?section=fields" class="menu-pill <%= menusTab === 'fields' ? 'active' : '' %>"><%= isEn ? 'Upload Fields' : '업로드 항목' %></a>
    </div>

    <% if (menusTab === 'public') { %>
      <div class="menu-manage-stack">
        <form method="post" action="/admin/menu/add" class="form-grid menu-manage-form">
          <label><%= isEn ? 'Menu Label (KR)' : '메뉴명 (KR)' %>
            <input type="text" name="labelKo" required />
          </label>
          <label><%= isEn ? 'Menu Label (EN)' : '메뉴명 (EN)' %>
            <input type="text" name="labelEn" required />
          </label>
          <label><%= isEn ? 'Path (e.g. /event)' : '경로 (예: /event)' %>
            <input type="text" name="path" required />
          </label>
          <button type="submit" class="chip dark menu-manage-submit"><%= isEn ? 'Add Menu' : '메뉴 추가' %></button>
        </form>

        <div class="admin-list menu-manage-list">
          <% publicMenus.forEach((menu) => { %>
            <div class="admin-list-item">
              <div class="menu-manage-item-row">
                <div class="menu-manage-item-copy">
                  <strong><%= menu.labelKo %> / <%= menu.labelEn %></strong>
                  <span><%= menu.path %></span>
                  <span class="muted-label"><%= menu.isHidden ? (isEn ? 'Hidden' : '숨김') : (isEn ? 'Visible' : '표시중') %></span>
                </div>
                <div class="admin-account-actions">
                  <form method="post" action="/admin/menu/toggle/<%= menu.id %>" class="inline-form">
                    <button type="submit" class="chip"><%= menu.isHidden ? (isEn ? 'Show' : '표시') : (isEn ? 'Hide' : '숨김') %></button>
                  </form>
                  <form method="post" action="/admin/menu/remove/<%= menu.id %>" class="inline-form">
                    <button type="submit" class="chip"><%= isEn ? 'Delete' : '삭제' %></button>
                  </form>
                </div>
              </div>
              <details class="menu-inline-edit">
                <summary><%= isEn ? 'Edit' : '수정' %></summary>
                <form method="post" action="/admin/menu/update/<%= menu.id %>" class="form-grid compact menu-inline-edit-form">
                  <label><%= isEn ? 'Menu Label (KR)' : '메뉴명 (KR)' %>
                    <input type="text" name="labelKo" value="<%= menu.labelKo %>" required />
                  </label>
                  <label><%= isEn ? 'Menu Label (EN)' : '메뉴명 (EN)' %>
                    <input type="text" name="labelEn" value="<%= menu.labelEn %>" required />
                  </label>
                  <label><%= isEn ? 'Path' : '경로' %>
                    <input type="text" name="path" value="<%= menu.path %>" required />
                  </label>
                  <button type="submit" class="chip dark"><%= isEn ? 'Save Changes' : '수정 저장' %></button>
                </form>
              </details>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (menusTab === 'groups') { %>
      <div class="menu-manage-stack">
        <p class="muted-label menu-manage-note">
          <%= isEn ? 'Add or remove shop top categories. Category filter settings are managed in the Category Filters tab.' : '쇼핑몰 상위 분류를 추가/삭제할 수 있습니다. 브랜드/공장 필터는 분류 필터 탭에서 관리합니다.' %>
        </p>
        <form method="post" action="/admin/product-group/add" class="form-grid menu-manage-form">
          <label><%= isEn ? 'Category Key (optional)' : '분류 키 (선택)' %>
            <input type="text" name="key" placeholder="<%= isEn ? 'factory-plus' : 'factory-plus' %>" />
          </label>
          <label><%= isEn ? 'Category Name (KR)' : '분류명 (KR)' %>
            <input type="text" name="labelKo" required />
          </label>
          <label><%= isEn ? 'Category Name (EN)' : '분류명 (EN)' %>
            <input type="text" name="labelEn" required />
          </label>
          <label><%= isEn ? 'Default Field Template' : '기본 항목 템플릿' %>
            <select name="templateType">
              <option value="simple"><%= isEn ? 'Basic (Title + Detail)' : '기본형 (제목 + 상세설명)' %></option>
              <option value="factory"><%= isEn ? 'Factory Spec Fields' : '공장제형 필드' %></option>
            </select>
          </label>
          <button type="submit" class="chip dark menu-manage-submit"><%= isEn ? 'Add Category' : '분류 추가' %></button>
        </form>

        <div class="admin-list menu-manage-list">
          <% productGroupConfigList.forEach((group) => { %>
            <div class="admin-list-item">
              <div class="menu-manage-item-row">
                <div class="menu-manage-item-copy">
                  <strong><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></strong>
                  <span><%= isEn ? 'Key' : '키' %>: <code><%= group.key %></code></span>
                  <span class="muted-label"><%= isEn ? `${(group.customFields || []).length} fields configured` : `설정된 업로드 항목 ${(group.customFields || []).length}개` %></span>
                </div>
                <div class="admin-account-actions">
                  <% if (productGroupConfigList.length > 1) { %>
                    <form method="post" action="/admin/product-group/remove/<%= encodeURIComponent(group.key) %>" class="inline-form">
                      <button type="submit" class="chip"><%= isEn ? 'Delete Category' : '분류 삭제' %></button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (menusTab === 'group-filters') { %>
      <div class="menu-manage-stack">
        <p class="muted-label menu-manage-note">
          <%= isEn ? 'Manage category-level brand/factory filters used by shop search and product upload dropdowns.' : '쇼핑몰 검색 필터와 상품 업로드 드롭다운에서 사용할 분류별 브랜드/공장 필터를 관리합니다.' %>
        </p>

        <div class="admin-list menu-manage-list">
          <% productGroupConfigList.forEach((group) => { %>
            <%
              const brandFilters = Array.isArray(group.brandOptions) ? group.brandOptions : [];
              const factoryFilters = Array.isArray(group.factoryOptions) ? group.factoryOptions : [];
              const supportsFactoryFilterGroup =
                String(group.key || '').trim() === '공장제' ||
                String(group.key || '').trim() === '현지중고' ||
                factoryFilters.length > 0;
            %>
            <div class="admin-list-item">
              <div class="menu-manage-item-row">
                <div class="menu-manage-item-copy">
                  <strong><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></strong>
                  <span><%= isEn ? 'Key' : '키' %>: <code><%= group.key %></code></span>
                </div>
              </div>

              <div class="admin-grid two-col">
                <section class="kpi-card">
                  <h4><%= isEn ? 'Brand Filters' : '브랜드 필터' %></h4>
                  <% if (brandFilters.length === 0) { %>
