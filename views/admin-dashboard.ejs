<%- include('partials/layout-start') %>
<%
  const tab = activeTab || 'dashboard';
  const isEn = ctx.lang === 'en';
  const groupLabelMap = {
    '공장제': isEn ? 'Factory' : '공장제',
    '젠파츠': isEn ? 'Gen Parts' : '젠파츠',
    '현지중고': isEn ? 'Local Used' : '현지중고'
  };

  const stats = dashboardStats || {
    users: { members: 0, admins: 0, total: 0 },
    memberVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    totalVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    boardCounts: { notice: 0, news: 0, qc: 0, review: 0, inquiry: 0 },
    shopCounts: { total: 0, active: 0, byGroup: [] },
    orderCounts: { total: 0, pendingReview: 0, confirmed: 0, readyToShip: 0, shipping: 0, delivered: 0 },
    orderAlerts: { stalePending: 0, longShipping: 0 }
  };
%>

<section class="admin-grid single">
  <% if (tab === 'dashboard') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Admin Dashboard' : '관리자 대시보드' %></h3>

    <div class="admin-kpi-grid two-col">
      <div class="kpi-card">
        <h4><%= isEn ? 'Members' : '회원 수' %></h4>
        <strong><%= stats.users.members %></strong>
        <p class="muted-label"><%= isEn ? `Admins ${stats.users.admins} / Total ${stats.users.total}` : `어드민 ${stats.users.admins} / 전체 계정 ${stats.users.total}` %></p>
      </div>
      <div class="kpi-card">
        <h4><%= isEn ? 'Orders Total' : '총 주문건' %></h4>
        <strong><%= stats.orderCounts.total %></strong>
        <p class="muted-label"><%= isEn ? 'Order pipeline summary below.' : '주문 상태 파이프라인은 아래에서 확인하세요.' %></p>
      </div>
    </div>

    <div class="admin-kpi-grid two-col">
      <div class="kpi-card">
        <h4><%= isEn ? 'Member Visits' : '회원 방문 집계' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Today' : '오늘' %></span><strong><%= stats.memberVisits.today %></strong></li>
          <li><span><%= isEn ? '7 Days' : '일주일' %></span><strong><%= stats.memberVisits.week %></strong></li>
          <li><span><%= isEn ? '30 Days' : '한달' %></span><strong><%= stats.memberVisits.month %></strong></li>
          <li><span><%= isEn ? '1 Year' : '1년' %></span><strong><%= stats.memberVisits.year %></strong></li>
          <li><span><%= isEn ? 'Total' : '총' %></span><strong><%= stats.memberVisits.total %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Total Visits (All)' : '총 방문자 집계(회원+비회원)' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Today' : '오늘' %></span><strong><%= stats.totalVisits.today %></strong></li>
          <li><span><%= isEn ? '7 Days' : '일주일' %></span><strong><%= stats.totalVisits.week %></strong></li>
          <li><span><%= isEn ? '30 Days' : '한달' %></span><strong><%= stats.totalVisits.month %></strong></li>
          <li><span><%= isEn ? '1 Year' : '1년' %></span><strong><%= stats.totalVisits.year %></strong></li>
          <li><span><%= isEn ? 'Total' : '총' %></span><strong><%= stats.totalVisits.total %></strong></li>
        </ul>
      </div>
    </div>

    <div class="admin-kpi-grid two-col">
      <div class="kpi-card">
        <h4><%= isEn ? 'Board Post Counts' : '게시판 게시물 수' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Notice' : '공지사항' %></span><strong><%= stats.boardCounts.notice %></strong></li>
          <li><span><%= isEn ? 'News' : '뉴스' %></span><strong><%= stats.boardCounts.news %></strong></li>
          <li><span>QC</span><strong><%= stats.boardCounts.qc %></strong></li>
          <li><span><%= isEn ? 'Reviews' : '구매후기' %></span><strong><%= stats.boardCounts.review %></strong></li>
          <li><span><%= isEn ? 'Inquiry' : '문의' %></span><strong><%= stats.boardCounts.inquiry %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Order Status Summary' : '주문 상태 집계' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Unchecked' : '미확인 주문건' %></span><strong><%= stats.orderCounts.pendingReview %></strong></li>
          <li><span><%= isEn ? 'Confirmed' : '확인 주문건' %></span><strong><%= stats.orderCounts.confirmed %></strong></li>
          <li><span><%= isEn ? 'Preparing Shipment' : '출고중 주문건' %></span><strong><%= stats.orderCounts.readyToShip %></strong></li>
          <li><span><%= isEn ? 'Shipping' : '배송중 주문건' %></span><strong><%= stats.orderCounts.shipping %></strong></li>
          <li><span><%= isEn ? 'Delivered' : '배송완료 주문건' %></span><strong><%= stats.orderCounts.delivered %></strong></li>
        </ul>
      </div>
    </div>

    <div class="kpi-card">
      <h4><%= isEn ? 'Operational Alerts' : '운영 알림' %></h4>
      <ul class="metric-list">
        <li><span><%= isEn ? 'Unchecked 24h+' : '24시간 이상 미확인' %></span><strong><%= stats.orderAlerts.stalePending %></strong></li>
        <li><span><%= isEn ? 'Shipping 7d+' : '7일 이상 배송중' %></span><strong><%= stats.orderAlerts.longShipping %></strong></li>
      </ul>
    </div>

    <div class="kpi-card">
      <h4><%= isEn ? 'Shop Inventory (3 Groups)' : '쇼핑몰 상품 현황 (3분할)' %></h4>
      <p class="muted-label"><%= isEn ? `Active ${stats.shopCounts.active} / Total ${stats.shopCounts.total}` : `활성 ${stats.shopCounts.active} / 전체 ${stats.shopCounts.total}` %></p>
      <div class="shop-split-grid">
        <% stats.shopCounts.byGroup.forEach((groupItem) => { %>
          <article class="shop-split-card">
            <h5><%= groupLabelMap[groupItem.groupName] || groupItem.groupName %></h5>
            <p><strong><%= groupItem.activeCount %></strong> <%= isEn ? 'active' : '활성' %></p>
            <small><%= isEn ? 'hidden' : '숨김' %>: <%= groupItem.hiddenCount %></small>
          </article>
        <% }) %>
      </div>
    </div>
  </article>
  <% } %>

  <% if (tab === 'security') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Admin Security' : '어드민 보안' %></h3>
    <form method="post" action="/admin/change-password" class="form-grid">
      <label><%= isEn ? 'Current Password' : '현재 비밀번호' %>
        <input type="password" name="currentPassword" required />
      </label>
      <label><%= isEn ? 'New Password (min 8, letters+numbers)' : '새 비밀번호 (영문/숫자 포함 8자 이상)' %>
        <input type="password" name="newPassword" required />
      </label>
      <label><%= isEn ? 'Confirm New Password' : '새 비밀번호 확인' %>
        <input type="password" name="newPasswordConfirm" required />
      </label>
      <button type="submit" class="cta-main"><%= isEn ? 'Change Password' : '비밀번호 변경' %></button>
    </form>
  </article>
  <% } %>

  <% if (tab === 'site') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Site Customization' : '사이트 커스터마이징' %></h3>
    <form method="post" action="/admin/settings" enctype="multipart/form-data" class="form-grid">
      <label><%= isEn ? 'Site Name' : '쇼핑몰 이름' %>
        <input type="text" name="siteName" value="<%= settings.siteName %>" />
      </label>

      <label><%= isEn ? 'Header Color' : '헤더 컬러' %>
        <input type="color" name="headerColor" value="<%= settings.headerColor %>" />
      </label>

      <label><%= isEn ? 'Background Type' : '배경 타입' %>
        <select name="backgroundType">
          <option value="color" <%= settings.backgroundType === 'color' ? 'selected' : '' %>>Color</option>
          <option value="image" <%= settings.backgroundType === 'image' ? 'selected' : '' %>>Image</option>
        </select>
      </label>

      <label><%= isEn ? 'Background Color' : '배경 컬러' %>
        <input type="color" name="backgroundColor" value="<%= settings.backgroundValue && settings.backgroundValue.startsWith('#') ? settings.backgroundValue : '#f7f7f8' %>" />
      </label>

      <label><%= isEn ? 'Background Image Upload' : '배경 이미지 업로드' %>
        <input type="file" name="backgroundImage" accept="image/*" />
      </label>

      <label><%= isEn ? 'Header Symbol Upload' : '헤더 심볼 업로드' %>
        <input type="file" name="headerSymbol" accept="image/*" />
      </label>

      <label><%= isEn ? 'Header Logo Upload' : '헤더 로고 업로드' %>
        <input type="file" name="headerLogo" accept="image/*" />
      </label>

      <label><%= isEn ? 'Footer Logo Upload' : '푸터 로고 업로드' %>
        <input type="file" name="footerLogo" accept="image/*" />
      </label>

      <label><%= isEn ? 'Default Language' : '기본 언어' %>
        <select name="languageDefault">
          <option value="ko" <%= settings.languageDefault === 'ko' ? 'selected' : '' %>><%= isEn ? 'Korean' : '한국어' %></option>
          <option value="en" <%= settings.languageDefault === 'en' ? 'selected' : '' %>>English</option>
        </select>
      </label>

      <label><%= isEn ? 'Business Info' : '사이트 정보' %>
        <textarea name="businessInfo" rows="2"><%= settings.businessInfo %></textarea>
      </label>

      <label><%= isEn ? 'Contact Info' : '연락처 정보' %>
        <textarea name="contactInfo" rows="2"><%= settings.contactInfo %></textarea>
      </label>

      <label><%= isEn ? 'Bank Account Info' : '입금 계좌 정보' %>
        <textarea name="bankAccountInfo" rows="2"><%= settings.bankAccountInfo %></textarea>
      </label>

      <label><%= isEn ? 'Menu JSON (Advanced)' : '메뉴 JSON (고급)' %>
        <textarea name="menusJson" rows="8"><%= settings.menusJson %></textarea>
      </label>

      <button type="submit" class="cta-main"><%= isEn ? 'Save Site Settings' : '사이트 설정 저장' %></button>
    </form>
  </article>
  <% } %>

  <% if (tab === 'menus') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Add / Remove Menus' : '메뉴 추가/삭제' %></h3>
    <form method="post" action="/admin/menu/add" class="form-grid">
      <label><%= isEn ? 'Menu Label (KR)' : '메뉴명 (KR)' %>
        <input type="text" name="labelKo" required />
      </label>
      <label><%= isEn ? 'Menu Label (EN)' : '메뉴명 (EN)' %>
        <input type="text" name="labelEn" required />
      </label>
      <label><%= isEn ? 'Path (e.g. /event)' : '경로 (예: /event)' %>
        <input type="text" name="path" required />
      </label>
      <button type="submit" class="chip dark"><%= isEn ? 'Add Menu' : '메뉴 추가' %></button>
    </form>

    <div class="admin-list">
      <% publicMenus.forEach((menu) => { %>
        <div class="admin-list-item">
          <strong><%= menu.labelKo %> / <%= menu.labelEn %></strong>
          <span><%= menu.path %></span>
          <form method="post" action="/admin/menu/remove/<%= menu.id %>" class="inline-form">
            <button type="submit" class="chip"><%= isEn ? 'Delete' : '삭제' %></button>
          </form>
        </div>
      <% }) %>
    </div>
  </article>
  <% } %>

  <% if (tab === 'products') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Product Upload' : '상품 업로드' %></h3>
    <form method="post" action="/admin/product/create" enctype="multipart/form-data" class="form-grid">
      <label><%= isEn ? 'Images (multiple upload)' : '사진 (여러 장 업로드 가능)' %>
        <input type="file" name="images" accept="image/*" multiple />
      </label>
      <label><%= isEn ? 'Top Category' : '상위 분류' %>
        <select name="categoryGroup" required>
          <% productGroups.forEach((groupName) => { %>
            <option value="<%= groupName %>"><%= groupLabelMap[groupName] || groupName %></option>
          <% }) %>
        </select>
      </label>
      <label><%= isEn ? 'Brand' : '브랜드' %>
        <input type="text" name="brand" placeholder="Rolex" required />
      </label>
      <label><%= isEn ? 'Model' : '모델명' %>
        <input type="text" name="model" placeholder="Submariner" required />
      </label>
      <label><%= isEn ? 'Sub Model' : '세부모델명' %>
        <input type="text" name="subModel" placeholder="Black, Starbucks" required />
      </label>
      <label><%= isEn ? 'Reference' : '레퍼런스' %>
        <input type="text" name="reference" />
      </label>
      <label><%= isEn ? 'Factory' : '공장' %>
        <input type="text" name="factoryName" />
      </label>
      <label><%= isEn ? 'Version' : '버전' %>
        <input type="text" name="versionName" />
      </label>
      <label><%= isEn ? 'Movement' : '무브먼트' %>
        <input type="text" name="movement" />
      </label>
      <label><%= isEn ? 'Case Size' : '케이스사이즈' %>
        <input type="text" name="caseSize" />
      </label>
      <label><%= isEn ? 'Dial Color' : '다이얼 색' %>
        <input type="text" name="dialColor" />
      </label>
      <label><%= isEn ? 'Case Material' : '케이스 재질' %>
        <input type="text" name="caseMaterial" placeholder="Steel, Titanium" />
      </label>
      <label><%= isEn ? 'Bracelet/Strap Material' : '브레이슬릿/스트랩 재질' %>
        <input type="text" name="strapMaterial" />
      </label>
      <label><%= isEn ? 'Features' : '특징' %>
        <textarea name="features" rows="2" placeholder="<%= isEn ? 'Plating, free-sprung, etc.' : '도금, 포금, 프리스프렁 등' %>"></textarea>
      </label>
      <label><%= isEn ? 'Price (KRW)' : '가격 (원)' %>
        <input type="number" name="price" min="0" required />
      </label>
      <label><%= isEn ? 'Shipping Period' : '배송기간' %>
        <input type="text" name="shippingPeriod" placeholder="<%= isEn ? '7-14 days' : '7~14일' %>" />
      </label>
      <button type="submit" class="cta-main"><%= isEn ? 'Add Product' : '상품 등록' %></button>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th><%= isEn ? 'Category' : '분류' %></th>
            <th><%= isEn ? 'Brand/Model' : '브랜드/모델' %></th>
            <th><%= isEn ? 'Price' : '가격' %></th>
            <th><%= isEn ? 'Status' : '상태' %></th>
            <th><%= isEn ? 'Action' : '제어' %></th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((item) => { %>
            <tr>
              <td><%= item.id %></td>
              <td><%= groupLabelMap[item.category_group] || item.category_group || '-' %></td>
              <td><%= item.brand %> <%= item.model %> <%= item.sub_model %></td>
              <td>₩<%= formatPrice(item.price) %></td>
              <td><%= item.is_active ? (isEn ? 'Visible' : '노출') : (isEn ? 'Hidden' : '숨김') %></td>
              <td>
                <form method="post" action="/admin/product/<%= item.id %>/toggle" class="inline-form">
                  <button type="submit" class="chip"><%= item.is_active ? (isEn ? 'Hide' : '숨기기') : (isEn ? 'Show' : '노출') %></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
  <% } %>

  <% if (tab === 'notices') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Notice Upload (Popup Optional)' : '공지사항 업로드 (팝업 선택 가능)' %></h3>
    <form method="post" action="/admin/notice/create" enctype="multipart/form-data" class="form-grid">
      <label><%= isEn ? 'Title' : '제목' %>
        <input type="text" name="title" required />
      </label>
      <label><%= isEn ? 'Content' : '내용' %>
        <textarea name="content" rows="4" required></textarea>
      </label>
      <label><%= isEn ? 'Image' : '이미지' %>
        <input type="file" name="image" accept="image/*" />
      </label>
      <label class="check-row">
        <input type="checkbox" name="isPopup" />
        <span><%= isEn ? 'Show as popup notice' : '팝업 공지로 노출' %></span>
      </label>
      <button type="submit" class="cta-main"><%= isEn ? 'Add Notice' : '공지 등록' %></button>
    </form>

    <ul class="line-list compact">
      <% notices.forEach((item) => { %>
        <li>
          <span><%= item.title %></span>
          <em><%= item.is_popup ? (isEn ? 'Popup' : '팝업') : (isEn ? 'Normal' : '일반') %></em>
        </li>
      <% }) %>
    </ul>
  </article>
  <% } %>

  <% if (tab === 'news') { %>
  <article class="block-card">
    <h3><%= isEn ? 'News Upload' : '뉴스 업로드' %></h3>
    <form method="post" action="/admin/news/create" enctype="multipart/form-data" class="form-grid">
      <label><%= isEn ? 'Title' : '제목' %>
        <input type="text" name="title" required />
      </label>
      <label><%= isEn ? 'Content' : '내용' %>
        <textarea name="content" rows="4" required></textarea>
      </label>
      <label><%= isEn ? 'Image' : '이미지' %>
        <input type="file" name="image" accept="image/*" />
      </label>
      <button type="submit" class="cta-main"><%= isEn ? 'Add News' : '뉴스 등록' %></button>
    </form>

    <ul class="line-list compact">
      <% newsPosts.forEach((item) => { %>
        <li>
          <span><%= item.title %></span>
          <em><%= item.created_at.slice(0, 10) %></em>
        </li>
      <% }) %>
    </ul>
  </article>
  <% } %>

  <% if (tab === 'qc') { %>
  <article class="block-card">
    <h3><%= isEn ? 'QC Upload' : 'QC 업로드' %></h3>
    <form method="post" action="/admin/qc/create" enctype="multipart/form-data" class="form-grid">
      <label><%= isEn ? 'Order No.' : '구매번호' %>
        <input type="text" name="orderNo" required />
      </label>
      <label><%= isEn ? 'QC Image' : 'QC 이미지' %>
        <input type="file" name="image" accept="image/*" required />
      </label>
      <label><%= isEn ? 'Memo' : '메모' %>
        <input type="text" name="note" />
      </label>
      <button type="submit" class="cta-main"><%= isEn ? 'Add QC' : 'QC 등록' %></button>
    </form>

    <ul class="line-list compact">
      <% qcs.forEach((item) => { %>
        <li>
          <span><%= item.order_no %> / <%= item.note || '-' %></span>
          <em><%= item.created_at.slice(0, 10) %></em>
        </li>
      <% }) %>
    </ul>
  </article>
  <% } %>

  <% if (tab === 'orders') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Order Management' : '주문관리' %></h3>
    <p class="muted-label"><%= isEn ? 'Flow: Unchecked -> Confirmed -> Preparing Shipment -> Shipped (In Transit) -> Delivered(auto)' : '프로세스: 미확인 -> 주문확인 -> 출고중 -> 출고완료(배송중) -> 배송완료(자동)' %></p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= isEn ? 'Order No.' : '구매번호' %></th>
            <th><%= isEn ? 'Order Info' : '신청 정보' %></th>
            <th><%= isEn ? 'Status' : '상태' %></th>
            <th><%= isEn ? 'Tracking' : '송장' %></th>
            <th><%= isEn ? 'Action' : '변경' %></th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach((item) => { %>
            <tr>
              <td><%= item.order_no %></td>
              <td>
                <strong><%= item.buyer_name %></strong><br />
                <small><%= item.buyer_contact %></small><br />
                <small><%= isEn ? 'Customs No.' : '통관번호' %>: <%= item.customs_clearance_no || '-' %></small><br />
                <small><%= item.buyer_address %></small><br />
                <small><%= isEn ? 'Depositor' : '입금자명' %>: <%= item.bank_depositor_name %></small>
              </td>
              <td>
                <strong><%= item.status_label %></strong>
                <% if (item.status_detail) { %>
                  <br />
                  <small><%= item.status_detail %></small>
                <% } %>
                <% if (item.checked_at || item.ready_to_ship_at || item.shipping_started_at || item.delivered_at) { %>
                  <br />
                  <small><%= isEn ? 'Timeline' : '타임라인' %>:</small>
                  <ul class="status-mini-list">
                    <% if (item.checked_at) { %>
                      <li><small><%= isEn ? 'Confirmed' : '주문확인' %> · <%= item.checked_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.ready_to_ship_at) { %>
                      <li><small><%= isEn ? 'Preparing' : '출고중' %> · <%= item.ready_to_ship_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.shipping_started_at) { %>
                      <li><small><%= isEn ? 'Shipping Start' : '배송시작' %> · <%= item.shipping_started_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.delivered_at) { %>
                      <li><small><%= isEn ? 'Delivered' : '배송완료' %> · <%= item.delivered_at.slice(0, 16) %></small></li>
                    <% } %>
                  </ul>
                <% } %>
                <% if (item.status_logs && item.status_logs.length > 0) { %>
                  <small><%= isEn ? 'Latest events' : '최근 이력' %>:</small>
                  <ul class="status-mini-list">
                    <% item.status_logs.forEach((log) => { %>
                      <li>
                        <small>
                          <%= log.created_at ? log.created_at.slice(0, 16) : '-' %> ·
                          <%= log.from_status_label ? `${log.from_status_label} → ` : '' %><%= log.to_status_label || log.to_status %>
                        </small>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>
              </td>
              <td>
                <% if (item.tracking_number) { %>
                  <small><strong><%= item.tracking_carrier_label %></strong></small><br />
                  <small><%= item.tracking_number %></small><br />
                  <small><%= item.tracking_last_event || (isEn ? 'Tracking pending' : '조회 대기중') %></small><br />
                  <small><%= item.tracking_last_checked_at ? item.tracking_last_checked_at.slice(0, 16) : '-' %></small>
                <% } else { %>
                  <small>-</small>
                <% } %>
              </td>
              <td>
                <% if (item.status_code === 'PENDING_REVIEW') { %>
                  <form method="post" action="/admin/order/<%= item.id %>/confirm" class="inline-form">
                    <button type="submit" class="chip dark"><%= isEn ? 'Confirm Order' : '주문확인' %></button>
                  </form>
                <% } else if (item.status_code === 'ORDER_CONFIRMED') { %>
                  <form method="post" action="/admin/order/<%= item.id %>/ready" class="inline-form">
                    <button type="submit" class="chip dark"><%= isEn ? 'Mark Preparing' : '출고중 처리' %></button>
                  </form>
                <% } else if (item.status_code === 'READY_TO_SHIP') { %>
                  <form method="post" action="/admin/order/<%= item.id %>/start-shipping" class="form-grid compact">
                    <label>
                      <span><%= isEn ? 'Carrier' : '택배사' %></span>
                      <select name="trackingCarrier" required>
                        <% trackingCarriers.forEach((carrier) => { %>
                          <option value="<%= carrier.id %>" <%= item.tracking_carrier === carrier.id ? 'selected' : '' %>><%= carrier.label %></option>
                        <% }) %>
                      </select>
                    </label>
                    <label>
                      <span><%= isEn ? 'Tracking No.' : '송장번호' %></span>
                      <input type="text" name="trackingNumber" value="<%= item.tracking_number || '' %>" required />
                    </label>
                    <button type="submit" class="chip dark"><%= isEn ? 'Shipped (Start)' : '출고완료(배송시작)' %></button>
                  </form>
                <% } else if (item.status_code === 'SHIPPING') { %>
                  <form method="post" action="/admin/order/<%= item.id %>/update-tracking" class="form-grid compact">
                    <label>
                      <span><%= isEn ? 'Carrier' : '택배사' %></span>
                      <select name="trackingCarrier" required>
                        <% trackingCarriers.forEach((carrier) => { %>
                          <option value="<%= carrier.id %>" <%= item.tracking_carrier === carrier.id ? 'selected' : '' %>><%= carrier.label %></option>
                        <% }) %>
                      </select>
                    </label>
                    <label>
                      <span><%= isEn ? 'Tracking No.' : '송장번호' %></span>
                      <input type="text" name="trackingNumber" value="<%= item.tracking_number || '' %>" required />
                    </label>
                    <button type="submit" class="chip"><%= isEn ? 'Update Tracking' : '송장 수정' %></button>
                  </form>
                  <form method="post" action="/admin/order/<%= item.id %>/sync-tracking" class="inline-form">
                    <button type="submit" class="chip"><%= isEn ? 'Sync Tracking' : '송장 상태 조회' %></button>
                  </form>
                  <form method="post" action="/admin/order/<%= item.id %>/mark-delivered" class="inline-form">
                    <button type="submit" class="chip"><%= isEn ? 'Mark Delivered' : '수동 배송완료' %></button>
                  </form>
                  <small class="muted-label"><%= isEn ? 'Auto delivery sync enabled.' : '배송완료 자동 반영 활성화됨' %></small>
                <% } else { %>
                  <span class="muted-label"><%= isEn ? 'Done' : '완료' %></span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
  <% } %>

  <% if (tab === 'inquiries') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Inquiry Replies' : '문의 답변' %></h3>
    <div class="admin-list">
      <% inquiries.forEach((item) => { %>
        <div class="inquiry-admin-item">
          <strong><%= item.title %></strong>
          <p><%= isEn ? 'Writer' : '작성자' %>: <%= item.username %></p>
          <p><%= isEn ? 'Content' : '내용' %>: <%= item.content %></p>
          <form method="post" action="/admin/inquiry/<%= item.id %>/reply" class="form-grid">
            <label><%= isEn ? 'Reply' : '답변' %>
              <textarea name="replyContent" rows="3"><%= item.reply_content || '' %></textarea>
            </label>
            <button type="submit" class="chip dark"><%= isEn ? 'Save Reply' : '답변 저장' %></button>
          </form>
        </div>
      <% }) %>
    </div>
  </article>
  <% } %>
</section>

<%- include('partials/layout-end') %>
