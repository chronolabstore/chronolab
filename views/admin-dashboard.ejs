              <div class="admin-field-chip-row">
                <button type="submit" class="chip dark"><%= isEn ? 'Save' : '수정 저장' %></button>
              </div>
            </form>
            <div class="admin-field-chip-row">
              <form method="post" action="/admin/qc/<%= item.id %>/toggle" class="inline-form">
                <button type="submit" class="chip"><%= Number(item.is_hidden || 0) === 1 ? (isEn ? 'Show' : '표시') : (isEn ? 'Hide' : '숨김') %></button>
              </form>
              <form method="post" action="/admin/qc/<%= item.id %>/delete" class="inline-form">
                <button type="submit" class="chip" onclick="return confirm('<%= isEn ? 'Delete this QC item?' : '이 QC 항목을 삭제할까요?' %>');"><%= isEn ? 'Delete' : '삭제' %></button>
              </form>
            </div>
          </details>
        <% }) %>
        <% if (qcs.length === 0) { %>
          <p class="muted-label"><%= isEn ? 'No QC items registered.' : '등록된 QC 항목이 없습니다.' %></p>
        <% } %>
      </div>
    <% } %>
  </article>
  <% } %>

  <% if (tab === 'orders') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Order Management' : '주문관리' %></h3>
    <p class="muted-label"><%= isEn ? 'Flow: Awaiting Payment Verification -> Payment Confirmed -> Preparing Shipment -> Shipping (Tracking Auto Sync) -> Delivered(auto)' : '프로세스: 입금확인중 -> 입금확인 -> 출고중 -> 배송중(송장 자동조회) -> 배송완료(자동)' %></p>
    <div class="admin-order-toolbar">
      <span class="muted-label"><%= isEn ? 'Category Filter' : '쇼핑몰 분류' %></span>
      <div class="chip-row admin-order-filter-row">
        <a href="/admin/orders?orderGroup=all&orderStatus=<%= encodeURIComponent(activeOrderStatusFilterKey) %><%= orderDateQuerySuffix %>" class="chip <%= activeOrderFilterKey === 'all' ? 'dark' : '' %>"><%= isEn ? 'All' : '전체' %></a>
        <% productGroupKeys.forEach((groupName) => { %>
          <a href="/admin/orders?orderGroup=<%= encodeURIComponent(groupName) %>&orderStatus=<%= encodeURIComponent(activeOrderStatusFilterKey) %><%= orderDateQuerySuffix %>" class="chip <%= activeOrderFilterKey === groupName ? 'dark' : '' %>"><%= groupLabelByKey[groupName] || groupName %></a>
        <% }) %>
      </div>
    </div>
    <div class="admin-order-toolbar">
      <span class="muted-label"><%= isEn ? 'Status Filter' : '주문 상태' %></span>
      <div class="chip-row admin-order-filter-row">
        <% orderStatusFilterOptions.forEach((statusFilter) => { %>
          <a
            href="/admin/orders?orderGroup=<%= encodeURIComponent(activeOrderFilterKey) %>&orderStatus=<%= encodeURIComponent(statusFilter.key) %><%= orderDateQuerySuffix %>"
            class="chip <%= activeOrderStatusFilterKey === statusFilter.key ? 'dark' : '' %>"
          >
            <%= isEn ? statusFilter.labelEn : statusFilter.labelKo %>
          </a>
        <% }) %>
      </div>
    </div>
    <form method="get" action="/admin/orders" class="admin-filter-row">
      <input type="hidden" name="orderGroup" value="<%= activeOrderFilterKey %>" />
      <input type="hidden" name="orderStatus" value="<%= activeOrderStatusFilterKey %>" />
      <label class="admin-filter-item">
        <span><%= isEn ? 'From Date' : '시작일' %></span>
        <input type="date" name="orderDateFrom" value="<%= activeOrderDateFrom %>" />
      </label>
      <label class="admin-filter-item">
        <span><%= isEn ? 'To Date' : '종료일' %></span>
        <input type="date" name="orderDateTo" value="<%= activeOrderDateTo %>" />
      </label>
      <div class="admin-filter-actions">
        <button type="submit" class="chip dark"><%= isEn ? 'Apply' : '조회' %></button>
        <a href="/admin/orders?orderGroup=<%= encodeURIComponent(activeOrderFilterKey) %>&orderStatus=<%= encodeURIComponent(activeOrderStatusFilterKey) %>" class="chip"><%= isEn ? 'Reset Date' : '날짜 초기화' %></a>
      </div>
    </form>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= isEn ? 'Order No.' : '구매번호' %></th>
            <th><%= isEn ? 'Order Info' : '신청 정보' %></th>
            <th><%= isEn ? 'Status' : '상태' %></th>
            <th><%= isEn ? 'Tracking' : '송장' %></th>
            <th><%= isEn ? 'Action' : '변경' %></th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach((item) => { %>
            <tr>
              <td><%= item.order_no %></td>
              <td>
                <small><%= item.category_group_label || item.category_group %></small><br />
                <strong><%= item.brand %> <%= item.model %> <%= item.sub_model %></strong><br />
                <strong><%= item.buyer_name %></strong><br />
                <small><%= item.buyer_contact %></small><br />
                <small><%= isEn ? 'Customs No.' : '통관번호' %>: <%= item.customs_clearance_no || '-' %></small><br />
                <small><%= item.buyer_address %></small><br />
                <small><%= isEn ? 'Depositor' : '입금자명' %>: <%= item.bank_depositor_name %></small>
              </td>
              <td>
                <strong><%= item.status_label %></strong>
                <% if (item.status_detail) { %>
                  <br />
                  <small><%= item.status_detail %></small>
                <% } %>
                <% if (item.checked_at || item.ready_to_ship_at || item.shipping_started_at || item.delivered_at) { %>
                  <br />
                  <small><%= isEn ? 'Timeline' : '타임라인' %>:</small>
                  <ul class="status-mini-list">
                    <% if (item.checked_at) { %>
                      <li><small><%= isEn ? 'Payment Confirmed' : '입금확인' %> · <%= item.checked_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.ready_to_ship_at) { %>
                      <li><small><%= isEn ? 'Preparing Shipment' : '출고중' %> · <%= item.ready_to_ship_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.shipping_started_at) { %>
                      <li><small><%= isEn ? 'Shipping Started' : '배송시작' %> · <%= item.shipping_started_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.delivered_at) { %>
                      <li><small><%= isEn ? 'Delivered' : '배송완료' %> · <%= item.delivered_at.slice(0, 16) %></small></li>
                    <% } %>
                  </ul>
                <% } %>
                <% if (item.status_logs && item.status_logs.length > 0) { %>
                  <small><%= isEn ? 'Latest events' : '최근 이력' %>:</small>
                  <ul class="status-mini-list">
                    <% item.status_logs.forEach((log) => { %>
                      <li>
                        <small>
                          <%= log.created_at ? log.created_at.slice(0, 16) : '-' %> ·
                          <%= log.from_status_label ? `${log.from_status_label} → ` : '' %><%= log.to_status_label || log.to_status %>
