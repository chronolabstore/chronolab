                    <input type="text" name="path" value="<%= menu.path %>" required />
                  </label>
                  <button type="submit" class="chip dark"><%= isEn ? 'Save Changes' : '수정 저장' %></button>
                </form>
              </details>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (menusTab === 'groups') { %>
      <div class="menu-manage-stack">
        <p class="muted-label menu-manage-note">
          <%= isEn ? 'Add or remove shop top categories. Each category can have its own upload fields.' : '쇼핑몰 상위 분류를 추가/삭제할 수 있고, 분류별 업로드 항목은 별도 탭에서 관리합니다.' %>
        </p>
        <form method="post" action="/admin/product-group/add" class="form-grid menu-manage-form">
          <label><%= isEn ? 'Category Key (optional)' : '분류 키 (선택)' %>
            <input type="text" name="key" placeholder="<%= isEn ? 'factory-plus' : 'factory-plus' %>" />
          </label>
          <label><%= isEn ? 'Category Name (KR)' : '분류명 (KR)' %>
            <input type="text" name="labelKo" required />
          </label>
          <label><%= isEn ? 'Category Name (EN)' : '분류명 (EN)' %>
            <input type="text" name="labelEn" required />
          </label>
          <label><%= isEn ? 'Default Field Template' : '기본 항목 템플릿' %>
            <select name="templateType">
              <option value="simple"><%= isEn ? 'Basic (Title + Detail)' : '기본형 (제목 + 상세설명)' %></option>
              <option value="factory"><%= isEn ? 'Factory Spec Fields' : '공장제형 필드' %></option>
            </select>
          </label>
          <button type="submit" class="chip dark menu-manage-submit"><%= isEn ? 'Add Category' : '분류 추가' %></button>
        </form>

        <div class="admin-list menu-manage-list">
          <% productGroupConfigList.forEach((group) => { %>
            <div class="admin-list-item">
              <strong><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></strong>
              <span><%= isEn ? 'Key' : '키' %>: <code><%= group.key %></code></span>
              <span class="muted-label"><%= isEn ? `${(group.customFields || []).length} fields configured` : `설정된 업로드 항목 ${(group.customFields || []).length}개` %></span>
              <div class="admin-account-actions">
                <% if (productGroupConfigList.length > 1) { %>
                  <form method="post" action="/admin/product-group/remove/<%= encodeURIComponent(group.key) %>" class="inline-form">
                    <button type="submit" class="chip"><%= isEn ? 'Delete Category' : '분류 삭제' %></button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
