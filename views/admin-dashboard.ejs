                                <label><%= isEn ? 'Name (EN)' : '이름 (EN)' %>
                                  <input type="text" name="optionLabelEn" value="<%= factoryLabelEntry.labelEn || optionValue %>" required />
                                </label>
                                <div class="admin-account-actions">
                                  <button type="submit" class="chip dark filter-chip"><%= isEn ? 'Save Factory' : '공장 수정' %></button>
                                </div>
                              </form>
                              <form method="post" action="/admin/product-group/filter/remove" class="inline-form">
                                <input type="hidden" name="groupKey" value="<%= group.key %>" />
                                <input type="hidden" name="filterType" value="factory" />
                                <input type="hidden" name="optionValue" value="<%= optionValue %>" />
                                <button type="submit" class="chip filter-chip"><%= isEn ? 'Delete' : '삭제' %></button>
                              </form>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    <% } %>

                    <form method="post" action="/admin/product-group/filter/add" class="form-grid compact">
                      <input type="hidden" name="groupKey" value="<%= group.key %>" />
                      <input type="hidden" name="filterType" value="factory" />
                      <label><%= isEn ? 'Factory Name (KR)' : '공장명 (KR)' %>
                        <input type="text" name="optionLabelKo" required />
                      </label>
                      <label><%= isEn ? 'Factory Name (EN)' : '공장명 (EN)' %>
                        <input type="text" name="optionLabelEn" required />
                      </label>
                      <button type="submit" class="chip dark filter-chip"><%= isEn ? 'Add Factory' : '공장 추가' %></button>
                    </form>
                  </section>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (menusTab === 'fields') { %>
      <div class="admin-grid menu-fields-grid">
        <section class="kpi-card">
          <h4><%= isEn ? 'Add Upload Field' : '업로드 항목 추가' %></h4>
          <form method="post" action="/admin/product-group/field/add" class="form-grid menu-manage-form">
            <label><%= isEn ? 'Target Category' : '대상 분류' %>
              <select name="groupKey" required>
                <% productGroupConfigList.forEach((group) => { %>
                  <option value="<%= group.key %>"><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></option>
                <% }) %>
              </select>
            </label>
            <label><%= isEn ? 'Field Key (optional)' : '항목 키 (선택)' %>
              <input type="text" name="fieldKey" placeholder="custom_grade" />
            </label>
            <label><%= isEn ? 'Field Name (KR)' : '항목명 (KR)' %>
              <input type="text" name="labelKo" required />
            </label>
            <label><%= isEn ? 'Field Name (EN)' : '항목명 (EN)' %>
              <input type="text" name="labelEn" required />
            </label>
            <label><%= isEn ? 'Field Type' : '항목 타입' %>
              <select name="fieldType" required>
                <option value="text"><%= isEn ? 'Text' : '텍스트' %></option>
                <option value="textarea"><%= isEn ? 'Textarea' : '긴 텍스트' %></option>
                <option value="number"><%= isEn ? 'Number' : '숫자' %></option>
              </select>
            </label>
            <label class="check-row">
              <input type="checkbox" name="required" />
              <span><%= isEn ? 'Required field' : '필수 항목' %></span>
            </label>
            <button type="submit" class="chip dark menu-manage-submit"><%= isEn ? 'Add Field' : '항목 추가' %></button>
          </form>
        </section>

        <section class="kpi-card">
          <div class="kpi-head-row menu-field-head-row">
            <h4><%= isEn ? 'Category Field List' : '분류별 업로드 항목 목록' %></h4>
            <%
              const preferredFieldFilterKeys = ['공장제', '젠파츠', '현지중고'];
              const preferredFieldFilterGroups = preferredFieldFilterKeys
                .map((key) => productGroupConfigList.find((group) => group.key === key))
                .filter(Boolean);
              const restFieldFilterGroups = productGroupConfigList.filter(
                (group) => !preferredFieldFilterGroups.some((preferredGroup) => preferredGroup.key === group.key)
              );
              const fallbackFieldFilterGroups =
                preferredFieldFilterGroups.length > 0
                  ? [...preferredFieldFilterGroups, ...restFieldFilterGroups]
                  : productGroupConfigList;
              const requestedMenuFieldGroup = String(menuFieldGroupFilter || '').trim();
              const availableMenuFieldGroupKeys = fallbackFieldFilterGroups.map((group) => String(group.key || '').trim());
              const activeMenuFieldGroup =
                availableMenuFieldGroupKeys.includes(requestedMenuFieldGroup) && requestedMenuFieldGroup
                  ? requestedMenuFieldGroup
                  : (availableMenuFieldGroupKeys[0] || '');
              const menuFieldFilterBaseHref = `/admin/menus?section=fields${isEn ? '&lang=en' : ''}`;
            %>
            <% if (fallbackFieldFilterGroups.length > 0) { %>
              <div class="chip-row menu-field-filter-row" data-menu-field-filter-wrap>
                <% fallbackFieldFilterGroups.forEach((group) => { %>
                  <%
                    const normalizedGroupKey = String(group.key || '').trim();
                    const isGroupActive = normalizedGroupKey === activeMenuFieldGroup;
                  %>
                  <a
                    href="<%= `${menuFieldFilterBaseHref}&fieldGroup=${encodeURIComponent(normalizedGroupKey)}` %>"
                    class="chip <%= isGroupActive ? 'dark' : '' %>"
                    data-menu-field-filter="<%= normalizedGroupKey %>"
                    aria-pressed="<%= isGroupActive ? 'true' : 'false' %>"
                  >
                    <%= group.labelKo || group.key %>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </div>
          <div class="admin-list menu-field-group-list" data-menu-field-list>
            <% productGroupConfigList.forEach((group) => { %>
              <%
                const normalizedGroupKey = String(group.key || '').trim();
                const isGroupActive = normalizedGroupKey === activeMenuFieldGroup;
              %>
              <details
                class="admin-list-item"
                data-menu-field-group="<%= normalizedGroupKey %>"
                <%= isGroupActive ? 'open' : '' %>
                <%= isGroupActive ? '' : 'hidden' %>
              >
                <summary><strong><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></strong> <small>(<%= (group.customFields || []).length %>)</small></summary>
                <div class="admin-list">
                  <% (group.customFields || []).forEach((field) => { %>
                    <div class="admin-list-item">
                      <form method="post" action="/admin/product-group/field/update" class="form-grid compact">
                        <input type="hidden" name="groupKey" value="<%= group.key %>" />
                        <input type="hidden" name="fieldKey" value="<%= field.key %>" />
                        <label><%= isEn ? 'Key' : '키' %>
                          <input type="text" value="<%= field.key %>" readonly />
                        </label>
                        <label><%= isEn ? 'Name (KR)' : '항목명 (KR)' %>
                          <input type="text" name="labelKo" value="<%= field.labelKo || field.key %>" required />
                        </label>
                        <label><%= isEn ? 'Name (EN)' : '항목명 (EN)' %>
                          <input type="text" name="labelEn" value="<%= field.labelEn || field.key %>" required />
                        </label>
                        <label><%= isEn ? 'Type' : '타입' %>
                          <select name="fieldType">
                            <option value="text" <%= field.type === 'text' ? 'selected' : '' %>><%= isEn ? 'Text' : '텍스트' %></option>
                            <option value="textarea" <%= field.type === 'textarea' ? 'selected' : '' %>><%= isEn ? 'Textarea' : '긴 텍스트' %></option>
                            <option value="number" <%= field.type === 'number' ? 'selected' : '' %>><%= isEn ? 'Number' : '숫자' %></option>
                          </select>
                        </label>
                        <label class="check-row">
                          <input type="checkbox" name="required" <%= field.required ? 'checked' : '' %> />
                          <span><%= isEn ? 'Required' : '필수' %></span>
                        </label>
                        <div class="admin-account-actions">
                          <button type="submit" class="chip dark"><%= isEn ? 'Save Field' : '항목 저장' %></button>
                        </div>
                      </form>
                      <% if ((group.customFields || []).length > 1) { %>
                        <form method="post" action="/admin/product-group/field/remove" class="inline-form">
                          <input type="hidden" name="groupKey" value="<%= group.key %>" />
                          <input type="hidden" name="fieldKey" value="<%= field.key %>" />
                          <button type="submit" class="chip"><%= isEn ? 'Delete Field' : '항목 삭제' %></button>
                        </form>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </details>
            <% }) %>
          </div>
        </section>
      </div>
      <script>
        (() => {
          const wrap = document.querySelector('[data-menu-field-filter-wrap]');
          const list = document.querySelector('[data-menu-field-list]');
          if (!wrap || !list) return;

          const buttons = Array.from(wrap.querySelectorAll('[data-menu-field-filter]'));
          const groups = Array.from(list.querySelectorAll('[data-menu-field-group]'));
          if (!buttons.length || !groups.length) return;
          const normalizeKey = (value) => String(value || '').trim();

          const applyFilter = (groupKey) => {
            const normalizedGroupKey = normalizeKey(groupKey);
            if (!normalizedGroupKey) return;
            buttons.forEach((button) => {
              const active = normalizeKey(button.dataset.menuFieldFilter) === normalizedGroupKey;
              button.classList.toggle('dark', active);
              button.setAttribute('aria-pressed', active ? 'true' : 'false');
            });
            groups.forEach((groupNode) => {
              const isTarget = normalizeKey(groupNode.dataset.menuFieldGroup) === normalizedGroupKey;
              groupNode.hidden = !isTarget;
              if (isTarget) {
                groupNode.setAttribute('open', '');
              } else {
                groupNode.removeAttribute('open');
              }
            });
          };

          const activeButton = buttons.find((button) => button.classList.contains('dark')) || buttons[0];
          const initialGroup = normalizeKey(activeButton?.dataset.menuFieldFilter || '');
          if (initialGroup) {
            applyFilter(initialGroup);
          }

          buttons.forEach((button) => {
            button.addEventListener('click', (event) => {
              event.preventDefault();
              const nextGroup = normalizeKey(button.dataset.menuFieldFilter || '');
              applyFilter(nextGroup);
              if (nextGroup && window.history?.replaceState) {
                const nextUrl = new URL(window.location.href);
                nextUrl.searchParams.set('section', 'fields');
                nextUrl.searchParams.set('fieldGroup', nextGroup);
                window.history.replaceState(null, '', nextUrl.toString());
              }
            });
          });
        })();
      </script>
    <% } %>
  </article>
  <% } %>

  <% if (tab === 'products') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Product Manager' : '상품관리' %></h3>
