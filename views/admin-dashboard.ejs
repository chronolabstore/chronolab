                                          <button type="submit" class="chip dark filter-chip"><%= isEn ? 'Save Model' : '모델 수정' %></button>
                                        </div>
                                      </form>
                                      <form method="post" action="/admin/product-group/filter/remove" class="inline-form">
                                        <input type="hidden" name="groupKey" value="<%= group.key %>" />
                                        <input type="hidden" name="filterType" value="model" />
                                        <input type="hidden" name="brandValue" value="<%= brandOption %>" />
                                        <input type="hidden" name="optionValue" value="<%= optionValue %>" />
                                        <button type="submit" class="chip filter-chip"><%= isEn ? 'Delete' : '삭제' %></button>
                                      </form>
                                    </div>
                                  </div>
                                <% }) %>
                              </div>
                            <% } %>

                            <form method="post" action="/admin/product-group/filter/add" class="form-grid compact menu-brand-model-add-form">
                              <input type="hidden" name="groupKey" value="<%= group.key %>" />
                              <input type="hidden" name="filterType" value="model" />
                              <input type="hidden" name="brandValue" value="<%= brandOption %>" />
                              <label><%= isEn ? `Model Name (KR)` : `모델명 (KR)` %>
                                <input type="text" name="optionLabelKo" required />
                              </label>
                              <label><%= isEn ? `Model Name (EN)` : `모델명 (EN)` %>
                                <input type="text" name="optionLabelEn" required />
                              </label>
                              <button type="submit" class="chip dark filter-chip"><%= isEn ? 'Add Model' : '모델 추가' %></button>
                            </form>
                          </div>
                        </details>
                      <% }) %>
                    </div>

                    <% if (modelFilterBrandKeys.length === 0 && legacyModelFilters.length > 0) { %>
                      <p class="muted-label">
                        <%= isEn ? 'Legacy shared models exist. Please re-add models under each brand.' : '기존 공용 모델 데이터가 남아있습니다. 브랜드를 펼쳐서 브랜드별 모델로 다시 추가해 주세요.' %>
                      </p>
                    <% } %>
                  <% } %>

                  <form method="post" action="/admin/product-group/filter/add" class="form-grid compact">
                    <input type="hidden" name="groupKey" value="<%= group.key %>" />
                    <input type="hidden" name="filterType" value="brand" />
                    <label><%= isEn ? 'Brand Name (KR)' : '브랜드명 (KR)' %>
                      <input type="text" name="optionLabelKo" required />
                    </label>
                    <label><%= isEn ? 'Brand Name (EN)' : '브랜드명 (EN)' %>
                      <input type="text" name="optionLabelEn" required />
                    </label>
                    <button type="submit" class="chip dark filter-chip"><%= isEn ? 'Add Brand' : '브랜드 추가' %></button>
                  </form>
                </section>

                <% if (supportsFactoryFilterGroup) { %>
                  <section class="kpi-card menu-factory-filter-card">
                    <h4><%= isEn ? 'Factory Filters' : '공장 필터' %></h4>
                    <p class="muted-label"><%= isEn ? 'Factory filters also support Korean/English labels.' : '공장 필터도 한국어/영어 라벨을 함께 관리할 수 있습니다.' %></p>
                    <% if (factoryFilters.length === 0) { %>
                      <p class="muted-label"><%= isEn ? 'No factory filter options yet.' : '등록된 공장 필터가 없습니다.' %></p>
                    <% } else { %>
                      <%
                        const factoryLabelMap = group.factoryOptionLabels && typeof group.factoryOptionLabels === 'object' && !Array.isArray(group.factoryOptionLabels)
                          ? group.factoryOptionLabels
                          : {};
                      %>
                      <div class="admin-list">
                        <% factoryFilters.forEach((optionValue) => { %>
                          <%
                            const factoryLabelEntry = resolveFilterLabelEntry(factoryLabelMap, optionValue);
                            const factoryDisplayName = isEn ? (factoryLabelEntry.labelEn || optionValue) : (factoryLabelEntry.labelKo || optionValue);
                          %>
