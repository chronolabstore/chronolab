<%- include('partials/layout-start') %>
<%
  const tab = activeTab || 'dashboard';
  const isEn = ctx.lang === 'en';
  const groupLabelMap = {
    '공장제': isEn ? 'Factory' : '공장제',
    '젠파츠': isEn ? 'Gen Parts' : '젠파츠',
    '현지중고': isEn ? 'Local Used' : '현지중고'
  };

  const stats = dashboardStats || {
    users: { active: 0, blocked: 0, total: 0 },
    signupCounts: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    memberVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    guestVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    totalVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    boardCounts: { notice: 0, news: 0, qc: 0, review: 0, inquiry: 0 },
    shopCounts: { total: 0, active: 0, byGroup: [] },
    orderCounts: { total: 0, pendingReview: 0, confirmed: 0, readyToShip: 0, shipping: 0, delivered: 0, byGroup: [] },
    orderAlerts: { stalePending: 0, longShipping: 0 },
    actionItems: { uncheckedOrders: 0, paymentWaiting: 0, pendingInquiries: 0, qcPending: 0, totalUrgent: 0 },
    delayWarnings: { pendingOver24h: 0, confirmedOver48h: 0, readyOver72h: 0, shippingOver7d: 0 },
    inquiryOps: { pending: 0, overdue24h: 0, repliedToday: 0, avgReplyHours: 0 },
    paymentPerformance: {
      todayCount: 0,
      todayAmount: 0,
      weekCount: 0,
      weekAmount: 0,
      monthCount: 0,
      monthAmount: 0,
      totalCount: 0,
      totalAmount: 0,
      confirmRate: 0
    },
    conversionFunnel: {
      windowDays: 30,
      window: { productViews: 0, purchaseViews: 0, orderCreated: 0, paymentConfirmed: 0 },
      total: { productViews: 0, purchaseViews: 0, orderCreated: 0, paymentConfirmed: 0 },
      rates: { viewToPurchase: 0, purchaseToOrder: 0, orderToPayment: 0, viewToPayment: 0 }
    }
  };
  const security = securityPanelData || {
    adminUsers: [],
    subAdminLogs: [],
    securityAlerts: [],
    unresolvedAlertsCount: 0,
    filters: {
      log: { from: '', to: '', adminId: 0 },
      alert: { from: '', to: '', adminId: 0 }
    },
    pagination: {
      log: { page: 1, totalPages: 1, totalCount: 0, pageSize: 20 },
      alert: { page: 1, totalPages: 1, totalCount: 0, pageSize: 20 }
    }
  };
  const memberPanel = memberManagePanelData || {
    members: [],
    filters: { section: 'active', keyword: '' },
    pagination: { page: 1, totalPages: 1, totalCount: 0, pageSize: 20 }
  };
  const securityTab = ['profile', 'admins', 'logs', 'alerts'].includes(String(securitySection || ''))
    ? String(securitySection)
    : 'profile';
%>

<section class="admin-grid single">
  <% if (tab === 'dashboard') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Admin Dashboard' : '관리자 대시보드' %></h3>

    <%
      const orderByGroup = Array.isArray(stats.orderCounts.byGroup) ? stats.orderCounts.byGroup : [];
      const shopByGroup = Array.isArray(stats.shopCounts.byGroup) ? stats.shopCounts.byGroup : [];
      const defaultOrderGroup = orderByGroup.find((item) => item.groupName === '공장제') || orderByGroup[0] || {
        groupName: '공장제',
        totalCount: 0,
        pendingReview: 0,
        confirmed: 0,
        readyToShip: 0,
        shipping: 0,
        delivered: 0
      };
      const defaultShopGroup = shopByGroup.find((item) => item.groupName === '공장제') || shopByGroup[0] || {
        groupName: '공장제',
        totalCount: 0,
        activeCount: 0,
        hiddenCount: 0
      };
    %>

    <div class="dashboard-kpi-grid">
      <div class="kpi-card" data-member-switch-root>
        <div class="kpi-head-row">
          <h4><%= isEn ? 'Members' : '회원 수' %></h4>
          <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'member segment switch' : '회원 구분 전환' %>">
            <button type="button" class="kpi-toggle-btn active" data-member-type="active"><%= isEn ? 'Member' : '회원' %></button>
            <button type="button" class="kpi-toggle-btn" data-member-type="blocked"><%= isEn ? 'Blacklist' : '블랙리스트' %></button>
          </div>
        </div>
        <strong data-member-value><%= stats.users.active %></strong>
        <p class="muted-label" data-member-caption><%= isEn ? 'Active members count.' : '활성 회원 수입니다.' %></p>
        <p class="muted-label"><%= isEn ? `Total members ${stats.users.total}` : `총 회원 ${stats.users.total}` %></p>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Orders Total' : '총 주문건' %></h4>
        <strong><%= stats.orderCounts.total %></strong>
        <p class="muted-label"><%= isEn ? 'Order pipeline summary below.' : '주문 상태 파이프라인은 아래에서 확인하세요.' %></p>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Signup Summary' : '회원가입 집계' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Today' : '오늘' %></span><strong><%= stats.signupCounts.today %></strong></li>
          <li><span><%= isEn ? '7 Days' : '일주일' %></span><strong><%= stats.signupCounts.week %></strong></li>
          <li><span><%= isEn ? '30 Days' : '한달' %></span><strong><%= stats.signupCounts.month %></strong></li>
          <li><span><%= isEn ? '1 Year' : '1년' %></span><strong><%= stats.signupCounts.year %></strong></li>
          <li><span><%= isEn ? 'Total' : '총 가입 회원' %></span><strong><%= stats.signupCounts.total %></strong></li>
        </ul>
      </div>

      <div class="kpi-card" data-order-switch-root>
        <div class="kpi-head-row">
          <h4><%= isEn ? 'Order Status Summary' : '주문 상태 집계' %></h4>
          <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'order group switch' : '주문 분류 전환' %>">
            <% ['공장제', '젠파츠', '현지중고'].forEach((groupName, idx) => { %>
              <button type="button" class="kpi-toggle-btn <%= idx === 0 ? 'active' : '' %>" data-order-group="<%= groupName %>"><%= groupLabelMap[groupName] || groupName %></button>
            <% }) %>
          </div>
        </div>
        <p class="muted-label" data-order-caption><%= isEn ? `${groupLabelMap[defaultOrderGroup.groupName] || defaultOrderGroup.groupName} order status summary.` : `${groupLabelMap[defaultOrderGroup.groupName] || defaultOrderGroup.groupName} 주문 상태 집계입니다.` %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Unchecked' : '미확인 주문건' %></span><strong data-order-value="pendingReview"><%= defaultOrderGroup.pendingReview %></strong></li>
          <li><span><%= isEn ? 'Confirmed' : '확인 주문건' %></span><strong data-order-value="confirmed"><%= defaultOrderGroup.confirmed %></strong></li>
          <li><span><%= isEn ? 'Preparing Shipment' : '출고중 주문건' %></span><strong data-order-value="readyToShip"><%= defaultOrderGroup.readyToShip %></strong></li>
          <li><span><%= isEn ? 'Shipping' : '배송중 주문건' %></span><strong data-order-value="shipping"><%= defaultOrderGroup.shipping %></strong></li>
          <li><span><%= isEn ? 'Delivered' : '배송완료 주문건' %></span><strong data-order-value="delivered"><%= defaultOrderGroup.delivered %></strong></li>
        </ul>
      </div>

      <div class="kpi-card" data-visit-switch-root>
        <div class="kpi-head-row">
          <h4><%= isEn ? 'Visit Summary' : '방문 집계' %></h4>
          <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'visit segment switch' : '방문 구분 전환' %>">
            <button type="button" class="kpi-toggle-btn active" data-visit-type="member"><%= isEn ? 'Member' : '회원' %></button>
            <button type="button" class="kpi-toggle-btn" data-visit-type="guest"><%= isEn ? 'Guest' : '비회원' %></button>
            <button type="button" class="kpi-toggle-btn" data-visit-type="total"><%= isEn ? 'Total' : '전체' %></button>
          </div>
        </div>
        <p class="muted-label" data-visit-caption><%= isEn ? 'Member visits summary.' : '회원 방문 기준 집계입니다.' %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Today' : '오늘' %></span><strong data-visit-value="today"><%= stats.memberVisits.today %></strong></li>
          <li><span><%= isEn ? '7 Days' : '일주일' %></span><strong data-visit-value="week"><%= stats.memberVisits.week %></strong></li>
          <li><span><%= isEn ? '30 Days' : '한달' %></span><strong data-visit-value="month"><%= stats.memberVisits.month %></strong></li>
          <li><span><%= isEn ? '1 Year' : '1년' %></span><strong data-visit-value="year"><%= stats.memberVisits.year %></strong></li>
          <li><span><%= isEn ? 'Total' : '총' %></span><strong data-visit-value="total"><%= stats.memberVisits.total %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Today Action Queue' : '오늘 우선 처리' %></h4>
        <strong><%= Number(stats.actionItems.totalUrgent || 0).toLocaleString() %></strong>
        <p class="muted-label"><%= isEn ? 'Priority tasks requiring immediate handling.' : '바로 처리해야 할 핵심 작업 건수입니다.' %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Unchecked Orders' : '미확인 주문건' %></span><strong><%= Number(stats.actionItems.uncheckedOrders || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Payment Check Wait 12h+' : '입금확인 대기 12시간+' %></span><strong><%= Number(stats.actionItems.paymentWaiting || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Unreplied Inquiries' : '미답변 문의' %></span><strong><%= Number(stats.actionItems.pendingInquiries || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'QC Missing Orders' : 'QC 미등록 주문' %></span><strong><%= Number(stats.actionItems.qcPending || 0).toLocaleString() %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Order Delay Warnings' : '주문 지연 경고' %></h4>
        <p class="muted-label"><%= isEn ? 'SLA delay alerts by order pipeline stage.' : '주문 단계별 지연 건수입니다.' %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Pending Review 24h+' : '미확인 24시간+' %></span><strong><%= Number(stats.delayWarnings.pendingOver24h || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Confirmed 48h+' : '확인 후 48시간+' %></span><strong><%= Number(stats.delayWarnings.confirmedOver48h || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Ready 72h+' : '출고중 72시간+' %></span><strong><%= Number(stats.delayWarnings.readyOver72h || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Shipping 7d+' : '배송중 7일+' %></span><strong><%= Number(stats.delayWarnings.shippingOver7d || 0).toLocaleString() %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Inquiry Operations' : '문의 운영 상태' %></h4>
        <p class="muted-label"><%= isEn ? 'Inquiry backlog and response speed.' : '문의 적체와 답변 속도 지표입니다.' %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Waiting Reply' : '답변 대기' %></span><strong><%= Number(stats.inquiryOps.pending || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Waiting 24h+' : '24시간 이상 대기' %></span><strong><%= Number(stats.inquiryOps.overdue24h || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Replied Today' : '오늘 답변 완료' %></span><strong><%= Number(stats.inquiryOps.repliedToday || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Avg Reply Time' : '평균 답변시간' %></span><strong><%= Number(stats.inquiryOps.avgReplyHours || 0).toLocaleString() %><%= isEn ? 'h' : '시간' %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Payment Performance' : '입금 성과' %></h4>
        <p class="muted-label"><%= isEn ? 'Order confirm and payment check performance.' : '주문확인(입금확인) 처리 성과입니다.' %></p>
        <ul class="metric-list">
          <li>
            <span><%= isEn ? 'Today' : '오늘' %></span>
            <strong><%= Number(stats.paymentPerformance.todayCount || 0).toLocaleString() %> / <%= isEn ? 'KRW ' : '₩' %><%= Number(stats.paymentPerformance.todayAmount || 0).toLocaleString('ko-KR') %></strong>
          </li>
          <li>
            <span><%= isEn ? '7 Days' : '일주일' %></span>
            <strong><%= Number(stats.paymentPerformance.weekCount || 0).toLocaleString() %> / <%= isEn ? 'KRW ' : '₩' %><%= Number(stats.paymentPerformance.weekAmount || 0).toLocaleString('ko-KR') %></strong>
          </li>
          <li>
            <span><%= isEn ? '30 Days' : '한달' %></span>
            <strong><%= Number(stats.paymentPerformance.monthCount || 0).toLocaleString() %> / <%= isEn ? 'KRW ' : '₩' %><%= Number(stats.paymentPerformance.monthAmount || 0).toLocaleString('ko-KR') %></strong>
          </li>
          <li>
            <span><%= isEn ? 'Total' : '누적' %></span>
            <strong><%= Number(stats.paymentPerformance.totalCount || 0).toLocaleString() %> / <%= isEn ? 'KRW ' : '₩' %><%= Number(stats.paymentPerformance.totalAmount || 0).toLocaleString('ko-KR') %></strong>
          </li>
          <li>
            <span><%= isEn ? 'Payment Confirm Rate' : '입금확인 전환율' %></span>
            <strong><%= Number(stats.paymentPerformance.confirmRate || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong>
          </li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Conversion Funnel' : '전환 퍼널' %></h4>
        <p class="muted-label"><%= isEn ? `${Number(stats.conversionFunnel.windowDays || 30)}-day conversion funnel.` : `최근 ${Number(stats.conversionFunnel.windowDays || 30)}일 전환 퍼널입니다.` %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Product Views' : '상품조회' %></span><strong><%= Number(stats.conversionFunnel.window.productViews || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Purchase Views' : '구매페이지 진입' %></span><strong><%= Number(stats.conversionFunnel.window.purchaseViews || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Orders Created' : '주문생성' %></span><strong><%= Number(stats.conversionFunnel.window.orderCreated || 0).toLocaleString() %></strong></li>
          <li><span><%= isEn ? 'Payments Confirmed' : '입금확인' %></span><strong><%= Number(stats.conversionFunnel.window.paymentConfirmed || 0).toLocaleString() %></strong></li>
        </ul>
        <ul class="metric-list">
          <li><span><%= isEn ? 'View → Purchase' : '상품조회 → 구매진입' %></span><strong><%= Number(stats.conversionFunnel.rates.viewToPurchase || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
          <li><span><%= isEn ? 'Purchase → Order' : '구매진입 → 주문생성' %></span><strong><%= Number(stats.conversionFunnel.rates.purchaseToOrder || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
          <li><span><%= isEn ? 'Order → Payment' : '주문생성 → 입금확인' %></span><strong><%= Number(stats.conversionFunnel.rates.orderToPayment || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
          <li><span><%= isEn ? 'View → Payment' : '상품조회 → 입금확인' %></span><strong><%= Number(stats.conversionFunnel.rates.viewToPayment || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Board Post Counts' : '게시판 게시물 수' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Notice' : '공지사항' %></span><strong><%= stats.boardCounts.notice %></strong></li>
          <li><span><%= isEn ? 'News' : '뉴스' %></span><strong><%= stats.boardCounts.news %></strong></li>
          <li><span>QC</span><strong><%= stats.boardCounts.qc %></strong></li>
          <li><span><%= isEn ? 'Reviews' : '구매후기' %></span><strong><%= stats.boardCounts.review %></strong></li>
          <li><span><%= isEn ? 'Inquiry' : '문의' %></span><strong><%= stats.boardCounts.inquiry %></strong></li>
        </ul>
      </div>

      <div class="kpi-card">
        <h4><%= isEn ? 'Operational Alerts' : '운영 알림' %></h4>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Unchecked 24h+' : '24시간 이상 미확인' %></span><strong><%= stats.orderAlerts.stalePending %></strong></li>
          <li><span><%= isEn ? 'Shipping 7d+' : '7일 이상 배송중' %></span><strong><%= stats.orderAlerts.longShipping %></strong></li>
        </ul>
      </div>

      <div class="kpi-card" data-shop-switch-root>
        <div class="kpi-head-row">
          <h4><%= isEn ? 'Shop Inventory' : '쇼핑몰 상품 현황' %></h4>
          <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'shop group switch' : '상품 분류 전환' %>">
            <% ['공장제', '젠파츠', '현지중고'].forEach((groupName, idx) => { %>
              <button type="button" class="kpi-toggle-btn <%= idx === 0 ? 'active' : '' %>" data-shop-group="<%= groupName %>"><%= groupLabelMap[groupName] || groupName %></button>
            <% }) %>
          </div>
        </div>
        <p class="muted-label" data-shop-caption><%= isEn ? `${groupLabelMap[defaultShopGroup.groupName] || defaultShopGroup.groupName} inventory summary.` : `${groupLabelMap[defaultShopGroup.groupName] || defaultShopGroup.groupName} 상품 현황입니다.` %></p>
        <ul class="metric-list">
          <li><span><%= isEn ? 'Total' : '전체 상품' %></span><strong data-shop-value="totalCount"><%= defaultShopGroup.totalCount %></strong></li>
          <li><span><%= isEn ? 'Active' : '활성' %></span><strong data-shop-value="activeCount"><%= defaultShopGroup.activeCount %></strong></li>
          <li><span><%= isEn ? 'Hidden' : '숨김' %></span><strong data-shop-value="hiddenCount"><%= defaultShopGroup.hiddenCount %></strong></li>
        </ul>
      </div>
    </div>

    <script id="member-kpi-payload" type="application/json"><%- JSON.stringify({
      active: stats.users.active,
      blocked: stats.users.blocked,
      total: stats.users.total
    }) %></script>
    <script id="order-group-kpi-payload" type="application/json"><%- JSON.stringify(orderByGroup) %></script>
    <script id="visit-kpi-payload" type="application/json"><%- JSON.stringify({
      member: stats.memberVisits,
      guest: stats.guestVisits,
      total: stats.totalVisits
    }) %></script>
    <script id="shop-group-kpi-payload" type="application/json"><%- JSON.stringify(shopByGroup) %></script>
    <script>
      (() => {
        const memberRoot = document.querySelector('[data-member-switch-root]');
        const memberPayloadNode = document.getElementById('member-kpi-payload');
        const orderRoot = document.querySelector('[data-order-switch-root]');
        const orderPayloadNode = document.getElementById('order-group-kpi-payload');
        const visitRoot = document.querySelector('[data-visit-switch-root]');
        const visitPayloadNode = document.getElementById('visit-kpi-payload');
        const shopRoot = document.querySelector('[data-shop-switch-root]');
        const shopPayloadNode = document.getElementById('shop-group-kpi-payload');
        if (!memberRoot || !memberPayloadNode || !visitRoot || !visitPayloadNode || !orderRoot || !orderPayloadNode || !shopRoot || !shopPayloadNode) return;

        let memberDataset = {};
        let orderDataset = [];
        let visitDataset = {};
        let shopDataset = [];
        try {
          memberDataset = JSON.parse(memberPayloadNode.textContent || '{}');
        } catch {
          memberDataset = {};
        }
        try {
          orderDataset = JSON.parse(orderPayloadNode.textContent || '[]');
        } catch {
          orderDataset = [];
        }
        try {
          visitDataset = JSON.parse(visitPayloadNode.textContent || '{}');
        } catch {
          visitDataset = {};
        }
        try {
          shopDataset = JSON.parse(shopPayloadNode.textContent || '[]');
        } catch {
          shopDataset = [];
        }

        const memberLabelMap = {
          active: <%- JSON.stringify(isEn ? 'Active members count.' : '활성 회원 수입니다.') %>,
          blocked: <%- JSON.stringify(isEn ? 'Blocked members count.' : '블락 회원 수입니다.') %>
        };
        const isEnMode = <%= isEn ? 'true' : 'false' %>;
        const groupLabelMapJs = <%- JSON.stringify(groupLabelMap) %>;

        const memberButtons = Array.from(memberRoot.querySelectorAll('[data-member-type]'));
        const memberValueNode = memberRoot.querySelector('[data-member-value]');
        const memberCaptionNode = memberRoot.querySelector('[data-member-caption]');

        const applyMemberType = (type) => {
          const value =
            type === 'blocked'
              ? Number(memberDataset.blocked || 0)
              : Number(memberDataset.active || 0);

          if (memberValueNode) {
            memberValueNode.textContent = value.toLocaleString();
          }

          if (memberCaptionNode) {
            memberCaptionNode.textContent = memberLabelMap[type] || memberLabelMap.active;
          }

          memberButtons.forEach((btn) => {
            btn.classList.toggle('active', btn.dataset.memberType === type);
          });
        };

        const orderButtons = Array.from(orderRoot.querySelectorAll('[data-order-group]'));
        const orderCaptionNode = orderRoot.querySelector('[data-order-caption]');
        const orderFields = ['pendingReview', 'confirmed', 'readyToShip', 'shipping', 'delivered'];
        const orderValueNodes = orderFields.reduce((acc, field) => {
          acc[field] = orderRoot.querySelector(`[data-order-value="${field}"]`);
          return acc;
        }, {});

        const applyOrderGroup = (groupName) => {
          const target =
            orderDataset.find((item) => item && item.groupName === groupName) ||
            orderDataset[0] ||
            { groupName: '공장제', pendingReview: 0, confirmed: 0, readyToShip: 0, shipping: 0, delivered: 0 };

          orderFields.forEach((field) => {
            if (orderValueNodes[field]) {
              orderValueNodes[field].textContent = Number(target[field] || 0).toLocaleString();
            }
          });

          if (orderCaptionNode) {
            const label = groupLabelMapJs[target.groupName] || target.groupName;
            orderCaptionNode.textContent = isEnMode
              ? `${label} order status summary.`
              : `${label} 주문 상태 집계입니다.`;
          }

          orderButtons.forEach((btn) => {
            btn.classList.toggle('active', btn.dataset.orderGroup === target.groupName);
          });
        };

        const visitLabelMap = {
          member: <%- JSON.stringify(isEn ? 'Member visits summary.' : '회원 방문 기준 집계입니다.') %>,
          guest: <%- JSON.stringify(isEn ? 'Guest visits summary.' : '비회원 방문 기준 집계입니다.') %>,
          total: <%- JSON.stringify(isEn ? 'All visits summary.' : '회원+비회원 전체 방문 집계입니다.') %>
        };

        const visitFields = ['today', 'week', 'month', 'year', 'total'];
        const visitButtons = Array.from(visitRoot.querySelectorAll('[data-visit-type]'));
        const visitCaptionNode = visitRoot.querySelector('[data-visit-caption]');
        const visitValueNodes = visitFields.reduce((acc, field) => {
          acc[field] = visitRoot.querySelector(`[data-visit-value="${field}"]`);
          return acc;
        }, {});

        const applyVisitType = (type) => {
          const target = visitDataset[type] || visitDataset.member || { today: 0, week: 0, month: 0, year: 0, total: 0 };
          visitFields.forEach((field) => {
            if (visitValueNodes[field]) {
              visitValueNodes[field].textContent = Number(target[field] || 0).toLocaleString();
            }
          });
          if (visitCaptionNode) {
            visitCaptionNode.textContent = visitLabelMap[type] || visitLabelMap.member;
          }
          visitButtons.forEach((btn) => {
            btn.classList.toggle('active', btn.dataset.visitType === type);
          });
        };

        const shopButtons = Array.from(shopRoot.querySelectorAll('[data-shop-group]'));
        const shopCaptionNode = shopRoot.querySelector('[data-shop-caption]');
        const shopFields = ['totalCount', 'activeCount', 'hiddenCount'];
        const shopValueNodes = shopFields.reduce((acc, field) => {
          acc[field] = shopRoot.querySelector(`[data-shop-value="${field}"]`);
          return acc;
        }, {});

        const applyShopGroup = (groupName) => {
          const target =
            shopDataset.find((item) => item && item.groupName === groupName) ||
            shopDataset[0] ||
            { groupName: '공장제', totalCount: 0, activeCount: 0, hiddenCount: 0 };

          shopFields.forEach((field) => {
            if (shopValueNodes[field]) {
              shopValueNodes[field].textContent = Number(target[field] || 0).toLocaleString();
            }
          });

          if (shopCaptionNode) {
            const label = groupLabelMapJs[target.groupName] || target.groupName;
            shopCaptionNode.textContent = isEnMode
              ? `${label} inventory summary.`
              : `${label} 상품 현황입니다.`;
          }

          shopButtons.forEach((btn) => {
            btn.classList.toggle('active', btn.dataset.shopGroup === target.groupName);
          });
        };

        memberButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            applyMemberType(btn.dataset.memberType || 'active');
          });
        });

        orderButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            applyOrderGroup(btn.dataset.orderGroup || '공장제');
          });
        });

        visitButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            applyVisitType(btn.dataset.visitType || 'member');
          });
        });

        shopButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            applyShopGroup(btn.dataset.shopGroup || '공장제');
          });
        });

        applyMemberType('active');
        applyOrderGroup('공장제');
        applyVisitType('member');
        applyShopGroup('공장제');
      })();
    </script>
  </article>
  <% } %>

