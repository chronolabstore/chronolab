    <% if (menusTab === 'fields') { %>
      <div class="admin-grid menu-fields-grid">
        <section class="kpi-card">
          <h4><%= isEn ? 'Add Upload Field' : '업로드 항목 추가' %></h4>
          <form method="post" action="/admin/product-group/field/add" class="form-grid menu-manage-form">
            <label><%= isEn ? 'Target Category' : '대상 분류' %>
              <select name="groupKey" required>
                <% productGroupConfigList.forEach((group) => { %>
                  <option value="<%= group.key %>"><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></option>
                <% }) %>
              </select>
            </label>
            <label><%= isEn ? 'Field Key (optional)' : '항목 키 (선택)' %>
              <input type="text" name="fieldKey" placeholder="custom_grade" />
            </label>
            <label><%= isEn ? 'Field Name (KR)' : '항목명 (KR)' %>
              <input type="text" name="labelKo" required />
            </label>
            <label><%= isEn ? 'Field Name (EN)' : '항목명 (EN)' %>
              <input type="text" name="labelEn" required />
            </label>
            <label><%= isEn ? 'Field Type' : '항목 타입' %>
              <select name="fieldType" required>
                <option value="text"><%= isEn ? 'Text' : '텍스트' %></option>
                <option value="textarea"><%= isEn ? 'Textarea' : '긴 텍스트' %></option>
                <option value="number"><%= isEn ? 'Number' : '숫자' %></option>
              </select>
            </label>
            <label class="check-row">
              <input type="checkbox" name="required" />
              <span><%= isEn ? 'Required field' : '필수 항목' %></span>
            </label>
            <button type="submit" class="chip dark menu-manage-submit"><%= isEn ? 'Add Field' : '항목 추가' %></button>
          </form>
        </section>

        <section class="kpi-card">
          <div class="kpi-head-row menu-field-head-row">
            <h4><%= isEn ? 'Category Field List' : '분류별 업로드 항목 목록' %></h4>
            <%
              const preferredFieldFilterKeys = ['공장제', '젠파츠', '현지중고'];
              const preferredFieldFilterGroups = preferredFieldFilterKeys
                .map((key) => productGroupConfigList.find((group) => group.key === key))
                .filter(Boolean);
              const restFieldFilterGroups = productGroupConfigList.filter(
                (group) => !preferredFieldFilterGroups.some((preferredGroup) => preferredGroup.key === group.key)
              );
              const fallbackFieldFilterGroups =
                preferredFieldFilterGroups.length > 0
                  ? [...preferredFieldFilterGroups, ...restFieldFilterGroups]
                  : productGroupConfigList;
            %>
            <% if (fallbackFieldFilterGroups.length > 0) { %>
              <div class="chip-row menu-field-filter-row" data-menu-field-filter-wrap>
                <% fallbackFieldFilterGroups.forEach((group, index) => { %>
                  <button type="button" class="chip <%= index === 0 ? 'dark' : '' %>" data-menu-field-filter="<%= group.key %>">
                    <%= group.labelKo || group.key %>
                  </button>
                <% }) %>
              </div>
            <% } %>
          </div>
          <div class="admin-list menu-field-group-list" data-menu-field-list>
            <% productGroupConfigList.forEach((group) => { %>
              <details class="admin-list-item" open data-menu-field-group="<%= group.key %>">
                <summary><strong><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></strong> <small>(<%= (group.customFields || []).length %>)</small></summary>
                <div class="admin-list">
                  <% (group.customFields || []).forEach((field) => { %>
                    <div class="admin-list-item">
                      <form method="post" action="/admin/product-group/field/update" class="form-grid compact">
                        <input type="hidden" name="groupKey" value="<%= group.key %>" />
                        <input type="hidden" name="fieldKey" value="<%= field.key %>" />
                        <label><%= isEn ? 'Key' : '키' %>
                          <input type="text" value="<%= field.key %>" readonly />
                        </label>
                        <label><%= isEn ? 'Name (KR)' : '항목명 (KR)' %>
                          <input type="text" name="labelKo" value="<%= field.labelKo || field.key %>" required />
                        </label>
                        <label><%= isEn ? 'Name (EN)' : '항목명 (EN)' %>
                          <input type="text" name="labelEn" value="<%= field.labelEn || field.key %>" required />
                        </label>
                        <label><%= isEn ? 'Type' : '타입' %>
                          <select name="fieldType">
                            <option value="text" <%= field.type === 'text' ? 'selected' : '' %>><%= isEn ? 'Text' : '텍스트' %></option>
                            <option value="textarea" <%= field.type === 'textarea' ? 'selected' : '' %>><%= isEn ? 'Textarea' : '긴 텍스트' %></option>
                            <option value="number" <%= field.type === 'number' ? 'selected' : '' %>><%= isEn ? 'Number' : '숫자' %></option>
                          </select>
                        </label>
                        <label class="check-row">
                          <input type="checkbox" name="required" <%= field.required ? 'checked' : '' %> />
                          <span><%= isEn ? 'Required' : '필수' %></span>
                        </label>
                        <div class="admin-account-actions">
                          <button type="submit" class="chip dark"><%= isEn ? 'Save Field' : '항목 저장' %></button>
                        </div>
                      </form>
                      <% if ((group.customFields || []).length > 1) { %>
                        <form method="post" action="/admin/product-group/field/remove" class="inline-form">
                          <input type="hidden" name="groupKey" value="<%= group.key %>" />
                          <input type="hidden" name="fieldKey" value="<%= field.key %>" />
                          <button type="submit" class="chip"><%= isEn ? 'Delete Field' : '항목 삭제' %></button>
                        </form>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </details>
            <% }) %>
          </div>
        </section>
      </div>
      <script>
        (() => {
          const wrap = document.querySelector('[data-menu-field-filter-wrap]');
          const list = document.querySelector('[data-menu-field-list]');
          if (!wrap || !list) return;

          const buttons = Array.from(wrap.querySelectorAll('[data-menu-field-filter]'));
          const groups = Array.from(list.querySelectorAll('[data-menu-field-group]'));
          if (!buttons.length || !groups.length) return;

          const applyFilter = (groupKey) => {
            buttons.forEach((button) => {
              const active = button.dataset.menuFieldFilter === groupKey;
              button.classList.toggle('dark', active);
            });
            groups.forEach((groupNode) => {
              groupNode.hidden = groupNode.dataset.menuFieldGroup !== groupKey;
            });
          };

          const initialGroup = buttons[0].dataset.menuFieldFilter || '';
          if (initialGroup) {
            applyFilter(initialGroup);
          }

          buttons.forEach((button) => {
            button.addEventListener('click', () => {
              applyFilter(button.dataset.menuFieldFilter || '');
            });
          });
        })();
      </script>
    <% } %>
  </article>
  <% } %>

  <% if (tab === 'products') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Product Manager' : '상품관리' %></h3>
    <div class="security-subnav">
      <a href="/admin/products?section=upload" class="menu-pill <%= productsTab === 'upload' ? 'active' : '' %>"><%= isEn ? 'Upload Product' : '상품 업로드' %></a>
      <a href="/admin/products?section=list" class="menu-pill <%= productsTab === 'list' ? 'active' : '' %>"><%= isEn ? 'Product List' : '상품 목록' %></a>
    </div>

    <% if (productsTab === 'upload') { %>
      <% if (editingItem) { %>
        <p class="muted-label">
          <%= isEn ? `Editing product #${editingItem.id}` : `상품 #${editingItem.id} 수정 중` %>
          <a href="/admin/products?section=upload" class="chip"><%= isEn ? 'Cancel Edit' : '수정 취소' %></a>
        </p>
      <% } %>

      <form method="post" action="<%= editingItem ? `/admin/product/${editingItem.id}/update` : '/admin/product/create' %>" enctype="multipart/form-data" class="form-grid" data-admin-product-form data-product-groups="<%- encodeURIComponent(JSON.stringify(productGroupConfigList)) %>" data-initial-group="<%- encodeURIComponent(uploadActiveGroupKey) %>">
        <label><%= isEn ? 'Images (multiple upload)' : '사진 (여러 장 업로드 가능)' %>
          <input type="file" name="images" accept="image/*" multiple />
          <small class="muted-label"><%= isEn ? 'All uploaded images are automatically watermarked with "Chrono Lab".' : '업로드된 모든 이미지는 자동으로 "Chrono Lab" 워터마크가 적용됩니다.' %></small>
        </label>
        <div class="watermark-preview-wrap" data-image-watermark-preview hidden>
          <p class="muted-label"><%= isEn ? 'Preview with watermark applied before upload' : '업로드 전 워터마크 적용 미리보기' %></p>
          <div class="watermark-preview-grid" data-image-watermark-preview-grid></div>
        </div>

        <% if (editingItem && editingItem.imageList && editingItem.imageList.length > 0) { %>
          <div class="admin-field-chip-row">
            <% editingItem.imageList.forEach((src) => { %>
              <span class="chip"><a href="<%= src %>" target="_blank" rel="noreferrer"><%= isEn ? 'Current Image' : '현재 이미지' %></a></span>
            <% }) %>
          </div>
        <% } %>

        <input type="hidden" name="categoryGroup" value="<%= uploadActiveGroupKey %>" data-admin-product-group-input />
        <div class="filter-group">
          <h4><%= isEn ? 'Upload Category' : '업로드 분류 선택' %></h4>
          <div class="chip-row" data-admin-product-group-btn-wrap>
            <% productGroupKeys.forEach((groupName) => { %>
              <button type="button" class="chip <%= uploadActiveGroupKey === groupName ? 'dark' : '' %>" data-admin-product-group-btn="<%= groupName %>"><%= groupLabelByKey[groupName] || groupName %></button>
            <% }) %>
          </div>
        </div>

        <p class="muted-label"><%= isEn ? 'Each category has its own upload field set. Field setup is managed in Menu Manager > Upload Fields.' : '분류별 업로드 항목이 다릅니다. 항목 설정은 메뉴관리 > 업로드 항목에서 수정할 수 있습니다.' %></p>

        <% productGroupConfigList.forEach((group) => { %>
          <div class="product-simple-fields" data-admin-product-fields="<%= group.key %>" <%= uploadActiveGroupKey === group.key ? '' : 'hidden' %>>
            <h4><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></h4>
            <% if (!group.customFields || group.customFields.length === 0) { %>
              <p class="muted-label"><%= isEn ? 'No fields configured. Add fields in Menu Manager.' : '설정된 업로드 항목이 없습니다. 메뉴관리에서 항목을 추가해 주세요.' %></p>
            <% } %>
            <% (group.customFields || []).forEach((field) => { %>
              <%
                const key = field.key;
                const value =
                  editingItem && editingItem.category_group === group.key && editingItem.fieldValues
                    ? (editingItem.fieldValues[key] || '')
                    : '';
              %>
              <label>
                <%= isEn ? (field.labelEn || field.labelKo || key) : (field.labelKo || field.labelEn || key) %>
                <% if (field.type === 'textarea') { %>
                  <textarea name="fieldValues[<%= key %>]" rows="3" data-admin-field-input data-group="<%= group.key %>" data-required="<%= field.required ? '1' : '0' %>"><%= value %></textarea>
                <% } else { %>
                  <input type="<%= field.type === 'number' ? 'number' : 'text' %>" name="fieldValues[<%= key %>]" value="<%= value %>" data-admin-field-input data-group="<%= group.key %>" data-required="<%= field.required ? '1' : '0' %>" />
                <% } %>
              </label>
            <% }) %>
          </div>
        <% }) %>

        <button type="submit" class="cta-main"><%= editingItem ? (isEn ? 'Update Product' : '상품 수정 저장') : (isEn ? 'Add Product' : '상품 등록') %></button>
      </form>

      <script>
        (() => {
          const form = document.querySelector('[data-admin-product-form]');
          if (!form) return;

          const hiddenGroupInput = form.querySelector('[data-admin-product-group-input]');
          const buttons = Array.from(form.querySelectorAll('[data-admin-product-group-btn]'));
          const fieldBoxes = Array.from(form.querySelectorAll('[data-admin-product-fields]'));
          const fieldInputs = Array.from(form.querySelectorAll('[data-admin-field-input]'));
          const imageInput = form.querySelector('input[name="images"]');
          const previewWrap = form.querySelector('[data-image-watermark-preview]');
          const previewGrid = form.querySelector('[data-image-watermark-preview-grid]');

          const clearWatermarkPreview = () => {
            if (!previewGrid) return;
            previewGrid.innerHTML = '';
            if (previewWrap) {
              previewWrap.hidden = true;
            }
          };

          const drawWatermark = (ctx, width, height) => {
            const text = 'Chrono Lab';
            const fontSize = Math.max(10, Math.round(width * 0.045));
            ctx.save();
            ctx.font = `600 ${fontSize}px system-ui, -apple-system, "Segoe UI", sans-serif`;
            ctx.textBaseline = 'middle';
            ctx.fillStyle = 'rgba(255, 255, 255, 0.18)';
            ctx.strokeStyle = 'rgba(0, 0, 0, 0.12)';
            ctx.lineWidth = Math.max(1, Math.round(fontSize * 0.06));

            const textWidth = ctx.measureText(text).width || fontSize * 5;
            const step = textWidth + Math.max(24, Math.round(fontSize * 1.8));
            const rows = [height * 0.25, height * 0.5, height * 0.75];

            rows.forEach((y) => {
              for (let x = -textWidth; x < width + textWidth; x += step) {
                ctx.strokeText(text, x, y);
                ctx.fillText(text, x, y);
              }
            });

            ctx.restore();
          };

          const appendWatermarkPreview = (file) => {
            if (!previewGrid) return;
            const blobUrl = URL.createObjectURL(file);
            const image = new Image();

            image.onload = () => {
              const maxWidth = 480;
              const maxHeight = 360;
              const scale = Math.min(1, maxWidth / image.width, maxHeight / image.height);
              const width = Math.max(1, Math.round(image.width * scale));
              const height = Math.max(1, Math.round(image.height * scale));

              const item = document.createElement('div');
              item.className = 'watermark-preview-item';

              const canvas = document.createElement('canvas');
              canvas.className = 'watermark-preview-canvas';
              canvas.width = width;
              canvas.height = height;

              const ctx = canvas.getContext('2d');
              if (ctx) {
                ctx.drawImage(image, 0, 0, width, height);
                drawWatermark(ctx, width, height);
              }

              const name = document.createElement('span');
              name.className = 'watermark-preview-name';
              name.textContent = file.name || 'image';

              item.appendChild(canvas);
              item.appendChild(name);
              previewGrid.appendChild(item);

              URL.revokeObjectURL(blobUrl);
            };

            image.onerror = () => {
              URL.revokeObjectURL(blobUrl);
            };

            image.src = blobUrl;
          };

          const refreshWatermarkPreview = () => {
            if (!imageInput || !previewWrap || !previewGrid) return;
            clearWatermarkPreview();
            const files = Array.from(imageInput.files || []).filter((file) =>
              typeof file.type === 'string' && file.type.startsWith('image/')
            );
            if (!files.length) return;
            previewWrap.hidden = false;
            files.forEach((file) => appendWatermarkPreview(file));
          };

          const applyGroup = (groupKey) => {
            if (hiddenGroupInput) {
              hiddenGroupInput.value = groupKey;
            }

            buttons.forEach((button) => {
              const active = button.dataset.adminProductGroupBtn === groupKey;
              button.classList.toggle('dark', active);
            });

            fieldBoxes.forEach((box) => {
              const active = box.dataset.adminProductFields === groupKey;
              box.hidden = !active;
              const inputs = Array.from(box.querySelectorAll('[data-admin-field-input]'));
              inputs.forEach((input) => {
                input.disabled = !active;
                input.required = active && input.dataset.required === '1';
              });
            });

            fieldInputs
              .filter((input) => !input.closest('[data-admin-product-fields]'))
              .forEach((input) => {
                input.disabled = false;
              });
          };

          const initialGroup = decodeURIComponent(form.dataset.initialGroup || '') || (buttons[0] && buttons[0].dataset.adminProductGroupBtn) || '';
          if (initialGroup) {
            applyGroup(initialGroup);
          }

          buttons.forEach((button) => {
            button.addEventListener('click', () => {
              applyGroup(button.dataset.adminProductGroupBtn || '');
            });
          });

          if (imageInput) {
            imageInput.addEventListener('change', refreshWatermarkPreview);
            refreshWatermarkPreview();
          }
        })();
      </script>
    <% } %>

    <% if (productsTab === 'list') { %>
      <div class="kpi-head-row">
        <div class="chip-row" data-admin-product-filter-wrap>
