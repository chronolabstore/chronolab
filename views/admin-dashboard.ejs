            <th>No</th>
            <th><%= isEn ? 'Factory' : '공장' %></th>
            <th><%= isEn ? 'Brand' : '브랜드' %></th>
            <th><%= isEn ? 'Model' : '모델' %></th>
            <th><%= isEn ? 'Reference' : '레퍼런스' %></th>
            <th><%= isEn ? 'Spec / Size' : '종류/사이즈' %></th>
            <th><%= isEn ? 'Cost (RMB)' : '원가 (RMB)' %></th>
            <th><%= isEn ? 'Cost (KRW)' : '원가 (KRW)' %></th>
            <th><%= isEn ? 'Final Cost (KRW)' : '최종원가 (KRW)' %></th>
            <th><%= isEn ? 'Sale Price (KRW)' : '판매가 (KRW)' %></th>
            <th><%= isEn ? 'Margin (KRW)' : '마진 (KRW)' %></th>
            <th><%= isEn ? 'Qty' : '수량' %></th>
            <th><%= isEn ? 'Memo' : '메모' %></th>
            <th><%= isEn ? 'Delete' : '삭제' %></th>
          </tr>
        </thead>
        <tbody id="salesEditorTbody"></tbody>
      </table>
    </div>

    <p class="muted-label sales-meta" id="salesMetaText">-</p>
    <p class="muted-label sales-error hidden" id="salesErrorText"></p>
  </article>

  <script>
    (() => {
      const mainTabButtons = Array.from(document.querySelectorAll('#salesMainTabNav [data-sales-main-tab]'));
      const fxSyncBtn = document.getElementById('salesFxSyncBtn');
      const applyGlobalBtn = document.getElementById('salesApplyGlobalBtn');
      const saveBtn = document.getElementById('salesSaveBtn');
      const addRowBtn = document.getElementById('salesAddRowBtn');
      const rowActionHost = document.getElementById('salesRowActionHost');
      const scopeToolbar = document.querySelector('.sales-scope-toolbar');
      const scopeControls = document.getElementById('salesScopeControls');
      const exchangeRateInput = document.getElementById('salesExchangeRateInput');
      const shippingFeeInput = document.getElementById('salesShippingFeeInput');
      const scopeDateInput = document.getElementById('salesScopeDateInput');
      const summaryGrid = document.getElementById('salesSummaryGrid');
      const tableBody = document.getElementById('salesEditorTbody');
      const metaText = document.getElementById('salesMetaText');
      const errorText = document.getElementById('salesErrorText');

      if (!mainTabButtons.length || !scopeControls || !rowActionHost || !scopeToolbar || !exchangeRateInput || !shippingFeeInput || !scopeDateInput || !summaryGrid || !tableBody || !metaText || !errorText) {
        return;
      }

      const isEn = <%= isEn ? 'true' : 'false' %>;
      const tabDefs = <%- JSON.stringify(salesTabs || []) %>;
      const integerFmt = new Intl.NumberFormat(isEn ? 'en-US' : 'ko-KR');

      let workbook = null;
      let activeTabKey = tabDefs[0]?.key || 'price';
      let activeScopeId = '';
      let dirty = false;

      const toNumber = (value, fallback = 0) => {
        const numeric = Number(String(value ?? '').replace(/,/g, ''));
        if (!Number.isFinite(numeric)) return fallback;
        return numeric;
      };

      const toPositive = (value, fallback = 0) => {
        const numeric = toNumber(value, fallback);
        if (!Number.isFinite(numeric) || numeric < 0) return fallback;
        return numeric;
      };

      const normalizeDate = (value) => {
        const raw = String(value || '').trim().replace(/[./]/g, '-');
        if (!raw) return '';
        return /^\d{4}-\d{2}-\d{2}$/.test(raw) ? raw : '';
      };

      const todayDateString = () => {
        const now = new Date();
        const y = now.getFullYear();
        const m = String(now.getMonth() + 1).padStart(2, '0');
        const d = String(now.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
      };

      const roundToStep = (value, step = 1) => {
        const safeStep = Math.max(0.000001, toPositive(step, 1));
        const numeric = toPositive(value, 0);
        return Math.round(numeric / safeStep) * safeStep;
      };

      const getScopeMode = (tabKey) => {
        if (tabKey === 'price') return 'factory';
        if (tabKey === 'preorder') return 'round';
        return 'date';
      };

      const formatKrw = (value) => {
        const amount = Math.round(toPositive(value, 0));
        return `${isEn ? 'KRW ' : '₩'}${integerFmt.format(amount)}`;
      };

      const showError = (message) => {
        errorText.textContent = message;
        errorText.classList.remove('hidden');
      };

      const clearError = () => {
        errorText.textContent = '';
        errorText.classList.add('hidden');
      };

      const getTabDef = () => tabDefs.find((item) => item.key === activeTabKey) || tabDefs[0] || { key: 'price', scopeType: 'factory' };
      const getTabData = () => (workbook?.tabs && typeof workbook.tabs === 'object' ? workbook.tabs[activeTabKey] || null : null);

      const normalizeSettings = (value, fallback = {}) => ({
        exchangeRate: Number(roundToStep((value?.exchangeRate ?? fallback.exchangeRate ?? 229), 0.01).toFixed(2)),
        shippingFeeKrw: Math.round(roundToStep((value?.shippingFeeKrw ?? fallback.shippingFeeKrw ?? 23000), 1000)),
        fxSource: String(value?.fxSource || fallback.fxSource || 'manual').slice(0, 40),
        fxUpdatedAt: String(value?.fxUpdatedAt || fallback.fxUpdatedAt || '').slice(0, 40),
        updatedAt: String(value?.updatedAt || fallback.updatedAt || new Date().toISOString()).slice(0, 40),
        baseDate: normalizeDate(value?.baseDate || value?.date || fallback.baseDate || '')
      });

      const ensureTabSettings = (tab) => {
        if (!tab) return null;
        const fallback = normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        tab.settings = normalizeSettings(tab.settings || {}, fallback);
        return tab.settings;
      };

      const getScopes = () => {
        const tab = getTabData();
        if (!tab) return [];
        const mode = getScopeMode(activeTabKey);
        if (mode === 'factory') {
          return Array.isArray(tab.groups) ? tab.groups : [];
        }
        return Array.isArray(tab.rounds) ? tab.rounds : [];
      };

      const ensureActiveScope = () => {
        const scopes = getScopes();
        if (!scopes.length) {
          activeScopeId = '';
          return;
        }
        if (!scopes.some((item) => item.id === activeScopeId)) {
          activeScopeId = scopes[0].id;
        }
      };

      const getActiveScope = () => getScopes().find((scope) => scope.id === activeScopeId) || getScopes()[0] || null;

      const ensureTodayScopeForDateTab = () => {
        if (getScopeMode(activeTabKey) !== 'date') return false;
        const tab = getTabData();
        if (!tab) return false;
        if (!Array.isArray(tab.rounds)) tab.rounds = [];
        const today = todayDateString();
        const existing = tab.rounds.find(
          (scope) => normalizeDate(scope?.settings?.baseDate || scope?.name || scope?.date || '') === today
        );
        if (existing) {
          activeScopeId = existing.id;
          return false;
        }

        const tabSettings = ensureTabSettings(tab) || normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        const nextScope = {
          id: `date-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
          name: today,
          date: today,
          settings: {
            ...normalizeSettings({}, tabSettings),
            baseDate: today
          },
          rows: []
        };
        tab.rounds.unshift(nextScope);
        activeScopeId = nextScope.id;
        dirty = true;
        return true;
      };

      const ensureScopeSettings = (scope, mode = getScopeMode(activeTabKey)) => {
        if (!scope) return null;
        const tab = getTabData();
        const tabSettings = ensureTabSettings(tab) || normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        scope.settings = normalizeSettings(scope.settings || {}, tabSettings);
        if (mode === 'date') {
          const normalizedDate = normalizeDate(scope.settings.baseDate || scope.date || scope.name || todayDateString());
          scope.settings.baseDate = normalizedDate;
          scope.date = normalizedDate;
          scope.name = normalizedDate;
        } else if (mode === 'round') {
          const normalizedDate = normalizeDate(scope.settings.baseDate || scope.date || '');
          scope.settings.baseDate = normalizedDate;
          scope.date = normalizedDate;
        } else {
          const normalizedDate = normalizeDate(scope.settings.baseDate || '');
          scope.settings.baseDate = normalizedDate;
          scope.date = normalizedDate;
        }
        return scope.settings;
      };

      const getActiveSettings = () => {
        const tab = getTabData();
        const mode = getScopeMode(activeTabKey);
        const tabSettings = ensureTabSettings(tab) || normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        if (mode === 'factory') {
          return tabSettings;
        }
        const scope = getActiveScope();
        return ensureScopeSettings(scope, mode) || tabSettings;
      };

      const getScopeDisplayName = (scope) => {
        if (!scope) return '-';
        const mode = getScopeMode(activeTabKey);
        const settings = ensureScopeSettings(scope, mode);
        if (mode === 'date') {
          return settings?.baseDate || scope.name || '-';
        }
        if (mode === 'round') {
          return settings?.baseDate ? `${scope.name} (${settings.baseDate})` : (scope.name || '-');
        }
        return scope.name || '-';
      };

      const calcRow = (row) => {
        const settings = getActiveSettings();
        const exchangeRate = Math.max(0.01, toPositive(settings?.exchangeRate, 0.01));
        const shippingFeeKrw = Math.max(0, toPositive(settings?.shippingFeeKrw, 0));
        const costRmb = Math.max(0, toPositive(row?.costRmb, 0));
        const saleKrw = Math.max(0, toPositive(row?.saleKrw, 0));
        const quantity = Math.max(1, Math.floor(toPositive(row?.quantity, 1) || 1));

        const costKrw = Math.round(costRmb * exchangeRate);
        const finalCostKrw = costKrw + Math.round(shippingFeeKrw);
        const marginKrw = saleKrw - finalCostKrw;

        return {
          costKrw,
          finalCostKrw,
          marginKrw,
          totalCostKrw: finalCostKrw * quantity,
          totalSalesKrw: saleKrw * quantity,
          totalMarginKrw: marginKrw * quantity
        };
      };

      const renderMeta = (extraText = '') => {
        const tabDef = getTabDef();
        const scope = getActiveScope();
        const activeSettings = getActiveSettings();
        const updatedAt = activeSettings?.updatedAt
          ? new Date(activeSettings.updatedAt).toLocaleString(isEn ? 'en-US' : 'ko-KR')
          : '-';
        const statusText = dirty ? (isEn ? 'unsaved changes' : '저장되지 않은 변경') : (isEn ? 'saved' : '저장됨');
        const scopeName = getScopeDisplayName(scope);
        const base = isEn
          ? `Tab: ${tabDef?.labelEn || tabDef?.key || '-'} · Scope: ${scopeName} · ${statusText} · Updated: ${updatedAt}`
          : `탭: ${tabDef?.labelKo || tabDef?.key || '-'} · 분류: ${scopeName} · ${statusText} · 마지막 저장: ${updatedAt}`;
        metaText.textContent = extraText ? `${base} · ${extraText}` : base;
      };

      const renderGlobalFields = () => {
        const activeSettings = getActiveSettings();
        if (!activeSettings) return;
        const exchangeRate = Number(roundToStep(toPositive(activeSettings.exchangeRate, 0), 0.01).toFixed(2));
        const shippingKrw = Math.round(roundToStep(toPositive(activeSettings.shippingFeeKrw, 0), 1000));
        exchangeRateInput.value = exchangeRate;
        shippingFeeInput.value = shippingKrw;
        scopeDateInput.value = normalizeDate(activeSettings.baseDate || '');
      };

      const renderSummary = () => {
        const scope = getActiveScope();
        if (!scope || !Array.isArray(scope.rows)) {
          summaryGrid.innerHTML = '';
          return;
        }

        let totalQty = 0;
        let totalCostKrw = 0;
        let totalSalesKrw = 0;
        let totalMarginKrw = 0;

        scope.rows.forEach((row) => {
          const qty = Math.max(1, Math.floor(toPositive(row.quantity, 1) || 1));
          const computed = calcRow(row);
          totalQty += qty;
          totalCostKrw += computed.totalCostKrw;
          totalSalesKrw += computed.totalSalesKrw;
          totalMarginKrw += computed.totalMarginKrw;
        });

        const cards = [
          { ko: '행 수', en: 'Rows', value: integerFmt.format(scope.rows.length) },
          { ko: '총 수량', en: 'Total Qty', value: integerFmt.format(totalQty) },
          { ko: '총 원가', en: 'Total Cost', value: formatKrw(totalCostKrw) },
          { ko: '총 판매', en: 'Total Sales', value: formatKrw(totalSalesKrw) },
          { ko: '총 마진', en: 'Total Margin', value: formatKrw(totalMarginKrw) }
        ];

        summaryGrid.innerHTML = cards
          .map((card) => `
            <article class="sales-summary-card">
              <h4>${isEn ? card.en : card.ko}</h4>
              <strong>${card.value}</strong>
            </article>
          `)
          .join('');
      };

      const updateComputedCells = (tr, row) => {
        const computed = calcRow(row);
        const costCell = tr.querySelector('[data-computed="costKrw"]');
        const finalCostCell = tr.querySelector('[data-computed="finalCostKrw"]');
        const marginCell = tr.querySelector('[data-computed="marginKrw"]');

        if (costCell) costCell.textContent = formatKrw(computed.costKrw);
        if (finalCostCell) finalCostCell.textContent = formatKrw(computed.finalCostKrw);
        if (marginCell) {
          marginCell.textContent = formatKrw(computed.marginKrw);
          marginCell.classList.toggle('is-negative', computed.marginKrw < 0);
          marginCell.classList.toggle('is-positive', computed.marginKrw > 0);
        }
      };

      const renderTableRows = () => {
        const scope = getActiveScope();
        if (!scope) {
          tableBody.innerHTML = `<tr><td colspan="14" class="muted-label">${isEn ? 'No scope selected.' : '선택된 분류가 없습니다.'}</td></tr>`;
          return;
        }

        if (!Array.isArray(scope.rows) || scope.rows.length === 0) {
          tableBody.innerHTML = `<tr><td colspan="14" class="muted-label">${isEn ? 'No rows yet. Add a row to start.' : '행이 없습니다. 행 추가로 시작하세요.'}</td></tr>`;
          return;
        }

        tableBody.innerHTML = '';
        scope.rows.forEach((row, index) => {
          const tr = document.createElement('tr');
          tr.dataset.rowId = row.id;

          const makeCell = (content) => {
            const td = document.createElement('td');
            if (content instanceof HTMLElement) {
              td.appendChild(content);
            } else {
              td.textContent = String(content ?? '');
            }
            return td;
          };

          const makeInput = (field, value, type = 'text', step = '') => {
            const input = document.createElement('input');
            input.type = type;
            if (step) input.step = step;
            if (type === 'number') input.min = '0';
            input.value = value ?? '';
            input.dataset.rowId = row.id;
            input.dataset.field = field;
            input.className = 'sales-inline-input';
            return input;
          };

          const indexCell = makeCell(String(index + 1));
          indexCell.className = 'sales-row-index';
          tr.appendChild(indexCell);
          tr.appendChild(makeCell(makeInput('factory', row.factory || (getScopeMode(activeTabKey) === 'factory' ? scope.name : ''))));
          tr.appendChild(makeCell(makeInput('brand', row.brand)));
          tr.appendChild(makeCell(makeInput('model', row.model)));
          tr.appendChild(makeCell(makeInput('reference', row.reference)));
          tr.appendChild(makeCell(makeInput('spec', row.spec)));
          tr.appendChild(makeCell(makeInput('costRmb', row.costRmb, 'number', '0.01')));

          const costCell = makeCell('-');
          costCell.dataset.computed = 'costKrw';
          costCell.className = 'sales-computed-cell';
          tr.appendChild(costCell);

          const finalCell = makeCell('-');
          finalCell.dataset.computed = 'finalCostKrw';
          finalCell.className = 'sales-computed-cell';
          tr.appendChild(finalCell);

          tr.appendChild(makeCell(makeInput('saleKrw', row.saleKrw, 'number', '1')));

          const marginCell = makeCell('-');
          marginCell.dataset.computed = 'marginKrw';
          marginCell.className = 'sales-computed-cell';
          tr.appendChild(marginCell);

          tr.appendChild(makeCell(makeInput('quantity', row.quantity, 'number', '1')));
          tr.appendChild(makeCell(makeInput('memo', row.memo)));

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'chip';
          deleteBtn.dataset.rowDelete = row.id;
          deleteBtn.textContent = isEn ? 'Delete' : '삭제';
          tr.appendChild(makeCell(deleteBtn));

          updateComputedCells(tr, row);
          tableBody.appendChild(tr);
        });
      };

      const renderScopeControls = () => {
        scopeControls.innerHTML = '';
        if (rowActionHost.parentElement !== scopeToolbar) {
          scopeToolbar.appendChild(rowActionHost);
        }

        const tabDef = getTabDef();
        const tab = getTabData();
        const scopes = getScopes();
        if (!tab) return;
        const scopeMode = getScopeMode(tab.key);

        const caption = document.createElement('p');
        caption.className = 'muted-label';
        if (scopeMode === 'factory') {
          caption.textContent = isEn
            ? 'Factory sub-categories for factory price table'
            : '공장제 가격표의 공장별 하위 분류';
        } else if (scopeMode === 'round') {
          caption.textContent = isEn
            ? 'Rounds/batches are stored separately. Set date + FX per selected round.'
            : '차수(회차)별로 별도 저장됩니다. 선택한 차수에 기준일자/환율/배송비를 저장하세요.';
        } else {
          caption.textContent = isEn
            ? 'Sales are managed by date. Select or add date to edit that day only.'
            : '매출은 날짜별로 관리됩니다. 날짜를 선택/추가해 해당 날짜 데이터만 편집하세요.';
        }
        scopeControls.appendChild(caption);

        if (scopeMode === 'factory') {
          const nav = document.createElement('div');
          nav.className = 'security-subnav';
          scopes.forEach((scope) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `menu-pill ${scope.id === activeScopeId ? 'active' : ''}`;
            btn.textContent = scope.name;
            btn.addEventListener('click', () => {
              activeScopeId = scope.id;
              clearError();
              renderGlobalFields();
              renderScopeControls();
              renderTableRows();
              renderSummary();
              renderMeta();
            });
            nav.appendChild(btn);
          });
          scopeControls.appendChild(nav);

          const action = document.createElement('div');
          action.className = 'sales-scope-action-row';

          const nameInput = document.createElement('input');
          nameInput.type = 'text';
          nameInput.placeholder = isEn ? 'Factory name' : '공장명';
          nameInput.value = getActiveScope()?.name || '';

          const addBtn = document.createElement('button');
          addBtn.type = 'button';
          addBtn.className = 'chip';
          addBtn.textContent = isEn ? 'Add Factory Table' : '공장표 추가';
          addBtn.addEventListener('click', () => {
            const nextName = String(nameInput.value || '').trim() || (isEn ? 'New Factory' : '새 공장');
            if (!Array.isArray(tab.groups)) tab.groups = [];
            tab.groups.push({
              id: `scope-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
              name: nextName.slice(0, 80),
              settings: normalizeSettings({}, ensureTabSettings(tab)),
              rows: []
            });
            activeScopeId = tab.groups[tab.groups.length - 1].id;
            dirty = true;
            clearError();
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const renameBtn = document.createElement('button');
          renameBtn.type = 'button';
          renameBtn.className = 'chip';
          renameBtn.textContent = isEn ? 'Rename' : '이름변경';
          renameBtn.addEventListener('click', () => {
            const scope = getActiveScope();
            if (!scope) return;
            const nextName = String(nameInput.value || '').trim();
            if (!nextName) return;
            scope.name = nextName.slice(0, 80);
            dirty = true;
            clearError();
            renderScopeControls();
            renderMeta();
          });

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'chip';
          deleteBtn.textContent = isEn ? 'Delete' : '삭제';
          deleteBtn.addEventListener('click', () => {
            if (!Array.isArray(tab.groups) || tab.groups.length <= 1) {
              showError(isEn ? 'At least one factory table is required.' : '공장표는 최소 1개가 필요합니다.');
              return;
            }
            clearError();
            tab.groups = tab.groups.filter((scope) => scope.id !== activeScopeId);
            activeScopeId = tab.groups[0]?.id || '';
            dirty = true;
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const rowSeparator = document.createElement('span');
          rowSeparator.className = 'sales-scope-inline-separator';
          rowSeparator.textContent = '|';

          action.append(nameInput, addBtn, renameBtn, deleteBtn, rowSeparator, rowActionHost);
          scopeControls.appendChild(action);
          return;
        }

        if (scopeMode === 'date') {
          const action = document.createElement('div');
          action.className = 'sales-scope-action-row';

          const dateLabel = document.createElement('label');
          dateLabel.className = 'sales-round-select-wrap';
          const dateCaption = document.createElement('span');
          dateCaption.textContent = isEn ? 'Date' : '날짜';
          const datePickerInput = document.createElement('input');
          datePickerInput.type = 'date';
          datePickerInput.value = normalizeDate(
            getActiveScope()?.settings?.baseDate || getActiveScope()?.name || todayDateString()
          );
          datePickerInput.addEventListener('change', () => {
            const selectedDate = normalizeDate(datePickerInput.value || '');
            if (!selectedDate) return;
            const matchedScope = scopes.find(
              (scope) => normalizeDate(scope?.settings?.baseDate || scope?.name || '') === selectedDate
            );
            if (!matchedScope) {
              renderMeta(isEn ? 'date selected (not created yet)' : '날짜 선택됨 (아직 생성 전)');
              return;
            }
            activeScopeId = matchedScope.id;
            clearError();
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          dateLabel.append(dateCaption, datePickerInput);

          const addBtn = document.createElement('button');
          addBtn.type = 'button';
          addBtn.className = 'chip';
          addBtn.textContent = isEn ? 'Add Date' : '날짜 추가';
          addBtn.addEventListener('click', () => {
            if (!Array.isArray(tab.rounds)) tab.rounds = [];
            const nextDate = normalizeDate(datePickerInput.value || '') || todayDateString();
            const exists = tab.rounds.find((scope) => normalizeDate(scope?.settings?.baseDate || scope?.name || '') === nextDate);
            if (exists) {
              activeScopeId = exists.id;
              clearError();
              renderGlobalFields();
              renderScopeControls();
              renderTableRows();
              renderSummary();
              renderMeta(isEn ? 'existing date selected' : '이미 등록된 날짜를 선택했습니다.');
              return;
            }
            tab.rounds.push({
              id: `date-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
              name: nextDate,
              date: nextDate,
              settings: {
                ...normalizeSettings({}, ensureTabSettings(tab)),
                baseDate: nextDate
              },
              rows: []
            });
            activeScopeId = tab.rounds[tab.rounds.length - 1].id;
            dirty = true;
            clearError();
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const saveDateBtn = document.createElement('button');
          saveDateBtn.type = 'button';
          saveDateBtn.className = 'chip';
          saveDateBtn.textContent = isEn ? 'Save Date' : '날짜 저장';
          saveDateBtn.addEventListener('click', () => {
            const scope = getActiveScope();
            if (!scope) return;
            const nextDate = normalizeDate(datePickerInput.value || '');
            if (!nextDate) {
              showError(isEn ? 'Select a valid date.' : '올바른 날짜를 선택해 주세요.');
              return;
            }
            const duplicated = tab.rounds.find(
              (candidate) =>
                candidate.id !== scope.id &&
                normalizeDate(candidate?.settings?.baseDate || candidate?.name || '') === nextDate
            );
            if (duplicated) {
              showError(isEn ? 'This date already exists.' : '이미 등록된 날짜입니다.');
              return;
            }
            ensureScopeSettings(scope, 'date');
            scope.settings.baseDate = nextDate;
            scope.date = nextDate;
            scope.name = nextDate;
            dirty = true;
            clearError();
            renderGlobalFields();
            renderScopeControls();
            renderMeta();
          });

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'chip';
          deleteBtn.textContent = isEn ? 'Delete' : '삭제';
          deleteBtn.addEventListener('click', () => {
            if (!Array.isArray(tab.rounds) || tab.rounds.length <= 1) {
              showError(isEn ? 'At least one date is required.' : '날짜는 최소 1개가 필요합니다.');
              return;
            }
            clearError();
            tab.rounds = tab.rounds.filter((scope) => scope.id !== activeScopeId);
            activeScopeId = tab.rounds[0]?.id || '';
            dirty = true;
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const topActionGroup = document.createElement('div');
          topActionGroup.className = 'sales-date-action-group';
          const groupSeparator = document.createElement('span');
          groupSeparator.className = 'sales-date-action-separator';
          groupSeparator.textContent = '|';
          topActionGroup.append(groupSeparator, addBtn, saveDateBtn, deleteBtn);

          action.append(dateLabel, topActionGroup);
          scopeControls.appendChild(action);
          return;
        }

        const action = document.createElement('div');
        action.className = 'sales-scope-action-row';

        const roundLabel = document.createElement('label');
        roundLabel.className = 'sales-round-select-wrap';
        const roundCaption = document.createElement('span');
        roundCaption.textContent = isEn ? 'Round/Batch' : '차수/회차';
        const roundSelect = document.createElement('select');
        scopes.forEach((scope) => {
          ensureScopeSettings(scope, 'round');
          const option = document.createElement('option');
          option.value = scope.id;
          option.textContent = getScopeDisplayName(scope);
          option.selected = scope.id === activeScopeId;
          roundSelect.appendChild(option);
        });
        roundSelect.addEventListener('change', () => {
          activeScopeId = roundSelect.value;
          clearError();
          renderGlobalFields();
          renderScopeControls();
          renderTableRows();
          renderSummary();
          renderMeta();
        });
        roundLabel.append(roundCaption, roundSelect);

        const nameInput = document.createElement('input');
        nameInput.type = 'text';
        nameInput.placeholder = isEn ? 'Round/Batch name' : '차수/회차명';
        nameInput.value = getActiveScope()?.name || '';

        const roundDateInput = document.createElement('input');
        roundDateInput.type = 'date';
        roundDateInput.value = normalizeDate(getActiveScope()?.settings?.baseDate || getActiveScope()?.date || '');

        const addBtn = document.createElement('button');
        addBtn.type = 'button';
        addBtn.className = 'chip';
        addBtn.textContent = isEn ? 'Add' : '추가';
        addBtn.addEventListener('click', () => {
          if (!Array.isArray(tab.rounds)) tab.rounds = [];
          const fallbackName = tab.key === 'preorder'
            ? `${tab.rounds.length + 1}차`
            : (isEn ? `Batch ${tab.rounds.length + 1}` : `회차 ${tab.rounds.length + 1}`);
          const nextName = String(nameInput.value || '').trim() || fallbackName;
          const nextDate = normalizeDate(roundDateInput.value || '');
          tab.rounds.push({
            id: `round-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
            name: nextName.slice(0, 80),
            date: nextDate,
            settings: {
              ...normalizeSettings({}, ensureTabSettings(tab)),
              baseDate: nextDate
            },
            rows: []
          });
          activeScopeId = tab.rounds[tab.rounds.length - 1].id;
          dirty = true;
          clearError();
          renderGlobalFields();
          renderScopeControls();
          renderTableRows();
          renderSummary();
          renderMeta();
        });

        const renameBtn = document.createElement('button');
        renameBtn.type = 'button';
        renameBtn.className = 'chip';
        renameBtn.textContent = isEn ? 'Rename' : '이름변경';
        renameBtn.addEventListener('click', () => {
          const scope = getActiveScope();
          if (!scope) return;
          const nextName = String(nameInput.value || '').trim();
          if (!nextName) return;
          scope.name = nextName.slice(0, 80);
          dirty = true;
          clearError();
          renderScopeControls();
          renderMeta();
        });

        const saveDateBtn = document.createElement('button');
        saveDateBtn.type = 'button';
        saveDateBtn.className = 'chip';
        saveDateBtn.textContent = isEn ? 'Save Date' : '날짜 저장';
        saveDateBtn.addEventListener('click', () => {
          const scope = getActiveScope();
          if (!scope) return;
          ensureScopeSettings(scope, 'round');
          scope.settings.baseDate = normalizeDate(roundDateInput.value || '');
          scope.date = scope.settings.baseDate;
          dirty = true;
          clearError();
          renderGlobalFields();
          renderScopeControls();
          renderMeta();
        });

        const deleteBtn = document.createElement('button');
        deleteBtn.type = 'button';
        deleteBtn.className = 'chip';
        deleteBtn.textContent = isEn ? 'Delete' : '삭제';
        deleteBtn.addEventListener('click', () => {
          if (!Array.isArray(tab.rounds) || tab.rounds.length <= 1) {
            showError(isEn ? 'At least one round is required.' : '차수/회차는 최소 1개가 필요합니다.');
            return;
          }
          clearError();
          tab.rounds = tab.rounds.filter((scope) => scope.id !== activeScopeId);
          activeScopeId = tab.rounds[0]?.id || '';
          dirty = true;
          renderGlobalFields();
          renderScopeControls();
          renderTableRows();
          renderSummary();
          renderMeta();
        });

        const rowSeparator = document.createElement('span');
        rowSeparator.className = 'sales-scope-inline-separator';
        rowSeparator.textContent = '|';

        action.append(roundLabel, nameInput, roundDateInput, addBtn, renameBtn, saveDateBtn, deleteBtn, rowSeparator, rowActionHost);
        scopeControls.appendChild(action);
      };

      const setMainTab = (tabKey) => {
        activeTabKey = tabKey;
        mainTabButtons.forEach((button) => {
          button.classList.toggle('active', button.getAttribute('data-sales-main-tab') === tabKey);
        });
        ensureActiveScope();
        const createdTodayScope = ensureTodayScopeForDateTab();
        renderGlobalFields();
        renderScopeControls();
        renderTableRows();
        renderSummary();
        renderMeta();
        if (createdTodayScope) {
          void saveWorkbook();
        }
      };

      const saveWorkbook = async () => {
        if (!workbook) return;
        clearError();
        try {
          const response = await fetch('/admin/sales/workbook', {
            method: 'POST',
            headers: {
              'content-type': 'application/json',
              accept: 'application/json'
            },
            body: JSON.stringify({ workbook })
          });
          const payload = await response.json();
          if (!response.ok || !payload?.ok || !payload?.workbook) {
            throw new Error(payload?.message || (isEn ? 'Save failed.' : '저장 실패'));
          }
          workbook = payload.workbook;
          dirty = false;
          ensureActiveScope();
          renderGlobalFields();
          renderScopeControls();
          renderTableRows();
          renderSummary();
          renderMeta(isEn ? 'saved' : '저장됨');
        } catch (error) {
          showError(error instanceof Error ? error.message : (isEn ? 'Unknown error' : '알 수 없는 오류'));
        }
      };

      const loadWorkbook = async () => {
        clearError();
        try {
          const response = await fetch('/admin/sales/data', {
            headers: { accept: 'application/json' }
          });
          const payload = await response.json();
          if (!response.ok || !payload?.ok || !payload?.workbook) {
            throw new Error(payload?.message || (isEn ? 'Failed to load workbook.' : '워크북을 불러오지 못했습니다.'));
          }
          workbook = payload.workbook;
          ensureActiveScope();
          dirty = false;
          renderGlobalFields();
          setMainTab(activeTabKey);
        } catch (error) {
          showError(error instanceof Error ? error.message : (isEn ? 'Unknown error' : '알 수 없는 오류'));
        }
      };

      mainTabButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const tabKey = button.getAttribute('data-sales-main-tab') || '';
          setMainTab(tabKey);
        });
      });

      tableBody.addEventListener('input', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        const rowId = String(target.dataset.rowId || '');
        const field = String(target.dataset.field || '');
        if (!rowId || !field) return;

        const scope = getActiveScope();
        if (!scope || !Array.isArray(scope.rows)) return;
        const row = scope.rows.find((item) => item.id === rowId);
        if (!row) return;

        if (field === 'costRmb' || field === 'saleKrw') {
          row[field] = toPositive(target.value, 0);
        } else if (field === 'quantity') {
          row[field] = Math.max(1, Math.floor(toPositive(target.value, 1) || 1));
        } else {
          row[field] = String(target.value || '').slice(0, field === 'memo' ? 500 : 200);
        }

        const tr = target.closest('tr');
        if (tr) updateComputedCells(tr, row);
        dirty = true;
        renderSummary();
        renderMeta();
      });

      tableBody.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;
        const rowId = String(target.dataset.rowDelete || '');
        if (!rowId) return;

        const scope = getActiveScope();
        if (!scope || !Array.isArray(scope.rows)) return;
        scope.rows = scope.rows.filter((row) => row.id !== rowId);
        dirty = true;
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      addRowBtn?.addEventListener('click', () => {
        const scope = getActiveScope();
        if (!scope || !Array.isArray(scope.rows)) return;
        scope.rows.push({
          id: `row-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
          factory: getScopeMode(activeTabKey) === 'factory' ? scope.name : '',
          brand: '',
          model: '',
          reference: '',
          spec: '',
          costRmb: 0,
          saleKrw: 0,
          quantity: 1,
          memo: ''
        });
        dirty = true;
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      const applySettingsInputsToActiveScope = () => {
        const tab = getTabData();
        const scope = getActiveScope();
        const activeSettings = getActiveSettings();
        if (!tab || !activeSettings) return;

        activeSettings.exchangeRate = Number(
          roundToStep(Math.max(0.01, toPositive(exchangeRateInput.value, activeSettings.exchangeRate || 0.01)), 0.01).toFixed(2)
        );
        activeSettings.shippingFeeKrw = Math.max(
          0,
          Math.round(roundToStep(toPositive(shippingFeeInput.value, activeSettings.shippingFeeKrw || 0), 1000))
        );
        activeSettings.updatedAt = new Date().toISOString();

        const mode = getScopeMode(activeTabKey);
        const nextScopeDate = normalizeDate(scopeDateInput.value || '');
        if (nextScopeDate && scope) {
          ensureScopeSettings(scope, mode);
          scope.settings.baseDate = nextScopeDate;
          scope.date = nextScopeDate;
          if (mode === 'date') {
            scope.name = nextScopeDate;
          }
        }

        dirty = true;
      };

      exchangeRateInput?.addEventListener('input', () => {
        applySettingsInputsToActiveScope();
        renderGlobalFields();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      shippingFeeInput?.addEventListener('input', () => {
        applySettingsInputsToActiveScope();
        renderGlobalFields();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      scopeDateInput?.addEventListener('change', () => {
        applySettingsInputsToActiveScope();
        renderGlobalFields();
        renderScopeControls();
        renderTableRows();
        renderSummary();
        renderMeta();
      });

      applyGlobalBtn?.addEventListener('click', () => {
        applySettingsInputsToActiveScope();
        void saveWorkbook();
      });

      saveBtn?.addEventListener('click', () => {
        void saveWorkbook();
      });

      fxSyncBtn?.addEventListener('click', async () => {
        clearError();
        try {
          const requestBody = {
            tabKey: activeTabKey,
            scopeId: activeScopeId || '',
            scopeDate:
              normalizeDate(scopeDateInput.value || '') ||
              normalizeDate(getActiveScope()?.settings?.baseDate || getActiveScope()?.date || '')
          };
          const response = await fetch('/admin/sales/fx-sync', {
            method: 'POST',
            headers: {
              accept: 'application/json',
              'content-type': 'application/json'
            },
            body: JSON.stringify(requestBody)
          });
          const payload = await response.json();
          if (!response.ok || !payload?.ok || !payload?.workbook) {
            throw new Error(payload?.message || (isEn ? 'FX sync failed.' : '환율 자동 반영 실패'));
          }
          workbook = payload.workbook;
          dirty = false;
          ensureActiveScope();
          renderGlobalFields();
          renderScopeControls();
          renderTableRows();
          renderSummary();
          renderMeta(isEn ? 'Naver/Hana rate applied' : '네이버/하나은행 환율 반영됨');
        } catch (error) {
          showError(error instanceof Error ? error.message : (isEn ? 'Unknown error' : '알 수 없는 오류'));
        }
      });

      void loadWorkbook();
    })();
  </script>
  <% } else { %>
  <article class="block-card sales-daily-card">
    <h3><%= isEn ? 'Daily Total Sales' : '날짜별 전체 매출' %></h3>
    <p class="muted-label">
      <%= isEn ? 'Automatically recorded from shop orders. Columns show sales/cost/margin/real margin by shop category and overall total.' : '쇼핑몰 주문건 기준으로 자동 기록됩니다. 쇼핑몰별 매출/원가/마진/실제마진과 전체 합계를 날짜별로 확인할 수 있습니다.' %>
    </p>

    <form method="get" action="/admin/sales" class="form-grid compact sales-daily-filter-form">
      <input type="hidden" name="section" value="daily" />
      <label>
        <span><%= isEn ? 'Shop Category' : '쇼핑몰 분류' %></span>
        <select name="salesGroup">
          <option value="all" <%= activeSalesGroupFilter === 'all' ? 'selected' : '' %>><%= isEn ? 'All' : '전체' %></option>
          <% productGroupKeys.forEach((groupKey) => { %>
            <option value="<%= groupKey %>" <%= activeSalesGroupFilter === groupKey ? 'selected' : '' %>><%= groupLabelByKey[groupKey] || groupKey %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <span><%= isEn ? 'From' : '시작일' %></span>
        <input type="date" name="salesDateFrom" value="<%= activeSalesDateFrom %>" />
      </label>
      <label>
        <span><%= isEn ? 'To' : '종료일' %></span>
        <input type="date" name="salesDateTo" value="<%= activeSalesDateTo %>" />
      </label>
      <div class="admin-field-chip-row">
        <button type="submit" class="chip dark"><%= isEn ? 'Search' : '조회' %></button>
        <a href="/admin/sales?section=daily" class="chip"><%= isEn ? 'Reset' : '초기화' %></a>
      </div>
    </form>

    <div class="sales-daily-summary-grid">
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Order Count' : '주문건' %></h4>
        <strong><%= salesDaily.totals.orderCount %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Sales' : '전체 매출' %></h4>
        <strong><%= formatPrice(salesDaily.totals.salesKrw) %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Cost' : '전체 원가' %></h4>
        <strong><%= formatPrice(salesDaily.totals.costKrw) %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Margin' : '전체 마진' %></h4>
        <strong><%= formatPrice(salesDaily.totals.marginKrw) %></strong>
      </article>
      <article class="sales-summary-card">
        <h4><%= isEn ? 'Total Real Margin' : '전체 실제마진' %></h4>
        <strong><%= formatPrice(salesDaily.totals.realMarginKrw) %></strong>
      </article>
    </div>

    <div class="table-wrap sales-daily-table-wrap">
      <table class="sales-daily-table">
        <thead>
          <tr>
            <th><%= isEn ? 'Date' : '날짜' %></th>
            <% salesDaily.groups.forEach((group) => { %>
              <th><%= group.label %></th>
            <% }) %>
            <th><%= isEn ? 'Total' : '전체' %></th>
          </tr>
        </thead>
        <tbody>
          <% salesDaily.rows.forEach((row) => { %>
            <tr>
              <td>
                <strong><%= row.date %></strong>
                <small class="muted-label"><%= isEn ? `Orders ${row.total.orderCount}` : `주문 ${row.total.orderCount}건` %></small>
              </td>
              <% salesDaily.groups.forEach((group) => { const metrics = row.metricsByGroup[group.key] || { orderCount: 0, salesKrw: 0, costKrw: 0, marginKrw: 0, realMarginKrw: 0 }; %>
                <td>
                  <div class="sales-daily-metric-cell">
                    <small><%= isEn ? 'Orders' : '주문건' %> <strong><%= metrics.orderCount %></strong></small>
                    <small><%= isEn ? 'Sales' : '매출' %> <strong><%= formatPrice(metrics.salesKrw) %></strong></small>
                    <small><%= isEn ? 'Cost' : '원가' %> <strong><%= formatPrice(metrics.costKrw) %></strong></small>
                    <small><%= isEn ? 'Margin' : '마진' %> <strong><%= formatPrice(metrics.marginKrw) %></strong></small>
                    <small><%= isEn ? 'Real Margin' : '실제마진' %> <strong><%= formatPrice(metrics.realMarginKrw) %></strong></small>
                  </div>
                </td>
              <% }) %>
              <td>
                <div class="sales-daily-metric-cell total">
                  <small><%= isEn ? 'Orders' : '주문건' %> <strong><%= row.total.orderCount %></strong></small>
                  <small><%= isEn ? 'Sales' : '매출' %> <strong><%= formatPrice(row.total.salesKrw) %></strong></small>
                  <small><%= isEn ? 'Cost' : '원가' %> <strong><%= formatPrice(row.total.costKrw) %></strong></small>
                  <small><%= isEn ? 'Margin' : '마진' %> <strong><%= formatPrice(row.total.marginKrw) %></strong></small>
                  <small><%= isEn ? 'Real Margin' : '실제마진' %> <strong><%= formatPrice(row.total.realMarginKrw) %></strong></small>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (salesDaily.rows.length === 0) { %>
            <tr>
              <td colspan="<%= salesDaily.groups.length + 2 %>">
                <span class="muted-label"><%= isEn ? 'No daily sales records found for this filter.' : '조건에 맞는 날짜별 매출 기록이 없습니다.' %></span>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </article>
  <% } %>
  <% } %>
  <% if (tab === 'inquiries') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Inquiry Answer Management' : '문의 답변 관리' %></h3>
    <div class="security-subnav">
      <a href="/admin/inquiries?section=reply" class="menu-pill <%= inquiriesTab === 'reply' ? 'active' : '' %>"><%= isEn ? 'Reply Queue' : '답변 등록' %></a>
      <a href="/admin/inquiries?section=list" class="menu-pill <%= inquiriesTab === 'list' ? 'active' : '' %>"><%= isEn ? 'Inquiry List' : '문의 목록 관리' %></a>
    </div>

    <% if (inquiriesTab === 'reply') { %>
      <% const replyTargets = inquiries.filter((item) => !String(item.reply_content || '').trim()); %>
      <div class="admin-list">
        <% replyTargets.forEach((item) => { %>
          <div class="inquiry-admin-item">
            <strong><%= item.title %></strong>
            <p><%= isEn ? 'Writer' : '작성자' %>: <%= item.username %></p>
            <p><%= isEn ? 'Created' : '작성일' %>: <%= item.created_at ? item.created_at.slice(0, 16) : '-' %></p>
            <p><%= isEn ? 'Content' : '내용' %>: <%= item.content %></p>
            <% if (item.image_path) { %>
              <img src="<%= item.image_path %>" alt="<%= item.title %>" class="inline-file-preview-image zoomable-media" data-lightbox-enabled="1" />
            <% } %>
            <form method="post" action="/admin/inquiry/<%= item.id %>/reply" class="form-grid">
              <label><%= isEn ? 'Reply' : '답변' %>
                <textarea name="replyContent" rows="3" required></textarea>
              </label>
              <button type="submit" class="chip dark"><%= isEn ? 'Save Reply' : '답변 저장' %></button>
            </form>
          </div>
        <% }) %>
        <% if (replyTargets.length === 0) { %>
          <p class="muted-label"><%= isEn ? 'No pending inquiries for reply.' : '답변 대기 중인 문의가 없습니다.' %></p>
        <% } %>
      </div>
    <% } else { %>
      <div class="admin-list">
        <% inquiries.forEach((item) => { %>
          <details class="admin-list-item">
            <summary>
              <strong><%= item.title %></strong>
              <small><%= isEn ? 'Writer' : '작성자' %>: <%= item.username %></small>
              <small><%= item.created_at ? item.created_at.slice(0, 16) : '-' %></small>
              <small><%= Number(item.is_hidden || 0) === 1 ? (isEn ? 'Hidden' : '숨김') : (isEn ? 'Visible' : '노출중') %></small>
            </summary>
            <form method="post" action="/admin/inquiry/<%= item.id %>/update" enctype="multipart/form-data" class="form-grid compact">
              <label><span><%= isEn ? 'Title' : '제목' %></span>
                <input type="text" name="title" value="<%= item.title %>" required />
              </label>
              <label><span><%= isEn ? 'Content' : '내용' %></span>
                <textarea name="content" rows="3" required><%= item.content %></textarea>
              </label>
              <label><span><%= isEn ? 'Reply' : '답변' %></span>
                <textarea name="replyContent" rows="3"><%= item.reply_content || '' %></textarea>
              </label>
              <label><span><%= isEn ? 'Replace Image' : '이미지 교체' %></span>
                <input type="file" name="image" accept="image/*" />
              </label>
              <% if (item.image_path) { %>
                <img src="<%= item.image_path %>" alt="<%= item.title %>" class="inline-file-preview-image zoomable-media" data-lightbox-enabled="1" />
              <% } %>
              <div class="admin-field-chip-row">
                <button type="submit" class="chip dark"><%= isEn ? 'Save' : '수정 저장' %></button>
              </div>
            </form>
            <div class="admin-field-chip-row">
              <form method="post" action="/admin/inquiry/<%= item.id %>/toggle" class="inline-form">
                <button type="submit" class="chip"><%= Number(item.is_hidden || 0) === 1 ? (isEn ? 'Show' : '표시') : (isEn ? 'Hide' : '숨김') %></button>
              </form>
              <form method="post" action="/admin/inquiry/<%= item.id %>/delete" class="inline-form">
                <button type="submit" class="chip" onclick="return confirm('<%= isEn ? 'Delete this inquiry?' : '이 문의 항목을 삭제할까요?' %>');"><%= isEn ? 'Delete' : '삭제' %></button>
              </form>
            </div>
          </details>
        <% }) %>
        <% if (inquiries.length === 0) { %>
          <p class="muted-label"><%= isEn ? 'No inquiries found.' : '문의 항목이 없습니다.' %></p>
        <% } %>
      </div>
    <% } %>
  </article>
  <% } %>
</section>

<%- include('partials/layout-end') %>
