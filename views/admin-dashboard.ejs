                          const brandModels = matchedBrandKey && Array.isArray(modelFilterMap[matchedBrandKey])
                            ? modelFilterMap[matchedBrandKey]
                            : [];
                          const brandLabelMap = group.brandOptionLabels && typeof group.brandOptionLabels === 'object' && !Array.isArray(group.brandOptionLabels)
                            ? group.brandOptionLabels
                            : {};
                          const modelLabelMapByBrand = group.modelOptionLabelsByBrand && typeof group.modelOptionLabelsByBrand === 'object' && !Array.isArray(group.modelOptionLabelsByBrand)
                            ? group.modelOptionLabelsByBrand
                            : {};
                          const matchedBrandModelLabelKey = Object.keys(modelLabelMapByBrand).find(
                            (optionValue) => String(optionValue || '').trim().toLowerCase() === String(brandOption || '').trim().toLowerCase()
                          );
                          const brandModelLabelMap =
                            matchedBrandModelLabelKey &&
                            modelLabelMapByBrand[matchedBrandModelLabelKey] &&
                            typeof modelLabelMapByBrand[matchedBrandModelLabelKey] === 'object' &&
                            !Array.isArray(modelLabelMapByBrand[matchedBrandModelLabelKey])
                              ? modelLabelMapByBrand[matchedBrandModelLabelKey]
                              : {};
                          const brandLabelEntry = resolveFilterLabelEntry(brandLabelMap, brandOption);
                          const brandDisplayName = isEn ? (brandLabelEntry.labelEn || brandOption) : (brandLabelEntry.labelKo || brandOption);
                        %>
                        <details class="admin-list-item menu-brand-model-item">
                          <summary class="menu-brand-model-summary">
                            <strong><%= brandDisplayName %></strong>
                            <small><%= isEn ? `${brandModels.length} models` : `모델 ${brandModels.length}개` %></small>
