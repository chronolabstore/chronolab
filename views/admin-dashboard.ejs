                  <small>-</small>
                <% } %>
              </td>
              <td>
                <div class="admin-order-actions">
                  <% if (item.status_code === 'PENDING_REVIEW') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/confirm" class="inline-form">
                      <button type="submit" class="chip dark"><%= isEn ? 'Confirm Payment' : '입금확인' %></button>
                    </form>
                  <% } else if (item.status_code === 'ORDER_CONFIRMED') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/ready" class="inline-form">
                      <button type="submit" class="chip dark"><%= isEn ? 'Mark Preparing' : '출고중 처리' %></button>
                    </form>
                  <% } else if (item.status_code === 'READY_TO_SHIP') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/start-shipping" class="form-grid compact">
                      <label>
                        <span><%= isEn ? 'Carrier' : '택배사' %></span>
                        <select name="trackingCarrier" required>
                          <% trackingCarriers.forEach((carrier) => { %>
                            <option value="<%= carrier.id %>" <%= item.tracking_carrier === carrier.id ? 'selected' : '' %>><%= carrier.label %></option>
                          <% }) %>
                        </select>
                      </label>
                      <label>
                        <span><%= isEn ? 'Tracking No.' : '송장번호' %></span>
                        <input type="text" name="trackingNumber" value="<%= item.tracking_number || '' %>" required />
                      </label>
                      <button type="submit" class="chip dark"><%= isEn ? 'Register Tracking & Start Shipping' : '송장등록(배송시작)' %></button>
                    </form>
                  <% } else if (item.status_code === 'SHIPPING') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/update-tracking" class="form-grid compact">
                      <label>
                        <span><%= isEn ? 'Carrier' : '택배사' %></span>
                        <select name="trackingCarrier" required>
                          <% trackingCarriers.forEach((carrier) => { %>
                            <option value="<%= carrier.id %>" <%= item.tracking_carrier === carrier.id ? 'selected' : '' %>><%= carrier.label %></option>
                          <% }) %>
                        </select>
                      </label>
                      <label>
                        <span><%= isEn ? 'Tracking No.' : '송장번호' %></span>
                        <input type="text" name="trackingNumber" value="<%= item.tracking_number || '' %>" required />
                      </label>
                      <button type="submit" class="chip"><%= isEn ? 'Update Tracking' : '송장 수정' %></button>
                    </form>
                    <form method="post" action="/admin/order/<%= item.id %>/sync-tracking" class="inline-form">
                      <button type="submit" class="chip"><%= isEn ? 'Sync Tracking' : '송장 상태 조회' %></button>
                    </form>
                    <form method="post" action="/admin/order/<%= item.id %>/mark-delivered" class="inline-form">
                      <button type="submit" class="chip"><%= isEn ? 'Mark Delivered' : '수동 배송완료' %></button>
                    </form>
                    <small class="muted-label"><%= isEn ? 'Auto delivery sync enabled.' : '배송완료 자동 반영 활성화됨' %></small>
                  <% } else { %>
                    <span class="muted-label"><%= isEn ? 'Done' : '완료' %></span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="5">
                <span class="muted-label"><%= isEn ? 'No orders found in this category.' : '해당 분류의 주문이 없습니다.' %></span>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </article>
  <% } %>

