        scopeControls.appendChild(action);
      };

      const saveWorkbook = async (options = {}) => {
        const silent = options?.silent === true;
        const reasonText = String(options?.reason || '').trim();
        if (!workbook) return;
        if (saveInFlight) {
          saveQueued = true;
          return;
        }
        if (autoSaveTimer) {
          clearTimeout(autoSaveTimer);
          autoSaveTimer = null;
        }
        if (!silent) {
          clearError();
        }
        saveInFlight = true;
        try {
          const response = await fetch('/admin/sales/workbook', {
            method: 'POST',
            headers: {
              'content-type': 'application/json',
              accept: 'application/json'
            },
            body: JSON.stringify({ workbook })
          });
          const payload = await response.json();
          if (!response.ok || !payload?.ok || !payload?.workbook) {
            throw new Error(payload?.message || (isEn ? 'Save failed.' : '저장 실패'));
          }
          workbook = payload.workbook;
          dirty = false;
          if (silent) {
            renderMeta(reasonText || (isEn ? 'auto-saved' : '자동 저장됨'));
          } else {
            ensureActiveScope();
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            if (reasonText) {
              renderMeta(reasonText);
            } else {
              renderMeta(isEn ? 'saved' : '저장됨');
            }
          }
        } catch (error) {
          showError(error instanceof Error ? error.message : (isEn ? 'Unknown error' : '알 수 없는 오류'));
        } finally {
          saveInFlight = false;
          if (saveQueued && dirty) {
            saveQueued = false;
            void saveWorkbook({
              silent: true,
              reason: isEn ? 'auto-saved (queued)' : '자동 저장됨 (대기 반영)'
            });
          } else {
            saveQueued = false;
          }
        }
      };

      const queueAutoSave = (reason = '') => {
        if (!isPriceTableActive() || !dirty || !workbook) {
          return;
        }
        if (autoSaveTimer) {
          clearTimeout(autoSaveTimer);
        }
        autoSaveTimer = setTimeout(() => {
          autoSaveTimer = null;
          if (!dirty) return;
          void saveWorkbook({
            silent: true,
            reason: reason || (isEn ? 'auto-saved' : '자동 저장됨')
          });
        }, AUTO_SAVE_DELAY_MS);
      };

      const flushAutoSaveNow = (reason = '') => {
        if (autoSaveTimer) {
          clearTimeout(autoSaveTimer);
          autoSaveTimer = null;
        }
        if (!dirty || !workbook) return;
        void saveWorkbook({
          silent: true,
          reason: reason || (isEn ? 'auto-saved' : '자동 저장됨')
        });
      };

      const markDirty = (reason = '') => {
        dirty = true;
        if (isPriceTableActive()) {
          queueAutoSave(reason);
        }
      };

