            <div class="admin-field-chip-row">
              <% productBadgeList.forEach((badge) => { %>
                <label class="check-chip product-badge-check-chip">
                  <input type="checkbox" name="badgeIds" value="<%= badge.id %>" <%= editingBadgeIdSet.has(Number(badge.id)) ? 'checked' : '' %> />
                  <span><%= isEn ? (badge.label_en || badge.label_ko) : (badge.label_ko || badge.label_en) %></span>
                </label>
              <% }) %>
            </div>
            <p class="muted-label"><%= isEn ? 'Checked badges are shown on the shop listing, main 4-item blocks, and product detail.' : '체크한 배지는 쇼핑몰 목록, 메인 4개 노출 카드, 상품 상세에 함께 표시됩니다.' %></p>
          </div>
        <% } else { %>
          <p class="muted-label"><%= isEn ? 'No badge definitions yet. Create badges in Badge Settings.' : '등록된 배지가 없습니다. 배지 설정에서 먼저 생성해 주세요.' %></p>
