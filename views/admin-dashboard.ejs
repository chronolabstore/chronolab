          <small class="muted-label"><%= isEn ? 'All uploaded images are automatically watermarked with "Chrono Lab".' : '업로드된 모든 이미지는 자동으로 "Chrono Lab" 워터마크가 적용됩니다.' %></small>
        </label>
        <div class="watermark-preview-wrap" data-image-watermark-preview hidden>
          <p class="muted-label"><%= isEn ? 'Preview with watermark applied before upload' : '업로드 전 워터마크 적용 미리보기' %></p>
          <p class="muted-label"><%= isEn ? 'Drag images to change order. Number 1 becomes the first image.' : '이미지를 드래그해 순서를 바꿀 수 있습니다. 1번 이미지가 대표 순서입니다.' %></p>
          <div class="watermark-preview-grid" data-image-watermark-preview-grid></div>
        </div>

        <% if (editingItem && editingItem.imageList && editingItem.imageList.length > 0) { %>
          <div class="admin-field-chip-row">
            <% editingItem.imageList.forEach((src) => { %>
              <span class="chip"><a href="<%= src %>" target="_blank" rel="noreferrer"><%= isEn ? 'Current Image' : '현재 이미지' %></a></span>
            <% }) %>
          </div>
        <% } %>

        <input type="hidden" name="categoryGroup" value="<%= uploadActiveGroupKey %>" data-admin-product-group-input />
        <div class="filter-group">
          <h4><%= isEn ? 'Upload Category' : '업로드 분류 선택' %></h4>
          <div class="chip-row" data-admin-product-group-btn-wrap>
            <% productGroupKeys.forEach((groupName) => { %>
              <button type="button" class="chip filter-chip <%= uploadActiveGroupKey === groupName ? 'dark' : '' %>" data-admin-product-group-btn="<%= groupName %>"><%= groupLabelByKey[groupName] || groupName %></button>
            <% }) %>
          </div>
        </div>

        <p class="muted-label"><%= isEn ? 'Each category has its own upload field set. Field setup is managed in Menu Manager > Upload Fields.' : '분류별 업로드 항목이 다릅니다. 항목 설정은 메뉴관리 > 업로드 항목에서 수정할 수 있습니다.' %></p>

        <% productGroupConfigList.forEach((group) => { %>
          <div class="product-simple-fields" data-admin-product-fields="<%= group.key %>" <%= uploadActiveGroupKey === group.key ? '' : 'hidden' %>>
            <h4><%= group.labelKo || group.key %> / <%= group.labelEn || group.key %></h4>
            <%
              const groupBrandOptions = Array.isArray(group.brandOptions) ? group.brandOptions : [];
              const groupFactoryOptions = Array.isArray(group.factoryOptions) ? group.factoryOptions : [];
              const groupModelOptions = Array.isArray(group.modelOptions) ? group.modelOptions : [];
              const groupBrandLabelMap =
                group.brandOptionLabels && typeof group.brandOptionLabels === 'object' && !Array.isArray(group.brandOptionLabels)
                  ? group.brandOptionLabels
                  : {};
              const groupFactoryLabelMap =
                group.factoryOptionLabels && typeof group.factoryOptionLabels === 'object' && !Array.isArray(group.factoryOptionLabels)
                  ? group.factoryOptionLabels
                  : {};
              const rawGroupModelLabelMapByBrand =
                group.modelOptionLabelsByBrand && typeof group.modelOptionLabelsByBrand === 'object' && !Array.isArray(group.modelOptionLabelsByBrand)
                  ? group.modelOptionLabelsByBrand
                  : {};
              const rawGroupModelOptionMap =
                group.modelOptionsByBrand && typeof group.modelOptionsByBrand === 'object' && !Array.isArray(group.modelOptionsByBrand)
                  ? group.modelOptionsByBrand
                  : {};
              const groupModelOptionMap = {};
              Object.entries(rawGroupModelOptionMap).forEach(([brandName, modelList]) => {
                const safeBrandName = String(brandName || '').trim();
                if (!safeBrandName) return;
                const normalizedModels = [];
                const seenModels = new Set();
                (Array.isArray(modelList) ? modelList : []).forEach((value) => {
                  const safeValue = String(value || '').trim();
                  if (!safeValue) return;
                  const dedupeKey = safeValue.toLowerCase();
                  if (seenModels.has(dedupeKey)) return;
                  seenModels.add(dedupeKey);
                  normalizedModels.push(safeValue);
                });
                if (normalizedModels.length > 0) {
                  groupModelOptionMap[safeBrandName] = normalizedModels;
                }
              });
              const groupModelLabelMapByBrand = {};
              Object.entries(rawGroupModelLabelMapByBrand).forEach(([brandName, modelLabelMap]) => {
                const safeBrandName = String(brandName || '').trim();
                if (!safeBrandName || !modelLabelMap || typeof modelLabelMap !== 'object' || Array.isArray(modelLabelMap)) return;
                groupModelLabelMapByBrand[safeBrandName] = modelLabelMap;
              });
              const groupHasModelOptionMap = Object.keys(groupModelOptionMap).length > 0;
              const supportsFactorySelectionGroup =
                String(group.mode || '').toLowerCase() === 'factory' ||
                String(group.key || '').trim() === '공장제' ||
                String(group.key || '').trim() === '현지중고' ||
                groupFactoryOptions.length > 0;
              const editBrandValue =
                editingItem && editingItem.category_group === group.key ? String(editingItem.brand || '').trim() : '';
              const editFactoryValue =
                editingItem && editingItem.category_group === group.key ? String(editingItem.factory_name || '').trim() : '';
              const editModelValue =
                editingItem && editingItem.category_group === group.key ? String(editingItem.model || '').trim() : '';
              const resolvedBrandOptions = (() => {
                const list = [];
                const seen = new Set();
                [...groupBrandOptions, editBrandValue].forEach((value) => {
                  const safeValue = String(value || '').trim();
                  if (!safeValue) return;
                  const dedupeKey = safeValue.toLowerCase();
                  if (seen.has(dedupeKey)) return;
                  seen.add(dedupeKey);
                  list.push(safeValue);
                });
                return list;
              })();
              const resolvedFactoryOptions = (() => {
                const list = [];
                const seen = new Set();
                [...groupFactoryOptions, editFactoryValue].forEach((value) => {
                  const safeValue = String(value || '').trim();
                  if (!safeValue) return;
                  const dedupeKey = safeValue.toLowerCase();
                  if (seen.has(dedupeKey)) return;
                  seen.add(dedupeKey);
                  list.push(safeValue);
                });
                return list;
              })();
              const resolvedModelOptions = (() => {
                const list = [];
                const seen = new Set();
                const seededOptions = (() => {
                  if (!groupHasModelOptionMap) {
                    return groupModelOptions;
                  }
                  if (!editBrandValue) {
                    return [];
                  }
                  const matchedBrandKey = Object.keys(groupModelOptionMap).find(
                    (optionValue) => String(optionValue || '').trim().toLowerCase() === editBrandValue.toLowerCase()
                  );
                  if (!matchedBrandKey) {
                    return [];
                  }
                  return Array.isArray(groupModelOptionMap[matchedBrandKey]) ? groupModelOptionMap[matchedBrandKey] : [];
                })();
                [...seededOptions, editModelValue].forEach((value) => {
                  const safeValue = String(value || '').trim();
                  if (!safeValue) return;
                  const dedupeKey = safeValue.toLowerCase();
                  if (seen.has(dedupeKey)) return;
                  seen.add(dedupeKey);
                  list.push(safeValue);
                });
                return list;
              })();
              const initialModelLabelMap = (() => {
                if (!editBrandValue) {
                  return {};
                }
                const matchedBrandLabelKey = findFilterMapKey(groupModelLabelMapByBrand, editBrandValue);
                if (!matchedBrandLabelKey) {
                  return {};
                }
                const source = groupModelLabelMapByBrand[matchedBrandLabelKey];
                return source && typeof source === 'object' && !Array.isArray(source) ? source : {};
              })();
              const shouldUseModelSelect = groupHasModelOptionMap || resolvedModelOptions.length > 0;
            %>
            <label>
              <%= isEn ? 'Brand Filter' : '브랜드 필터' %>
              <select
                name="selectedBrandOption"
                data-admin-field-input
                data-group="<%= group.key %>"
                data-required="<%= resolvedBrandOptions.length > 0 ? '1' : '0' %>"
              >
                <option value=""><%= resolvedBrandOptions.length > 0 ? (isEn ? 'Select Brand' : '브랜드 선택') : (isEn ? 'No brand options' : '등록된 브랜드 옵션 없음') %></option>
                <% resolvedBrandOptions.forEach((optionValue) => { %>
                  <option value="<%= optionValue %>" <%= editBrandValue === optionValue ? 'selected' : '' %>><%= resolveFilterLabelByValue(groupBrandLabelMap, optionValue) %></option>
                <% }) %>
              </select>
            </label>

            <% if (supportsFactorySelectionGroup) { %>
              <label>
                <%= isEn ? 'Factory Filter' : '공장 필터' %>
                <select
                  name="selectedFactoryOption"
                  data-admin-field-input
                  data-group="<%= group.key %>"
                  data-required="<%= resolvedFactoryOptions.length > 0 ? '1' : '0' %>"
                >
                  <option value=""><%= resolvedFactoryOptions.length > 0 ? (isEn ? 'Select Factory' : '공장 선택') : (isEn ? 'No factory options' : '등록된 공장 옵션 없음') %></option>
                  <% resolvedFactoryOptions.forEach((optionValue) => { %>
                    <option value="<%= optionValue %>" <%= editFactoryValue === optionValue ? 'selected' : '' %>><%= resolveFilterLabelByValue(groupFactoryLabelMap, optionValue) %></option>
                  <% }) %>
                </select>
              </label>
            <% } %>

            <label>
              <%= isEn ? 'Model Filter' : '모델 필터' %>
              <select
                name="selectedModelOption"
                data-admin-field-input
                data-group="<%= group.key %>"
                data-required="<%= resolvedModelOptions.length > 0 ? '1' : '0' %>"
                data-has-model-map="<%= groupHasModelOptionMap ? '1' : '0' %>"
                data-initial-model-value="<%= editModelValue %>"
              >
                <option value="">
                  <%= groupHasModelOptionMap
                    ? (editBrandValue
                        ? (resolvedModelOptions.length > 0 ? (isEn ? 'Select Model' : '모델 선택') : (isEn ? 'No model options for this brand' : '이 브랜드에 등록된 모델 옵션 없음'))
                        : (isEn ? 'Select brand first' : '브랜드를 먼저 선택하세요'))
                    : (shouldUseModelSelect ? (isEn ? 'Select Model' : '모델 선택') : (isEn ? 'No model options' : '등록된 모델 옵션 없음')) %>
                </option>
                <% resolvedModelOptions.forEach((optionValue) => { %>
                  <option value="<%= optionValue %>" <%= editModelValue === optionValue ? 'selected' : '' %>><%= resolveFilterLabelByValue(initialModelLabelMap, optionValue) %></option>
                <% }) %>
              </select>
            </label>

            <% if (!group.customFields || group.customFields.length === 0) { %>
              <p class="muted-label"><%= isEn ? 'No fields configured. Add fields in Menu Manager.' : '설정된 업로드 항목이 없습니다. 메뉴관리에서 항목을 추가해 주세요.' %></p>
            <% } %>
            <% (group.customFields || []).forEach((field) => { %>
              <%
                const key = field.key;
                if (key === 'brand' || key === 'factory_name' || (key === 'model' && shouldUseModelSelect)) {
                  return;
                }
                const value =
                  editingItem && editingItem.category_group === group.key && editingItem.fieldValues
                    ? (editingItem.fieldValues[key] || '')
                    : '';
              %>
              <label>
                <%= isEn ? (field.labelEn || field.labelKo || key) : (field.labelKo || field.labelEn || key) %>
                <% if (field.type === 'textarea') { %>
                  <textarea name="fieldValues[<%= key %>]" rows="3" data-admin-field-input data-group="<%= group.key %>" data-required="<%= field.required ? '1' : '0' %>"><%= value %></textarea>
                <% } else { %>
                  <input type="<%= field.type === 'number' ? 'number' : 'text' %>" name="fieldValues[<%= key %>]" value="<%= value %>" data-admin-field-input data-group="<%= group.key %>" data-required="<%= field.required ? '1' : '0' %>" />
                <% } %>
              </label>
            <% }) %>
          </div>
        <% }) %>

        <% if (productBadgeList.length > 0) { %>
          <div class="filter-group">
            <h4><%= isEn ? 'Product Badges' : '상품 배지' %></h4>
            <div class="admin-field-chip-row">
              <% productBadgeList.forEach((badge) => { %>
                <% const badgeThemeClass = `product-badge-theme-${normalizeBadgeThemeKey(badge.color_theme)}`; %>
                <label class="check-chip product-badge-check-chip">
                  <input type="checkbox" name="badgeIds" value="<%= badge.id %>" <%= editingBadgeIdSet.has(Number(badge.id)) ? 'checked' : '' %> />
                  <span class="product-badge-chip <%= badgeThemeClass %>"><%= isEn ? (badge.label_en || badge.label_ko) : (badge.label_ko || badge.label_en) %></span>
