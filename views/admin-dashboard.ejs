<%- include('partials/layout-start') %>
<%
  const tab = activeTab || 'dashboard';
  const isEn = ctx.lang === 'en';
  const productGroupConfigList = Array.isArray(productGroupConfigs) ? productGroupConfigs : [];
  const productGroupKeys = Array.isArray(productGroups) && productGroups.length > 0
    ? productGroups
    : productGroupConfigList.map((group) => group.key);
  const groupLabelByKey = (() => {
    if (groupLabelMap && typeof groupLabelMap === 'object' && !Array.isArray(groupLabelMap)) {
      return groupLabelMap;
    }
    const generated = {};
    productGroupConfigList.forEach((group) => {
      generated[group.key] = isEn ? (group.labelEn || group.key) : (group.labelKo || group.key);
    });
    return generated;
  })();
  const normalizeFilterValue = (value) =>
    String(value || '')
      .trim()
      .replace(/\s+/g, ' ')
      .slice(0, 80);
  const findFilterMapKey = (map, rawValue) => {
    if (!map || typeof map !== 'object' || Array.isArray(map)) return '';
    const needle = normalizeFilterValue(rawValue).toLowerCase();
    if (!needle) return '';
    return (
      Object.keys(map).find((key) => normalizeFilterValue(key).toLowerCase() === needle) || ''
    );
  };
  const resolveFilterLabelEntry = (map, rawValue) => {
    const fallback = normalizeFilterValue(rawValue);
    const matchedKey = findFilterMapKey(map, rawValue);
    const source =
      matchedKey &&
      map[matchedKey] &&
      typeof map[matchedKey] === 'object' &&
      !Array.isArray(map[matchedKey])
        ? map[matchedKey]
        : null;
    const labelKo = normalizeFilterValue(source?.labelKo || source?.label_ko || source?.ko || source?.label || fallback);
    const labelEn = normalizeFilterValue(source?.labelEn || source?.label_en || source?.en || source?.label || fallback);
    return {
      labelKo: labelKo || fallback,
      labelEn: labelEn || fallback
    };
  };
  const resolveFilterLabelByValue = (map, rawValue) => {
    const entry = resolveFilterLabelEntry(map, rawValue);
    return isEn ? (entry.labelEn || entry.labelKo || normalizeFilterValue(rawValue)) : (entry.labelKo || entry.labelEn || normalizeFilterValue(rawValue));
  };
  const defaultGroupKey = productGroupKeys[0] || '공장제';
  const activeOrderFilterKey = (() => {
    const candidate = String(orderGroupFilter || 'all');
    if (candidate === 'all') return 'all';
    return productGroupKeys.includes(candidate) ? candidate : 'all';
  })();
  const activeOrderStatusFilterKey = (() => {
    const candidate = String(orderStatusFilter || 'all').toUpperCase();
    const supported = ['PENDING_REVIEW', 'ORDER_CONFIRMED', 'READY_TO_SHIP', 'SHIPPING', 'DELIVERED'];
    if (!candidate || candidate === 'ALL') return 'all';
    return supported.includes(candidate) ? candidate : 'all';
  })();
  const orderStatusFilterOptions = [
    { key: 'all', labelKo: '전체', labelEn: 'All' },
    { key: 'PENDING_REVIEW', labelKo: '입금확인중', labelEn: 'Awaiting Payment' },
    { key: 'ORDER_CONFIRMED', labelKo: '입금확인', labelEn: 'Payment Confirmed' },
    { key: 'READY_TO_SHIP', labelKo: '출고완료', labelEn: 'Shipment Complete' },
    { key: 'SHIPPING', labelKo: '배송중', labelEn: 'Shipping' },
    { key: 'DELIVERED', labelKo: '배송완료', labelEn: 'Delivered' }
  ];

  const stats = dashboardStats || {
    users: { active: 0, blocked: 0, total: 0 },
    signupCounts: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    memberVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    guestVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    totalVisits: { today: 0, week: 0, month: 0, year: 0, total: 0 },
    boardCounts: { notice: 0, news: 0, qc: 0, review: 0, inquiry: 0 },
    shopCounts: { total: 0, active: 0, byGroup: [] },
    orderCounts: { total: 0, pendingReview: 0, confirmed: 0, readyToShip: 0, shipping: 0, delivered: 0, byGroup: [] },
    orderAlerts: { stalePending: 0, longShipping: 0 },
    actionItems: { uncheckedOrders: 0, paymentWaiting: 0, pendingInquiries: 0, qcPending: 0, totalUrgent: 0 },
    delayWarnings: { pendingOver24h: 0, confirmedOver48h: 0, readyOver72h: 0, shippingOver7d: 0 },
    inquiryOps: { pending: 0, overdue24h: 0, repliedToday: 0, avgReplyHours: 0 },
    paymentPerformance: {
      todayCount: 0,
      todayAmount: 0,
      weekCount: 0,
      weekAmount: 0,
      monthCount: 0,
      monthAmount: 0,
      totalCount: 0,
      totalAmount: 0,
      confirmRate: 0
    },
    conversionFunnel: {
      windowDays: 30,
      window: { productViews: 0, purchaseViews: 0, orderCreated: 0, paymentConfirmed: 0 },
      total: { productViews: 0, purchaseViews: 0, orderCreated: 0, paymentConfirmed: 0 },
      rates: { viewToPurchase: 0, purchaseToOrder: 0, orderToPayment: 0, viewToPayment: 0 }
    }
  };
  const security = securityPanelData || {
    adminUsers: [],
    subAdminLogs: [],
    securityAlerts: [],
    unresolvedAlertsCount: 0,
    filters: {
      log: { from: '', to: '', adminId: 0 },
      alert: { from: '', to: '', adminId: 0 }
    },
    pagination: {
      log: { page: 1, totalPages: 1, totalCount: 0, pageSize: 20 },
      alert: { page: 1, totalPages: 1, totalCount: 0, pageSize: 20 }
    }
  };
  const memberPanel = memberManagePanelData || {
    members: [],
    filters: { section: 'active', keyword: '' },
    levelConfig: { availableGroups: [], includedGroups: [], rules: [], pointRates: {} },
    levelSummaries: [],
    pagination: { page: 1, totalPages: 1, totalCount: 0, pageSize: 20 }
  };
  const memberLevelConfig = memberPanel.levelConfig || {
    availableGroups: [],
    includedGroups: [],
    rules: [],
    pointRates: {}
  };
  const memberLevelRules = Array.isArray(memberLevelConfig.rules) ? memberLevelConfig.rules : [];
  const memberLevelSummaries = Array.isArray(memberPanel.levelSummaries) ? memberPanel.levelSummaries : [];
  const securityTab = ['profile', 'admins', 'logs', 'alerts'].includes(String(securitySection || ''))
    ? String(securitySection)
    : 'profile';
  const menusTab = ['public', 'groups', 'group-filters', 'fields'].includes(String(menuSection || ''))
    ? String(menuSection)
    : 'public';
  const pointsTab = ['signup', 'level-rates'].includes(String(pointSection || ''))
    ? String(pointSection)
    : 'signup';
  const siteTab = String(siteSection || '') === 'theme' ? 'theme' : 'basic';
  const productsTab = ['upload', 'list', 'badges'].includes(String(productSection || ''))
    ? String(productSection)
    : 'upload';
  const noticesTab = String(noticeSection || '') === 'list' ? 'list' : 'create';
  const newsTab = String(newsSection || '') === 'list' ? 'list' : 'create';
  const qcTab = String(qcSection || '') === 'list' ? 'list' : 'create';
  const inquiriesTab = String(inquirySection || '') === 'list' ? 'list' : 'reply';
  const salesManageTabRaw = String((typeof salesSection === 'undefined' ? '' : salesSection) || '').trim().toLowerCase();
  const salesManageTab =
    salesManageTabRaw === 'daily'
      ? 'daily'
      : (salesManageTabRaw === 'price' ? 'price' : 'editor');
  const salesAllTabs = (() => {
    if (Array.isArray(salesMainTabs) && salesMainTabs.length > 0) {
      return salesMainTabs;
    }
    const fallbackTabs = [
      { key: 'preorder', labelKo: '선주문 정산', labelEn: 'Pre-Order Settlement', scopeType: 'round' }
    ];
    const legacyGroupTabKeyMap = { 공장제: 'factory', 젠파츠: 'genparts', 현지중고: 'used' };
    const legacyPriceTabKeyMap = { 공장제: 'price' };
    const fallbackBaseGroups = [
      { key: '공장제', labelKo: '공장제', labelEn: 'Factory' },
      { key: '젠파츠', labelKo: '젠파츠', labelEn: 'Gen Parts' },
      { key: '현지중고', labelKo: '현지중고', labelEn: 'Local Used' },
      { key: '기타', labelKo: '기타', labelEn: 'Other' }
    ];
    const fallbackGroupMap = new Map();
    const pushFallbackGroup = (group) => {
      const groupKey = String(group?.key || '').trim();
      if (!groupKey || fallbackGroupMap.has(groupKey)) return;
      const labelKo = String(group?.labelKo || groupKey).trim() || groupKey;
      const labelEn = String(group?.labelEn || labelKo).trim() || labelKo;
      fallbackGroupMap.set(groupKey, { key: groupKey, labelKo, labelEn });
    };
    fallbackBaseGroups.forEach((group) => pushFallbackGroup(group));
    productGroupConfigList.forEach((group) => pushFallbackGroup(group));
    const fallbackGroups = [...fallbackGroupMap.values()];
    const usedTabKeys = new Set(fallbackTabs.map((tabInfo) => String(tabInfo.key || '').trim()));

    fallbackGroups.forEach((group, index) => {
      const groupKey = String(group?.key || '').trim();
      if (!groupKey) return;

      const slugBase = groupKey
        .toLowerCase()
        .replace(/[^a-z0-9가-힣]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 48);
      const mappedLegacyKey = legacyGroupTabKeyMap[groupKey] || '';
      const defaultTabKey = mappedLegacyKey || (slugBase ? `group-${slugBase}` : `group-${index + 1}`);
      let nextTabKey = defaultTabKey;
      let suffix = 2;
      while (usedTabKeys.has(nextTabKey)) {
        nextTabKey = `${defaultTabKey}-${suffix}`;
        suffix += 1;
      }
      usedTabKeys.add(nextTabKey);

      const groupLabelKo = String(group?.labelKo || groupKey).trim() || groupKey;
      const groupLabelEn = String(group?.labelEn || groupLabelKo).trim() || groupLabelKo;
      const mappedPriceKey = legacyPriceTabKeyMap[groupKey] || '';
      const defaultPriceTabKey = mappedPriceKey || (slugBase ? `price-${slugBase}` : `price-${index + 1}`);
      let nextPriceTabKey = defaultPriceTabKey;
      let priceSuffix = 2;
      while (usedTabKeys.has(nextPriceTabKey)) {
        nextPriceTabKey = `${defaultPriceTabKey}-${priceSuffix}`;
        priceSuffix += 1;
      }
      usedTabKeys.add(nextPriceTabKey);
      fallbackTabs.push({
        key: nextPriceTabKey,
        labelKo: `${groupLabelKo} 가격표`,
        labelEn: `${groupLabelEn} Price Table`,
        scopeType: 'factory',
        groupKey
      });

      fallbackTabs.push({
        key: nextTabKey,
        labelKo: `${groupLabelKo} 매출`,
        labelEn: `${groupLabelEn} Sales`,
        scopeType: 'date',
        groupKey
      });
    });

    return fallbackTabs;
  })();
  const salesPriceTabs = salesAllTabs.filter((tabInfo) => String(tabInfo?.scopeType || '') === 'factory');
  const salesEditorTabs = salesAllTabs.filter((tabInfo) => String(tabInfo?.scopeType || '') !== 'factory');
  const salesTabs =
    salesManageTab === 'price'
      ? (salesPriceTabs.length > 0 ? salesPriceTabs : salesAllTabs.slice(0, 1))
      : (salesManageTab === 'editor'
          ? (salesEditorTabs.length > 0 ? salesEditorTabs : salesAllTabs)
          : salesAllTabs);
  const salesDaily = salesDailyData || {
    filters: { groupFilter: 'all', dateFrom: '', dateTo: '' },
    groups: [],
    rows: [],
    totals: { orderCount: 0, salesKrw: 0, costKrw: 0, marginKrw: 0, realMarginKrw: 0 }
  };
  const editingItem = editingProduct && typeof editingProduct === 'object' ? editingProduct : null;
  const productBadgeList = Array.isArray(productBadgeDefinitions) ? productBadgeDefinitions : [];
  const productBadgeColorThemeList =
    Array.isArray(productBadgeColorThemes) && productBadgeColorThemes.length > 0
      ? productBadgeColorThemes
      : [
          { key: 'slate', labelKo: '기본', labelEn: 'Default' },
          { key: 'red', labelKo: '레드', labelEn: 'Red' },
          { key: 'blue', labelKo: '블루', labelEn: 'Blue' },
          { key: 'green', labelKo: '그린', labelEn: 'Green' },
          { key: 'amber', labelKo: '앰버', labelEn: 'Amber' },
          { key: 'purple', labelKo: '퍼플', labelEn: 'Purple' }
        ];
  const productBadgeThemeKeySet = new Set(productBadgeColorThemeList.map((item) => String(item.key || '').trim().toLowerCase()).filter(Boolean));
  const normalizeBadgeThemeKey = (value) => {
    const candidate = String(value || '').trim().toLowerCase();
    if (productBadgeThemeKeySet.has(candidate)) return candidate;
    return 'slate';
  };
  const badgeThemeLabel = (themeKey) => {
    const normalized = normalizeBadgeThemeKey(themeKey);
    const matched = productBadgeColorThemeList.find((item) => String(item.key || '').trim().toLowerCase() === normalized);
    if (!matched) return isEn ? 'Default' : '기본';
    return isEn ? (matched.labelEn || matched.labelKo || matched.key) : (matched.labelKo || matched.labelEn || matched.key);
  };
  const editingBadgeIds = Array.isArray(editingItem?.product_badges)
    ? editingItem.product_badges
        .map((badge) => Number.parseInt(String(badge?.id ?? ''), 10))
        .filter((id) => Number.isInteger(id) && id > 0)
    : [];
  const editingBadgeIdSet = new Set(editingBadgeIds);
  const uploadActiveGroupKey =
    String(editingItem?.category_group || productGroupKeys[0] || defaultGroupKey);
  const activeOrderDateFrom = String(orderDateFrom || '');
  const activeOrderDateTo = String(orderDateTo || '');
  const orderDateQuerySuffix = `${activeOrderDateFrom ? `&orderDateFrom=${encodeURIComponent(activeOrderDateFrom)}` : ''}${activeOrderDateTo ? `&orderDateTo=${encodeURIComponent(activeOrderDateTo)}` : ''}`;
  const activeSalesGroupFilter = String(salesGroupFilter || salesDaily.filters?.groupFilter || 'all');
  const activeSalesDateFrom = String(salesDateFrom || salesDaily.filters?.dateFrom || '');
  const activeSalesDateTo = String(salesDateTo || salesDaily.filters?.dateTo || '');
  const salesDateQuerySuffix = `${activeSalesGroupFilter && activeSalesGroupFilter !== 'all' ? `&salesGroup=${encodeURIComponent(activeSalesGroupFilter)}` : ''}${activeSalesDateFrom ? `&salesDateFrom=${encodeURIComponent(activeSalesDateFrom)}` : ''}${activeSalesDateTo ? `&salesDateTo=${encodeURIComponent(activeSalesDateTo)}` : ''}`;
%>

<section class="admin-grid single <%= tab === 'sales' ? 'admin-grid-sales' : '' %>">
  <% if (tab === 'dashboard') { %>
  <article class="block-card">
    <h3><%= isEn ? 'Admin Dashboard' : '관리자 대시보드' %></h3>

    <%
      const orderByGroup = Array.isArray(stats.orderCounts.byGroup) ? stats.orderCounts.byGroup : [];
      const shopByGroup = Array.isArray(stats.shopCounts.byGroup) ? stats.shopCounts.byGroup : [];
      const defaultOrderGroup = orderByGroup.find((item) => item.groupName === defaultGroupKey) || orderByGroup[0] || {
        groupName: defaultGroupKey,
        totalCount: 0,
        pendingReview: 0,
        confirmed: 0,
        readyToShip: 0,
        shipping: 0,
        delivered: 0
      };
      const defaultShopGroup = shopByGroup.find((item) => item.groupName === defaultGroupKey) || shopByGroup[0] || {
        groupName: defaultGroupKey,
        totalCount: 0,
        activeCount: 0,
        hiddenCount: 0
      };
    %>

    <div class="dashboard-group">
      <h4 class="dashboard-group-title"><%= isEn ? 'Members' : '회원' %></h4>
      <div class="dashboard-kpi-grid">
        <div class="kpi-card" data-member-switch-root>
          <div class="kpi-head-row">
            <h4><%= isEn ? 'Members' : '회원 수' %></h4>
            <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'member segment switch' : '회원 구분 전환' %>">
              <button type="button" class="kpi-toggle-btn active" data-member-type="active"><%= isEn ? 'Member' : '회원' %></button>
              <button type="button" class="kpi-toggle-btn" data-member-type="blocked"><%= isEn ? 'Blacklist' : '블랙리스트' %></button>
            </div>
          </div>
          <strong data-member-value><%= stats.users.active %></strong>
          <p class="muted-label" data-member-caption><%= isEn ? 'Active members count.' : '활성 회원 수입니다.' %></p>
          <p class="muted-label"><%= isEn ? `Total members ${stats.users.total}` : `총 회원 ${stats.users.total}` %></p>
        </div>

        <div class="kpi-card">
          <h4><%= isEn ? 'Signup Summary' : '회원가입 집계' %></h4>
          <ul class="metric-list">
            <li><span><%= isEn ? 'Today' : '오늘' %></span><strong><%= stats.signupCounts.today %></strong></li>
            <li><span><%= isEn ? '7 Days' : '일주일' %></span><strong><%= stats.signupCounts.week %></strong></li>
            <li><span><%= isEn ? '30 Days' : '한달' %></span><strong><%= stats.signupCounts.month %></strong></li>
            <li><span><%= isEn ? '1 Year' : '1년' %></span><strong><%= stats.signupCounts.year %></strong></li>
            <li><span><%= isEn ? 'Total' : '총 가입 회원' %></span><strong><%= stats.signupCounts.total %></strong></li>
          </ul>
        </div>

        <div class="kpi-card" data-visit-switch-root>
          <div class="kpi-head-row">
            <h4><%= isEn ? 'Visit Summary' : '방문 집계' %></h4>
            <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'visit segment switch' : '방문 구분 전환' %>">
              <button type="button" class="kpi-toggle-btn active" data-visit-type="member"><%= isEn ? 'Member' : '회원' %></button>
              <button type="button" class="kpi-toggle-btn" data-visit-type="guest"><%= isEn ? 'Guest' : '비회원' %></button>
              <button type="button" class="kpi-toggle-btn" data-visit-type="total"><%= isEn ? 'Total' : '전체' %></button>
            </div>
          </div>
          <p class="muted-label" data-visit-caption><%= isEn ? 'Member visits summary.' : '회원 방문 기준 집계입니다.' %></p>
          <ul class="metric-list">
            <li><span><%= isEn ? 'Today' : '오늘' %></span><strong data-visit-value="today"><%= stats.memberVisits.today %></strong></li>
            <li><span><%= isEn ? '7 Days' : '일주일' %></span><strong data-visit-value="week"><%= stats.memberVisits.week %></strong></li>
            <li><span><%= isEn ? '30 Days' : '한달' %></span><strong data-visit-value="month"><%= stats.memberVisits.month %></strong></li>
            <li><span><%= isEn ? '1 Year' : '1년' %></span><strong data-visit-value="year"><%= stats.memberVisits.year %></strong></li>
            <li><span><%= isEn ? 'Total' : '총' %></span><strong data-visit-value="total"><%= stats.memberVisits.total %></strong></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="dashboard-group">
      <h4 class="dashboard-group-title"><%= isEn ? 'Orders' : '주문' %></h4>
      <div class="dashboard-kpi-grid">
        <div class="kpi-card">
          <h4><%= isEn ? 'Orders Total' : '총 주문건' %></h4>
          <strong><%= stats.orderCounts.total %></strong>
          <p class="muted-label"><%= isEn ? 'Order pipeline summary below.' : '주문 상태 파이프라인은 아래에서 확인하세요.' %></p>
        </div>

        <div class="kpi-card" data-order-switch-root>
          <div class="kpi-head-row">
            <h4><%= isEn ? 'Order Status Summary' : '주문 상태 집계' %></h4>
            <div class="kpi-toggle-row" role="tablist" aria-label="<%= isEn ? 'order group switch' : '주문 분류 전환' %>">
              <% productGroupKeys.forEach((groupName, idx) => { %>
                <button type="button" class="kpi-toggle-btn <%= idx === 0 ? 'active' : '' %>" data-order-group="<%= groupName %>"><%= groupLabelByKey[groupName] || groupName %></button>
              <% }) %>
            </div>
          </div>
          <p class="muted-label" data-order-caption><%= isEn ? `${groupLabelByKey[defaultOrderGroup.groupName] || defaultOrderGroup.groupName} order status summary.` : `${groupLabelByKey[defaultOrderGroup.groupName] || defaultOrderGroup.groupName} 주문 상태 집계입니다.` %></p>
          <ul class="metric-list">
            <li><span><%= isEn ? 'Awaiting Payment Verification' : '입금확인중 주문건' %></span><strong data-order-value="pendingReview"><%= defaultOrderGroup.pendingReview %></strong></li>
            <li><span><%= isEn ? 'Payment Confirmed' : '입금확인 주문건' %></span><strong data-order-value="confirmed"><%= defaultOrderGroup.confirmed %></strong></li>
            <li><span><%= isEn ? 'Shipment Complete' : '출고완료 주문건' %></span><strong data-order-value="readyToShip"><%= defaultOrderGroup.readyToShip %></strong></li>
            <li><span><%= isEn ? 'Shipping' : '배송중 주문건' %></span><strong data-order-value="shipping"><%= defaultOrderGroup.shipping %></strong></li>
            <li><span><%= isEn ? 'Delivered' : '배송완료 주문건' %></span><strong data-order-value="delivered"><%= defaultOrderGroup.delivered %></strong></li>
          </ul>
        </div>

        <div class="kpi-card">
          <h4><%= isEn ? 'Today Action Queue' : '오늘 우선 처리' %></h4>
          <strong><%= Number(stats.actionItems.totalUrgent || 0).toLocaleString() %></strong>
          <p class="muted-label"><%= isEn ? 'Priority tasks requiring immediate handling.' : '바로 처리해야 할 핵심 작업 건수입니다.' %></p>
          <ul class="metric-list">
            <li><span><%= isEn ? 'Awaiting Payment Verification' : '입금확인중 주문건' %></span><strong><%= Number(stats.actionItems.uncheckedOrders || 0).toLocaleString() %></strong></li>
            <li><span><%= isEn ? 'Payment Check Wait 12h+' : '입금확인 대기 12시간+' %></span><strong><%= Number(stats.actionItems.paymentWaiting || 0).toLocaleString() %></strong></li>
            <li><span><%= isEn ? 'Unreplied Inquiries' : '미답변 문의' %></span><strong><%= Number(stats.actionItems.pendingInquiries || 0).toLocaleString() %></strong></li>
            <li><span><%= isEn ? 'QC Missing Orders' : 'QC 미등록 주문' %></span><strong><%= Number(stats.actionItems.qcPending || 0).toLocaleString() %></strong></li>
          </ul>
        </div>

        <div class="kpi-card">
          <h4><%= isEn ? 'Order Delay Warnings' : '주문 지연 경고' %></h4>
          <p class="muted-label"><%= isEn ? 'SLA delay alerts by order pipeline stage.' : '주문 단계별 지연 건수입니다.' %></p>
          <ul class="metric-list">
            <li><span><%= isEn ? 'Awaiting Payment 24h+' : '입금확인중 24시간+' %></span><strong><%= Number(stats.delayWarnings.pendingOver24h || 0).toLocaleString() %></strong></li>
            <li><span><%= isEn ? 'Payment Confirmed 48h+' : '입금확인 후 48시간+' %></span><strong><%= Number(stats.delayWarnings.confirmedOver48h || 0).toLocaleString() %></strong></li>
            <li><span><%= isEn ? 'Shipment Complete 72h+' : '출고완료 72시간+' %></span><strong><%= Number(stats.delayWarnings.readyOver72h || 0).toLocaleString() %></strong></li>
            <li><span><%= isEn ? 'Shipping 7d+' : '배송중 7일+' %></span><strong><%= Number(stats.delayWarnings.shippingOver7d || 0).toLocaleString() %></strong></li>
          </ul>
