            <li><span><%= isEn ? 'Purchase → Order' : '구매진입 → 주문생성' %></span><strong><%= Number(stats.conversionFunnel.rates.purchaseToOrder || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
            <li><span><%= isEn ? 'Order → Payment' : '주문생성 → 입금확인' %></span><strong><%= Number(stats.conversionFunnel.rates.orderToPayment || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
            <li><span><%= isEn ? 'View → Payment' : '상품조회 → 입금확인' %></span><strong><%= Number(stats.conversionFunnel.rates.viewToPayment || 0).toLocaleString(undefined, { maximumFractionDigits: 1 }) %>%</strong></li>
