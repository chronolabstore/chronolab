      </form>

      <script>
        (() => {
          const form = document.querySelector('[data-admin-product-form]');
          if (!form) return;

          const hiddenGroupInput = form.querySelector('[data-admin-product-group-input]');
          const buttons = Array.from(form.querySelectorAll('[data-admin-product-group-btn]'));
          const fieldBoxes = Array.from(form.querySelectorAll('[data-admin-product-fields]'));
          const fieldInputs = Array.from(form.querySelectorAll('[data-admin-field-input]'));
          const imageInput = form.querySelector('input[name="images"]');
          const previewWrap = form.querySelector('[data-image-watermark-preview]');
          const previewGrid = form.querySelector('[data-image-watermark-preview-grid]');
          const watermarkImageUrl = '<%= ctx.settings.watermarkLogoPath || '' %>';
          const watermarkDomainText = 'www.chronolab.co.kr';
          const MAX_IMAGE_FILE_BYTES = 100 * 1024 * 1024;
          const MAX_IMAGE_FILE_MB = Math.round(MAX_IMAGE_FILE_BYTES / (1024 * 1024));
          const imageOverLimitMessage = '<%= isEn ? 'Some files exceed 100MB per image. Please reduce file size and try again.' : '이미지 1개당 최대 100MB까지 업로드할 수 있습니다. 용량을 줄여 다시 시도해 주세요.' %>';
          const removeImageLabel = '<%= isEn ? 'Remove image' : '이미지 선택 취소' %>';
          const browserUnsupportedFileEditMessage = '<%= isEn ? 'Your browser does not support file reordering/removal for this input. Please reselect images.' : '현재 브라우저에서는 이미지 순서/삭제 반영을 지원하지 않습니다. 이미지를 다시 선택해 주세요.' %>';
          const selectBrandFirstLabel = '<%= isEn ? 'Select brand first' : '브랜드를 먼저 선택하세요' %>';
          const selectModelLabel = '<%= isEn ? 'Select Model' : '모델 선택' %>';
          const emptyBrandModelLabel = '<%= isEn ? 'No model options for this brand' : '이 브랜드에 등록된 모델 옵션 없음' %>';
          const noModelOptionsLabel = '<%= isEn ? 'No model options' : '등록된 모델 옵션 없음' %>';
          const useEnglishLabels = <%= isEn ? 'true' : 'false' %>;
          const parsedProductGroups = (() => {
            try {
              const decoded = decodeURIComponent(form.dataset.productGroups || '');
              const parsed = JSON.parse(decoded);
              return Array.isArray(parsed) ? parsed : [];
            } catch (error) {
              return [];
            }
          })();
          const productGroupConfigMap = new Map(
            parsedProductGroups
              .filter((item) => item && typeof item === 'object')
              .map((item) => [String(item.key || ''), item])
          );
          let watermarkImage = null;
          let watermarkImagePromise = null;
          let selectedImageFiles = [];
          let draggingPreviewItem = null;
          let draggingPointerId = null;
          let dragStartX = 0;
          let dragStartY = 0;
          let dragMoved = false;
          let dragActivated = false;
          let lastDragFinishedAt = 0;

          const normalizeSelectValue = (value) => String(value || '').trim();
          const findCaseInsensitiveKey = (source, rawValue) => {
            if (!source || typeof source !== 'object' || Array.isArray(source)) return '';
            const needle = normalizeSelectValue(rawValue).toLowerCase();
            if (!needle) return '';
            return (
              Object.keys(source).find((key) => normalizeSelectValue(key).toLowerCase() === needle) || ''
            );
          };
          const resolveLabelEntry = (source, rawValue) => {
            const fallback = normalizeSelectValue(rawValue);
            const matchedKey = findCaseInsensitiveKey(source, rawValue);
            const rawEntry =
              matchedKey &&
              source[matchedKey] &&
              typeof source[matchedKey] === 'object' &&
              !Array.isArray(source[matchedKey])
                ? source[matchedKey]
                : {};
            const labelKo = normalizeSelectValue(
              rawEntry.labelKo || rawEntry.label_ko || rawEntry.ko || rawEntry.label || fallback
            );
            const labelEn = normalizeSelectValue(
              rawEntry.labelEn || rawEntry.label_en || rawEntry.en || rawEntry.label || fallback
            );
            return {
              labelKo: labelKo || fallback,
              labelEn: labelEn || fallback
            };
          };
          const dedupeOptionList = (rawList = []) => {
            const list = [];
            const seen = new Set();
            (Array.isArray(rawList) ? rawList : []).forEach((item) => {
              const value = normalizeSelectValue(item);
              if (!value) return;
              const dedupeKey = value.toLowerCase();
              if (seen.has(dedupeKey)) return;
              seen.add(dedupeKey);
              list.push(value);
            });
            return list;
          };
          const getGroupModelMap = (groupKey) => {
            const groupConfig = productGroupConfigMap.get(String(groupKey || '')) || {};
            const rawMap =
              groupConfig.modelOptionsByBrand &&
              typeof groupConfig.modelOptionsByBrand === 'object' &&
              !Array.isArray(groupConfig.modelOptionsByBrand)
                ? groupConfig.modelOptionsByBrand
                : {};
            const modelMap = {};
            Object.entries(rawMap).forEach(([rawBrand, rawModels]) => {
              const brand = normalizeSelectValue(rawBrand);
              if (!brand) return;
              const models = dedupeOptionList(rawModels);
              if (models.length === 0) return;
              modelMap[brand] = models;
            });
            return modelMap;
          };
          const getGroupModelLabelMapByBrand = (groupKey) => {
            const groupConfig = productGroupConfigMap.get(String(groupKey || '')) || {};
            const rawMap =
              groupConfig.modelOptionLabelsByBrand &&
              typeof groupConfig.modelOptionLabelsByBrand === 'object' &&
              !Array.isArray(groupConfig.modelOptionLabelsByBrand)
                ? groupConfig.modelOptionLabelsByBrand
                : {};
            return rawMap;
          };
          const getModelLabelForBrand = (groupKey, brandValue, modelValue) => {
            const mapByBrand = getGroupModelLabelMapByBrand(groupKey);
            const matchedBrandKey = findCaseInsensitiveKey(mapByBrand, brandValue);
            if (!matchedBrandKey) {
              return normalizeSelectValue(modelValue);
            }
            const brandMap =
              mapByBrand[matchedBrandKey] &&
              typeof mapByBrand[matchedBrandKey] === 'object' &&
              !Array.isArray(mapByBrand[matchedBrandKey])
                ? mapByBrand[matchedBrandKey]
                : {};
            const entry = resolveLabelEntry(brandMap, modelValue);
            return useEnglishLabels ? (entry.labelEn || entry.labelKo || modelValue) : (entry.labelKo || entry.labelEn || modelValue);
          };
          const getModelOptionsForBrand = (groupKey, selectedBrand) => {
            const groupConfig = productGroupConfigMap.get(String(groupKey || '')) || {};
            const modelMap = getGroupModelMap(groupKey);
            const mapKeys = Object.keys(modelMap);
            const normalizedBrand = normalizeSelectValue(selectedBrand);
            if (normalizedBrand) {
              const matchedKey = mapKeys.find((item) => item.toLowerCase() === normalizedBrand.toLowerCase());
              if (matchedKey) {
                return { hasBrandMap: mapKeys.length > 0, options: modelMap[matchedKey] };
              }
              if (mapKeys.length > 0) {
                return { hasBrandMap: true, options: [] };
              }
            }
            if (!normalizedBrand && mapKeys.length > 0) {
              return { hasBrandMap: true, options: [] };
            }
            return {
              hasBrandMap: false,
              options: dedupeOptionList(groupConfig.modelOptions)
            };
          };
          const refreshModelSelectForGroup = (groupKey) => {
            const safeGroupKey = String(groupKey || '');
            if (!safeGroupKey) return;
            const fieldBox = fieldBoxes.find((box) => box.dataset.adminProductFields === safeGroupKey);
            if (!fieldBox) return;

            const brandSelect = fieldBox.querySelector('select[name="selectedBrandOption"]');
            const modelSelect = fieldBox.querySelector('select[name="selectedModelOption"]');
            if (!modelSelect) return;

            const selectedBrand = normalizeSelectValue(brandSelect?.value || '');
            const currentValue = normalizeSelectValue(modelSelect.value || modelSelect.dataset.initialModelValue || '');
            const initialModelValue = normalizeSelectValue(modelSelect.dataset.initialModelValue || '');
            const lastResolvedBrand = normalizeSelectValue(modelSelect.dataset.lastResolvedBrand || '');
            const isFirstRefresh = modelSelect.dataset.modelRefreshInitialized !== '1';
            const brandChanged = !isFirstRefresh && lastResolvedBrand !== selectedBrand;
            const resolved = getModelOptionsForBrand(safeGroupKey, selectedBrand);
            let modelOptions = dedupeOptionList(resolved.options || []);

            if (
              !brandChanged &&
              currentValue &&
              !modelOptions.some((item) => item.toLowerCase() === currentValue.toLowerCase())
            ) {
              modelOptions = [...modelOptions, currentValue];
            } else if (
              isFirstRefresh &&
              initialModelValue &&
              !modelOptions.some((item) => item.toLowerCase() === initialModelValue.toLowerCase())
            ) {
              modelOptions = [...modelOptions, initialModelValue];
            }

            const placeholder = resolved.hasBrandMap
              ? (selectedBrand
                  ? (modelOptions.length > 0 ? selectModelLabel : emptyBrandModelLabel)
                  : selectBrandFirstLabel)
              : (modelOptions.length > 0 ? selectModelLabel : noModelOptionsLabel);

            modelSelect.innerHTML = '';
            const baseOption = document.createElement('option');
            baseOption.value = '';
            baseOption.textContent = placeholder;
            modelSelect.appendChild(baseOption);
            modelOptions.forEach((item) => {
              const option = document.createElement('option');
              option.value = item;
              option.textContent = getModelLabelForBrand(safeGroupKey, selectedBrand, item) || item;
              modelSelect.appendChild(option);
            });

            const matchedValue = modelOptions.find((item) => item.toLowerCase() === currentValue.toLowerCase()) || '';
            modelSelect.value = matchedValue;
            modelSelect.dataset.required = modelOptions.length > 0 ? '1' : '0';
            modelSelect.required = !modelSelect.disabled && modelSelect.dataset.required === '1';
            modelSelect.dataset.lastResolvedBrand = selectedBrand;
            modelSelect.dataset.modelRefreshInitialized = '1';
          };

          const clearWatermarkPreview = () => {
            if (!previewGrid) return;
            previewGrid.innerHTML = '';
            if (previewWrap) {
              previewWrap.hidden = true;
            }
          };

          const replaceInputFiles = (files) => {
            if (!imageInput || typeof DataTransfer !== 'function') {
              return false;
            }
            try {
              const transfer = new DataTransfer();
              (files || []).forEach((file) => {
                transfer.items.add(file);
              });
              imageInput.files = transfer.files;
              return true;
            } catch (error) {
              return false;
            }
          };

          const syncInputFilesOrReset = (files = []) => {
            const replaced = replaceInputFiles(files);
            if (replaced) {
              return true;
            }
            if (imageInput) {
              imageInput.value = '';
            }
            selectedImageFiles = [];
            renderWatermarkPreview();
            window.alert(browserUnsupportedFileEditMessage);
            return false;
          };

          const updatePreviewOrderLabels = () => {
            if (!previewGrid) return;
            const items = Array.from(previewGrid.querySelectorAll('.watermark-preview-item'));
            items.forEach((item, index) => {
              const orderNode = item.querySelector('[data-watermark-preview-order]');
              if (orderNode) {
                orderNode.textContent = String(index + 1);
              }
            });
          };

          const syncSelectedFilesFromPreviewDom = () => {
            if (!previewGrid) return;
            const orderedIds = Array.from(previewGrid.querySelectorAll('.watermark-preview-item'))
              .map((item) => String(item.dataset.fileId || ''))
              .filter(Boolean);
            if (!orderedIds.length) {
              updatePreviewOrderLabels();
              return;
            }

            const entryMap = new Map(selectedImageFiles.map((entry) => [entry.id, entry]));
            selectedImageFiles = orderedIds
              .map((id) => entryMap.get(id))
              .filter((entry) => entry && entry.file);
            updatePreviewOrderLabels();

            syncInputFilesOrReset(selectedImageFiles.map((entry) => entry.file));
          };

          const loadWatermarkImage = () => {
            if (!watermarkImageUrl) {
              return Promise.resolve(null);
            }
            if (watermarkImage) {
              return Promise.resolve(watermarkImage);
            }
            if (watermarkImagePromise) {
              return watermarkImagePromise;
            }
            watermarkImagePromise = new Promise((resolve) => {
              const image = new Image();
              image.onload = () => {
                watermarkImage = image;
                resolve(image);
              };
              image.onerror = () => {
                resolve(null);
              };
              image.src = watermarkImageUrl;
            });
            return watermarkImagePromise;
          };

          const drawWatermarkText = (ctx, width, height) => {
            const text = watermarkDomainText;
            const fontSize = Math.max(10, Math.round(width * 0.04));
            ctx.save();
            ctx.font = `700 ${fontSize}px "Noto Sans KR", "Noto Sans", system-ui, -apple-system, "Segoe UI", sans-serif`;
            ctx.textBaseline = 'middle';
            ctx.fillStyle = 'rgba(255, 255, 255, 0.18)';

            const textWidth = ctx.measureText(text).width || Math.round(fontSize * 8);
            const step = textWidth + Math.max(18, Math.round(fontSize * 1.2));
            const rows = [height * 0.25, height * 0.5, height * 0.75];

            rows.forEach((y) => {
              for (let x = -textWidth; x < width + textWidth; x += step) {
                ctx.fillText(text, x, y);
              }
            });

            ctx.restore();
          };

          const drawWatermarkImage = (ctx, width, height, image) => {
            if (!image || !image.width || !image.height) {
              drawWatermarkText(ctx, width, height);
              return;
            }

            const targetWidth = Math.max(48, Math.round(width * 0.12));
            const ratio = image.width / image.height;
            const targetHeight = Math.max(12, Math.round(targetWidth / Math.max(0.01, ratio)));
            const fontSize = Math.max(10, Math.round(targetHeight * 0.82));
            const imageTextGap = Math.max(10, Math.round(targetHeight * 0.34));
            const textTailGap = Math.max(10, Math.round(targetHeight * 0.34));
            const text = watermarkDomainText;
            const rows = [height * 0.25, height * 0.5, height * 0.75];

            ctx.save();
            ctx.globalAlpha = 0.18;
            ctx.font = `700 ${fontSize}px "Noto Sans KR", "Noto Sans", system-ui, -apple-system, "Segoe UI", sans-serif`;
            ctx.textBaseline = 'middle';
            ctx.fillStyle = '#ffffff';
            const textWidth = ctx.measureText(text).width || Math.round(fontSize * 8);
            const xStep = Math.max(targetWidth + imageTextGap + textWidth + textTailGap, targetWidth + 18);

            rows.forEach((y) => {
              for (let x = -targetWidth; x < width + targetWidth; x += xStep) {
                const imageX = Math.round(x);
                const textX = Math.round(x + targetWidth + imageTextGap);
                ctx.drawImage(image, imageX, Math.round(y - targetHeight / 2), targetWidth, targetHeight);
                ctx.fillText(text, textX, Math.round(y));
              }
            });
            ctx.restore();
          };

          const appendWatermarkPreview = (fileEntry) => {
            if (!previewGrid) return;
            if (!fileEntry || !fileEntry.file) return;

            const file = fileEntry.file;
            const blobUrl = URL.createObjectURL(file);
            const image = new Image();
            const item = document.createElement('div');
            item.className = 'watermark-preview-item';
            item.dataset.fileId = fileEntry.id;

            const order = document.createElement('span');
            order.className = 'watermark-preview-order';
            order.setAttribute('data-watermark-preview-order', '1');
            order.textContent = '1';

            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'watermark-preview-remove-btn';
            removeBtn.setAttribute('data-preview-remove', '1');
            removeBtn.setAttribute('data-preview-remove-id', fileEntry.id);
            removeBtn.setAttribute('aria-label', removeImageLabel);
            removeBtn.textContent = '×';

            const canvas = document.createElement('canvas');
            canvas.className = 'watermark-preview-canvas';
            canvas.width = 4;
            canvas.height = 3;

            const name = document.createElement('span');
            name.className = 'watermark-preview-name';
            name.textContent = file.name || 'image';

            item.appendChild(order);
            item.appendChild(removeBtn);
            item.appendChild(canvas);
            item.appendChild(name);
            previewGrid.appendChild(item);

            image.onload = async () => {
              const maxWidth = 480;
              const maxHeight = 360;
              const scale = Math.min(1, maxWidth / image.width, maxHeight / image.height);
              const width = Math.max(1, Math.round(image.width * scale));
              const height = Math.max(1, Math.round(image.height * scale));
              canvas.width = width;
              canvas.height = height;

              const ctx = canvas.getContext('2d');
              if (ctx) {
                ctx.drawImage(image, 0, 0, width, height);
                const watermarkGraphic = await loadWatermarkImage();
                if (watermarkGraphic) {
                  drawWatermarkImage(ctx, width, height, watermarkGraphic);
                } else {
                  drawWatermarkText(ctx, width, height);
                }
              }

              URL.revokeObjectURL(blobUrl);
            };

            image.onerror = () => {
              URL.revokeObjectURL(blobUrl);
            };

            image.src = blobUrl;
          };

          const renderWatermarkPreview = () => {
            if (!previewWrap || !previewGrid) return;
            previewGrid.innerHTML = '';
            if (!selectedImageFiles.length) {
              previewWrap.hidden = true;
              return;
            }
            previewWrap.hidden = false;
            selectedImageFiles.forEach((fileEntry) => appendWatermarkPreview(fileEntry));
            updatePreviewOrderLabels();
          };

          const startPreviewDrag = (event) => {
            if (!previewGrid || !event || !event.target) return;
            if (event.target.closest('[data-preview-remove]')) return;
            if (event.pointerType === 'mouse' && Number(event.button) !== 0) return;
            const item = event.target.closest('.watermark-preview-item');
            if (!item || item.parentElement !== previewGrid) return;

            draggingPreviewItem = item;
            draggingPointerId = event.pointerId;
            dragStartX = event.clientX;
            dragStartY = event.clientY;
            dragMoved = false;
            dragActivated = false;
          };

          const movePreviewDrag = (event) => {
            if (!previewGrid || !draggingPreviewItem) return;
            if (event.pointerId !== draggingPointerId) return;

            const dx = event.clientX - dragStartX;
            const dy = event.clientY - dragStartY;
            if (!dragActivated) {
              if (Math.abs(dx) < 6 && Math.abs(dy) < 6) {
                return;
              }
              dragActivated = true;
              dragMoved = true;
              draggingPreviewItem.classList.add('is-dragging');
              draggingPreviewItem.style.pointerEvents = 'none';
              if (draggingPreviewItem.setPointerCapture) {
                try {
                  draggingPreviewItem.setPointerCapture(event.pointerId);
                } catch (error) {
                  // ignore pointer capture failures
                }
              }
            }
            draggingPreviewItem.style.transform = `translate(${dx}px, ${dy}px)`;

            const hoverNode = document.elementFromPoint(event.clientX, event.clientY);
            const targetItem = hoverNode ? hoverNode.closest('.watermark-preview-item') : null;
            if (!targetItem || targetItem === draggingPreviewItem || targetItem.parentElement !== previewGrid) {
              event.preventDefault();
              return;
            }

            const allItems = Array.from(previewGrid.querySelectorAll('.watermark-preview-item'));
            const draggingIndex = allItems.indexOf(draggingPreviewItem);
            const targetIndex = allItems.indexOf(targetItem);
            if (draggingIndex < 0 || targetIndex < 0 || draggingIndex === targetIndex) {
              event.preventDefault();
              return;
            }

            const rect = targetItem.getBoundingClientRect();
            const placeAfter = event.clientX > rect.left + rect.width / 2;
            if (placeAfter) {
              previewGrid.insertBefore(draggingPreviewItem, targetItem.nextSibling);
            } else {
              previewGrid.insertBefore(draggingPreviewItem, targetItem);
            }
            updatePreviewOrderLabels();
            event.preventDefault();
          };

          const finishPreviewDrag = (event) => {
            if (!draggingPreviewItem) return;
            if (event && typeof event.pointerId === 'number' && event.pointerId !== draggingPointerId) {
              return;
            }

            if (dragActivated) {
              draggingPreviewItem.classList.remove('is-dragging');
              draggingPreviewItem.style.transform = '';
              draggingPreviewItem.style.pointerEvents = '';
              lastDragFinishedAt = Date.now();
              syncSelectedFilesFromPreviewDom();
            }
            draggingPreviewItem = null;
            draggingPointerId = null;
            dragMoved = false;
            dragActivated = false;
          };

          const removePreviewFileById = (fileId) => {
            const targetId = String(fileId || '').trim();
            if (!targetId) return;
            selectedImageFiles = selectedImageFiles.filter((entry) => entry && entry.id !== targetId);
            if (!syncInputFilesOrReset(selectedImageFiles.map((entry) => entry.file))) {
              return;
            }
            renderWatermarkPreview();
          };

          const handlePreviewGridClick = (event) => {
            if (!previewGrid || !event || !event.target) return;

            const removeBtn = event.target.closest('[data-preview-remove]');
            if (removeBtn) {
              event.preventDefault();
              event.stopPropagation();
              removePreviewFileById(removeBtn.getAttribute('data-preview-remove-id') || '');
              return;
            }

            if (Date.now() - lastDragFinishedAt < 300) {
              event.preventDefault();
              event.stopPropagation();
            }
          };

          const refreshWatermarkPreview = () => {
            if (!imageInput || !previewWrap || !previewGrid) return;
            clearWatermarkPreview();

            const rawFiles = Array.from(imageInput.files || []).filter((file) =>
              typeof file.type === 'string' && file.type.startsWith('image/')
            );
            if (!rawFiles.length) {
              selectedImageFiles = [];
              return;
            }

            const validFiles = rawFiles.filter((file) => Number(file.size || 0) <= MAX_IMAGE_FILE_BYTES);
            if (validFiles.length !== rawFiles.length) {
              window.alert(imageOverLimitMessage.replace('100MB', `${MAX_IMAGE_FILE_MB}MB`));
              const replaced = replaceInputFiles(validFiles);
              if (!replaced) {
                imageInput.value = '';
                selectedImageFiles = [];
                renderWatermarkPreview();
                return;
              }
            }

            const previewFiles = (validFiles.length !== rawFiles.length ? Array.from(imageInput.files || []) : validFiles).filter(
              (file) =>
                typeof file.type === 'string' &&
                file.type.startsWith('image/') &&
                Number(file.size || 0) <= MAX_IMAGE_FILE_BYTES
            );

            selectedImageFiles = previewFiles.map((file, index) => ({
              id: `preview-file-${Date.now()}-${index}-${Math.random().toString(36).slice(2, 8)}`,
              file
            }));
            renderWatermarkPreview();
          };

          const applyGroup = (groupKey) => {
            if (hiddenGroupInput) {
              hiddenGroupInput.value = groupKey;
            }

            buttons.forEach((button) => {
              const active = button.dataset.adminProductGroupBtn === groupKey;
              button.classList.toggle('dark', active);
            });

            fieldBoxes.forEach((box) => {
              const active = box.dataset.adminProductFields === groupKey;
              box.hidden = !active;
              const inputs = Array.from(box.querySelectorAll('[data-admin-field-input]'));
              inputs.forEach((input) => {
                input.disabled = !active;
                input.required = active && input.dataset.required === '1';
              });
            });

            fieldInputs
              .filter((input) => !input.closest('[data-admin-product-fields]'))
              .forEach((input) => {
                input.disabled = false;
              });

            refreshModelSelectForGroup(groupKey);
          };

          fieldBoxes.forEach((box) => {
            const groupKey = box.dataset.adminProductFields || '';
            if (!groupKey) return;
            const brandSelect = box.querySelector('select[name="selectedBrandOption"]');
            if (brandSelect) {
              brandSelect.addEventListener('change', () => {
                refreshModelSelectForGroup(groupKey);
              });
            }
            refreshModelSelectForGroup(groupKey);
          });

          const initialGroup = decodeURIComponent(form.dataset.initialGroup || '') || (buttons[0] && buttons[0].dataset.adminProductGroupBtn) || '';
          if (initialGroup) {
            applyGroup(initialGroup);
          }

          buttons.forEach((button) => {
            button.addEventListener('click', () => {
              applyGroup(button.dataset.adminProductGroupBtn || '');
            });
          });

          if (imageInput) {
            imageInput.addEventListener('change', refreshWatermarkPreview);
            refreshWatermarkPreview();
          }

          if (previewGrid) {
            previewGrid.addEventListener('pointerdown', startPreviewDrag);
            previewGrid.addEventListener('pointermove', movePreviewDrag);
            previewGrid.addEventListener('pointerup', finishPreviewDrag);
            previewGrid.addEventListener('pointercancel', finishPreviewDrag);
            previewGrid.addEventListener('click', handlePreviewGridClick, true);
            window.addEventListener('pointerup', finishPreviewDrag);
            window.addEventListener('pointercancel', finishPreviewDrag);
          }
        })();
      </script>
    <% } %>

    <% if (productsTab === 'list') { %>
      <div class="kpi-head-row">
        <div class="chip-row" data-admin-product-filter-wrap>
          <button type="button" class="chip dark" data-admin-product-filter="__ALL__"><%= isEn ? 'All' : '전체' %></button>
          <% productGroupKeys.forEach((groupName) => { %>
            <button type="button" class="chip" data-admin-product-filter="<%= groupName %>"><%= groupLabelByKey[groupName] || groupName %></button>
          <% }) %>
        </div>
        <form method="post" action="/admin/product/watermark/apply-all" class="inline-form">
          <button type="submit" class="chip dark"><%= isEn ? 'Apply Watermark to Existing Images' : '기존 상품 이미지 워터마크 일괄 적용' %></button>
        </form>
      </div>

      <div class="table-wrap">
        <table class="product-list-table">
          <thead>
            <tr>
              <th><%= isEn ? 'No.' : '번호' %></th>
              <th><%= isEn ? 'Category' : '분류' %></th>
              <th><%= isEn ? 'Title' : '제목' %></th>
              <th><%= isEn ? 'Price' : '가격' %></th>
              <th><%= isEn ? 'Status' : '상태' %></th>
              <th><%= isEn ? 'Actions' : '작업' %></th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach((item) => { %>
              <tr data-admin-product-row data-group="<%= item.category_group %>">
                <td><%= item.id %></td>
                <td><%= groupLabelByKey[item.category_group] || item.category_group || '-' %></td>
                <td>
                  <strong><%= item.display_title || `${item.brand || ''} ${item.model || ''}`.trim() %></strong>
                  <% if (item.display_subtitle) { %>
                    <br />
                    <small><%= item.display_subtitle %></small>
                  <% } %>
                  <% if ((item.product_badges || []).length > 0) { %>
                    <div class="product-badge-row admin-product-badge-row">
                      <% (item.product_badges || []).forEach((badge) => { %>
                        <% const badgeThemeClass = `product-badge-theme-${normalizeBadgeThemeKey(badge.color_theme)}`; %>
                        <span class="product-badge-chip <%= badgeThemeClass %>"><%= isEn ? (badge.label_en || badge.label_ko) : (badge.label_ko || badge.label_en) %></span>
                      <% }) %>
                    </div>
                  <% } %>
                </td>
                <td><%= Number(item.price || 0) > 0 ? `₩${formatPrice(item.price)}` : (isEn ? 'On request' : '가격문의') %></td>
                <td>
                  <% const soldOut = Number(item.is_sold_out || 0) === 1; %>
                  <%= item.is_active ? (isEn ? 'Visible' : '노출') : (isEn ? 'Hidden' : '숨김') %>
                  <% if (soldOut) { %>
                    · <%= isEn ? 'Sold Out' : '판매완료' %>
                  <% } %>
                </td>
                <td>
                  <div class="admin-account-actions">
                    <a href="/shop/item/<%= item.id %>" class="chip" target="_blank" rel="noreferrer"><%= isEn ? 'View' : '보기' %></a>
                    <a href="/admin/products?section=upload&editId=<%= item.id %>" class="chip"><%= isEn ? 'Edit' : '수정' %></a>
                    <form method="post" action="/admin/product/<%= item.id %>/sold-out-toggle" class="inline-form">
                      <button type="submit" class="chip"><%= Number(item.is_sold_out || 0) === 1 ? (isEn ? 'On Sale' : '판매중') : (isEn ? 'Sold Out' : '판매완료') %></button>
                    </form>
                    <form method="post" action="/admin/product/<%= item.id %>/toggle" class="inline-form">
                      <button type="submit" class="chip"><%= item.is_active ? (isEn ? 'Hide' : '숨김') : (isEn ? 'Show' : '노출') %></button>
                    </form>
                    <form method="post" action="/admin/product/<%= item.id %>/delete" class="inline-form" onsubmit="return confirm('<%= isEn ? 'Delete this product?' : '이 상품을 삭제할까요?' %>');">
                      <button type="submit" class="chip"><%= isEn ? 'Delete' : '삭제' %></button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <script>
        (() => {
          const wrap = document.querySelector('[data-admin-product-filter-wrap]');
          if (!wrap) return;
          const buttons = Array.from(wrap.querySelectorAll('[data-admin-product-filter]'));
          const rows = Array.from(document.querySelectorAll('[data-admin-product-row]'));
          if (buttons.length === 0 || rows.length === 0) return;

          const applyFilter = (key) => {
            rows.forEach((row) => {
              const match = key === '__ALL__' || row.dataset.group === key;
              row.hidden = !match;
            });
            buttons.forEach((button) => {
              button.classList.toggle('dark', button.dataset.adminProductFilter === key);
            });
          };

          buttons.forEach((button) => {
            button.addEventListener('click', () => {
              applyFilter(button.dataset.adminProductFilter || '__ALL__');
            });
          });
          applyFilter('__ALL__');
        })();
      </script>
    <% } %>

