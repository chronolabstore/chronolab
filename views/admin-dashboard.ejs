            </label>
            <label><%= isEn ? 'Header Symbol Upload (Day)' : '헤더 심볼 업로드 (데이)' %>
              <input type="file" name="dayHeaderSymbol" accept="image/*" />
              <% if (dayThemeAssets.headerSymbolPath) { %>
                <small class="muted-label"><%= isEn ? 'Current:' : '현재:' %> <code><%= dayThemeAssets.headerSymbolPath %></code></small>
              <% } %>
            </label>
            <label><%= isEn ? 'Header Logo Upload (Day)' : '헤더 로고 업로드 (데이)' %>
              <input type="file" name="dayHeaderLogo" accept="image/*" />
              <% if (dayThemeAssets.headerLogoPath) { %>
                <small class="muted-label"><%= isEn ? 'Current:' : '현재:' %> <code><%= dayThemeAssets.headerLogoPath %></code></small>
              <% } %>
            </label>
            <label><%= isEn ? 'Footer Logo Upload (Day)' : '푸터 로고 업로드 (데이)' %>
              <input type="file" name="dayFooterLogo" accept="image/*" />
              <% if (dayThemeAssets.footerLogoPath) { %>
                <small class="muted-label"><%= isEn ? 'Current:' : '현재:' %> <code><%= dayThemeAssets.footerLogoPath %></code></small>
              <% } %>
            </label>
          </fieldset>

          <fieldset class="theme-color-fieldset">
