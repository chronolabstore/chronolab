            <div class="admin-filter-actions">
              <button type="submit" class="chip dark"><%= isEn ? 'Filter' : '조회' %></button>
              <a href="/admin/security?section=logs" class="chip"><%= isEn ? 'Reset' : '초기화' %></a>
            </div>
          </form>
          <p class="muted-label"><%= isEn ? `Total ${logPager.totalCount} records · Page ${logPager.page}/${logPager.totalPages}` : `총 ${logPager.totalCount}건 · ${logPager.page}/${logPager.totalPages} 페이지` %></p>
