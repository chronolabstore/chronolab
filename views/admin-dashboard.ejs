                  <th><%= isEn ? 'Attempt' : '시도' %></th>
                  <th><%= isEn ? 'Reason' : '사유' %></th>
                  <th><%= isEn ? 'Status' : '상태' %></th>
                </tr>
              </thead>
              <tbody>
                <% if (security.securityAlerts.length === 0) { %>
                  <tr><td colspan="6"><%= isEn ? 'No security alerts found.' : '조건에 맞는 보안 알림이 없습니다.' %></td></tr>
