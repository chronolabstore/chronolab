        </form>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th><%= isEn ? 'Category' : '분류' %></th>
              <th><%= isEn ? 'Title' : '제목' %></th>
              <th><%= isEn ? 'Price' : '가격' %></th>
              <th><%= isEn ? 'Status' : '상태' %></th>
              <th><%= isEn ? 'Actions' : '작업' %></th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach((item) => { %>
              <tr data-admin-product-row data-group="<%= item.category_group %>">
