        <a href="/admin/security?section=admins" class="menu-pill <%= securityTab === 'admins' ? 'active' : '' %>"><%= isEn ? 'Sub Admins' : '서브관리자 관리' %></a>
        <a href="/admin/security?section=logs" class="menu-pill <%= securityTab === 'logs' ? 'active' : '' %>"><%= isEn ? 'Admin Logs' : '관리자 로그' %></a>
        <a href="/admin/security?section=alerts" class="menu-pill <%= securityTab === 'alerts' ? 'active' : '' %>"><%= isEn ? 'Anomaly Alerts' : '이상행동 알림' %></a>
      </div>

      <% if (securityTab === 'profile') { %>
        <% const primaryUser = security.adminUsers.find((row) => row.is_primary) || { username: ctx.currentUser.username, full_name: ctx.currentUser.fullName || '', email: ctx.currentUser.email || '', phone: ctx.currentUser.phone || '' }; %>
        <div class="security-panel-grid">
