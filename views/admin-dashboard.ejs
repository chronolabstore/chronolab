              </tbody>
            </table>
          </div>
          <div class="admin-pagination">
            <% if (alertPager.page > 1) { %>
              <a
                class="chip"
                href="/admin/security?section=alerts&alertPage=<%= alertPager.page - 1 %><%= Number(alertFilters.adminId || 0) > 0 ? `&alertAdminId=${Number(alertFilters.adminId)}` : '' %><%= alertFilters.from ? `&alertFrom=${encodeURIComponent(alertFilters.from)}` : '' %><%= alertFilters.to ? `&alertTo=${encodeURIComponent(alertFilters.to)}` : '' %>"
              ><%= isEn ? 'Prev' : '이전' %></a>
