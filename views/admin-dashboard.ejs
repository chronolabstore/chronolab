                  <br />
                  <small><%= isEn ? 'Timeline' : '타임라인' %>:</small>
                  <ul class="status-mini-list">
                    <% if (item.checked_at) { %>
                      <li><small><%= isEn ? 'Payment Confirmed' : '입금확인' %> · <%= item.checked_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.ready_to_ship_at) { %>
                      <li><small><%= isEn ? 'Shipment Complete' : '출고완료' %> · <%= item.ready_to_ship_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.shipping_started_at) { %>
                      <li><small><%= isEn ? 'Shipping Started' : '배송시작' %> · <%= item.shipping_started_at.slice(0, 16) %></small></li>
                    <% } %>
                    <% if (item.delivered_at) { %>
                      <li><small><%= isEn ? 'Delivered' : '배송완료' %> · <%= item.delivered_at.slice(0, 16) %></small></li>
                    <% } %>
                  </ul>
                <% } %>
                <% if (item.status_logs && item.status_logs.length > 0) { %>
                  <small><%= isEn ? 'Latest events' : '최근 이력' %>:</small>
                  <ul class="status-mini-list">
                    <% item.status_logs.forEach((log) => { %>
                      <li>
                        <small>
                          <%= log.created_at ? log.created_at.slice(0, 16) : '-' %> ·
                          <%= log.from_status_label ? `${log.from_status_label} → ` : '' %><%= log.to_status_label || log.to_status %>
                        </small>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>
              </td>
              <td>
                <% if (item.tracking_number) { %>
                  <small><strong><%= item.tracking_carrier_label %></strong></small><br />
                  <small><%= item.tracking_number %></small><br />
                  <small><%= item.tracking_last_event || (isEn ? 'Tracking pending' : '조회 대기중') %></small><br />
                  <small><%= item.tracking_last_checked_at ? item.tracking_last_checked_at.slice(0, 16) : '-' %></small>
                <% } else { %>
                  <small>-</small>
                <% } %>
              </td>
              <td>
                <div class="admin-order-actions">
                  <% if (item.status_code === 'PENDING_REVIEW') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/confirm" class="inline-form">
                      <button type="submit" class="chip dark"><%= isEn ? 'Confirm Payment' : '입금확인' %></button>
                    </form>
                  <% } else if (item.status_code === 'ORDER_CONFIRMED') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/ready" class="inline-form">
                      <button type="submit" class="chip dark"><%= isEn ? 'Mark Shipment Complete' : '출고완료 처리' %></button>
                    </form>
                  <% } else if (item.status_code === 'READY_TO_SHIP') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/start-shipping" class="form-grid compact">
                      <label>
                        <span><%= isEn ? 'Carrier' : '택배사' %></span>
                        <select name="trackingCarrier" required>
                          <% trackingCarriers.forEach((carrier) => { %>
                            <option value="<%= carrier.id %>" <%= item.tracking_carrier === carrier.id ? 'selected' : '' %>><%= carrier.label %></option>
                          <% }) %>
                        </select>
                      </label>
                      <label>
                        <span><%= isEn ? 'Tracking No.' : '송장번호' %></span>
                        <input type="text" name="trackingNumber" value="<%= item.tracking_number || '' %>" required />
                      </label>
                      <button type="submit" class="chip dark"><%= isEn ? 'Register Tracking & Start Shipping' : '송장등록(배송시작)' %></button>
                    </form>
                  <% } else if (item.status_code === 'SHIPPING') { %>
                    <form method="post" action="/admin/order/<%= item.id %>/update-tracking" class="form-grid compact">
                      <label>
                        <span><%= isEn ? 'Carrier' : '택배사' %></span>
                        <select name="trackingCarrier" required>
                          <% trackingCarriers.forEach((carrier) => { %>
                            <option value="<%= carrier.id %>" <%= item.tracking_carrier === carrier.id ? 'selected' : '' %>><%= carrier.label %></option>
                          <% }) %>
                        </select>
                      </label>
                      <label>
                        <span><%= isEn ? 'Tracking No.' : '송장번호' %></span>
                        <input type="text" name="trackingNumber" value="<%= item.tracking_number || '' %>" required />
                      </label>
                      <button type="submit" class="chip"><%= isEn ? 'Update Tracking' : '송장 수정' %></button>
                    </form>
                    <form method="post" action="/admin/order/<%= item.id %>/sync-tracking" class="inline-form">
                      <button type="submit" class="chip"><%= isEn ? 'Sync Tracking' : '송장 상태 조회' %></button>
                    </form>
                    <form method="post" action="/admin/order/<%= item.id %>/mark-delivered" class="inline-form">
                      <button type="submit" class="chip"><%= isEn ? 'Mark Delivered' : '수동 배송완료' %></button>
                    </form>
                    <small class="muted-label"><%= isEn ? 'Auto delivery sync enabled.' : '배송완료 자동 반영 활성화됨' %></small>
                  <% } else { %>
                    <span class="muted-label"><%= isEn ? 'Done' : '완료' %></span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="5">
                <span class="muted-label"><%= isEn ? 'No orders found in this category.' : '해당 분류의 주문이 없습니다.' %></span>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </article>
  <% } %>

  <% if (tab === 'sales') { %>
  <article class="block-card sales-mode-card">
    <h3><%= isEn ? 'Sales Management' : '매출관리' %></h3>
    <div class="security-subnav">
      <a href="/admin/sales?section=price<%= salesDateQuerySuffix %>" class="menu-pill <%= salesManageTab === 'price' ? 'active' : '' %>"><%= isEn ? 'Price Table' : '가격표' %></a>
      <a href="/admin/sales?section=editor<%= salesDateQuerySuffix %>" class="menu-pill <%= salesManageTab === 'editor' ? 'active' : '' %>"><%= isEn ? 'Workbook Editor' : '매출 시트 편집' %></a>
      <a href="/admin/sales?section=daily<%= salesDateQuerySuffix %>" class="menu-pill <%= salesManageTab === 'daily' ? 'active' : '' %>"><%= isEn ? 'Daily Summary' : '날짜별 전체 매출' %></a>
    </div>
  </article>

  <% if (salesManageTab === 'editor' || salesManageTab === 'price') { %>
  <article class="block-card sales-editor-card">
    <div class="sales-global-settings">
      <label class="sales-global-field">
        <span><%= isEn ? 'CNY Cash Buying (KRW)' : '위안화 환율 (하나은행 현찰 살때 KRW)' %></span>
        <input type="number" min="0" step="0.01" id="salesExchangeRateInput" />
      </label>
      <label class="sales-global-field">
        <span><%= isEn ? 'Shipping Fee (KRW)' : '배송비 (KRW)' %></span>
        <input type="number" min="0" step="1000" id="salesShippingFeeInput" />
      </label>
      <label class="sales-global-field">
        <span><%= isEn ? 'Base Date (for round/date tabs)' : '기준일자 (차수/날짜 탭용)' %></span>
        <input type="date" id="salesScopeDateInput" />
      </label>
      <div class="sales-global-actions">
        <button type="button" class="chip dark" id="salesApplyGlobalBtn"><%= isEn ? 'Save' : '저장' %></button>
        <button type="button" class="chip" id="salesFxSyncBtn"><%= isEn ? 'Sync Naver FX' : '네이버 환율 반영' %></button>
      </div>
    </div>

    <div class="security-subnav sales-tab-nav" id="salesMainTabNav">
      <% salesTabs.forEach((salesTab, idx) => { %>
        <button type="button" class="menu-pill <%= idx === 0 ? 'active' : '' %>" data-sales-main-tab="<%= salesTab.key %>">
          <%= isEn ? salesTab.labelEn : salesTab.labelKo %>
        </button>
      <% }) %>
    </div>

    <div class="sales-scope-toolbar">
      <div id="salesScopeControls" class="sales-scope-controls"></div>
      <div class="admin-field-chip-row" id="salesRowActionHost">
        <button type="button" class="chip" id="salesAddRowBtn"><%= isEn ? 'Add Row' : '행 추가' %></button>
        <button type="button" class="chip dark" id="salesSaveBtn"><%= isEn ? 'Save Changes' : '변경 저장' %></button>
      </div>
    </div>

    <div class="sales-summary-grid" id="salesSummaryGrid"></div>

    <div class="table-wrap sales-table-wrap">
      <table class="sales-data-table" id="salesEditorTable">
        <thead>
          <tr>
            <th>No</th>
            <th><%= isEn ? 'Factory' : '공장' %></th>
            <th><%= isEn ? 'Brand' : '브랜드' %></th>
            <th><%= isEn ? 'Model' : '모델' %></th>
            <th><%= isEn ? 'Reference' : '레퍼런스' %></th>
            <th><%= isEn ? 'Spec / Size' : '종류/사이즈' %></th>
            <th><%= isEn ? 'Cost (RMB)' : '원가 (RMB)' %></th>
            <th><%= isEn ? 'Cost (KRW)' : '원가 (KRW)' %></th>
            <th><%= isEn ? 'Final Cost (KRW)' : '최종원가 (KRW)' %></th>
            <th><%= isEn ? 'Sale Price (KRW)' : '판매가 (KRW)' %></th>
            <th><%= isEn ? 'Margin (KRW)' : '마진 (KRW)' %></th>
            <th><%= isEn ? 'Qty' : '수량' %></th>
            <th><%= isEn ? 'Memo' : '메모' %></th>
            <th><%= isEn ? 'Delete' : '삭제' %></th>
          </tr>
        </thead>
        <tbody id="salesEditorTbody"></tbody>
      </table>
    </div>

    <p class="muted-label sales-meta" id="salesMetaText">-</p>
    <p class="muted-label sales-error hidden" id="salesErrorText"></p>
  </article>

  <script>
    (() => {
      const mainTabButtons = Array.from(document.querySelectorAll('#salesMainTabNav [data-sales-main-tab]'));
      const fxSyncBtn = document.getElementById('salesFxSyncBtn');
      const applyGlobalBtn = document.getElementById('salesApplyGlobalBtn');
      const saveBtn = document.getElementById('salesSaveBtn');
      const addRowBtn = document.getElementById('salesAddRowBtn');
      const rowActionHost = document.getElementById('salesRowActionHost');
      const scopeToolbar = document.querySelector('.sales-scope-toolbar');
      const scopeControls = document.getElementById('salesScopeControls');
      const exchangeRateInput = document.getElementById('salesExchangeRateInput');
      const shippingFeeInput = document.getElementById('salesShippingFeeInput');
      const scopeDateInput = document.getElementById('salesScopeDateInput');
      const summaryGrid = document.getElementById('salesSummaryGrid');
      const tableBody = document.getElementById('salesEditorTbody');
      const metaText = document.getElementById('salesMetaText');
      const errorText = document.getElementById('salesErrorText');

      if (!mainTabButtons.length || !scopeControls || !rowActionHost || !scopeToolbar || !exchangeRateInput || !shippingFeeInput || !scopeDateInput || !summaryGrid || !tableBody || !metaText || !errorText) {
        return;
      }

      const isEn = <%= isEn ? 'true' : 'false' %>;
      const tabDefs = <%- JSON.stringify(salesTabs || []) %>;
      const integerFmt = new Intl.NumberFormat(isEn ? 'en-US' : 'ko-KR');

      let workbook = null;
      let activeTabKey = tabDefs[0]?.key || 'price';
      let activeScopeId = '';
      let activePriceBrand = '';
      let activePriceModel = '';
      let activePriceScopeAll = false;
      let dirty = false;
      let saveInFlight = false;
      let saveQueued = false;
      let autoSaveTimer = null;
      const AUTO_SAVE_DELAY_MS = 550;
      const PRICE_SCOPE_ALL_VALUE = '__ALL__';

      const toNumber = (value, fallback = 0) => {
        const numeric = Number(String(value ?? '').replace(/,/g, ''));
        if (!Number.isFinite(numeric)) return fallback;
        return numeric;
      };

      const toPositive = (value, fallback = 0) => {
        const numeric = toNumber(value, fallback);
        if (!Number.isFinite(numeric) || numeric < 0) return fallback;
        return numeric;
      };

      const normalizeDate = (value) => {
        const raw = String(value || '').trim().replace(/[./]/g, '-');
        if (!raw) return '';
        return /^\d{4}-\d{2}-\d{2}$/.test(raw) ? raw : '';
      };

      const todayDateString = () => {
        const now = new Date();
        const y = now.getFullYear();
        const m = String(now.getMonth() + 1).padStart(2, '0');
        const d = String(now.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
      };

      const roundToStep = (value, step = 1) => {
        const safeStep = Math.max(0.000001, toPositive(step, 1));
        const numeric = toPositive(value, 0);
        return Math.round(numeric / safeStep) * safeStep;
      };

      const getScopeMode = (tabKey) => {
        const tabDef = tabDefs.find((item) => item.key === tabKey) || null;
        const scopeType = String(tabDef?.scopeType || '').trim();
        if (scopeType === 'factory') return 'factory';
        if (scopeType === 'round') return 'round';
        if (scopeType === 'date') return 'date';
        if (tabKey === 'preorder') return 'round';
        return 'date';
      };

      const isPriceTableActive = () => getScopeMode(activeTabKey) === 'factory';

      const normalizePriceSheetName = (value, maxLength = 80) =>
        String(value || '')
          .trim()
          .replace(/\s+/g, ' ')
          .slice(0, maxLength);

      const normalizePriceSheetNameKey = (value) => normalizePriceSheetName(value).toLowerCase();

      const comparePriceSheetNames = (left, right) =>
        String(left || '').localeCompare(String(right || ''), isEn ? 'en' : 'ko', { sensitivity: 'base' });

      const ensureScopeTaxonomy = (scope) => {
        if (!scope || typeof scope !== 'object') {
          return { brands: [] };
        }

        const brandMap = new Map();
        const upsertBrand = (rawBrandName) => {
          const brandName = normalizePriceSheetName(rawBrandName, 80);
          if (!brandName) return null;
          const brandKey = normalizePriceSheetNameKey(brandName);
          if (!brandMap.has(brandKey)) {
            brandMap.set(brandKey, { name: brandName, models: [] });
          }
          return brandMap.get(brandKey);
        };
        const pushModel = (brandEntry, rawModelName) => {
          if (!brandEntry) return;
          const modelName = normalizePriceSheetName(rawModelName, 120);
          if (!modelName) return;
          const exists = brandEntry.models.some(
            (item) => normalizePriceSheetNameKey(item) === normalizePriceSheetNameKey(modelName)
          );
          if (!exists) {
            brandEntry.models.push(modelName);
          }
        };

        const rawBrands = Array.isArray(scope?.taxonomy?.brands) ? scope.taxonomy.brands : [];
        rawBrands.forEach((brandItem) => {
          const brandEntry = upsertBrand(brandItem?.name || '');
          const rawModels = Array.isArray(brandItem?.models) ? brandItem.models : [];
          rawModels.forEach((modelName) => pushModel(brandEntry, modelName));
        });

        const rows = Array.isArray(scope.rows) ? scope.rows : [];
        rows.forEach((row) => {
          const brandEntry = upsertBrand(row?.brand || '');
          pushModel(brandEntry, row?.model || '');
        });

        const brands = [...brandMap.values()]
          .map((brandItem) => ({
            name: brandItem.name,
            models: [...brandItem.models].sort(comparePriceSheetNames)
          }))
          .sort((a, b) => comparePriceSheetNames(a.name, b.name));

        scope.taxonomy = { brands };
        return scope.taxonomy;
      };

      const findPriceBrandEntry = (scope, brandName = '') => {
        const taxonomy = ensureScopeTaxonomy(scope);
        const brandKey = normalizePriceSheetNameKey(brandName);
        if (!brandKey) return null;
        return taxonomy.brands.find((brandItem) => normalizePriceSheetNameKey(brandItem.name) === brandKey) || null;
      };

      const normalizePriceScopeList = (scopeOrScopes) => {
        const scopeList = Array.isArray(scopeOrScopes)
          ? scopeOrScopes
          : (scopeOrScopes ? [scopeOrScopes] : []);
        return scopeList.filter((scope) => scope && typeof scope === 'object');
      };

      const getFilteredPriceScopes = () => {
        const scopes = getScopes();
        if (!isPriceTableActive()) {
          return [];
        }
        if (activePriceScopeAll) {
          return scopes;
        }
        const activeScope = getActiveScope();
        return activeScope ? [activeScope] : (scopes[0] ? [scopes[0]] : []);
      };

      const getPriceBrandNames = (scopeOrScopes) => {
        const scopeList = normalizePriceScopeList(scopeOrScopes);
        const brandMap = new Map();
        scopeList.forEach((scope) => {
          const taxonomy = ensureScopeTaxonomy(scope);
          taxonomy.brands.forEach((brandItem) => {
            const normalizedName = normalizePriceSheetName(brandItem?.name || '', 80);
            if (!normalizedName) return;
            const key = normalizePriceSheetNameKey(normalizedName);
            if (!brandMap.has(key)) {
              brandMap.set(key, normalizedName);
            }
          });
        });
        return [...brandMap.values()].sort(comparePriceSheetNames);
      };

      const getPriceModelNames = (scopeOrScopes, brandName = '') => {
        const scopeList = normalizePriceScopeList(scopeOrScopes);
        const brandKey = normalizePriceSheetNameKey(brandName);
        const modelMap = new Map();
        scopeList.forEach((scope) => {
          const taxonomy = ensureScopeTaxonomy(scope);
          taxonomy.brands.forEach((brandItem) => {
            const currentBrandKey = normalizePriceSheetNameKey(brandItem?.name || '');
            if (brandKey && currentBrandKey !== brandKey) {
              return;
            }
            const models = Array.isArray(brandItem?.models) ? brandItem.models : [];
            models.forEach((modelName) => {
              const normalizedName = normalizePriceSheetName(modelName, 120);
              if (!normalizedName) return;
              const key = normalizePriceSheetNameKey(normalizedName);
              if (!modelMap.has(key)) {
                modelMap.set(key, normalizedName);
              }
            });
          });
        });
        return [...modelMap.values()].sort(comparePriceSheetNames);
      };

      const ensurePriceFilters = () => {
        if (!isPriceTableActive()) {
          activePriceBrand = '';
          activePriceModel = '';
          return;
        }

        const scopeList = getFilteredPriceScopes();
        if (!scopeList.length) {
          activePriceBrand = '';
          activePriceModel = '';
          return;
        }

        const brandNames = getPriceBrandNames(scopeList);
        const activeBrandKey = normalizePriceSheetNameKey(activePriceBrand || '');
        if (activeBrandKey) {
          const matchedBrand = brandNames.find(
            (brandName) => normalizePriceSheetNameKey(brandName) === activeBrandKey
          );
          activePriceBrand = matchedBrand || '';
        } else {
          activePriceBrand = '';
        }

        const modelNames = getPriceModelNames(scopeList, activePriceBrand);
        const modelExists = modelNames.some(
          (modelName) => normalizePriceSheetNameKey(modelName) === normalizePriceSheetNameKey(activePriceModel)
        );
        if (!modelExists) {
          activePriceModel = '';
        } else {
          const matchedModel = modelNames.find(
            (modelName) => normalizePriceSheetNameKey(modelName) === normalizePriceSheetNameKey(activePriceModel)
          );
          activePriceModel = matchedModel || activePriceModel;
        }
      };

      const formatKrw = (value) => {
        const amount = Math.round(toPositive(value, 0));
        return `${isEn ? 'KRW ' : '₩'}${integerFmt.format(amount)}`;
      };

      const showError = (message) => {
        errorText.textContent = message;
        errorText.classList.remove('hidden');
      };

      const clearError = () => {
        errorText.textContent = '';
        errorText.classList.add('hidden');
      };

      const getTabDef = () => tabDefs.find((item) => item.key === activeTabKey) || tabDefs[0] || { key: 'price', scopeType: 'factory' };
      const getTabData = () => (workbook?.tabs && typeof workbook.tabs === 'object' ? workbook.tabs[activeTabKey] || null : null);

      const normalizeSettings = (value, fallback = {}) => ({
        exchangeRate: Number(roundToStep((value?.exchangeRate ?? fallback.exchangeRate ?? 229), 0.01).toFixed(2)),
        shippingFeeKrw: Math.round(roundToStep((value?.shippingFeeKrw ?? fallback.shippingFeeKrw ?? 23000), 1000)),
        fxSource: String(value?.fxSource || fallback.fxSource || 'manual').slice(0, 40),
        fxUpdatedAt: String(value?.fxUpdatedAt || fallback.fxUpdatedAt || '').slice(0, 40),
        updatedAt: String(value?.updatedAt || fallback.updatedAt || new Date().toISOString()).slice(0, 40),
        baseDate: normalizeDate(value?.baseDate || value?.date || fallback.baseDate || '')
      });

      const ensureTabSettings = (tab) => {
        if (!tab) return null;
        const fallback = normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        tab.settings = normalizeSettings(tab.settings || {}, fallback);
        return tab.settings;
      };

      const getScopes = () => {
        const tab = getTabData();
        if (!tab) return [];
        const mode = getScopeMode(activeTabKey);
        if (mode === 'factory') {
          return Array.isArray(tab.groups) ? tab.groups : [];
        }
        return Array.isArray(tab.rounds) ? tab.rounds : [];
      };

      const ensureActiveScope = () => {
        const scopes = getScopes();
        if (!scopes.length) {
          activeScopeId = '';
          if (getScopeMode(activeTabKey) !== 'factory') {
            activePriceScopeAll = false;
          }
          return;
        }
        if (!scopes.some((item) => item.id === activeScopeId)) {
          activeScopeId = scopes[0].id;
        }
        if (getScopeMode(activeTabKey) !== 'factory') {
          activePriceScopeAll = false;
        }
      };

      const getActiveScope = () => getScopes().find((scope) => scope.id === activeScopeId) || getScopes()[0] || null;

      const ensureTodayScopeForDateTab = () => {
        if (getScopeMode(activeTabKey) !== 'date') return false;
        const tab = getTabData();
        if (!tab) return false;
        if (!Array.isArray(tab.rounds)) tab.rounds = [];
        const today = todayDateString();
        const existing = tab.rounds.find(
          (scope) => normalizeDate(scope?.settings?.baseDate || scope?.name || scope?.date || '') === today
        );
        if (existing) {
          activeScopeId = existing.id;
          return false;
        }

        const tabSettings = ensureTabSettings(tab) || normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        const nextScope = {
          id: `date-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
          name: today,
          date: today,
          settings: {
            ...normalizeSettings({}, tabSettings),
            baseDate: today
          },
          rows: []
        };
        tab.rounds.unshift(nextScope);
        activeScopeId = nextScope.id;
        markDirty();
        return true;
      };

      const ensureScopeSettings = (scope, mode = getScopeMode(activeTabKey)) => {
        if (!scope) return null;
        const tab = getTabData();
        const tabSettings = ensureTabSettings(tab) || normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        scope.settings = normalizeSettings(scope.settings || {}, tabSettings);
        if (mode === 'date') {
          const normalizedDate = normalizeDate(scope.settings.baseDate || scope.date || scope.name || todayDateString());
          scope.settings.baseDate = normalizedDate;
          scope.date = normalizedDate;
          scope.name = normalizedDate;
        } else if (mode === 'round') {
          const normalizedDate = normalizeDate(scope.settings.baseDate || scope.date || '');
          scope.settings.baseDate = normalizedDate;
          scope.date = normalizedDate;
        } else {
          const normalizedDate = normalizeDate(scope.settings.baseDate || '');
          scope.settings.baseDate = normalizedDate;
          scope.date = normalizedDate;
        }
        return scope.settings;
      };

      const getActiveSettings = () => {
        const tab = getTabData();
        const mode = getScopeMode(activeTabKey);
        const tabSettings = ensureTabSettings(tab) || normalizeSettings(workbook?.globals || {}, { exchangeRate: 229, shippingFeeKrw: 23000 });
        if (mode === 'factory') {
          return tabSettings;
        }
        const scope = getActiveScope();
        return ensureScopeSettings(scope, mode) || tabSettings;
      };

      const getScopeDisplayName = (scope) => {
        if (!scope) return '-';
        const mode = getScopeMode(activeTabKey);
        if (mode === 'factory' && activePriceScopeAll) {
          return isEn ? 'All Factory Sheets' : '전체 공장 시트';
        }
        const settings = ensureScopeSettings(scope, mode);
        if (mode === 'date') {
          return settings?.baseDate || scope.name || '-';
        }
        if (mode === 'round') {
          return settings?.baseDate ? `${scope.name} (${settings.baseDate})` : (scope.name || '-');
        }
        return scope.name || '-';
      };

      const calcRow = (row) => {
        const settings = getActiveSettings();
        const exchangeRate = Math.max(0.01, toPositive(settings?.exchangeRate, 0.01));
        const shippingFeeKrw = Math.max(0, toPositive(settings?.shippingFeeKrw, 0));
        const costRmb = Math.max(0, toPositive(row?.costRmb, 0));
        const saleKrw = Math.max(0, toPositive(row?.saleKrw, 0));
        const quantity = Math.max(1, Math.floor(toPositive(row?.quantity, 1) || 1));

        const costKrw = Math.round(costRmb * exchangeRate);
        const finalCostKrw = costKrw + Math.round(shippingFeeKrw);
        const marginKrw = saleKrw - finalCostKrw;

        return {
          costKrw,
          finalCostKrw,
          marginKrw,
          totalCostKrw: finalCostKrw * quantity,
          totalSalesKrw: saleKrw * quantity,
          totalMarginKrw: marginKrw * quantity
        };
      };

      const renderMeta = (extraText = '') => {
        const tabDef = getTabDef();
        const scope = getActiveScope();
        const activeSettings = getActiveSettings();
        const updatedAt = activeSettings?.updatedAt
          ? new Date(activeSettings.updatedAt).toLocaleString(isEn ? 'en-US' : 'ko-KR')
          : '-';
        const statusText = dirty ? (isEn ? 'unsaved changes' : '저장되지 않은 변경') : (isEn ? 'saved' : '저장됨');
        const scopeName = getScopeDisplayName(scope);
        const base = isEn
          ? `Tab: ${tabDef?.labelEn || tabDef?.key || '-'} · Scope: ${scopeName} · ${statusText} · Updated: ${updatedAt}`
          : `탭: ${tabDef?.labelKo || tabDef?.key || '-'} · 분류: ${scopeName} · ${statusText} · 마지막 저장: ${updatedAt}`;
        metaText.textContent = extraText ? `${base} · ${extraText}` : base;
      };

      const renderGlobalFields = () => {
        const activeSettings = getActiveSettings();
        if (!activeSettings) return;
        const exchangeRate = Number(roundToStep(toPositive(activeSettings.exchangeRate, 0), 0.01).toFixed(2));
        const shippingKrw = Math.round(roundToStep(toPositive(activeSettings.shippingFeeKrw, 0), 1000));
        exchangeRateInput.value = exchangeRate;
        shippingFeeInput.value = shippingKrw;
        scopeDateInput.value = normalizeDate(activeSettings.baseDate || '');
      };

      const getVisibleRowEntries = () => {
        const scope = getActiveScope();
        if (!scope) {
          return [];
        }
        const mode = getScopeMode(activeTabKey);
        if (mode !== 'factory') {
          const rows = Array.isArray(scope.rows) ? scope.rows : [];
          return rows.map((row) => ({ scope, row }));
        }

        ensurePriceFilters();
        const sourceScopes = getFilteredPriceScopes();
        const allEntries = [];
        sourceScopes.forEach((sourceScope) => {
          const rows = Array.isArray(sourceScope?.rows) ? sourceScope.rows : [];
          rows.forEach((row) => {
            allEntries.push({ scope: sourceScope, row });
          });
        });

        const activeBrandKey = normalizePriceSheetNameKey(activePriceBrand || '');
        const activeModelKey = normalizePriceSheetNameKey(activePriceModel || '');
        return allEntries.filter(({ row }) => {
          const rowBrandKey = normalizePriceSheetNameKey(row?.brand || '');
          const rowModelKey = normalizePriceSheetNameKey(row?.model || '');
          if (activeBrandKey && rowBrandKey !== activeBrandKey) return false;
          if (activeModelKey && rowModelKey !== activeModelKey) return false;
          return true;
        });
      };

      const renderSummary = () => {
        const scope = getActiveScope();
        if (!scope) {
          summaryGrid.innerHTML = '';
          return;
        }

        const visibleEntries = getVisibleRowEntries();
        let totalQty = 0;
        let totalCostKrw = 0;
        let totalSalesKrw = 0;
        let totalMarginKrw = 0;

        visibleEntries.forEach(({ row }) => {
          const qty = Math.max(1, Math.floor(toPositive(row.quantity, 1) || 1));
          const computed = calcRow(row);
          totalQty += qty;
          totalCostKrw += computed.totalCostKrw;
          totalSalesKrw += computed.totalSalesKrw;
          totalMarginKrw += computed.totalMarginKrw;
        });

        const cards = [
          { ko: '행 수', en: 'Rows', value: integerFmt.format(visibleEntries.length) },
          { ko: '총 수량', en: 'Total Qty', value: integerFmt.format(totalQty) },
          { ko: '총 원가', en: 'Total Cost', value: formatKrw(totalCostKrw) },
          { ko: '총 판매', en: 'Total Sales', value: formatKrw(totalSalesKrw) },
          { ko: '총 마진', en: 'Total Margin', value: formatKrw(totalMarginKrw) }
        ];

        summaryGrid.innerHTML = cards
          .map((card) => `
            <article class="sales-summary-card">
              <h4>${isEn ? card.en : card.ko}</h4>
              <strong>${card.value}</strong>
            </article>
          `)
          .join('');
      };

      const updateComputedCells = (tr, row) => {
        const computed = calcRow(row);
        const costCell = tr.querySelector('[data-computed="costKrw"]');
        const finalCostCell = tr.querySelector('[data-computed="finalCostKrw"]');
        const marginCell = tr.querySelector('[data-computed="marginKrw"]');

        if (costCell) costCell.textContent = formatKrw(computed.costKrw);
        if (finalCostCell) finalCostCell.textContent = formatKrw(computed.finalCostKrw);
        if (marginCell) {
          marginCell.textContent = formatKrw(computed.marginKrw);
          marginCell.classList.toggle('is-negative', computed.marginKrw < 0);
          marginCell.classList.toggle('is-positive', computed.marginKrw > 0);
        }
      };

      const renderTableRows = () => {
        const scope = getActiveScope();
        if (!scope) {
          tableBody.innerHTML = `<tr><td colspan="14" class="muted-label">${isEn ? 'No scope selected.' : '선택된 분류가 없습니다.'}</td></tr>`;
          return;
        }

        const isPriceSheet = isPriceTableActive();
        const visibleRowEntries = getVisibleRowEntries();
        if (visibleRowEntries.length === 0) {
          tableBody.innerHTML = `<tr><td colspan="14" class="muted-label">${
            isPriceSheet && activePriceBrand
              ? (isEn ? 'No rows in selected brand/model. Add a row to start.' : '선택한 브랜드/모델 분류에 행이 없습니다. 행 추가로 시작하세요.')
              : (isEn ? 'No rows yet. Add a row to start.' : '행이 없습니다. 행 추가로 시작하세요.')
          }</td></tr>`;
          return;
        }

        tableBody.innerHTML = '';
        visibleRowEntries.forEach((entry, index) => {
          const row = entry.row;
          const rowScope = entry.scope;
          const tr = document.createElement('tr');
          tr.dataset.rowId = row.id;
          tr.dataset.scopeId = String(rowScope?.id || '');
          const defaultFactoryValue = row.factory || (isPriceSheet ? String(rowScope?.name || '') : '');
          const defaultBrandValue = row.brand || (isPriceSheet ? String(activePriceBrand || '') : '');
          const defaultModelValue = row.model || (isPriceSheet ? String(activePriceModel || '') : '');

          const makeCell = (content) => {
            const td = document.createElement('td');
            if (content instanceof HTMLElement) {
              td.appendChild(content);
            } else {
              td.textContent = String(content ?? '');
            }
            return td;
          };

          const makeInput = (field, value, type = 'text', step = '') => {
            const input = document.createElement('input');
            input.type = type;
            if (step) input.step = step;
            if (type === 'number') input.min = '0';
            input.value = value ?? '';
            input.dataset.rowId = row.id;
            input.dataset.field = field;
            input.className = 'sales-inline-input';
            return input;
          };

          const indexCell = makeCell(String(index + 1));
          indexCell.className = 'sales-row-index';
          tr.appendChild(indexCell);
          tr.appendChild(makeCell(makeInput('factory', defaultFactoryValue)));
          tr.appendChild(makeCell(makeInput('brand', defaultBrandValue)));
          tr.appendChild(makeCell(makeInput('model', defaultModelValue)));
          tr.appendChild(makeCell(makeInput('reference', row.reference)));
          tr.appendChild(makeCell(makeInput('spec', row.spec)));
          tr.appendChild(makeCell(makeInput('costRmb', row.costRmb, 'number', '0.01')));

          const costCell = makeCell('-');
          costCell.dataset.computed = 'costKrw';
          costCell.className = 'sales-computed-cell';
          tr.appendChild(costCell);

          const finalCell = makeCell('-');
          finalCell.dataset.computed = 'finalCostKrw';
          finalCell.className = 'sales-computed-cell';
          tr.appendChild(finalCell);

          tr.appendChild(makeCell(makeInput('saleKrw', row.saleKrw, 'number', '1')));

          const marginCell = makeCell('-');
          marginCell.dataset.computed = 'marginKrw';
          marginCell.className = 'sales-computed-cell';
          tr.appendChild(marginCell);

          tr.appendChild(makeCell(makeInput('quantity', row.quantity, 'number', '1')));
          tr.appendChild(makeCell(makeInput('memo', row.memo)));

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'chip';
          deleteBtn.dataset.rowDelete = row.id;
          deleteBtn.textContent = isEn ? 'Delete' : '삭제';
          tr.appendChild(makeCell(deleteBtn));

          updateComputedCells(tr, row);
          tableBody.appendChild(tr);
        });
      };

      const renderScopeControls = () => {
        scopeControls.innerHTML = '';
        if (rowActionHost.parentElement !== scopeToolbar) {
          scopeToolbar.appendChild(rowActionHost);
        }

        const tabDef = getTabDef();
        const tab = getTabData();
        const scopes = getScopes();
        if (!tab) return;
        const scopeMode = getScopeMode(tab.key);

        if (scopeMode === 'factory') {
          const activePriceScope = getActiveScope();
          if (!activePriceScope) {
            return;
          }
          scopes.forEach((scope) => ensureScopeTaxonomy(scope));
          ensurePriceFilters();
          const isAllFactoryScopesSelected = activePriceScopeAll;
          const getCurrentPriceTab = () => getTabData();
          const getCurrentPriceScope = () => getActiveScope();

          const taxonomyPanel = document.createElement('div');
          taxonomyPanel.className = 'sales-price-taxonomy-grid';

          const triggerOnEnter = (input, button) => {
            if (!input || !button) return;
            input.addEventListener('keydown', (event) => {
              if (event.key !== 'Enter' || event.isComposing) return;
              event.preventDefault();
              if (!button.disabled) {
                button.click();
              }
            });
          };

          const factoryRow = document.createElement('div');
          factoryRow.className = 'sales-price-taxonomy-row';
          const factoryTitle = document.createElement('strong');
          factoryTitle.className = 'sales-price-taxonomy-row-title';
          factoryTitle.textContent = isEn ? 'Factory Sheet' : '공장 시트';
          const factorySelect = document.createElement('select');
          const factoryAllOption = document.createElement('option');
          factoryAllOption.value = PRICE_SCOPE_ALL_VALUE;
          factoryAllOption.textContent = isEn ? 'All' : '전체';
          factoryAllOption.selected = isAllFactoryScopesSelected;
          factorySelect.appendChild(factoryAllOption);
          scopes.forEach((scope) => {
            const option = document.createElement('option');
            option.value = scope.id;
            option.textContent = scope.name;
            option.selected = !isAllFactoryScopesSelected && scope.id === activeScopeId;
            factorySelect.appendChild(option);
          });
          factorySelect.addEventListener('change', () => {
            if (factorySelect.value === PRICE_SCOPE_ALL_VALUE) {
              activePriceScopeAll = true;
            } else {
              activePriceScopeAll = false;
              activeScopeId = factorySelect.value;
            }
            activePriceBrand = '';
            activePriceModel = '';
            ensurePriceFilters();
            clearError();
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          const factoryNameInput = document.createElement('input');
          factoryNameInput.type = 'text';
          factoryNameInput.placeholder = isEn ? 'Factory sheet name' : '공장 시트명';
          factoryNameInput.value = isAllFactoryScopesSelected ? '' : String(activePriceScope?.name || '');

          const factoryActions = document.createElement('div');
          factoryActions.className = 'sales-price-taxonomy-actions';

          const addFactoryBtn = document.createElement('button');
          addFactoryBtn.type = 'button';
          addFactoryBtn.className = 'chip';
          addFactoryBtn.textContent = isEn ? 'Add' : '추가';
          addFactoryBtn.addEventListener('click', () => {
            const currentTab = getCurrentPriceTab();
            if (!currentTab) return;
            const nextName =
              normalizePriceSheetName(factoryNameInput.value, 80) || (isEn ? 'New Factory' : '새 공장');
            if (!Array.isArray(currentTab.groups)) currentTab.groups = [];
            currentTab.groups.push({
              id: `scope-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
              name: nextName,
              settings: normalizeSettings({}, ensureTabSettings(currentTab)),
              taxonomy: { brands: [] },
              rows: []
            });
            activePriceScopeAll = false;
            activeScopeId = currentTab.groups[currentTab.groups.length - 1].id;
            activePriceBrand = '';
            activePriceModel = '';
            ensurePriceFilters();
            markDirty(isEn ? 'factory sheet added (auto-save)' : '공장 시트 추가됨 (자동 저장)');
            clearError();
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const renameFactoryBtn = document.createElement('button');
          renameFactoryBtn.type = 'button';
          renameFactoryBtn.className = 'chip';
          renameFactoryBtn.textContent = isEn ? 'Rename' : '이름변경';
          renameFactoryBtn.disabled = isAllFactoryScopesSelected || !activePriceScope;
          renameFactoryBtn.addEventListener('click', () => {
            const scope = getCurrentPriceScope();
            if (isAllFactoryScopesSelected || !scope) return;
            const previousName = normalizePriceSheetName(scope.name, 80);
            const nextName = normalizePriceSheetName(factoryNameInput.value, 80);
            if (!nextName) return;
            scope.name = nextName;
            if (Array.isArray(scope.rows)) {
              scope.rows.forEach((row) => {
                const rowFactoryName = normalizePriceSheetName(row?.factory || '', 80);
                if (!rowFactoryName || rowFactoryName === previousName) {
                  row.factory = nextName;
                }
              });
            }
            markDirty(isEn ? 'factory sheet renamed (auto-save)' : '공장 시트 이름 변경됨 (자동 저장)');
            clearError();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const deleteFactoryBtn = document.createElement('button');
          deleteFactoryBtn.type = 'button';
          deleteFactoryBtn.className = 'chip';
          deleteFactoryBtn.textContent = isEn ? 'Delete' : '삭제';
          deleteFactoryBtn.disabled =
            isAllFactoryScopesSelected || !Array.isArray(tab.groups) || tab.groups.length <= 1;
          deleteFactoryBtn.addEventListener('click', () => {
            const currentTab = getCurrentPriceTab();
            if (!currentTab) return;
            if (!Array.isArray(currentTab.groups) || currentTab.groups.length <= 1) {
              showError(isEn ? 'At least one factory sheet is required.' : '공장 시트는 최소 1개가 필요합니다.');
              return;
            }
            clearError();
            currentTab.groups = currentTab.groups.filter((scope) => scope.id !== activeScopeId);
            activePriceScopeAll = false;
            activeScopeId = currentTab.groups[0]?.id || '';
            activePriceBrand = '';
            activePriceModel = '';
            ensurePriceFilters();
            markDirty(isEn ? 'factory sheet deleted (auto-save)' : '공장 시트 삭제됨 (자동 저장)');
            renderGlobalFields();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          triggerOnEnter(factoryNameInput, addFactoryBtn);
          factoryActions.append(addFactoryBtn, renameFactoryBtn, deleteFactoryBtn);
          factoryRow.append(factoryTitle, factorySelect, factoryNameInput, factoryActions);
          taxonomyPanel.appendChild(factoryRow);

          const brandRow = document.createElement('div');
          brandRow.className = 'sales-price-taxonomy-row';
          const brandTitle = document.createElement('strong');
          brandTitle.className = 'sales-price-taxonomy-row-title';
          brandTitle.textContent = isEn ? 'Brand' : '브랜드';
          const brandSelect = document.createElement('select');
          const brandNames = getPriceBrandNames(getFilteredPriceScopes());
          const brandPlaceholder = document.createElement('option');
          brandPlaceholder.value = '';
          brandPlaceholder.textContent = isEn ? 'All' : '전체';
          brandSelect.appendChild(brandPlaceholder);
          brandNames.forEach((brandName) => {
            const option = document.createElement('option');
            option.value = brandName;
            option.textContent = brandName;
            option.selected =
              normalizePriceSheetNameKey(brandName) === normalizePriceSheetNameKey(activePriceBrand || '');
            brandSelect.appendChild(option);
          });
          brandSelect.addEventListener('change', () => {
            activePriceBrand = brandSelect.value || '';
            activePriceModel = '';
            ensurePriceFilters();
            clearError();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          const brandInput = document.createElement('input');
          brandInput.type = 'text';
          brandInput.placeholder = isEn ? 'Brand name' : '브랜드명';
          brandInput.value = activePriceBrand || '';
          brandInput.disabled = isAllFactoryScopesSelected;
          const addBrandBtn = document.createElement('button');
          addBrandBtn.type = 'button';
          addBrandBtn.className = 'chip';
          addBrandBtn.textContent = isEn ? 'Add' : '추가';
          addBrandBtn.disabled = isAllFactoryScopesSelected;
          addBrandBtn.addEventListener('click', () => {
            const currentScope = getCurrentPriceScope();
            if (isAllFactoryScopesSelected) {
              showError(isEn ? 'Select a factory sheet first.' : '먼저 공장 시트를 선택해 주세요.');
              return;
            }
            if (!currentScope) return;
            const nextBrandName = normalizePriceSheetName(brandInput.value, 80);
            if (!nextBrandName) {
              showError(isEn ? 'Enter a brand name.' : '브랜드명을 입력해 주세요.');
              return;
            }
            if (findPriceBrandEntry(currentScope, nextBrandName)) {
              showError(isEn ? 'Brand already exists.' : '이미 존재하는 브랜드입니다.');
              return;
            }
            const taxonomy = ensureScopeTaxonomy(currentScope);
            taxonomy.brands.push({ name: nextBrandName, models: [] });
            taxonomy.brands.sort((a, b) => comparePriceSheetNames(a.name, b.name));
            activePriceBrand = nextBrandName;
            activePriceModel = '';
            markDirty(isEn ? 'brand group added (auto-save)' : '브랜드 분류 추가됨 (자동 저장)');
            clearError();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          const renameBrandBtn = document.createElement('button');
          renameBrandBtn.type = 'button';
          renameBrandBtn.className = 'chip';
          renameBrandBtn.textContent = isEn ? 'Rename' : '이름변경';
          renameBrandBtn.disabled = isAllFactoryScopesSelected || !activePriceBrand;
          renameBrandBtn.addEventListener('click', () => {
            const currentScope = getCurrentPriceScope();
            if (isAllFactoryScopesSelected) {
              showError(isEn ? 'Select a factory sheet first.' : '먼저 공장 시트를 선택해 주세요.');
              return;
            }
            if (!currentScope) return;
            if (!activePriceBrand) {
              showError(isEn ? 'Select a brand first.' : '먼저 브랜드를 선택해 주세요.');
              return;
            }
            const nextBrandName = normalizePriceSheetName(brandInput.value, 80);
            if (!nextBrandName) {
              showError(isEn ? 'Enter a brand name.' : '브랜드명을 입력해 주세요.');
              return;
            }
            const currentBrandEntry = findPriceBrandEntry(currentScope, activePriceBrand);
            if (!currentBrandEntry) {
              showError(isEn ? 'Brand not found.' : '브랜드를 찾을 수 없습니다.');
              return;
            }
            const duplicatedEntry = findPriceBrandEntry(currentScope, nextBrandName);
            if (
              duplicatedEntry &&
              normalizePriceSheetNameKey(duplicatedEntry.name) !== normalizePriceSheetNameKey(currentBrandEntry.name)
            ) {
              showError(isEn ? 'Brand already exists.' : '이미 존재하는 브랜드입니다.');
              return;
            }
            const prevBrandKey = normalizePriceSheetNameKey(currentBrandEntry.name);
            currentBrandEntry.name = nextBrandName;
            const taxonomy = ensureScopeTaxonomy(currentScope);
            taxonomy.brands.sort((a, b) => comparePriceSheetNames(a.name, b.name));
            if (Array.isArray(currentScope.rows)) {
              currentScope.rows.forEach((row) => {
                if (normalizePriceSheetNameKey(row?.brand || '') === prevBrandKey) {
                  row.brand = nextBrandName;
                }
              });
            }
            activePriceBrand = nextBrandName;
            ensurePriceFilters();
            markDirty(isEn ? 'brand group renamed (auto-save)' : '브랜드 분류 이름 변경됨 (자동 저장)');
            clearError();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          const deleteBrandBtn = document.createElement('button');
          deleteBrandBtn.type = 'button';
          deleteBrandBtn.className = 'chip';
          deleteBrandBtn.textContent = isEn ? 'Delete' : '삭제';
          deleteBrandBtn.disabled = isAllFactoryScopesSelected || !activePriceBrand;
          deleteBrandBtn.addEventListener('click', () => {
            const currentScope = getCurrentPriceScope();
            if (isAllFactoryScopesSelected) {
              showError(isEn ? 'Select a factory sheet first.' : '먼저 공장 시트를 선택해 주세요.');
              return;
            }
            if (!currentScope) return;
            if (!activePriceBrand) {
              showError(isEn ? 'Select a brand first.' : '먼저 브랜드를 선택해 주세요.');
              return;
            }
            const targetBrandKey = normalizePriceSheetNameKey(activePriceBrand);
            const taxonomy = ensureScopeTaxonomy(currentScope);
            taxonomy.brands = taxonomy.brands.filter(
              (brandItem) => normalizePriceSheetNameKey(brandItem.name) !== targetBrandKey
            );
            if (Array.isArray(currentScope.rows)) {
              currentScope.rows = currentScope.rows.filter(
                (row) => normalizePriceSheetNameKey(row?.brand || '') !== targetBrandKey
              );
            }
            activePriceBrand = '';
            activePriceModel = '';
            ensurePriceFilters();
            markDirty(isEn ? 'brand group deleted (auto-save)' : '브랜드 분류 삭제됨 (자동 저장)');
            clearError();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });
          triggerOnEnter(brandInput, addBrandBtn);
          const brandActions = document.createElement('div');
          brandActions.className = 'sales-price-taxonomy-actions';
          brandActions.append(addBrandBtn, renameBrandBtn, deleteBrandBtn);
          brandRow.append(brandTitle, brandSelect, brandInput, brandActions);
          taxonomyPanel.appendChild(brandRow);

          const modelRow = document.createElement('div');
          modelRow.className = 'sales-price-taxonomy-row';
          const modelTitle = document.createElement('strong');
          modelTitle.className = 'sales-price-taxonomy-row-title';
          modelTitle.textContent = isEn ? 'Model' : '모델';
          const modelSelect = document.createElement('select');
          const modelNames = getPriceModelNames(getFilteredPriceScopes(), activePriceBrand);
          const modelPlaceholder = document.createElement('option');
          modelPlaceholder.value = '';
          modelPlaceholder.textContent = isEn ? 'All' : '전체';
          modelSelect.appendChild(modelPlaceholder);
          modelNames.forEach((modelName) => {
            const option = document.createElement('option');
            option.value = modelName;
            option.textContent = modelName;
            option.selected =
              normalizePriceSheetNameKey(modelName) === normalizePriceSheetNameKey(activePriceModel || '');
            modelSelect.appendChild(option);
          });
          modelSelect.addEventListener('change', () => {
            activePriceModel = modelSelect.value || '';
            ensurePriceFilters();
            clearError();
            renderScopeControls();
            renderTableRows();
            renderSummary();
            renderMeta();
          });

          const modelInput = document.createElement('input');
          modelInput.type = 'text';
          modelInput.placeholder = isEn ? 'Model name' : '모델명';
          modelInput.value = activePriceModel || '';
          modelInput.disabled = isAllFactoryScopesSelected;

          const addModelBtn = document.createElement('button');
          addModelBtn.type = 'button';
          addModelBtn.className = 'chip';
          addModelBtn.textContent = isEn ? 'Add' : '추가';
