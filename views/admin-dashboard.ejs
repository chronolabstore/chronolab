              <thead>
                <tr>
                  <th><%= isEn ? 'Time' : '시간' %></th>
                  <th><%= isEn ? 'Admin' : '관리자' %></th>
                  <th>IP</th>
                  <th><%= isEn ? 'Device' : '접속기기' %></th>
                  <th><%= isEn ? 'Method/Path' : '메서드/경로' %></th>
                  <th><%= isEn ? 'Action' : '행동' %></th>
                  <th><%= isEn ? 'Detail' : '상세' %></th>
                </tr>
              </thead>
              <tbody>
                <% if (security.subAdminLogs.length === 0) { %>
                  <tr><td colspan="7"><%= isEn ? 'No admin logs found.' : '조건에 맞는 관리자 로그가 없습니다.' %></td></tr>
                <% } %>
                <% security.subAdminLogs.forEach((log) => { %>
                  <tr>
                    <td><%= log.created_at ? log.created_at.slice(0, 16) : '-' %></td>
                    <td><%= log.admin_username %></td>
                    <td><%= log.ip_address || '-' %></td>
                    <td><%= log.user_agent || '-' %></td>
                    <td><%= log.method %> <%= log.path %></td>
                    <td><%= log.action_type %></td>
                    <td><%= log.detail || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="admin-pagination">
            <% if (logPager.page > 1) { %>
              <a
                class="chip"
                href="/admin/security?section=logs&logPage=<%= logPager.page - 1 %><%= Number(logFilters.adminId || 0) > 0 ? `&logAdminId=${Number(logFilters.adminId)}` : '' %><%= logFilters.from ? `&logFrom=${encodeURIComponent(logFilters.from)}` : '' %><%= logFilters.to ? `&logTo=${encodeURIComponent(logFilters.to)}` : '' %>"
              ><%= isEn ? 'Prev' : '이전' %></a>
            <% } %>
            <span class="chip muted"><%= logPager.page %> / <%= logPager.totalPages %></span>
            <% if (logPager.page < logPager.totalPages) { %>
              <a
                class="chip"
                href="/admin/security?section=logs&logPage=<%= logPager.page + 1 %><%= Number(logFilters.adminId || 0) > 0 ? `&logAdminId=${Number(logFilters.adminId)}` : '' %><%= logFilters.from ? `&logFrom=${encodeURIComponent(logFilters.from)}` : '' %><%= logFilters.to ? `&logTo=${encodeURIComponent(logFilters.to)}` : '' %>"
              ><%= isEn ? 'Next' : '다음' %></a>
            <% } %>
          </div>
        </section>
      <% } %>

      <% if (securityTab === 'alerts') { %>
        <section class="kpi-card">
          <h4><%= isEn ? 'Admin Security Alerts' : '관리자 보안 알림' %></h4>
          <% const alertFilters = (security.filters && security.filters.alert) ? security.filters.alert : { from: '', to: '', adminId: 0 }; %>
          <% const alertPager = (security.pagination && security.pagination.alert) ? security.pagination.alert : { page: 1, totalPages: 1, totalCount: security.securityAlerts.length }; %>
          <form method="get" action="/admin/security" class="admin-filter-row">
            <input type="hidden" name="section" value="alerts" />
            <label class="admin-filter-item">
              <span><%= isEn ? 'Admin' : '관리자' %></span>
              <select name="alertAdminId">
                <option value=""><%= isEn ? 'All Admins' : '전체 관리자' %></option>
                <% security.adminUsers.forEach((adminItem) => { %>
                  <option value="<%= adminItem.id %>" <%= Number(alertFilters.adminId || 0) === Number(adminItem.id) ? 'selected' : '' %>>
                    <%= adminItem.username %> (<%= adminItem.admin_role_label %>)
                  </option>
