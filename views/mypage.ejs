<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>
<% const activeSection = myPageSection || 'info'; %>
<% const filters = myPageFilters || { group: 'all', dateFrom: '', dateTo: '' }; %>
<% const groups = Array.isArray(myPageGroups) ? myPageGroups : []; %>
<% const profile = profileForm || {}; %>
<% const addressBook = Array.isArray(addressBookEntries) ? addressBookEntries : []; %>
<% const summary = myPageSummary || { totalPurchaseAmount: 0, totalEarnedPoints: 0, usedPoints: 0, availablePoints: 0, cartCount: 0 }; %>
<% const profileImage = profile.profileImagePath || ''; %>
<% const nickname = profile.nickname || profile.username || (ctx.currentUser && ctx.currentUser.username) || '-'; %>
<% const email = profile.email || (ctx.currentUser && ctx.currentUser.email) || '-'; %>

<section class="block-card">
  <div class="section-head">
    <h2><%= isEn ? 'My Page' : '마이페이지' %></h2>
  </div>

  <div class="chip-row mypage-tab-row">
    <a href="/mypage?section=info" class="chip <%= activeSection === 'info' ? 'dark' : '' %>">
      <%= isEn ? 'My Info' : '내 정보' %>
    </a>
    <a href="/mypage?section=orders" class="chip <%= activeSection === 'orders' ? 'dark' : '' %>">
      <%= isEn ? 'Order Status' : '주문 현황' %>
    </a>
    <a href="/mypage?section=profile" class="chip <%= activeSection === 'profile' ? 'dark' : '' %>">
      <%= isEn ? 'Profile Settings' : '정보 설정' %>
    </a>
  </div>

  <% if (activeSection === 'info') { %>
    <div class="mypage-info-layout">
      <article class="mypage-info-hero">
        <div class="mypage-avatar-wrap">
          <form method="post" action="/mypage/profile/avatar" enctype="multipart/form-data" class="mypage-avatar-inline-form" id="mypageAvatarForm">
            <% if (profileImage) { %>
              <img src="<%= profileImage %>" alt="Profile" class="mypage-avatar" />
            <% } else { %>
              <div class="mypage-avatar mypage-avatar-fallback"><%= String(nickname || '?').slice(0, 1).toUpperCase() %></div>
            <% } %>
            <input type="file" name="profileImage" accept="image/*" class="mypage-avatar-input" id="mypageAvatarInput" />
            <button
              type="button"
              class="mypage-avatar-upload-btn"
              id="mypageAvatarTrigger"
              aria-label="<%= isEn ? 'Change profile photo' : '프로필 사진 변경' %>"
              title="<%= isEn ? 'Change profile photo' : '프로필 사진 변경' %>"
            >
              +
            </button>
          </form>
        </div>
        <h3><%= nickname %></h3>
        <p><%= email %></p>
      </article>

      <article class="mypage-info-stats">
        <div class="mypage-stat-card">
          <h4><%= isEn ? 'Total Purchase Amount' : '누적 구매 금액' %></h4>
          <strong>₩<%= ctx.formatPrice(summary.totalPurchaseAmount || 0) %></strong>
        </div>
        <div class="mypage-stat-card">
          <h4><%= isEn ? 'Total Earned Points' : '누적 포인트' %></h4>
          <strong><%= ctx.formatPrice(summary.totalEarnedPoints || 0) %>P</strong>
        </div>
        <div class="mypage-stat-card">
          <h4><%= isEn ? 'Used Points' : '사용 포인트' %></h4>
          <strong><%= ctx.formatPrice(summary.usedPoints || 0) %>P</strong>
        </div>
        <div class="mypage-stat-card">
          <h4><%= isEn ? 'Available Points' : '사용 가능 포인트' %></h4>
          <strong><%= ctx.formatPrice(summary.availablePoints || 0) %>P</strong>
        </div>
        <div class="mypage-stat-card">
          <h4><%= isEn ? 'Cart' : '장바구니' %></h4>
          <strong><%= ctx.formatPrice(summary.cartCount || 0) %></strong>
        </div>
      </article>
    </div>
  <% } else if (activeSection === 'profile') { %>
    <div class="mypage-profile-grid">
      <article class="mypage-panel">
        <h3><%= isEn ? 'Profile Information' : '기본 정보 설정' %></h3>
        <p class="muted-label"><%= isEn ? 'Saved values are used as defaults on purchase request pages.' : '여기에 저장한 값은 구매신청 페이지 기본값으로 사용됩니다.' %></p>

        <form method="post" action="/mypage/profile/update" class="form-grid mypage-form-grid">
          <label><%= isEn ? 'Name' : '이름' %>
            <input type="text" name="fullName" maxlength="80" value="<%= profile.fullName || '' %>" />
          </label>

          <label><%= isEn ? 'Contact' : '연락처' %>
            <input type="text" name="phone" maxlength="20" value="<%= profile.phone || '' %>" />
          </label>

          <label><%= isEn ? 'Customs Clearance No.' : '통관번호' %>
            <input type="text" name="customsClearanceNo" maxlength="30" value="<%= profile.customsClearanceNo || '' %>" />
          </label>

          <label><%= isEn ? 'Postcode' : '우편번호' %>
            <div class="field-inline">
              <input type="text" name="defaultPostcode" id="defaultPostcode" maxlength="5" value="<%= profile.defaultPostcode || '' %>" readonly />
              <button type="button" class="chip field-inline-btn" id="defaultAddressSearchBtn"><%= isEn ? 'Search Address' : '주소찾기' %></button>
            </div>
          </label>

          <label><%= isEn ? 'Main Address' : '기본주소' %>
            <input type="text" name="defaultAddressBase" id="defaultAddressBase" maxlength="160" value="<%= profile.defaultAddressBase || '' %>" readonly />
          </label>

          <label><%= isEn ? 'Detailed Address' : '상세주소' %>
            <input type="text" name="defaultAddressDetail" id="defaultAddressDetail" maxlength="120" value="<%= profile.defaultAddressDetail || '' %>" />
          </label>

          <button type="submit" class="cta-main full mypage-form-btn"><%= isEn ? 'Save Profile' : '정보 저장' %></button>
        </form>

        <div class="mypage-addressbook-section">
          <h4><%= isEn ? 'Address Book' : '주소록' %></h4>
          <p class="muted-label"><%= isEn ? 'Save extra addresses and select them quickly during purchase.' : '추가 주소를 저장해 두고 주문서에서 빠르게 선택할 수 있습니다.' %></p>

          <form method="post" action="/mypage/address-book/add" class="form-grid mypage-form-grid">
            <label><%= isEn ? 'Address Label' : '주소록 이름' %>
              <input type="text" name="label" maxlength="40" placeholder="<%= isEn ? 'e.g. Home / Office' : '예: 집 / 회사' %>" required />
            </label>

            <label><%= isEn ? 'Postcode' : '우편번호' %>
              <div class="field-inline">
                <input type="text" name="postcode" id="addressBookPostcode" maxlength="5" readonly required />
                <button type="button" class="chip field-inline-btn" id="addressBookSearchBtn"><%= isEn ? 'Search Address' : '주소찾기' %></button>
              </div>
            </label>

            <label><%= isEn ? 'Main Address' : '기본주소' %>
              <input type="text" name="addressBase" id="addressBookBase" maxlength="160" readonly required />
            </label>

            <label><%= isEn ? 'Detailed Address' : '상세주소' %>
              <input type="text" name="addressDetail" id="addressBookDetail" maxlength="120" />
            </label>

            <label class="check-row">
              <input type="checkbox" name="setAsDefault" value="1" />
              <span><%= isEn ? 'Set as default address' : '기본주소로 설정' %></span>
            </label>

            <button type="submit" class="cta-main full mypage-form-btn"><%= isEn ? 'Add Address' : '주소록 추가' %></button>
          </form>

          <div class="mypage-addressbook-list">
            <% if (addressBook.length === 0) { %>
              <div class="muted-label"><%= isEn ? 'No saved addresses.' : '저장된 주소록이 없습니다.' %></div>
            <% } %>

            <% addressBook.forEach((entry) => { %>
              <article class="mypage-addressbook-item <%= entry.isDefault ? 'is-default' : '' %>">
                <div class="mypage-addressbook-head">
                  <strong><%= entry.label %></strong>
                  <% if (entry.isDefault) { %>
                    <span class="chip dark"><%= isEn ? 'Default' : '기본주소' %></span>
                  <% } %>
                </div>
                <p><%= entry.fullAddress %></p>
                <div class="mypage-addressbook-actions">
                  <% if (!entry.isDefault) { %>
                    <form method="post" action="/mypage/address-book/<%= entry.id %>/default">
                      <button type="submit" class="chip"><%= isEn ? 'Set Default' : '기본으로' %></button>
                    </form>
                  <% } %>
                  <form method="post" action="/mypage/address-book/<%= entry.id %>/delete" onsubmit="return confirm('<%= isEn ? 'Delete this address?' : '이 주소를 삭제할까요?' %>');">
                    <button type="submit" class="chip"><%= isEn ? 'Delete' : '삭제' %></button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </article>

      <article class="mypage-panel">
        <h3><%= isEn ? 'Change Password' : '비밀번호 변경' %></h3>
        <p class="muted-label"><%= isEn ? 'Enter your current password first, then set a new one.' : '현재 비밀번호를 먼저 입력한 뒤 새 비밀번호를 설정해 주세요.' %></p>

        <form method="post" action="/mypage/profile/password" class="form-grid mypage-form-grid">
          <label><%= isEn ? 'Current Password' : '현재 비밀번호' %>
            <input type="password" name="currentPassword" required />
          </label>

          <label><%= isEn ? 'New Password' : '새 비밀번호' %>
            <input type="password" name="newPassword" required />
          </label>

          <label><%= isEn ? 'Confirm New Password' : '새 비밀번호 확인' %>
            <input type="password" name="newPasswordConfirm" required />
          </label>

          <button type="submit" class="cta-main full mypage-form-btn"><%= isEn ? 'Change Password' : '비밀번호 변경' %></button>
        </form>
      </article>
    </div>
  <% } else { %>
    <form method="get" action="/mypage" class="admin-filter-row mypage-order-filter-row">
      <input type="hidden" name="section" value="orders" />
      <input type="hidden" name="group" value="<%= filters.group || 'all' %>" id="mypageGroupInput" />

      <div class="admin-filter-item mypage-group-filter-item">
        <span><%= isEn ? 'Shop Category' : '쇼핑몰 분류' %></span>
        <div class="chip-row mypage-group-chip-row" id="mypageGroupChips">
          <button type="button" class="chip <%= filters.group === 'all' ? 'dark' : '' %>" data-group="all"><%= isEn ? 'All' : '전체' %></button>
          <% groups.forEach((group) => { %>
            <button type="button" class="chip <%= filters.group === group.key ? 'dark' : '' %>" data-group="<%= group.key %>"><%= group.label %></button>
          <% }) %>
        </div>
      </div>

      <label class="admin-filter-item">
        <span><%= isEn ? 'From Date' : '시작일' %></span>
        <input type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
      </label>

      <label class="admin-filter-item">
        <span><%= isEn ? 'To Date' : '종료일' %></span>
        <input type="date" name="dateTo" value="<%= filters.dateTo || '' %>" />
      </label>

      <div class="admin-filter-actions">
        <button type="submit" class="chip dark"><%= isEn ? 'Filter' : '조회' %></button>
        <a href="/mypage?section=orders" class="chip"><%= isEn ? 'Reset' : '초기화' %></a>
      </div>
    </form>

    <div class="table-wrap">
      <table class="mypage-order-table">
        <thead>
          <tr>
            <th><%= isEn ? 'Order No.' : '구매번호' %></th>
            <th><%= isEn ? 'Category' : '분류' %></th>
            <th><%= isEn ? 'Product' : '상품' %></th>
            <th><%= isEn ? 'My Info' : '주문자 정보' %></th>
            <th><%= isEn ? 'Status' : '상태' %></th>
            <th><%= isEn ? 'Points' : '적립포인트' %></th>
            <th><%= isEn ? 'Tracking' : '송장' %></th>
            <th><%= isEn ? 'Requested' : '신청일' %></th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr>
              <td colspan="8"><%= isEn ? 'No order history found.' : '조건에 맞는 주문 내역이 없습니다.' %></td>
            </tr>
          <% } %>
          <% orders.forEach((item) => { %>
            <tr>
              <td><%= item.order_no %></td>
              <td><%= item.category_group_label || item.category_group || '-' %></td>
              <td>
                <strong><%= item.brand %> <%= item.model %></strong><br />
                <small><%= item.sub_model || '-' %></small>
              </td>
              <td>
                <strong><%= item.buyer_name %></strong><br />
                <small><%= item.buyer_contact %></small><br />
                <small><%= isEn ? 'Customs' : '통관번호' %>: <%= item.customs_clearance_no || '-' %></small><br />
                <small><%= item.buyer_address || '-' %></small>
              </td>
              <td>
                <span class="order-status"><%= item.status_label %></span>
                <% if (item.status_detail) { %>
                  <small class="muted-label"><%= item.status_detail %></small>
                <% } %>
                <% if (item.latest_event_at) { %>
                  <small class="muted-label"><%= isEn ? 'Updated' : '최근 변경' %>: <%= item.latest_event_at.slice(0, 16) %></small>
                <% } %>
              </td>
              <td><%= Number(item.awarded_points || 0) > 0 ? `${ctx.formatPrice(item.awarded_points)}P` : '-' %></td>
              <td>
                <% if (item.tracking_number) { %>
                  <small><strong><%= item.tracking_carrier_label || item.tracking_carrier || '-' %></strong></small><br />
                  <small><%= item.tracking_number %></small><br />
                  <small><%= item.tracking_last_event || '-' %></small><br />
                  <small><%= item.tracking_last_checked_at ? item.tracking_last_checked_at.slice(0, 16) : '-' %></small>
                <% } else { %>
                  <small>-</small>
                <% } %>
              </td>
              <td><%= item.created_at ? item.created_at.slice(0, 16) : '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
  (() => {
    const isEn = <%= isEn ? 'true' : 'false' %>;
    const chips = document.querySelectorAll('#mypageGroupChips [data-group]');
    const groupInput = document.getElementById('mypageGroupInput');
    const form = groupInput?.closest('form');
    if (chips.length && groupInput && form) {
      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const targetGroup = chip.getAttribute('data-group') || 'all';
          groupInput.value = targetGroup;
          form.requestSubmit();
        });
      });
    }

    const avatarTrigger = document.getElementById('mypageAvatarTrigger');
    const avatarInput = document.getElementById('mypageAvatarInput');
    const avatarForm = document.getElementById('mypageAvatarForm');
    if (avatarTrigger && avatarInput && avatarForm) {
      avatarTrigger.addEventListener('click', () => {
        avatarInput.click();
      });

      avatarInput.addEventListener('change', () => {
        if (!avatarInput.files || avatarInput.files.length === 0) return;
        if (typeof avatarForm.requestSubmit === 'function') {
          avatarForm.requestSubmit();
          return;
        }
        avatarForm.submit();
      });
    }

    const openAddressSearch = (postcodeId, baseId, detailId) => {
      if (!window.daum || !window.daum.Postcode) {
        window.alert(isEn ? 'Address search is unavailable right now.' : '주소 검색 서비스를 불러올 수 없습니다.');
        return;
      }

      const postcodeInput = document.getElementById(postcodeId);
      const baseInput = document.getElementById(baseId);
      const detailInput = document.getElementById(detailId);
      if (!postcodeInput || !baseInput) return;

      new window.daum.Postcode({
        oncomplete(data) {
          postcodeInput.value = data.zonecode || '';
          baseInput.value = data.roadAddress || data.jibunAddress || '';
          if (detailInput) {
            detailInput.focus();
          }
        }
      }).open();
    };

    const defaultAddressSearchBtn = document.getElementById('defaultAddressSearchBtn');
    if (defaultAddressSearchBtn) {
      defaultAddressSearchBtn.addEventListener('click', () => {
        openAddressSearch('defaultPostcode', 'defaultAddressBase', 'defaultAddressDetail');
      });
    }

    const addressBookSearchBtn = document.getElementById('addressBookSearchBtn');
    if (addressBookSearchBtn) {
      addressBookSearchBtn.addEventListener('click', () => {
        openAddressSearch('addressBookPostcode', 'addressBookBase', 'addressBookDetail');
      });
    }
  })();
</script>

<%- include('partials/layout-end') %>
