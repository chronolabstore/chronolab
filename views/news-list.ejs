<%- include('partials/layout-start') %>

<section class="block-card">
  <div class="section-head">
    <h2><%= ctx.lang === 'en' ? 'News' : '뉴스' %></h2>
  </div>

  <div class="news-blog-list">
    <% if (newsPosts.length === 0) { %>
      <p><%= ctx.lang === 'en' ? 'No news posts found.' : '등록된 뉴스가 없습니다.' %></p>
    <% } %>

    <% newsPosts.forEach((item) => { %>
      <article class="news-blog-item">
        <% if (item.image_path) { %>
          <a href="/news/<%= item.id %>" class="news-blog-cover-wrap">
            <img src="<%= item.image_path %>" alt="<%= item.title %>" class="news-blog-cover" />
          </a>
        <% } %>
        <div class="news-blog-body">
          <h3><a href="/news/<%= item.id %>"><%= item.title %></a></h3>
          <p><%= item.content.length > 220 ? item.content.slice(0, 220) + '...' : item.content %></p>
          <div class="news-blog-meta">
            <span><%= item.created_at.slice(0, 10) %></span>
            <a href="/news/<%= item.id %>" class="chip"><%= ctx.lang === 'en' ? 'Read more' : '자세히 보기' %></a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/layout-end') %>
