<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="block-card">
  <div class="section-head">
    <h2><%= isEn ? 'Reviews' : '구매후기' %></h2>
  </div>
  <p class="muted-label">
    <%= isEn ? 'Review writing is available only from My Page > Orders after delivery completion.' : '후기 작성은 배송완료 후 마이페이지 > 구매목록에서만 가능합니다.' %>
  </p>

  <div class="review-grid">
    <% if (reviews.length === 0) { %>
      <p><%= isEn ? 'No reviews yet.' : '아직 등록된 후기가 없습니다.' %></p>
    <% } %>

    <% reviews.forEach((item) => { %>
      <article class="review-card">
        <% if (item.image_path) { %>
          <img src="<%= item.image_path %>" alt="review" />
        <% } %>
        <h3><%= item.title %></h3>
        <p><%= item.content %></p>
        <small>
          <%= isEn ? 'Writer' : '작성자' %> <%= maskUsername(item.username) %>
          <% if (item.brand) { %>
            / <%= item.brand %> <%= item.model %> <%= item.sub_model %>
          <% } %>
        </small>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/layout-end') %>
