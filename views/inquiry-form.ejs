<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="block-card narrow">
  <h2><%= isEn ? 'Write Inquiry' : '문의 작성' %></h2>
  <p class="muted-label"><%= isEn ? 'Only the writer and admin can view this inquiry.' : '문의 내용은 작성자와 어드민만 확인 가능합니다.' %></p>
  <form method="post" action="/inquiry/new" enctype="multipart/form-data" class="form-grid">
    <label><%= isEn ? 'Title' : '제목' %>
      <input type="text" name="title" required />
    </label>

    <label><%= isEn ? 'Content' : '내용' %>
      <textarea name="content" rows="6" required></textarea>
    </label>

    <label><%= isEn ? 'Images (optional, multiple)' : '이미지 (선택, 여러 장 가능)' %>
      <input type="file" name="image" accept="image/*" multiple />
    </label>

    <button type="submit" class="cta-main"><%= isEn ? 'Submit Inquiry' : '문의 등록' %></button>
  </form>
</section>

<%- include('partials/layout-end') %>
