<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="block-card narrow">
  <h2><%= inquiry.title %></h2>
  <p class="muted-label"><%= isEn ? 'Writer' : '작성자' %>: <%= writerMasked %> / <%= inquiry.created_at.slice(0, 10) %></p>

  <% if (canOpen) { %>
    <article class="content-article"><%= inquiry.content %></article>
    <% if (inquiry.image_path) { %>
      <img src="<%= inquiry.image_path %>" alt="inquiry image" class="notice-image" data-lightbox-enabled="1" />
    <% } %>

    <div class="notice-box">
      <h4><%= isEn ? 'Admin Reply' : '어드민 답변' %></h4>
      <p><%= inquiry.reply_content || (isEn ? 'No reply has been posted yet.' : '아직 답변이 등록되지 않았습니다.') %></p>
    </div>
  <% } else { %>
    <p><%= ctx.t('inquiryLocked') %></p>
  <% } %>

  <a href="/inquiry" class="chip"><%= isEn ? 'Back to list' : '목록으로' %></a>
</section>

<%- include('partials/layout-end') %>
