<%- include('partials/layout-start') %>

<section class="block-card">
  <div class="section-head">
    <h2><%= ctx.lang === 'en' ? 'Notice' : '공지사항' %></h2>
  </div>
  <ul class="media-line-list">
    <% if (notices.length === 0) { %>
      <li class="media-line-empty"><%= ctx.lang === 'en' ? 'No notices found.' : '등록된 공지사항이 없습니다.' %></li>
    <% } %>
    <% notices.forEach((item) => { %>
      <li class="media-line-item">
        <a href="/notice/<%= item.id %>" class="media-line-thumb-link">
          <span class="media-line-thumb">
            <% if (item.image_path) { %>
              <img src="<%= item.image_path %>" alt="<%= item.title %>" loading="lazy" />
            <% } else { %>
              <span class="media-line-fallback"><%= ctx.lang === 'en' ? 'NO IMG' : '이미지 없음' %></span>
            <% } %>
          </span>
        </a>
        <div class="media-line-body">
          <a href="/notice/<%= item.id %>" class="media-line-title"><%= item.title %></a>
          <span class="media-line-meta"><%= item.is_popup ? (ctx.lang === 'en' ? 'Popup' : '팝업') : (ctx.lang === 'en' ? 'Normal' : '일반') %> / <%= item.created_at.slice(0, 10) %></span>
        </div>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/layout-end') %>
