<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>
<% const pageFlow = flow || {}; %>
<% const step = pageFlow.step || 'request'; %>
<% const account = pageFlow.account || ''; %>
<% const email = pageFlow.email || ''; %>
<% const reset = pageFlow.reset || null; %>

<section class="auth-wrap">
  <div class="auth-card auth-card-wide">
    <h2><%= isEn ? 'Find Password' : '비밀번호찾기' %></h2>

    <% if (reset && reset.ticket) { %>
      <p class="muted-label"><%= isEn ? 'Verified account' : '인증된 계정' %>: <strong><%= reset.account %></strong></p>
      <form method="post" action="/password/reset/update" class="form-grid" id="passwordResetForm" novalidate>
        <input type="hidden" name="ticket" value="<%= reset.ticket %>" />
        <label><%= isEn ? 'New Password' : '새 비밀번호' %>
          <input type="password" name="password" autocomplete="new-password" required />
          <small class="muted-label"><%= isEn ? 'Use upper/lowercase letters, number, and symbol (8+).' : '영문 대/소문자, 숫자, 특수기호를 포함해 8자 이상.' %></small>
          <small class="field-error" data-error-for="password"></small>
        </label>
        <label><%= isEn ? 'Confirm New Password' : '새 비밀번호 확인' %>
          <input type="password" name="passwordConfirm" autocomplete="new-password" required />
          <small class="field-error" data-error-for="passwordConfirm"></small>
        </label>
        <button type="submit" class="cta-main"><%= isEn ? 'Reset Password' : '비밀번호 재설정' %></button>
      </form>
    <% } else { %>
      <form method="post" action="/password/reset/send-code" class="form-grid">
        <label><%= isEn ? 'Account' : '계정' %>
          <input type="text" name="account" value="<%= account %>" autocomplete="username" required />
          <small class="muted-label"><%= isEn ? 'Enter the account you signed up with.' : '가입한 계정을 입력해 주세요.' %></small>
        </label>
        <label><%= isEn ? 'Email used for sign-up' : '가입 시 사용한 이메일' %>
          <input type="email" name="email" value="<%= email %>" autocomplete="email" required />
        </label>
        <button type="submit" class="cta-main"><%= isEn ? 'Send Verification Code' : '인증번호 받기' %></button>
      </form>

      <% if (step === 'verify' && account && email) { %>
        <hr class="auth-divider" />
        <form method="post" action="/password/reset/verify-code" class="form-grid">
          <input type="hidden" name="account" value="<%= account %>" />
          <input type="hidden" name="email" value="<%= email %>" />
          <label><%= isEn ? '6-digit verification code' : '6자리 인증번호' %>
            <input type="text" name="code" inputmode="numeric" maxlength="6" pattern="[0-9]{6}" required />
          </label>
          <button type="submit" class="cta-main"><%= isEn ? 'Verify' : '인증하기' %></button>
        </form>
      <% } %>
    <% } %>

    <p class="muted-label auth-foot-note">
      <a href="/login"><%= isEn ? 'Back to Login' : '로그인으로 돌아가기' %></a>
      ·
      <a href="/account/find"><%= isEn ? 'Find Account' : '계정찾기' %></a>
    </p>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById('passwordResetForm');
    if (!form) return;

    const isEn = <%= isEn ? 'true' : 'false' %>;
    const passwordInput = form.querySelector('input[name="password"]');
    const passwordConfirmInput = form.querySelector('input[name="passwordConfirm"]');
    const errorByName = (name) => form.querySelector(`[data-error-for="${name}"]`);

    const setError = (name, message) => {
      const el = errorByName(name);
      if (!el) return;
      if (message) {
        el.textContent = message;
        el.classList.add('show');
      } else {
        el.textContent = '';
        el.classList.remove('show');
      }
    };

    const validatePassword = () => {
      const value = String(passwordInput?.value || '');
      if (!value) return isEn ? 'Password is required.' : '비밀번호를 입력해 주세요.';
      if (!/^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}$/.test(value)) {
        return isEn
          ? 'Use upper/lowercase letters, number, and symbol (8+).'
          : '비밀번호는 영문 대/소문자, 숫자, 특수기호를 포함해 8자 이상이어야 합니다.';
      }
      return '';
    };

    const validatePasswordConfirm = () => {
      const value = String(passwordConfirmInput?.value || '');
      if (!value) return isEn ? 'Please confirm your password.' : '비밀번호 확인을 입력해 주세요.';
      if (value !== String(passwordInput?.value || '')) {
        return isEn ? 'Passwords do not match.' : '비밀번호가 일치하지 않습니다.';
      }
      return '';
    };

    const validators = {
      password: validatePassword,
      passwordConfirm: validatePasswordConfirm
    };

    Object.entries(validators).forEach(([name, validator]) => {
      const input = form.querySelector(`[name="${name}"]`);
      if (!input) return;
      input.addEventListener('blur', () => setError(name, validator()));
      input.addEventListener('input', () => {
        if (!errorByName(name)?.classList.contains('show')) return;
        setError(name, validator());
      });
    });

    form.addEventListener('submit', (event) => {
      let hasError = false;
      Object.entries(validators).forEach(([name, validator]) => {
        const message = validator();
        setError(name, message);
        if (message) hasError = true;
      });
      if (hasError) {
        event.preventDefault();
      }
    });
  })();
</script>

<%- include('partials/layout-end') %>
