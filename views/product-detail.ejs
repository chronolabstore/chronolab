<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="detail-shell">
  <div class="detail-visual detail-gallery" data-gallery>
    <% if (imageList && imageList.length > 0) { %>
      <div class="detail-main-wrap">
        <button
          type="button"
          class="gallery-nav gallery-prev"
          data-gallery-prev
          aria-label="<%= isEn ? 'Previous image' : '이전 이미지' %>"
        >
          &#8249;
        </button>
        <img
          src="<%= imageList[0] %>"
          alt="<%= product.brand %> <%= product.model %>"
          class="detail-main-image"
          data-gallery-main
        />
        <button
          type="button"
          class="gallery-nav gallery-next"
          data-gallery-next
          aria-label="<%= isEn ? 'Next image' : '다음 이미지' %>"
        >
          &#8250;
        </button>
      </div>

      <div class="detail-thumb-row">
        <% imageList.forEach((src, index) => { %>
          <button
            type="button"
            class="detail-thumb <%= index === 0 ? 'active' : '' %>"
            data-gallery-thumb
            data-index="<%= index %>"
            data-src="<%= src %>"
            aria-label="<%= isEn ? 'Product image' : '상품 이미지' %> <%= index + 1 %>"
          >
            <img src="<%= src %>" alt="<%= product.brand %> <%= isEn ? 'thumbnail' : '썸네일' %> <%= index + 1 %>" loading="lazy" />
          </button>
        <% }) %>
      </div>
    <% } else { %>
      <div class="image-fallback large">WATCH</div>
    <% } %>
  </div>

  <div class="detail-card-dark">
    <h2><%= Number(product.price || 0) > 0 ? `₩${ctx.formatPrice(product.price)}` : (isEn ? 'Price on request' : '가격문의') %></h2>
    <h3>
      <%= productDisplay?.title || `${product.brand || ''} ${product.model || ''}`.trim() %>
      <% if (productDisplay?.subtitle) { %>
        <small class="muted-label"><%= productDisplay.subtitle %></small>
      <% } %>
    </h3>
    <p class="muted-label"><%= productGroupLabel || product.category_group %></p>

    <% if ((productGroupConfig && productGroupConfig.mode === 'factory') || product.category_group === '공장제') { %>
      <div class="spec-grid">
        <span>Reference: <strong><%= product.reference || '-' %></strong></span>
        <span>Factory: <strong><%= product.factory_name || '-' %></strong></span>
        <span>Version: <strong><%= product.version_name || '-' %></strong></span>
        <span>Movement: <strong><%= product.movement || '-' %></strong></span>
        <span>Case Size: <strong><%= product.case_size || '-' %></strong></span>
        <span>Dial: <strong><%= product.dial_color || '-' %></strong></span>
        <span>Case: <strong><%= product.case_material || '-' %></strong></span>
        <span>Bracelet/Strap: <strong><%= product.strap_material || '-' %></strong></span>
        <span><%= isEn ? 'Shipping' : '배송기간' %>: <strong><%= product.shipping_period || '-' %></strong></span>
      </div>
      <p class="feature-copy"><%= product.features || '-' %></p>
      <a href="/shop/item/<%= product.id %>/purchase" class="cta-main full"><%= isEn ? 'Go to Purchase' : '구매하기' %></a>
    <% } else { %>
      <div class="spec-grid">
        <span><%= isEn ? 'Summary' : '간략 설명' %>: <strong><%= productDisplay?.summary || '-' %></strong></span>
        <% (productDisplay?.customPairs || []).forEach((field) => { %>
          <span><%= isEn ? (field.labelEn || field.labelKo || field.key) : (field.labelKo || field.labelEn || field.key) %>: <strong><%= field.value %></strong></span>
        <% }) %>
      </div>
      <form method="post" action="/order/create" class="order-form">
        <input type="hidden" name="productId" value="<%= product.id %>" />
        <label><%= isEn ? 'Quantity' : '수량' %>
          <input type="number" name="quantity" value="1" min="1" required />
        </label>
        <label><%= isEn ? 'Name' : '이름' %>
          <input type="text" name="buyerName" required />
        </label>
        <label><%= isEn ? 'Contact' : '연락처' %>
          <input type="text" name="buyerContact" required />
        </label>
        <label><%= isEn ? 'Address' : '주소' %>
          <textarea name="buyerAddress" rows="2" required></textarea>
        </label>
        <label><%= isEn ? 'Depositor Name' : '입금자명' %>
          <input type="text" name="bankDepositorName" required />
        </label>
        <button type="submit" class="cta-main full"><%= ctx.t('buyNow') %></button>
      </form>
    <% } %>
  </div>
</section>

<section class="block-card">
  <h3><%= isEn ? 'Similar Watches' : '유사 상품' %></h3>
  <div class="product-grid compact">
    <% if (similar.length === 0) { %>
      <p><%= isEn ? 'No similar products found.' : '같은 브랜드의 다른 상품이 없습니다.' %></p>
    <% } %>
    <% similar.forEach((item) => { %>
      <a href="/shop/item/<%= item.id %>" class="mini-product">
        <% if (item.image_path) { %>
          <img src="<%= item.image_path %>" alt="<%= item.brand %>" />
        <% } else { %>
          <div class="image-fallback">WATCH</div>
        <% } %>
        <strong><%= item.display_title || item.model %></strong>
        <span><%= Number(item.price || 0) > 0 ? `₩${ctx.formatPrice(item.price)}` : (isEn ? 'Price on request' : '가격문의') %></span>
      </a>
    <% }) %>
  </div>
</section>

<%- include('partials/layout-end') %>
