<%- include('partials/layout-start') %>
<%
  const isEn = ctx.lang === 'en';
  const resolvedGroupLabelMap = (() => {
    if (groupLabelMap && typeof groupLabelMap === 'object' && !Array.isArray(groupLabelMap)) {
      return groupLabelMap;
    }
    const generated = {};
    (productGroupConfigs || []).forEach((groupItem) => {
      generated[groupItem.key] = isEn ? (groupItem.labelEn || groupItem.key) : (groupItem.labelKo || groupItem.key);
    });
    return generated;
  })();
  const heroQuickMenus = Array.isArray(ctx.settings?.heroQuickMenus) ? ctx.settings.heroQuickMenus : [];
  const heroLeftTitle = String(ctx.settings?.heroLeftTitle || '').trim() || ctx.t('homeHeroTitle');
  const heroLeftSubtitle = String(ctx.settings?.heroLeftSubtitle || '').trim() || ctx.t('homeHeroSubtitle');
  const heroLeftCtaPath = String(ctx.settings?.heroLeftCtaPath || '').trim() || '/shop';
  const heroLeftCtaLabel = String(ctx.settings?.heroLeftCtaLabel || '').trim() || ctx.t('goToShop');
  const heroRightTitle = String(ctx.settings?.heroRightTitle || '').trim() || ctx.t('welcome');
  const heroRightSubtitle = String(ctx.settings?.heroRightSubtitle || '').trim() || ctx.t('orderBankOnly');
  const safeFeaturedTopProducts = Array.isArray(featuredTopProducts) ? featuredTopProducts : [];
%>

<section class="hero-wrap">
  <div class="hero-image-pane" style="<%= ctx.settings?.heroLeftPaneStyle || '' %>">
    <div class="hero-badge"><%= ctx.settings.siteName || 'Chrono Lab' %></div>
    <h1><%= heroLeftTitle %></h1>
    <p><%= heroLeftSubtitle %></p>
    <a href="<%= heroLeftCtaPath %>" class="cta-main cta-pill"><%= heroLeftCtaLabel %></a>
  </div>

  <div class="hero-dark-card" style="<%= ctx.settings?.heroRightPaneStyle || '' %>">
    <h3><%= heroRightTitle %></h3>
    <p><%= heroRightSubtitle %></p>
    <div class="hero-quick-grid">
      <% heroQuickMenus.forEach((menuItem) => { %>
        <a href="<%= menuItem.path %>"><%= menuItem.label %></a>
      <% }) %>
    </div>
  </div>
</section>

<% if (safeFeaturedTopProducts.length > 0) { %>
  <section class="block-card main-featured-top-card">
    <div class="shop-row-list main-featured-top-list">
      <% safeFeaturedTopProducts.forEach((group) => { %>
        <div class="shop-row-block main-featured-top-group">
          <div class="shop-row-head">
            <h3><%= resolvedGroupLabelMap[group.groupName] || group.groupName %></h3>
            <a href="/shop?group=<%= encodeURIComponent(group.groupName) %>"><%= isEn ? 'View more' : '더보기' %></a>
          </div>
          <div class="product-grid domestic-stock-grid">
            <% if (!group.products || group.products.length === 0) { %>
              <p class="muted-label"><%= isEn ? 'No products found.' : '등록된 상품이 없습니다.' %></p>
            <% } %>
            <% (group.products || []).forEach((item) => { %>
              <% const soldOut = Number(item.is_sold_out || 0) === 1; %>
              <a href="/shop/item/<%= item.id %>" class="product-card">
                <div class="product-image-box <%= soldOut ? 'is-sold-out' : '' %>">
                  <% if (item.image_path) { %>
                    <img src="<%= item.image_path %>" alt="<%= item.brand %>" />
                  <% } else { %>
                    <div class="image-fallback">WATCH</div>
                  <% } %>
                  <% if (soldOut) { %>
                    <span class="soldout-overlay-label"><%= isEn ? 'Sold out' : '판매완료' %></span>
                  <% } %>
                </div>
                <div class="product-meta">
                  <strong><%= item.display_title || `${item.brand || ''} ${item.model || ''}`.trim() %></strong>
                  <% if ((item.product_badges || []).length > 0) { %>
                    <div class="product-badge-row">
                      <% (item.product_badges || []).forEach((badge) => { %>
                        <% const badgeThemeClass = `product-badge-theme-${String(badge.color_theme || 'slate').toLowerCase().replace(/[^a-z0-9-]/g, '') || 'slate'}`; %>
                        <span class="product-badge-chip <%= badgeThemeClass %>"><%= isEn ? (badge.label_en || badge.label_ko) : (badge.label_ko || badge.label_en) %></span>
                      <% }) %>
                    </div>
                  <% } %>
                  <span><%= item.display_subtitle || '' %></span>
                  <em><%= Number(item.price || 0) > 0 ? `₩${ctx.formatPrice(item.price)}` : (isEn ? 'Price on request' : '가격문의') %></em>
                  <small><%= isEn ? 'Shipping' : '배송기간' %>: <%= item.shipping_period || '-' %></small>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>

<section class="block-card">
  <div class="section-head">
    <h2><%= isEn ? 'Shop' : '쇼핑몰' %></h2>
    <a href="/shop"><%= isEn ? 'View more' : '더보기' %></a>
  </div>
  <div class="shop-row-list">
    <% groupedProducts.forEach((group) => { %>
      <div class="shop-row-block">
        <div class="shop-row-head">
          <h3><%= resolvedGroupLabelMap[group.groupName] || group.groupName %></h3>
          <a href="/shop?group=<%= encodeURIComponent(group.groupName) %>"><%= isEn ? 'View more' : '더보기' %></a>
        </div>
        <div class="product-grid shop-row-grid">
          <% if (group.products.length === 0) { %>
            <p class="muted-label"><%= isEn ? 'No products found.' : '등록된 상품이 없습니다.' %></p>
          <% } %>
          <% group.products.forEach((item) => { %>
            <% const soldOut = Number(item.is_sold_out || 0) === 1; %>
            <a href="/shop/item/<%= item.id %>" class="product-card">
              <div class="product-image-box <%= soldOut ? 'is-sold-out' : '' %>">
                <% if (item.image_path) { %>
                  <img src="<%= item.image_path %>" alt="<%= item.brand %>" />
                <% } else { %>
                  <div class="image-fallback">WATCH</div>
                <% } %>
                <% if (soldOut) { %>
                  <span class="soldout-overlay-label"><%= isEn ? 'Sold out' : '판매완료' %></span>
                <% } %>
              </div>
              <div class="product-meta">
                <strong><%= item.display_title || `${item.brand || ''} ${item.model || ''}`.trim() %></strong>
                <% if ((item.product_badges || []).length > 0) { %>
                  <div class="product-badge-row">
                    <% (item.product_badges || []).forEach((badge) => { %>
                      <% const badgeThemeClass = `product-badge-theme-${String(badge.color_theme || 'slate').toLowerCase().replace(/[^a-z0-9-]/g, '') || 'slate'}`; %>
                      <span class="product-badge-chip <%= badgeThemeClass %>"><%= isEn ? (badge.label_en || badge.label_ko) : (badge.label_ko || badge.label_en) %></span>
                    <% }) %>
                  </div>
                <% } %>
                <span><%= item.display_subtitle || '' %></span>
                <em><%= Number(item.price || 0) > 0 ? `₩${ctx.formatPrice(item.price)}` : (isEn ? 'Price on request' : '가격문의') %></em>
                <small><%= isEn ? 'Shipping' : '배송기간' %>: <%= item.shipping_period || '-' %></small>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="block-card">
  <div class="section-head">
    <h2><%= isEn ? 'News' : '뉴스' %></h2>
    <a href="/news"><%= isEn ? 'View all' : '전체보기' %></a>
  </div>
  <div class="news-card-grid">
    <% if (latestNews.length === 0) { %>
      <p><%= isEn ? 'No news yet.' : '아직 등록된 뉴스가 없습니다.' %></p>
    <% } %>
    <% latestNews.forEach((item) => { %>
      <a href="/news/<%= item.id %>" class="news-card">
        <% if (item.image_path) { %>
          <img src="<%= item.image_path %>" alt="<%= item.title %>" class="news-card-image" />
        <% } %>
        <div class="news-card-body">
          <h3><%= item.title %></h3>
          <p><%= item.content.length > 120 ? item.content.slice(0, 120) + '...' : item.content %></p>
          <small><%= item.created_at.slice(0, 10) %></small>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<section class="block-card">
  <div class="section-head">
    <h2><%= isEn ? 'Notice' : '공지사항' %></h2>
    <a href="/notice"><%= isEn ? 'View all' : '전체보기' %></a>
  </div>
  <ul class="line-list">
    <% if (latestNotices.length === 0) { %>
      <li><%= isEn ? 'No notices yet.' : '아직 등록된 공지사항이 없습니다.' %></li>
    <% } %>
    <% latestNotices.forEach((item) => { %>
      <li>
        <a href="/notice/<%= item.id %>"><%= item.title %></a>
        <span><%= item.created_at.slice(0, 10) %></span>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/layout-end') %>
