<%- include('partials/layout-start') %>
<%
  const isEn = ctx.lang === 'en';
  const groupLabelMap = {
    '공장제': isEn ? 'Factory' : '공장제',
    '젠파츠': isEn ? 'Gen Parts' : '젠파츠',
    '현지중고': isEn ? 'Local Used' : '현지중고'
  };
%>

<section class="block-card shop-filter-card">
  <div class="section-head">
    <h2><%= isEn ? 'Shop' : '쇼핑몰' %></h2>
  </div>

  <div class="filter-group">
    <div class="chip-row">
      <% productGroups.forEach((item) => { %>
        <a href="/shop?group=<%= encodeURIComponent(item) %>" class="chip <%= group === item ? 'dark' : '' %>"><%= groupLabelMap[item] || item %></a>
      <% }) %>
    </div>
  </div>

  <% if (group === '공장제') { %>
    <div class="filter-group">
      <h4><%= isEn ? 'Brand' : '브랜드' %></h4>
      <div class="chip-row chip-scroll-row">
        <a href="/shop?group=<%= encodeURIComponent(group) %>" class="chip <%= brand ? '' : 'dark' %>"><%= isEn ? 'All' : '전체' %></a>
        <% brands.forEach((item) => { %>
          <a href="/shop?group=<%= encodeURIComponent(group) %>&brand=<%= encodeURIComponent(item) %>" class="chip <%= brand === item ? 'dark' : '' %>"><%= item %></a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (group === '공장제' && brand) { %>
    <div class="filter-group">
      <h4><%= isEn ? 'Model' : '소분류 (모델)' %></h4>
      <div class="chip-row">
        <a href="/shop?group=<%= encodeURIComponent(group) %>&brand=<%= encodeURIComponent(brand) %>" class="chip <%= model ? '' : 'dark' %>"><%= isEn ? 'All' : '전체' %></a>
        <% models.forEach((item) => { %>
          <a href="/shop?group=<%= encodeURIComponent(group) %>&brand=<%= encodeURIComponent(brand) %>&model=<%= encodeURIComponent(item) %>" class="chip <%= model === item ? 'dark' : '' %>"><%= item %></a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (group !== '공장제') { %>
    <p class="muted-label"><%= isEn ? 'Products are listed directly by selected top category.' : '선택한 카테고리는 상위 분류 기준으로 상품을 바로 확인할 수 있습니다.' %></p>
  <% } %>
</section>

<section class="block-card">
  <div class="product-grid">
    <% if (products.length === 0) { %>
      <p><%= isEn ? 'No products found for this filter.' : '조건에 맞는 상품이 없습니다.' %></p>
    <% } %>

    <% products.forEach((item) => { %>
      <a href="/shop/item/<%= item.id %>" class="product-card">
        <div class="product-image-box">
          <% if (item.image_path) { %>
            <img src="<%= item.image_path %>" alt="<%= item.brand %>" />
          <% } else { %>
            <div class="image-fallback">WATCH</div>
          <% } %>
        </div>
        <div class="product-meta">
          <small><%= groupLabelMap[item.category_group] || item.category_group || '-' %></small>
          <strong><%= item.brand %> <%= item.model %></strong>
          <span><%= item.sub_model %></span>
          <small><%= item.case_material || '-' %> / <%= item.movement || '-' %></small>
          <em>₩<%= ctx.formatPrice(item.price) %></em>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<%- include('partials/layout-end') %>
