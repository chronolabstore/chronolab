<%- include('partials/layout-start') %>
<%
  const isEn = ctx.lang === 'en';
  const resolvedGroupLabelMap = (() => {
    if (groupLabelMap && typeof groupLabelMap === 'object' && !Array.isArray(groupLabelMap)) {
      return groupLabelMap;
    }
    const generated = {};
    (productGroupConfigs || []).forEach((groupItem) => {
      generated[groupItem.key] = isEn ? (groupItem.labelEn || groupItem.key) : (groupItem.labelKo || groupItem.key);
    });
    return generated;
  })();
  const safeBrand = String(brand || '').trim();
  const safeFactory = String(factory || '').trim();
  const safeModel = String(model || '').trim();
  const makeShopHref = (next = {}) => {
    const params = new URLSearchParams();
    params.set('group', group);
    const merged = {
      brand: safeBrand,
      factory: safeFactory,
      model: safeModel,
      ...next
    };

    ['brand', 'factory', 'model'].forEach((key) => {
      const value = String(merged[key] || '').trim();
      if (value) {
        params.set(key, value);
      } else {
        params.delete(key);
      }
    });

    return `/shop?${params.toString()}`;
  };
%>

<section class="block-card shop-filter-card">
  <div class="section-head">
    <h2><%= isEn ? 'Shop' : '쇼핑몰' %></h2>
  </div>

  <div class="filter-group">
    <div class="chip-row">
      <% productGroups.forEach((item) => { %>
        <a href="/shop?group=<%= encodeURIComponent(item) %>" class="chip <%= group === item ? 'dark' : '' %>"><%= resolvedGroupLabelMap[item] || item %></a>
      <% }) %>
    </div>
  </div>

  <div class="filter-group">
    <h4><%= isEn ? 'Brand' : '브랜드' %></h4>
    <div class="chip-row chip-scroll-row">
      <a href="<%= makeShopHref({ brand: '', model: '' }) %>" class="chip <%= safeBrand ? '' : 'dark' %>"><%= isEn ? 'All' : '전체' %></a>
      <% brands.forEach((item) => { %>
        <a href="<%= makeShopHref({ brand: item, model: '' }) %>" class="chip <%= safeBrand === item ? 'dark' : '' %>"><%= item %></a>
      <% }) %>
    </div>
  </div>

  <% if (supportsFactoryFilter) { %>
    <div class="filter-group">
      <h4><%= isEn ? 'Factory' : '공장' %></h4>
      <div class="chip-row chip-scroll-row">
        <a href="<%= makeShopHref({ factory: '', model: '' }) %>" class="chip <%= safeFactory ? '' : 'dark' %>"><%= isEn ? 'All' : '전체' %></a>
        <% factories.forEach((item) => { %>
          <a href="<%= makeShopHref({ factory: item, model: '' }) %>" class="chip <%= safeFactory === item ? 'dark' : '' %>"><%= item %></a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (supportsBrandModelFilter && safeBrand) { %>
    <div class="filter-group">
      <h4><%= isEn ? 'Model' : '모델' %></h4>
      <div class="chip-row">
        <a href="<%= makeShopHref({ model: '' }) %>" class="chip <%= safeModel ? '' : 'dark' %>"><%= isEn ? 'All' : '전체' %></a>
        <% models.forEach((item) => { %>
          <a href="<%= makeShopHref({ model: item }) %>" class="chip <%= safeModel === item ? 'dark' : '' %>"><%= item %></a>
        <% }) %>
      </div>
    </div>
  <% } %>
</section>

<section class="block-card">
  <div class="product-grid">
    <% if (products.length === 0) { %>
      <p><%= isEn ? 'No products found for this filter.' : '조건에 맞는 상품이 없습니다.' %></p>
    <% } %>

    <% products.forEach((item) => { %>
      <a href="/shop/item/<%= item.id %>" class="product-card">
        <div class="product-image-box">
          <% if (item.image_path) { %>
            <img src="<%= item.image_path %>" alt="<%= item.brand %>" />
          <% } else { %>
            <div class="image-fallback">WATCH</div>
          <% } %>
        </div>
        <div class="product-meta">
          <small><%= resolvedGroupLabelMap[item.category_group] || item.category_group || '-' %></small>
          <strong><%= item.display_title || `${item.brand || ''} ${item.model || ''}`.trim() %></strong>
          <% if ((item.product_badges || []).length > 0) { %>
            <div class="product-badge-row">
              <% (item.product_badges || []).forEach((badge) => { %>
                <span class="product-badge-chip"><%= isEn ? (badge.label_en || badge.label_ko) : (badge.label_ko || badge.label_en) %></span>
              <% }) %>
            </div>
          <% } %>
          <span><%= item.display_subtitle || '' %></span>
          <small><%= item.display_meta || (item.case_material || '-') + ' / ' + (item.movement || '-') %></small>
          <em><%= Number(item.price || 0) > 0 ? `₩${ctx.formatPrice(item.price)}` : (isEn ? 'Price on request' : '가격문의') %></em>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<%- include('partials/layout-end') %>
