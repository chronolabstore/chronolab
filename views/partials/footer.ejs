<footer class="site-footer">
  <% const footerBrandCopyKo = String(ctx.settings.footerBrandCopyKo || '').trim() || '심플하고 신뢰할 수 있는 시계 쇼핑.'; %>
  <% const footerBrandCopyEn = String(ctx.settings.footerBrandCopyEn || '').trim() || 'Simple. Clean. Trusted watch shopping.'; %>
  <% const footerNoticeRows = Array.from({ length: 6 }, (_, index) => ctx.footerNotices[index] || null); %>
  <% const rawBusinessInfo = String(ctx.settings.businessInfo || '').trim(); %>
  <% const rawContactInfo = String(ctx.settings.contactInfo || '').trim(); %>
  <% const extractField = (source, regexList = [], fallbackSegment = '') => {
    for (const regex of regexList) {
      const match = String(source || '').match(regex);
      if (match && String(match[1] || '').trim()) {
        return String(match[1] || '').trim();
      }
    }
    const cleaned = String(fallbackSegment || '')
      .replace(/^[^:：]+[:：]\s*/u, '')
      .trim();
    return cleaned;
  }; %>
  <% const businessSegments = rawBusinessInfo.split('|').map((segment) => segment.trim()).filter(Boolean); %>
  <% const contactSegments = rawContactInfo.split('/').map((segment) => segment.trim()).filter(Boolean); %>
  <% const siteInfoRows = [
    {
      label: ctx.lang === 'en' ? 'Business' : '상호',
      value: extractField(
        rawBusinessInfo,
        [/(?:상호|business\s*name|company)\s*[:：]\s*([^|/\n]+)/iu],
        businessSegments[0] || ''
      )
    },
    {
      label: ctx.lang === 'en' ? 'CEO' : '대표',
      value: extractField(
        rawBusinessInfo,
        [/(?:대표|ceo|owner)\s*[:：]\s*([^|/\n]+)/iu],
        businessSegments[1] || ''
      )
    },
    {
      label: ctx.lang === 'en' ? 'Business No.' : '사업자번호',
      value: extractField(
        rawBusinessInfo,
        [/(?:사업자(?:등록)?번호|business(?:\s*registration)?\s*(?:no\.?|number)?)\s*[:：]\s*([^|/\n]+)/iu],
        businessSegments[2] || ''
      )
    },
    {
      label: ctx.lang === 'en' ? 'Support' : '고객센터',
      value: extractField(
        rawContactInfo,
        [/(?:고객센터|customer\s*(?:service|support)|support)\s*[:：]\s*([^|/\n]+)/iu],
        contactSegments[0] || ''
      )
    },
    {
      label: ctx.lang === 'en' ? 'KakaoTalk' : '카카오톡',
      value: extractField(
        rawContactInfo,
        [/(?:카카오톡|kakao(?:talk)?)\s*[:：]\s*([^|/\n]+)/iu],
        contactSegments[1] || ''
      )
    }
  ].map((row) => ({ ...row, value: String(row.value || '').trim() || '-' })); %>
  <div class="footer-grid">
    <section class="footer-card footer-brand-card">
      <h4>Brand</h4>
      <div class="footer-brand-card-body">
        <div class="footer-brand-visual">
          <% if (ctx.settings.footerLogoPath) { %>
            <img src="<%= ctx.settings.footerLogoPath %>" alt="footer logo" class="footer-logo" />
          <% } else { %>
            <div class="footer-logo-fallback">Chrono Lab</div>
          <% } %>
        </div>
        <p class="footer-small footer-brand-copy"><%= ctx.lang === 'en' ? footerBrandCopyEn : footerBrandCopyKo %></p>
      </div>
    </section>

    <section class="footer-card footer-site-info-card">
      <h4><%= ctx.lang === 'en' ? 'Site Info' : '사이트 정보' %></h4>
      <div class="footer-site-info-body">
        <ul class="footer-site-info-list">
          <% siteInfoRows.forEach((row) => { %>
            <li class="footer-data-row footer-site-info-row">
              <span class="footer-site-info-label"><%= row.label %></span>
              <span class="footer-site-info-value"><%= row.value %></span>
            </li>
          <% }) %>
        </ul>
      </div>
    </section>

    <section class="footer-card footer-notice-card">
      <h4><%= ctx.lang === 'en' ? 'Notice' : '공지사항' %></h4>
      <ul class="footer-notice-list">
        <% footerNoticeRows.forEach((notice) => { %>
          <li class="footer-notice-row">
            <% if (notice) { %>
              <a href="/notice/<%= notice.id %>" class="footer-data-row"><%= notice.title %></a>
            <% } else { %>
              <span class="footer-data-row footer-data-placeholder">-</span>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </section>

    <section class="footer-card footer-metrics-card">
      <h4><%= ctx.lang === 'en' ? 'Metrics' : '집계' %></h4>
      <div class="footer-metrics-list">
        <p class="footer-data-row"><%= ctx.t('footerVisitorsToday') %> : <strong><%= ctx.metrics.visitToday %></strong></p>
        <p class="footer-data-row"><%= ctx.t('footerVisitorsTotal') %> : <strong><%= ctx.metrics.visitTotal %></strong></p>
        <p class="footer-data-row"><%= ctx.t('footerProductsToday') %> : <strong><%= ctx.metrics.productToday || 0 %></strong></p>
        <p class="footer-data-row"><%= ctx.t('footerProductsTotal') %> : <strong><%= ctx.metrics.productTotal || 0 %></strong></p>
        <p class="footer-data-row"><%= ctx.t('footerPostsToday') %> : <strong><%= ctx.metrics.postToday %></strong></p>
        <p class="footer-data-row"><%= ctx.t('footerPostsTotal') %> : <strong><%= ctx.metrics.postTotal %></strong></p>
      </div>
    </section>
  </div>
</footer>
