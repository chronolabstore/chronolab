      </main>
      <%- include('./footer') %>
    </div>

    <% const popupFlashState = (ctx.popupFlash && ctx.popupFlash.message) ? ctx.popupFlash : ((ctx.flash && ctx.flash.message) ? ctx.flash : null); %>
    <% if (popupFlashState) { %>
      <div id="flashPopup" class="popup-backdrop popup-alert-backdrop hidden">
        <div class="popup-card popup-alert-card <%= popupFlashState.type === 'error' ? 'error' : 'success' %>">
          <h3>
            <%= popupFlashState.type === 'error'
              ? (ctx.lang === 'en' ? 'Action Failed' : '작업 실패')
              : (ctx.lang === 'en' ? 'Upload Complete' : '업로드 완료') %>
          </h3>
          <p><%= popupFlashState.message %></p>
          <div class="popup-actions">
            <button type="button" data-flash-popup-action="confirm" class="chip dark"><%= ctx.lang === 'en' ? 'OK' : '확인' %></button>
          </div>
        </div>
      </div>
    <% } %>

    <% const popupNoticeList = Array.isArray(ctx.popupNotices) ? ctx.popupNotices : []; %>
    <% if (popupNoticeList.length > 0) { %>
      <div id="noticePopupDeck" class="popup-backdrop hidden" data-popup-deck>
        <div class="popup-notice-deck-shell">
          <button
            type="button"
            class="popup-deck-nav popup-deck-nav-prev"
            data-popup-nav="prev"
            aria-label="<%= ctx.lang === 'en' ? 'Previous notice' : '이전 공지' %>"
          >
            <svg class="popup-deck-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M15 6l-6 6 6 6" />
            </svg>
          </button>

          <section class="popup-notice-deck-viewport" data-popup-viewport>
            <div class="popup-notice-deck-stack" data-popup-stack>
              <div class="popup-notice-deck-meta" data-popup-meta>
                <strong data-popup-current>1</strong>
                <span>/</span>
                <span data-popup-total><%= popupNoticeList.length %></span>
              </div>
              <% popupNoticeList.forEach((popupNotice) => { %>
                <article class="popup-card popup-notice-card" data-popup-card data-popup-id="<%= popupNotice.id %>">
                  <h3><%= popupNotice.title %></h3>
                  <% if (popupNotice.imagePath) { %>
                    <img src="<%= popupNotice.imagePath %>" alt="popup notice" class="popup-image" />
                  <% } %>
                  <div class="popup-notice-body" data-popup-scrollable>
                    <p class="popup-notice-content"><%= popupNotice.content %></p>
                  </div>
                  <div class="popup-actions">
                    <button type="button" data-popup-action="hide7" class="chip ghost"><%= ctx.lang === 'en' ? "Don't show for 7 days" : '7일간 보지 않기' %></button>
                    <button type="button" data-popup-action="close" class="chip"><%= ctx.lang === 'en' ? 'Close' : '닫기' %></button>
                    <button type="button" data-popup-action="confirm" class="chip dark"><%= ctx.lang === 'en' ? 'OK' : '확인' %></button>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>

          <button
            type="button"
            class="popup-deck-nav popup-deck-nav-next"
            data-popup-nav="next"
            aria-label="<%= ctx.lang === 'en' ? 'Next notice' : '다음 공지' %>"
          >
            <svg class="popup-deck-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 6l6 6-6 6" />
            </svg>
          </button>
        </div>
      </div>
    <% } %>

    <div id="imageLightbox" class="image-lightbox hidden" aria-hidden="true">
      <div class="image-lightbox-shell">
        <div class="image-lightbox-toolbar">
          <span class="image-lightbox-zoom" data-lightbox-zoom>100%</span>
          <button type="button" class="chip" data-lightbox-action="zoom-out"><%= ctx.lang === 'en' ? 'Zoom Out' : '축소' %></button>
          <button type="button" class="chip" data-lightbox-action="zoom-in"><%= ctx.lang === 'en' ? 'Zoom In' : '확대' %></button>
          <button type="button" class="chip" data-lightbox-action="reset"><%= ctx.lang === 'en' ? 'Reset' : '원본' %></button>
          <button type="button" class="chip dark" data-lightbox-action="close"><%= ctx.lang === 'en' ? 'Close' : '닫기' %></button>
        </div>
        <div class="image-lightbox-stage" data-lightbox-stage>
          <img src="" alt="" class="image-lightbox-image" data-lightbox-image />
        </div>
      </div>
    </div>

    <% const canUseMemberSupportChat = Boolean(ctx.currentUser && !ctx.currentUser.isAdmin); %>
    <% if (!ctx.isAdminRoute && (!ctx.currentUser || !ctx.currentUser.isAdmin)) { %>
      <button
        type="button"
        class="floating-support-btn floating-support-btn-member"
        data-member-chat-open
        <% if (!canUseMemberSupportChat) { %>data-login-required-action="member-support-chat"<% } %>
        aria-label="<%= ctx.lang === 'en' ? 'Open support chat' : '상담 채팅 열기' %>"
      >
        <span class="floating-support-icon" aria-hidden="true">
          <svg class="floating-support-headset" viewBox="0 0 24 24" focusable="false">
            <path d="M6 11.2a6 6 0 0 1 12 0" />
            <rect x="3.3" y="11" width="3.7" height="6.2" rx="1.85" />
            <rect x="17" y="11" width="3.7" height="6.2" rx="1.85" />
            <path d="M17 17.2a4.2 4.2 0 0 1-4.2 4.2h-1.1" />
          </svg>
        </span>
        <span class="floating-support-label"><%= ctx.lang === 'en' ? 'Support Chat' : '상담 채팅' %></span>
        <span class="floating-support-badge <%= canUseMemberSupportChat && Number(ctx.supportChatMemberUnreadCount || 0) > 0 ? '' : 'hidden' %>" data-member-chat-unread-badge>
          <%= canUseMemberSupportChat && Number(ctx.supportChatMemberUnreadCount || 0) > 99 ? '99+' : Number(ctx.supportChatMemberUnreadCount || 0) %>
        </span>
      </button>

      <% if (canUseMemberSupportChat) { %>
        <section class="support-chat-panel support-chat-panel-member hidden" data-member-chat-panel>
          <header class="support-chat-header">
            <div class="support-chat-header-text">
              <strong><%= ctx.lang === 'en' ? '1:1 Support Chat' : '1:1 상담 채팅' %></strong>
              <small data-member-chat-assigned><%= ctx.lang === 'en' ? 'Assigned: Chrono Lab Admin' : '담당: Chrono Lab 관리자' %></small>
            </div>
            <button type="button" class="chip" data-member-chat-close><%= ctx.lang === 'en' ? 'Close' : '닫기' %></button>
          </header>
          <div class="support-chat-body" data-member-chat-messages></div>
          <form class="support-chat-composer" data-member-chat-form>
            <textarea
              name="message"
              rows="1"
              maxlength="1000"
              placeholder="<%= ctx.lang === 'en' ? 'Type your message...' : '메시지를 입력하세요...' %>"
              required
            ></textarea>
            <button type="submit" class="chip dark"><%= ctx.lang === 'en' ? 'Send' : '전송' %></button>
          </form>
        </section>
      <% } %>
    <% } %>

    <% if (ctx.isAdminRoute && ctx.currentUser && ctx.currentUser.isAdmin) { %>
      <button
        type="button"
        class="floating-support-btn floating-support-btn-admin"
        data-admin-chat-open
        aria-label="<%= ctx.lang === 'en' ? 'Open member chats' : '회원 채팅 열기' %>"
      >
        <span class="floating-support-icon" aria-hidden="true">
          <svg class="floating-support-headset" viewBox="0 0 24 24" focusable="false">
            <path d="M6 11.2a6 6 0 0 1 12 0" />
            <rect x="3.3" y="11" width="3.7" height="6.2" rx="1.85" />
            <rect x="17" y="11" width="3.7" height="6.2" rx="1.85" />
            <path d="M17 17.2a4.2 4.2 0 0 1-4.2 4.2h-1.1" />
          </svg>
        </span>
        <span class="floating-support-label"><%= ctx.lang === 'en' ? 'Member Chat' : '회원 채팅' %></span>
        <span class="floating-support-badge <%= Number(ctx.supportChatAdminUnreadCount || 0) > 0 ? '' : 'hidden' %>" data-admin-chat-unread-badge>
          <%= Number(ctx.supportChatAdminUnreadCount || 0) > 99 ? '99+' : Number(ctx.supportChatAdminUnreadCount || 0) %>
        </span>
      </button>

      <section class="support-chat-panel support-chat-panel-admin hidden" data-admin-chat-panel>
        <header class="support-chat-header">
          <div class="support-chat-header-text">
            <strong><%= ctx.lang === 'en' ? 'Member Support Chats' : '회원 상담 채팅' %></strong>
            <small><%= ctx.lang === 'en' ? 'All admin accounts can view and reply' : '모든 관리자 계정이 확인/답장할 수 있습니다' %></small>
          </div>
          <button type="button" class="chip" data-admin-chat-close><%= ctx.lang === 'en' ? 'Close' : '닫기' %></button>
        </header>
        <div class="support-admin-chat-layout">
          <aside class="support-admin-thread-list" data-admin-chat-thread-list></aside>
          <section class="support-admin-thread-panel">
            <div class="support-admin-thread-head" data-admin-chat-thread-title>
              <strong><%= ctx.lang === 'en' ? 'Select a member chat' : '회원 채팅을 선택하세요' %></strong>
            </div>
            <div class="support-chat-body support-chat-body-admin" data-admin-chat-messages></div>
            <form class="support-chat-composer" data-admin-chat-form>
              <textarea
                name="message"
                rows="1"
                maxlength="1000"
                placeholder="<%= ctx.lang === 'en' ? 'Type a reply...' : '답장을 입력하세요...' %>"
                required
                disabled
              ></textarea>
              <button type="submit" class="chip dark" disabled><%= ctx.lang === 'en' ? 'Reply' : '답장' %></button>
            </form>
          </section>
        </div>
      </section>
    <% } %>

    <% if (!ctx.isAdminRoute) { %>
      <% const kakaoChatUrl = String(ctx.settings.kakaoChatUrl || '').trim(); %>
      <% if (!ctx.currentUser) { %>
        <button
          type="button"
          class="floating-kakao-btn"
          data-login-required-action="kakao-chat"
          aria-label="<%= ctx.lang === 'en' ? 'Open KakaoTalk chat' : '카카오톡 채팅 열기' %>"
        >
          <span class="floating-kakao-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3C7.03 3 3 6.41 3 10.62c0 2.63 1.56 4.95 3.96 6.33L6.08 21l4.24-2.32c.55.09 1.11.14 1.68.14 4.97 0 9-3.41 9-7.62S16.97 3 12 3Z" />
              <circle cx="9.1" cy="10.9" r="1.1" />
              <circle cx="12" cy="10.9" r="1.1" />
              <circle cx="14.9" cy="10.9" r="1.1" />
            </svg>
          </span>
          <span class="floating-kakao-label"><%= ctx.lang === 'en' ? 'Kakao Chat' : '카카오톡 상담' %></span>
        </button>
      <% } else if (kakaoChatUrl) { %>
        <a
          href="<%= kakaoChatUrl %>"
          class="floating-kakao-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="<%= ctx.lang === 'en' ? 'Open KakaoTalk chat' : '카카오톡 채팅 열기' %>"
        >
          <span class="floating-kakao-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3C7.03 3 3 6.41 3 10.62c0 2.63 1.56 4.95 3.96 6.33L6.08 21l4.24-2.32c.55.09 1.11.14 1.68.14 4.97 0 9-3.41 9-7.62S16.97 3 12 3Z" />
              <circle cx="9.1" cy="10.9" r="1.1" />
              <circle cx="12" cy="10.9" r="1.1" />
              <circle cx="14.9" cy="10.9" r="1.1" />
            </svg>
          </span>
          <span class="floating-kakao-label"><%= ctx.lang === 'en' ? 'Kakao Chat' : '카카오톡 상담' %></span>
        </a>
      <% } else { %>
        <button
          type="button"
          class="floating-kakao-btn"
          data-kakao-chat-unavailable
          aria-label="<%= ctx.lang === 'en' ? 'KakaoTalk channel unavailable' : '카카오톡 채널 준비중' %>"
        >
          <span class="floating-kakao-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3C7.03 3 3 6.41 3 10.62c0 2.63 1.56 4.95 3.96 6.33L6.08 21l4.24-2.32c.55.09 1.11.14 1.68.14 4.97 0 9-3.41 9-7.62S16.97 3 12 3Z" />
              <circle cx="9.1" cy="10.9" r="1.1" />
              <circle cx="12" cy="10.9" r="1.1" />
              <circle cx="14.9" cy="10.9" r="1.1" />
            </svg>
          </span>
          <span class="floating-kakao-label"><%= ctx.lang === 'en' ? 'Kakao Chat' : '카카오톡 상담' %></span>
        </button>
      <% } %>
    <% } %>

    <script src="/assets/js/app.js?v=<%= encodeURIComponent(ctx.assetVersion) %>"></script>
  </body>
</html>
