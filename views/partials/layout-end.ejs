      </main>
      <%- include('./footer') %>
    </div>

    <% const popupFlashState = (ctx.popupFlash && ctx.popupFlash.message) ? ctx.popupFlash : ((ctx.flash && ctx.flash.message) ? ctx.flash : null); %>
    <% if (popupFlashState) { %>
      <div id="flashPopup" class="popup-backdrop popup-alert-backdrop hidden">
        <div class="popup-card popup-alert-card <%= popupFlashState.type === 'error' ? 'error' : 'success' %>">
          <h3>
            <%= popupFlashState.type === 'error'
              ? (ctx.lang === 'en' ? 'Action Failed' : '작업 실패')
              : (ctx.lang === 'en' ? 'Upload Complete' : '업로드 완료') %>
          </h3>
          <p><%= popupFlashState.message %></p>
          <div class="popup-actions">
            <button type="button" data-flash-popup-action="confirm" class="chip dark"><%= ctx.lang === 'en' ? 'OK' : '확인' %></button>
          </div>
        </div>
      </div>
    <% } %>

    <% const popupNoticeList = Array.isArray(ctx.popupNotices) ? ctx.popupNotices : []; %>
    <% if (popupNoticeList.length > 0) { %>
      <div id="noticePopupDeck" class="popup-backdrop hidden" data-popup-deck>
        <div class="popup-notice-deck-shell">
          <button
            type="button"
            class="popup-deck-nav popup-deck-nav-prev"
            data-popup-nav="prev"
            aria-label="<%= ctx.lang === 'en' ? 'Previous notice' : '이전 공지' %>"
          >
            <svg class="popup-deck-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M15 6l-6 6 6 6" />
            </svg>
          </button>

          <section class="popup-notice-deck-viewport" data-popup-viewport>
            <div class="popup-notice-deck-stack" data-popup-stack>
              <div class="popup-notice-deck-meta" data-popup-meta>
                <strong data-popup-current>1</strong>
                <span>/</span>
                <span data-popup-total><%= popupNoticeList.length %></span>
              </div>
              <% popupNoticeList.forEach((popupNotice) => { %>
                <article class="popup-card popup-notice-card" data-popup-card data-popup-id="<%= popupNotice.id %>">
                  <h3><%= popupNotice.title %></h3>
                  <% if (popupNotice.imagePath) { %>
                    <img src="<%= popupNotice.imagePath %>" alt="popup notice" class="popup-image" />
                  <% } %>
                  <p class="popup-notice-content"><%= popupNotice.content %></p>
                  <div class="popup-actions">
                    <button type="button" data-popup-action="hide7" class="chip ghost"><%= ctx.lang === 'en' ? "Don't show for 7 days" : '7일간 보지 않기' %></button>
                    <button type="button" data-popup-action="close" class="chip"><%= ctx.lang === 'en' ? 'Close' : '닫기' %></button>
                    <button type="button" data-popup-action="confirm" class="chip dark"><%= ctx.lang === 'en' ? 'OK' : '확인' %></button>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>

          <button
            type="button"
            class="popup-deck-nav popup-deck-nav-next"
            data-popup-nav="next"
            aria-label="<%= ctx.lang === 'en' ? 'Next notice' : '다음 공지' %>"
          >
            <svg class="popup-deck-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9 6l6 6-6 6" />
            </svg>
          </button>
        </div>
      </div>
    <% } %>

    <div id="imageLightbox" class="image-lightbox hidden" aria-hidden="true">
      <div class="image-lightbox-shell">
        <div class="image-lightbox-toolbar">
          <span class="image-lightbox-zoom" data-lightbox-zoom>100%</span>
          <button type="button" class="chip" data-lightbox-action="zoom-out"><%= ctx.lang === 'en' ? 'Zoom Out' : '축소' %></button>
          <button type="button" class="chip" data-lightbox-action="zoom-in"><%= ctx.lang === 'en' ? 'Zoom In' : '확대' %></button>
          <button type="button" class="chip" data-lightbox-action="reset"><%= ctx.lang === 'en' ? 'Reset' : '원본' %></button>
          <button type="button" class="chip dark" data-lightbox-action="close"><%= ctx.lang === 'en' ? 'Close' : '닫기' %></button>
        </div>
        <div class="image-lightbox-stage" data-lightbox-stage>
          <img src="" alt="" class="image-lightbox-image" data-lightbox-image />
        </div>
      </div>
    </div>

    <script src="/assets/js/app.js?v=<%= encodeURIComponent(ctx.assetVersion) %>"></script>
  </body>
</html>
