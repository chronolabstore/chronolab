<header class="site-header" style="--header-color:<%= ctx.settings.headerColor %>">
  <div class="header-top">
    <a href="<%= ctx.isAdminPage ? '/admin/dashboard' : '/main' %>" class="brand-box">
      <% if (ctx.settings.headerSymbolPath) { %>
        <img src="<%= ctx.settings.headerSymbolPath %>" alt="symbol" class="brand-symbol" />
      <% } else { %>
        <span class="brand-symbol-fallback">CL</span>
      <% } %>

      <% if (ctx.settings.headerLogoPath) { %>
        <img src="<%= ctx.settings.headerLogoPath %>" alt="<%= ctx.settings.siteName %>" class="brand-logo" />
      <% } else { %>
        <span class="brand-text"><%= ctx.settings.siteName %></span>
      <% } %>
    </a>

    <div class="header-actions">
      <div class="header-actions-main">
        <% if (ctx.currentUser) { %>
          <% if (ctx.currentUser.isAdmin) { %>
            <% if (ctx.isAdminPage) { %>
              <% if (!ctx.currentUser.isAdminOtpEnabled) { %>
                <a href="/admin/otp" class="chip"><%= ctx.lang === 'en' ? 'OTP' : 'OTP 설정' %></a>
              <% } %>
              <a href="/admin/logout" class="chip"><%= ctx.lang === 'en' ? 'Admin Logout' : '어드민 로그아웃' %></a>
            <% } else { %>
              <span class="chip muted"><%= ctx.currentUser.username %></span>
              <form method="post" action="/logout" class="inline-form">
                <button type="submit" class="chip"><%= ctx.t('logout') %></button>
              </form>
            <% } %>
          <% } else { %>
            <span class="chip muted"><%= ctx.currentUser.username %></span>
            <a href="/mypage" class="chip"><%= ctx.t('myPage') %></a>
            <a href="/cart" class="icon-circle-action" aria-label="<%= ctx.lang === 'en' ? 'Cart' : '장바구니' %>" title="<%= ctx.lang === 'en' ? 'Cart' : '장바구니' %>">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="9" cy="20" r="1.6" />
                <circle cx="18" cy="20" r="1.6" />
                <path d="M3.5 4.5h2l2.2 10h9.7l2-7.5H7" />
              </svg>
              <% if (Number(ctx.cartCount || 0) > 0) { %>
                <span class="header-icon-badge"><%= Number(ctx.cartCount || 0) > 99 ? '99+' : Number(ctx.cartCount || 0) %></span>
              <% } %>
            </a>
            <form method="post" action="/logout" class="inline-form">
              <button type="submit" class="icon-circle-action" aria-label="<%= ctx.lang === 'en' ? 'Logout' : '로그아웃' %>" title="<%= ctx.lang === 'en' ? 'Logout' : '로그아웃' %>">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M14 17.5 19.5 12 14 6.5" />
                  <path d="M19 12H9" />
                  <path d="M10 4.5H6.5A2.5 2.5 0 0 0 4 7v10a2.5 2.5 0 0 0 2.5 2.5H10" />
                </svg>
              </button>
            </form>
          <% } %>
        <% } else { %>
          <a href="/login" class="chip"><%= ctx.t('login') %></a>
          <a href="/signup" class="chip dark"><%= ctx.t('signup') %></a>
        <% } %>
      </div>

      <div class="header-actions-icons">
        <button
          type="button"
          class="header-icon-btn header-lang-btn"
          data-lang-panel-toggle
          aria-controls="headerLangPanel"
          aria-expanded="false"
          aria-label="<%= ctx.lang === 'en' ? 'Language and currency settings' : '언어 및 통화 설정' %>"
        >
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
            <path d="M3.5 9.5h17" />
            <path d="M3.5 14.5h17" />
            <path d="M12 3a15 15 0 0 1 0 18" />
            <path d="M12 3a15 15 0 0 0 0 18" />
          </svg>
        </button>

        <a href="/toggle-theme" class="header-icon-btn header-theme-toggle" aria-label="<%= ctx.themeMode === 'day' ? (ctx.lang === 'en' ? 'Switch to night mode' : '야간 모드로 전환') : (ctx.lang === 'en' ? 'Switch to day mode' : '주간 모드로 전환') %>">
          <% if (ctx.themeMode === 'day') { %>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 14.2A8 8 0 1 1 9.8 4a6.8 6.8 0 1 0 10.2 10.2Z" />
            </svg>
          <% } else { %>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 4.5v-2" />
              <path d="M12 21.5v-2" />
              <path d="m6.7 6.7-1.4-1.4" />
              <path d="m18.7 18.7-1.4-1.4" />
              <path d="M4.5 12h-2" />
              <path d="M21.5 12h-2" />
              <path d="m6.7 17.3-1.4 1.4" />
              <path d="m18.7 5.3-1.4 1.4" />
              <circle cx="12" cy="12" r="4.2" />
            </svg>
          <% } %>
        </a>
      </div>
    </div>
  </div>

  <div id="headerLangPanel" class="header-lang-panel" data-lang-panel hidden>
    <div class="header-lang-panel-grid">
      <section class="header-lang-column">
        <h4><%= ctx.lang === 'en' ? 'Language' : '언어' %></h4>
        <label class="header-lang-search">
          <input type="search" data-lang-search="lang" placeholder="<%= ctx.lang === 'en' ? 'Search' : '검색' %>" />
        </label>
        <div class="header-lang-list" data-lang-list="lang">
          <a href="/set-lang/en" data-filter-item="english en" class="<%= ctx.lang === 'en' ? 'is-active' : '' %>">English</a>
          <a href="/set-lang/ko" data-filter-item="korean ko 한국어" class="<%= ctx.lang === 'ko' ? 'is-active' : '' %>"><%= ctx.lang === 'en' ? 'Korean (한국어)' : '한국어' %></a>
        </div>
      </section>
      <section class="header-lang-column">
        <h4><%= ctx.lang === 'en' ? 'Currency' : '통화' %></h4>
        <label class="header-lang-search">
          <input type="search" data-lang-search="currency" placeholder="<%= ctx.lang === 'en' ? 'Search' : '검색' %>" />
        </label>
        <div class="header-lang-list" data-lang-list="currency">
          <button type="button" data-currency-item data-filter-item="usd $" data-currency-value="USD-$" class="is-active">USD-$</button>
          <button type="button" data-currency-item data-filter-item="aed" data-currency-value="AED-د.إ">AED-د.إ</button>
          <button type="button" data-currency-item data-filter-item="eur" data-currency-value="EUR-€">EUR-€</button>
          <button type="button" data-currency-item data-filter-item="gbp" data-currency-value="GBP-£">GBP-£</button>
          <button type="button" data-currency-item data-filter-item="jpy" data-currency-value="JPY-¥">JPY-¥</button>
          <button type="button" data-currency-item data-filter-item="krw 원" data-currency-value="KRW-₩">KRW-₩</button>
          <button type="button" data-currency-item data-filter-item="cny 위안" data-currency-value="CNY-¥">CNY-¥</button>
          <button type="button" data-currency-item data-filter-item="sgd" data-currency-value="SGD-S$">SGD-S$</button>
          <button type="button" data-currency-item data-filter-item="cad" data-currency-value="CAD-C$">CAD-C$</button>
          <button type="button" data-currency-item data-filter-item="aud" data-currency-value="AUD-A$">AUD-A$</button>
        </div>
      </section>
    </div>
  </div>

  <nav class="menu-scroller">
    <% ctx.menus.forEach((menu) => { 
      const active = requestPath === menu.path || (menu.path !== '/main' && requestPath.startsWith(menu.path + '/'));
      const menuLabel = ctx.lang === 'en' ? menu.labelEn : menu.labelKo;
    %>
      <a href="<%= menu.path %>" class="menu-pill <%= active ? 'active' : '' %>"><%= menuLabel %></a>
    <% }) %>
  </nav>
</header>
