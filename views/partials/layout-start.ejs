<!DOCTYPE html>
<html lang="<%= ctx.lang %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | <%= ctx.settings.siteName %></title>
    <link rel="stylesheet" href="/assets/css/style.css?v=<%= encodeURIComponent(ctx.assetVersion) %>" />
  </head>
  <body class="theme-<%= ctx.themeMode %>" style="<%- ctx.settings.themeCssVars %>; <%- ctx.settings.backgroundStyle %>">
    <div class="app-shell">
      <%- include('./header') %>

      <% if (ctx.flash) { %>
        <div class="flash <%= ctx.flash.type %>"><%= ctx.flash.message %></div>
      <% } %>

      <main class="page-container">
