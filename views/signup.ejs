<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>
<% const captchaPrompt = signupCaptchaPrompt || '4 + 5 = ?'; %>

<section class="auth-wrap">
  <div class="auth-card">
    <h2><%= isEn ? 'Create Account' : '회원가입' %></h2>
    <form method="post" action="/signup" class="form-grid signup-form-grid" id="signupForm" novalidate>
      <label><%= isEn ? 'Account' : '계정' %>
        <input type="text" name="account" autocomplete="username" required />
        <small class="muted-label"><%= isEn ? 'Lowercase letters and numbers only (4~20).' : '영문 소문자 + 숫자만 사용 가능 (4~20자).' %></small>
        <small class="field-error" data-error-for="account"></small>
      </label>

      <label><%= isEn ? 'Nickname' : '닉네임' %>
        <input type="text" name="nickname" autocomplete="nickname" required />
        <small class="field-error" data-error-for="nickname"></small>
      </label>

      <label><%= isEn ? 'Email (for password reset)' : '이메일 (비번 찾기용)' %>
        <input type="email" name="email" autocomplete="email" required />
        <small class="field-error" data-error-for="email"></small>
      </label>

      <label><%= isEn ? 'Mobile Number' : '핸드폰번호' %>
        <input type="tel" name="phone" inputmode="numeric" autocomplete="tel" required />
        <small class="field-error" data-error-for="phone"></small>
      </label>

      <label><%= isEn ? 'Password' : '비밀번호' %>
        <input type="password" name="password" autocomplete="new-password" required />
        <small class="muted-label"><%= isEn ? 'Use upper/lowercase letters, number, and symbol (8+).' : '영문 대/소문자, 숫자, 특수기호를 포함해 8자 이상.' %></small>
        <small class="field-error" data-error-for="password"></small>
      </label>

      <label><%= isEn ? 'Confirm password' : '비밀번호 확인' %>
        <input type="password" name="passwordConfirm" autocomplete="new-password" required />
        <small class="field-error" data-error-for="passwordConfirm"></small>
      </label>

      <label><%= isEn ? 'Anti-bot Verification' : '자동등록방지' %>
        <div class="signup-captcha-row">
          <strong class="signup-captcha-prompt"><%= captchaPrompt %></strong>
          <input type="text" name="captchaAnswer" inputmode="numeric" autocomplete="off" required />
        </div>
        <small class="field-error" data-error-for="captchaAnswer"></small>
      </label>

      <label class="hp-field" aria-hidden="true">
        <span>Website</span>
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>

      <label class="check-row">
        <input type="checkbox" name="agreedTerms" />
        <span><%= isEn ? 'I agree to the terms.' : '약관에 동의합니다.' %></span>
      </label>
      <small class="field-error" data-error-for="agreedTerms"></small>
      <button type="submit" class="cta-main"><%= isEn ? 'Sign up' : '회원가입' %></button>
      <% if (Number(ctx.settings.signupBonusPoints || 0) > 0) { %>
        <small class="muted-label">
          <%= isEn ? 'Signup bonus' : '가입 보너스' %>:
          <strong><%= ctx.formatPrice(ctx.settings.signupBonusPoints) %>P</strong>
          (<%= isEn ? '1 point = 1 KRW' : '1포인트 = 1원' %>)
        </small>
      <% } %>
    </form>
    <p class="muted-label"><%= isEn ? 'Already have an account?' : '이미 계정이 있나요?' %> <a href="/login"><%= isEn ? 'Login' : '로그인' %></a></p>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById('signupForm');
    if (!form) return;

    const fieldOrder = ['account', 'nickname', 'email', 'phone', 'password', 'passwordConfirm', 'captchaAnswer', 'agreedTerms'];
    const duplicateFieldOrder = ['account', 'nickname', 'email'];
    const accountInput = form.querySelector('input[name="account"]');
    const nicknameInput = form.querySelector('input[name="nickname"]');
    const emailInput = form.querySelector('input[name="email"]');
    const phoneInput = form.querySelector('input[name="phone"]');
    const passwordInput = form.querySelector('input[name="password"]');
    const passwordConfirmInput = form.querySelector('input[name="passwordConfirm"]');
    const captchaInput = form.querySelector('input[name="captchaAnswer"]');
    const agreedTermsInput = form.querySelector('input[name="agreedTerms"]');

    const errorByName = (name) => form.querySelector(`[data-error-for="${name}"]`);
    const isEn = <%= isEn ? 'true' : 'false' %>;
    const duplicateMessage = {
      account: isEn ? 'This account is already in use.' : '이미 사용중인 계정입니다.',
      nickname: isEn ? 'This nickname is already in use.' : '이미 사용중인 닉네임입니다.',
      email: isEn ? 'This email is already in use.' : '이미 사용중인 이메일입니다.'
    };
    const availabilityCheckFailMessage = isEn
      ? 'Could not verify duplication. Please try again.'
      : '중복 여부를 확인하지 못했습니다. 잠시 후 다시 시도해 주세요.';
    const availabilityRequestSeq = {
      account: 0,
      nickname: 0,
      email: 0
    };
    const availabilityCache = {
      account: { value: '', exists: false },
      nickname: { value: '', exists: false },
      email: { value: '', exists: false }
    };
    const duplicateDebounceTimers = {
      account: 0,
      nickname: 0,
      email: 0
    };

    const getInputByName = (name) => form.querySelector(`[name="${name}"]`);
    const getFieldContainer = (name) => {
      const input = getInputByName(name);
      if (!input) return null;
      if (input.type === 'checkbox') {
        return input.closest('.check-row') || input;
      }
      return input;
    };

    const setFieldInvalid = (name, isInvalid) => {
      const target = getFieldContainer(name);
      const input = getInputByName(name);
      if (!target || !input) return;

      if (input.type === 'checkbox') {
        target.classList.toggle('field-invalid-row', isInvalid);
      } else {
        target.classList.toggle('field-invalid', isInvalid);
      }
      input.setAttribute('aria-invalid', isInvalid ? 'true' : 'false');
    };

    const setError = (name, message) => {
      const el = errorByName(name);
      if (!el) {
        setFieldInvalid(name, Boolean(message));
        return;
      }
      if (message) {
        el.textContent = message;
        el.classList.add('show');
      } else {
        el.textContent = '';
        el.classList.remove('show');
      }
      setFieldInvalid(name, Boolean(message));
    };

    const validateAccount = () => {
      const value = String(accountInput?.value || '').trim();
      if (!value) return isEn ? 'Account is required.' : '계정을 입력해 주세요.';
      if (!/^[a-z0-9]{4,20}$/.test(value)) {
        return isEn
          ? 'Use lowercase letters and numbers only (4~20).'
          : '계정은 영문 소문자와 숫자만 사용해 4~20자로 입력해 주세요.';
      }
      return '';
    };

    const validateNickname = () => {
      const value = String(nicknameInput?.value || '').trim();
      if (!value) return isEn ? 'Nickname is required.' : '닉네임을 입력해 주세요.';
      if (value.length < 2 || value.length > 40) {
        return isEn ? 'Nickname must be 2~40 characters.' : '닉네임은 2~40자로 입력해 주세요.';
      }
      return '';
    };

    const validateEmail = () => {
      const value = String(emailInput?.value || '').trim();
      if (!value) return isEn ? 'Email is required.' : '이메일을 입력해 주세요.';
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
        return isEn ? 'Invalid email format.' : '이메일 형식이 올바르지 않습니다.';
      }
      return '';
    };

    const validatePhone = () => {
      const value = String(phoneInput?.value || '').replace(/[^0-9]/g, '');
      if (!value) return isEn ? 'Mobile number is required.' : '핸드폰번호를 입력해 주세요.';
      if (!/^[0-9]{8,20}$/.test(value)) {
        return isEn ? 'Enter 8~20 digit mobile number.' : '핸드폰번호는 숫자 8~20자로 입력해 주세요.';
      }
      return '';
    };

    const validatePassword = () => {
      const value = String(passwordInput?.value || '');
      if (!value) return isEn ? 'Password is required.' : '비밀번호를 입력해 주세요.';
      if (!/^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}$/.test(value)) {
        return isEn
          ? 'Use upper/lowercase letters, number, and symbol (8+).'
          : '비밀번호는 영문 대/소문자, 숫자, 특수기호를 포함해 8자 이상이어야 합니다.';
      }
      return '';
    };

    const validatePasswordConfirm = () => {
      const value = String(passwordConfirmInput?.value || '');
      if (!value) return isEn ? 'Please confirm your password.' : '비밀번호 확인을 입력해 주세요.';
      if (value !== String(passwordInput?.value || '')) {
        return isEn ? 'Passwords do not match.' : '비밀번호가 일치하지 않습니다.';
      }
      return '';
    };

    const validateCaptcha = () => {
      const value = String(captchaInput?.value || '').trim();
      if (!value) return isEn ? 'Captcha answer is required.' : '자동등록방지 답변을 입력해 주세요.';
      if (!/^[0-9]{1,3}$/.test(value)) {
        return isEn ? 'Enter numbers only.' : '숫자로만 입력해 주세요.';
      }
      return '';
    };

    const validateAgreedTerms = () => {
      if (agreedTermsInput?.checked) return '';
      return isEn ? 'Please agree to the terms.' : '약관에 동의해 주세요.';
    };

    const validators = {
      account: validateAccount,
      nickname: validateNickname,
      email: validateEmail,
      phone: validatePhone,
      password: validatePassword,
      passwordConfirm: validatePasswordConfirm,
      captchaAnswer: validateCaptcha,
      agreedTerms: validateAgreedTerms
    };

    const resetAvailabilityCache = (name) => {
      if (!Object.prototype.hasOwnProperty.call(availabilityCache, name)) return;
      availabilityCache[name] = { value: '', exists: false };
    };

    const fetchAvailability = async (name, value) => {
      const params = new URLSearchParams();
      params.set(name, value);
      const response = await fetch(`/api/signup/availability?${params.toString()}`, {
        method: 'GET',
        credentials: 'same-origin',
        headers: {
          Accept: 'application/json'
        }
      });

      let payload = null;
      try {
        payload = await response.json();
      } catch {
        payload = null;
      }

      if (!response.ok || !payload || payload.ok !== true) {
        throw new Error('availability-check-failed');
      }
      return payload.checks || {};
    };

    const validateDuplicateField = async (name) => {
      if (!duplicateFieldOrder.includes(name)) {
        return '';
      }

      const input = getInputByName(name);
      const value = String(input?.value || '').trim();
      const syncMessage = validators[name]();
      if (syncMessage) {
        return syncMessage;
      }
      if (!value) {
        return '';
      }

      const cached = availabilityCache[name];
      if (cached && cached.value === value) {
        return cached.exists ? duplicateMessage[name] : '';
      }

      availabilityRequestSeq[name] += 1;
      const currentSeq = availabilityRequestSeq[name];
      try {
        const checks = await fetchAvailability(name, value);
        if (availabilityRequestSeq[name] !== currentSeq) {
          return '';
        }
        const exists = Boolean(checks?.[name]?.exists);
        availabilityCache[name] = { value, exists };
        return exists ? duplicateMessage[name] : '';
      } catch {
        if (availabilityRequestSeq[name] !== currentSeq) {
          return '';
        }
        availabilityCache[name] = { value: '', exists: false };
        return availabilityCheckFailMessage;
      }
    };

    const validateField = async (name, options = {}) => {
      const syncMessage = validators[name]?.() || '';
      if (syncMessage) {
        setError(name, syncMessage);
        return syncMessage;
      }

      if (options.checkDuplicate === true && duplicateFieldOrder.includes(name)) {
        const duplicateError = await validateDuplicateField(name);
        setError(name, duplicateError);
        return duplicateError;
      }

      setError(name, '');
      return '';
    };

    const focusFirstInvalidField = (firstInvalidName) => {
      const target = getFieldContainer(firstInvalidName);
      const input = getInputByName(firstInvalidName);
      if (!target || !input) return;

      target.scrollIntoView({ behavior: 'smooth', block: 'center' });
      window.setTimeout(() => {
        try {
          input.focus({ preventScroll: true });
        } catch {
          input.focus();
        }
      }, 80);
    };

    Object.entries(validators).forEach(([name]) => {
      const input = form.querySelector(`[name="${name}"]`);
      if (!input) return;

      input.addEventListener('blur', () => {
        void validateField(name, { checkDuplicate: duplicateFieldOrder.includes(name) });
      });

      input.addEventListener('input', () => {
        resetAvailabilityCache(name);
        if (!errorByName(name)?.classList.contains('show')) return;

        const syncMessage = validators[name]?.() || '';
        setError(name, syncMessage);

        if (syncMessage || !duplicateFieldOrder.includes(name)) return;
        window.clearTimeout(duplicateDebounceTimers[name]);
        duplicateDebounceTimers[name] = window.setTimeout(() => {
          void validateField(name, { checkDuplicate: true });
        }, 220);
      });
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      let firstInvalidName = '';
      for (const name of fieldOrder) {
        const syncMessage = validators[name]?.() || '';
        setError(name, syncMessage);
        if (!firstInvalidName && syncMessage) {
          firstInvalidName = name;
        }
      }

      await Promise.all(
        duplicateFieldOrder.map(async (name) => {
          if (validators[name]?.()) return;
          const duplicateError = await validateDuplicateField(name);
          setError(name, duplicateError);
          if (!firstInvalidName && duplicateError) {
            firstInvalidName = name;
          }
        })
      );

      if (firstInvalidName) {
        focusFirstInvalidField(firstInvalidName);
        return;
      }

      form.submit();
    });
  })();
</script>

<%- include('partials/layout-end') %>
