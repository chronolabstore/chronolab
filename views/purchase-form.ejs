<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>
<% const pointRate = Number(purchasePointRate || 0); %>
<% const pointAmount = Number(expectedPoints || 0); %>
<% const addressBook = Array.isArray(addressBookEntries) ? addressBookEntries : []; %>
<%
  const availablePoints = Math.max(0, Number(availableRewardPoints || 0));
  const quantityValue = Math.max(1, Number.parseInt(String(formData.quantity || '1'), 10) || 1);
  const orderSubtotal = Math.max(0, Number(product.price || 0) * quantityValue);
  const useRewardPointsRaw = String(formData.useRewardPoints || '0').replace(/[^0-9]/g, '');
  const requestedUsePoints = Math.max(0, Number.parseInt(useRewardPointsRaw || '0', 10) || 0);
  const maxUsablePoints = Math.max(0, Math.min(availablePoints, orderSubtotal));
  const appliedUsePoints = Math.min(requestedUsePoints, maxUsablePoints);
  const payableAmount = Math.max(0, orderSubtotal - appliedUsePoints);
  const expectedPointsByPayable = pointRate > 0 ? Math.max(0, Math.floor((payableAmount * pointRate) / 100)) : 0;
%>

<section class="block-card purchase-page-card">
  <div class="purchase-page-head">
    <h2><%= ctx.lang === 'en' ? 'Purchase Request' : '구매 신청' %></h2>
    <% if (productGroupLabel) { %>
      <p class="muted-label"><%= productGroupLabel %></p>
    <% } %>
  </div>

  <div class="purchase-page-layout">
    <aside class="purchase-page-summary">
      <div class="line-list-box purchase-summary-box">
        <p><span><%= isEn ? 'Product' : '상품' %></span><strong><%= product.brand %> <%= product.model %> <%= product.sub_model %></strong></p>
        <p><span><%= isEn ? 'Price (Unit)' : '가격(개당)' %></span><strong>₩<%= ctx.formatPrice(product.price) %></strong></p>
        <p><span><%= isEn ? 'Order Amount' : '주문금액' %></span><strong id="purchaseSubtotalText">₩<%= ctx.formatPrice(orderSubtotal) %></strong></p>
        <p><span><%= isEn ? 'Used Points' : '사용 포인트' %></span><strong id="purchaseUsedPointsText"><%= appliedUsePoints > 0 ? '-' : '' %><%= ctx.formatPrice(appliedUsePoints) %>P</strong></p>
        <p><span><%= isEn ? 'Final Payment' : '최종 결제금액' %></span><strong id="purchasePayableText">₩<%= ctx.formatPrice(payableAmount) %></strong></p>
        <p><span><%= isEn ? 'Shipping' : '배송기간' %></span><strong><%= product.shipping_period || '-' %></strong></p>
        <p>
          <span><%= isEn ? 'Reward Points' : '적립 포인트' %></span>
          <strong id="purchaseExpectedRewardPoints">
            <%= pointRate > 0 ? `${pointRate}% (${ctx.formatPrice(expectedPointsByPayable || pointAmount)}P)` : (isEn ? 'Not set' : '미설정') %>
          </strong>
        </p>
        <p class="purchase-summary-note">
          <small class="muted-label"><%= isEn ? '(credited after delivery completion)' : '(배송완료 후 적립)' %></small>
        </p>
        <p><span><%= isEn ? 'Available Points' : '보유 포인트' %></span><strong><%= ctx.formatPrice(availablePoints) %>P</strong></p>
      </div>
    </aside>

    <div class="purchase-page-content">
      <form method="post" action="/shop/item/<%= product.id %>/purchase" class="form-grid purchase-request-form">
        <label><%= isEn ? 'Name' : '이름' %>
          <input type="text" name="buyerName" value="<%= formData.buyerName || '' %>" required />
          <small class="strong-warning">
            <%= isEn ? 'Transfer must be made with this exact name.' : '반드시 이 이름으로 입금해 주세요.' %>
          </small>
        </label>

        <label><%= isEn ? 'Contact' : '연락처' %>
          <input type="text" name="buyerContact" value="<%= formData.buyerContact || '' %>" required />
        </label>

        <label><%= isEn ? 'Customs Clearance No.' : '통관번호' %>
          <input type="text" name="customsClearanceNo" value="<%= formData.customsClearanceNo || '' %>" required />
        </label>

        <label class="purchase-field-span-2"><%= isEn ? 'Address Book' : '주소록' %>
          <select name="addressBookId" id="purchaseAddressBookSelect">
            <option value=""><%= isEn ? 'Use current input' : '직접 입력 사용' %></option>
            <% addressBook.forEach((item) => { %>
              <option
                value="<%= item.id %>"
                data-postcode="<%= item.postcode %>"
                data-address-base="<%= item.addressBase %>"
                data-address-detail="<%= item.addressDetail %>"
                <%= String(formData.addressBookId || '') === String(item.id) ? 'selected' : '' %>
              >
                <%= item.label %> - <%= item.fullAddress %>
              </option>
            <% }) %>
          </select>
        </label>

        <label class="purchase-field-span-2"><%= isEn ? 'Postcode' : '우편번호' %>
          <div class="field-inline">
            <input type="text" name="buyerPostcode" id="buyerPostcode" value="<%= formData.buyerPostcode || '' %>" maxlength="5" required readonly />
            <button type="button" class="chip field-inline-btn" id="buyerAddressSearchBtn"><%= isEn ? 'Search Address' : '주소찾기' %></button>
          </div>
        </label>

        <label class="purchase-field-span-2"><%= isEn ? 'Main Address' : '기본주소' %>
          <input type="text" name="buyerAddressBase" id="buyerAddressBase" value="<%= formData.buyerAddressBase || '' %>" maxlength="160" required readonly />
        </label>

        <label class="purchase-field-span-2"><%= isEn ? 'Detailed Address' : '상세주소' %>
          <input type="text" name="buyerAddressDetail" id="buyerAddressDetail" value="<%= formData.buyerAddressDetail || '' %>" maxlength="120" />
        </label>

        <label><%= isEn ? 'Quantity' : '수량' %>
          <input type="number" name="quantity" min="1" value="<%= formData.quantity || 1 %>" required />
        </label>

        <label><%= isEn ? 'Use Points' : '포인트 사용' %>
          <input
            type="number"
            name="useRewardPoints"
            id="purchaseUseRewardPoints"
            min="0"
            step="1"
            inputmode="numeric"
            value="<%= formData.useRewardPoints || 0 %>"
          />
          <small class="muted-label">
            <%= isEn ? `Available ${ctx.formatPrice(availablePoints)}P / Max ${ctx.formatPrice(maxUsablePoints)}P` : `보유 ${ctx.formatPrice(availablePoints)}P / 최대 ${ctx.formatPrice(maxUsablePoints)}P 사용 가능` %>
          </small>
        </label>

        <div class="address-book-save-box purchase-field-span-2">
          <label class="check-row">
            <input type="checkbox" name="saveToAddressBook" value="1" <%= String(formData.saveToAddressBook || '') === '1' ? 'checked' : '' %> />
            <span><%= isEn ? 'Save this address to address book' : '이번 주소를 주소록에 저장' %></span>
          </label>
          <label>
            <span><%= isEn ? 'Address Label' : '주소록 이름' %></span>
            <input type="text" name="addressLabel" value="<%= formData.addressLabel || '' %>" maxlength="40" placeholder="<%= isEn ? 'e.g. Home / Office' : '예: 집 / 회사' %>" />
          </label>
          <label class="check-row">
            <input type="checkbox" name="setAsDefaultAddress" value="1" <%= String(formData.setAsDefaultAddress || '') === '1' ? 'checked' : '' %> />
            <span><%= isEn ? 'Set as default address' : '기본주소로 설정' %></span>
          </label>
        </div>

        <button type="submit" class="cta-main full purchase-field-span-2"><%= isEn ? 'Submit Purchase' : '구매 신청하기' %></button>
      </form>

      <div class="notice-box purchase-transfer-notice">
        <h4><%= isEn ? 'Bank Transfer Guide' : '계좌이체 안내' %></h4>
        <p><%= ctx.settings.bankAccountInfo %></p>
      </div>
    </div>
  </div>
</section>

<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
  (() => {
    const isEn = <%= isEn ? 'true' : 'false' %>;
    const select = document.getElementById('purchaseAddressBookSelect');
    const postcodeInput = document.getElementById('buyerPostcode');
    const baseInput = document.getElementById('buyerAddressBase');
    const detailInput = document.getElementById('buyerAddressDetail');
    const searchBtn = document.getElementById('buyerAddressSearchBtn');
    const quantityInput = document.querySelector('input[name="quantity"]');
    const useRewardPointsInput = document.getElementById('purchaseUseRewardPoints');
    const subtotalText = document.getElementById('purchaseSubtotalText');
    const usedPointsText = document.getElementById('purchaseUsedPointsText');
    const payableText = document.getElementById('purchasePayableText');
    const expectedRewardText = document.getElementById('purchaseExpectedRewardPoints');
    const unitPrice = Number(<%= Number(product.price || 0) %>) || 0;
    const pointRate = Number(<%= Number(pointRate || 0) %>) || 0;
    const availablePoints = Number(<%= Math.max(0, Number(availablePoints || 0)) %>) || 0;
    const notSetRewardLabel = <%- JSON.stringify(isEn ? 'Not set' : '미설정') %>;

    const normalizePositiveInt = (rawValue, fallback = 1) => {
      const parsed = Number.parseInt(String(rawValue ?? ''), 10);
      if (!Number.isInteger(parsed) || parsed <= 0) {
        return fallback;
      }
      return parsed;
    };

    const normalizeNonNegativeInt = (rawValue, fallback = 0) => {
      const numeric = String(rawValue ?? '').replace(/[^0-9]/g, '');
      if (!numeric) {
        return fallback;
      }
      const parsed = Number.parseInt(numeric, 10);
      if (!Number.isInteger(parsed) || parsed < 0) {
        return fallback;
      }
      return parsed;
    };

    const formatNumber = (value) => Number(value || 0).toLocaleString('ko-KR');

    const refreshPaymentPreview = () => {
      const quantity = normalizePositiveInt(quantityInput ? quantityInput.value : 1, 1);
      if (quantityInput && String(quantityInput.value) !== String(quantity)) {
        quantityInput.value = String(quantity);
      }
      const subtotal = Math.max(0, unitPrice * quantity);
      const maxUsable = Math.max(0, Math.min(availablePoints, subtotal));
      let usingPoints = normalizeNonNegativeInt(useRewardPointsInput ? useRewardPointsInput.value : 0, 0);
      if (usingPoints > maxUsable) {
        usingPoints = maxUsable;
      }
      if (useRewardPointsInput) {
        useRewardPointsInput.max = String(maxUsable);
        if (String(useRewardPointsInput.value) !== String(usingPoints)) {
          useRewardPointsInput.value = String(usingPoints);
        }
      }
      const payable = Math.max(0, subtotal - usingPoints);
      const expectedRewardPoints = pointRate > 0 ? Math.max(0, Math.floor((payable * pointRate) / 100)) : 0;

      if (subtotalText) subtotalText.textContent = `₩${formatNumber(subtotal)}`;
      if (usedPointsText) usedPointsText.textContent = `${usingPoints > 0 ? '-' : ''}${formatNumber(usingPoints)}P`;
      if (payableText) payableText.textContent = `₩${formatNumber(payable)}`;
      if (expectedRewardText) {
        expectedRewardText.textContent =
          pointRate > 0 ? `${pointRate}% (${formatNumber(expectedRewardPoints)}P)` : notSetRewardLabel;
      }
    };

    const applyAddressFromOption = (option) => {
      if (!option) return;
      const postcode = option.getAttribute('data-postcode') || '';
      const base = option.getAttribute('data-address-base') || '';
      const detail = option.getAttribute('data-address-detail') || '';
      if (!postcode && !base) return;
      postcodeInput.value = postcode;
      baseInput.value = base;
      detailInput.value = detail;
    };

    if (select) {
      if (select.value) {
        const selected = select.options[select.selectedIndex];
        applyAddressFromOption(selected);
      }
      select.addEventListener('change', () => {
        const selected = select.options[select.selectedIndex];
        applyAddressFromOption(selected);
      });
    }

    if (searchBtn) {
      searchBtn.addEventListener('click', () => {
        if (!window.daum || !window.daum.Postcode) {
          window.alert(isEn ? 'Address search is unavailable right now.' : '주소 검색 서비스를 불러올 수 없습니다.');
          return;
        }

        new window.daum.Postcode({
          oncomplete(data) {
            const roadAddress = data.roadAddress || data.jibunAddress || '';
            postcodeInput.value = data.zonecode || '';
            baseInput.value = roadAddress;
            if (detailInput) {
              detailInput.focus();
            }
          }
        }).open();
      });
    }

    if (quantityInput) {
      quantityInput.addEventListener('input', refreshPaymentPreview);
      quantityInput.addEventListener('change', refreshPaymentPreview);
    }
    if (useRewardPointsInput) {
      useRewardPointsInput.addEventListener('input', refreshPaymentPreview);
      useRewardPointsInput.addEventListener('change', refreshPaymentPreview);
    }
    refreshPaymentPreview();
  })();
</script>

<%- include('partials/layout-end') %>
