<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>
<% const pointRate = Number(purchasePointRate || 0); %>
<% const pointAmount = Number(expectedPoints || 0); %>
<% const addressBook = Array.isArray(addressBookEntries) ? addressBookEntries : []; %>

<section class="block-card narrow">
  <h2><%= ctx.lang === 'en' ? 'Purchase Request' : '구매 신청' %></h2>
  <% if (productGroupLabel) { %>
    <p class="muted-label"><%= productGroupLabel %></p>
  <% } %>

  <div class="line-list-box">
    <p><%= isEn ? 'Product' : '상품' %>: <strong><%= product.brand %> <%= product.model %> <%= product.sub_model %></strong></p>
    <p><%= isEn ? 'Price' : '가격' %>: <strong>₩<%= ctx.formatPrice(product.price) %></strong></p>
    <p><%= isEn ? 'Shipping' : '배송기간' %>: <strong><%= product.shipping_period || '-' %></strong></p>
    <p>
      <%= isEn ? 'Reward Points' : '적립 포인트' %>:
      <strong>
        <%= pointRate > 0 ? `${pointRate}% (${ctx.formatPrice(pointAmount)}P)` : (isEn ? 'Not set' : '미설정') %>
      </strong>
      <small class="muted-label"><%= isEn ? '(credited after delivery completion)' : '(배송완료 후 적립)' %></small>
    </p>
  </div>

  <form method="post" action="/shop/item/<%= product.id %>/purchase" class="form-grid">
    <label><%= isEn ? 'Name' : '이름' %>
      <input type="text" name="buyerName" value="<%= formData.buyerName || '' %>" required />
      <small class="strong-warning">
        <%= isEn ? 'Transfer must be made with this exact name.' : '반드시 이 이름으로 입금해 주세요.' %>
      </small>
    </label>

    <label><%= isEn ? 'Contact' : '연락처' %>
      <input type="text" name="buyerContact" value="<%= formData.buyerContact || '' %>" required />
    </label>

    <label><%= isEn ? 'Customs Clearance No.' : '통관번호' %>
      <input type="text" name="customsClearanceNo" value="<%= formData.customsClearanceNo || '' %>" required />
    </label>

    <label><%= isEn ? 'Address Book' : '주소록' %>
      <select name="addressBookId" id="purchaseAddressBookSelect">
        <option value=""><%= isEn ? 'Use current input' : '직접 입력 사용' %></option>
        <% addressBook.forEach((item) => { %>
          <option
            value="<%= item.id %>"
            data-postcode="<%= item.postcode %>"
            data-address-base="<%= item.addressBase %>"
            data-address-detail="<%= item.addressDetail %>"
            <%= String(formData.addressBookId || '') === String(item.id) ? 'selected' : '' %>
          >
            <%= item.label %> - <%= item.fullAddress %>
          </option>
        <% }) %>
      </select>
    </label>

    <label><%= isEn ? 'Postcode' : '우편번호' %>
      <div class="field-inline">
        <input type="text" name="buyerPostcode" id="buyerPostcode" value="<%= formData.buyerPostcode || '' %>" maxlength="5" required readonly />
        <button type="button" class="chip field-inline-btn" id="buyerAddressSearchBtn"><%= isEn ? 'Search Address' : '주소찾기' %></button>
      </div>
    </label>

    <label><%= isEn ? 'Main Address' : '기본주소' %>
      <input type="text" name="buyerAddressBase" id="buyerAddressBase" value="<%= formData.buyerAddressBase || '' %>" maxlength="160" required readonly />
    </label>

    <label><%= isEn ? 'Detailed Address' : '상세주소' %>
      <input type="text" name="buyerAddressDetail" id="buyerAddressDetail" value="<%= formData.buyerAddressDetail || '' %>" maxlength="120" />
    </label>

    <label><%= isEn ? 'Quantity' : '수량' %>
      <input type="number" name="quantity" min="1" value="<%= formData.quantity || 1 %>" required />
    </label>

    <div class="address-book-save-box">
      <label class="check-row">
        <input type="checkbox" name="saveToAddressBook" value="1" <%= String(formData.saveToAddressBook || '') === '1' ? 'checked' : '' %> />
        <span><%= isEn ? 'Save this address to address book' : '이번 주소를 주소록에 저장' %></span>
      </label>
      <label>
        <span><%= isEn ? 'Address Label' : '주소록 이름' %></span>
        <input type="text" name="addressLabel" value="<%= formData.addressLabel || '' %>" maxlength="40" placeholder="<%= isEn ? 'e.g. Home / Office' : '예: 집 / 회사' %>" />
      </label>
      <label class="check-row">
        <input type="checkbox" name="setAsDefaultAddress" value="1" <%= String(formData.setAsDefaultAddress || '') === '1' ? 'checked' : '' %> />
        <span><%= isEn ? 'Set as default address' : '기본주소로 설정' %></span>
      </label>
    </div>

    <button type="submit" class="cta-main full"><%= isEn ? 'Submit Purchase' : '구매 신청하기' %></button>
  </form>

  <div class="notice-box">
    <h4><%= isEn ? 'Bank Transfer Guide' : '계좌이체 안내' %></h4>
    <p><%= ctx.settings.bankAccountInfo %></p>
  </div>
</section>

<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
  (() => {
    const isEn = <%= isEn ? 'true' : 'false' %>;
    const select = document.getElementById('purchaseAddressBookSelect');
    const postcodeInput = document.getElementById('buyerPostcode');
    const baseInput = document.getElementById('buyerAddressBase');
    const detailInput = document.getElementById('buyerAddressDetail');
    const searchBtn = document.getElementById('buyerAddressSearchBtn');

    const applyAddressFromOption = (option) => {
      if (!option) return;
      const postcode = option.getAttribute('data-postcode') || '';
      const base = option.getAttribute('data-address-base') || '';
      const detail = option.getAttribute('data-address-detail') || '';
      if (!postcode && !base) return;
      postcodeInput.value = postcode;
      baseInput.value = base;
      detailInput.value = detail;
    };

    if (select) {
      if (select.value) {
        const selected = select.options[select.selectedIndex];
        applyAddressFromOption(selected);
      }
      select.addEventListener('change', () => {
        const selected = select.options[select.selectedIndex];
        applyAddressFromOption(selected);
      });
    }

    if (searchBtn) {
      searchBtn.addEventListener('click', () => {
        if (!window.daum || !window.daum.Postcode) {
          window.alert(isEn ? 'Address search is unavailable right now.' : '주소 검색 서비스를 불러올 수 없습니다.');
          return;
        }

        new window.daum.Postcode({
          oncomplete(data) {
            const roadAddress = data.roadAddress || data.jibunAddress || '';
            postcodeInput.value = data.zonecode || '';
            baseInput.value = roadAddress;
            if (detailInput) {
              detailInput.focus();
            }
          }
        }).open();
      });
    }
  })();
</script>

<%- include('partials/layout-end') %>
